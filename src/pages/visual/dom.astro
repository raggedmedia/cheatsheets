---
import '~styles/styles.css'
import MethodCard from '~components/visual-js/MethodCard.astro';
import ProTip from '~components/visual-js/ProTip.astro';
import GlobalNav from '~components/visual-js/GlobalNav.astro';
---

<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>JavaScript DOM Manipulation - Visual Cheatsheet</title>
    </head>
    <body class="m-0 p-4 bg-[#1a1d29] text-gray-200">
        <div class="flex gap-6 max-w-[1600px] mx-auto">
            <!-- Main Content -->
            <main class="flex-1 min-w-0">
                <h1 class="text-white mb-1 text-2xl font-bold">JavaScript DOM Manipulation</h1>
                <p class="text-gray-400 mb-6 text-sm">Visual blueprint-style reference for working with the DOM</p>

                <ProTip>
                    <div>💡 <strong>DOM = Document Object Model:</strong></div>
                    <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                        <div class="font-mono text-[10px]"><span class="text-gray-400">// HTML represents a tree structure of nodes</span></div>
                        <div class="font-mono text-[10px]">document <span class="text-gray-400">// root of the DOM tree</span></div>
                        <div class="font-mono text-[10px]">document.documentElement <span class="text-gray-400">// &lt;html&gt;</span></div>
                        <div class="font-mono text-[10px]">document.body <span class="text-gray-400">// &lt;body&gt;</span></div>
                    </div>
                </ProTip>

                <!-- ============================================ -->
                <!-- 🔍 SELECTING ELEMENTS -->
                <!-- ============================================ -->

                <h2 id="selecting" class="text-blue-300 text-xl my-4 pb-2 border-b-2 border-blue-600">
                    🔍 Selecting Elements
                </h2>

                <!-- QUERYSELECTOR -->
                <div id="query-selector">
                    <MethodCard
                        methodName="querySelector() / querySelectorAll()"
                        signature="document.querySelector(selector)"
                        description="Find element(s) using CSS selectors"
                        mutates={false}
                    >
                        <div class="p-6 bg-gray-800 rounded">
                            <div class="space-y-3">
                                <!-- querySelector -->
                                <div class="bg-blue-500/20 border border-blue-400 rounded p-3">
                                    <div class="text-blue-300 font-mono text-xs space-y-0.5">
                                        <div>document.querySelector('.button')</div>
                                        <div class="text-gray-400 text-[10px] mt-1">Returns first match or null</div>
                                    </div>
                                </div>

                                <!-- querySelectorAll -->
                                <div class="bg-purple-500/20 border border-purple-400 rounded p-3">
                                    <div class="text-purple-300 font-mono text-xs space-y-0.5">
                                        <div>document.querySelectorAll('.button')</div>
                                        <div class="text-gray-400 text-[10px] mt-1">Returns NodeList of all matches</div>
                                    </div>
                                </div>

                                <!-- Examples -->
                                <div class="bg-gray-800/50 border border-gray-700 rounded p-3">
                                    <div class="text-gray-300 font-mono text-[10px] space-y-0.5">
                                        <div>querySelector('#header') <span class="text-gray-400">// by ID</span></div>
                                        <div>querySelector('.active') <span class="text-gray-400">// by class</span></div>
                                        <div>querySelector('button') <span class="text-gray-400">// by tag</span></div>
                                        <div>querySelector('[type="text"]') <span class="text-gray-400">// by attribute</span></div>
                                        <div>querySelector('div &gt; p:first-child') <span class="text-gray-400">// complex</span></div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <ProTip>
                            <div>⚡ <strong>querySelectorAll returns NodeList (not Array):</strong></div>
                            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                                <div class="font-mono text-[10px]">const items = querySelectorAll('.item')</div>
                                <div class="font-mono text-[10px]">items.forEach(...) <span class="text-green-400">// ✅ works</span></div>
                                <div class="font-mono text-[10px]">items.map(...) <span class="text-red-400">// ❌ not an array method</span></div>
                                <div class="font-mono text-[10px]">[...items].map(...) <span class="text-green-400">// ✅ convert to array</span></div>
                            </div>
                        </ProTip>
                    </MethodCard>
                </div>

                <!-- GETELEMENTBY -->
                <div id="get-element-by">
                    <MethodCard
                        methodName="getElementById / getElementsBy..."
                        signature="document.getElementById(id)"
                        description="Older selector methods (less flexible)"
                        mutates={false}
                    >
                        <div class="p-6 bg-gray-800 rounded">
                            <div class="space-y-2">
                                <div class="flex items-center gap-3">
                                    <div class="w-48 text-blue-300 font-mono text-xs">getElementById('main')</div>
                                    <div class="text-xs text-gray-400">Single element</div>
                                </div>
                                <div class="flex items-center gap-3">
                                    <div class="w-48 text-blue-300 font-mono text-xs">getElementsByClassName('active')</div>
                                    <div class="text-xs text-gray-400">HTMLCollection (live)</div>
                                </div>
                                <div class="flex items-center gap-3">
                                    <div class="w-48 text-blue-300 font-mono text-xs">getElementsByTagName('div')</div>
                                    <div class="text-xs text-gray-400">HTMLCollection (live)</div>
                                </div>
                            </div>
                        </div>

                        <div class="text-gray-300 text-sm mt-3 p-3 bg-gray-800/50 rounded border border-gray-700">
                            <strong>Prefer querySelector/All</strong> - more flexible with CSS selectors. These are legacy but still widely used.
                        </div>

                        <ProTip>
                            <div>⚠️ <strong>HTMLCollection is LIVE:</strong></div>
                            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                                <div class="font-mono text-[10px]">const divs = getElementsByTagName('div')</div>
                                <div class="font-mono text-[10px]">divs.length <span class="text-gray-400">// 5</span></div>
                                <div class="font-mono text-[10px]">document.body.appendChild(document.createElement('div'))</div>
                                <div class="font-mono text-[10px]">divs.length <span class="text-yellow-400">// 6 (auto-updated!)</span></div>
                            </div>
                        </ProTip>
                    </MethodCard>
                </div>

                <!-- ============================================ -->
                <!-- ✏️ MODIFYING CONTENT -->
                <!-- ============================================ -->

                <h2 id="content" class="text-purple-300 text-xl my-4 pb-2 border-b-2 border-purple-600">
                    ✏️ Modifying Content
                </h2>

                <!-- TEXTCONTENT VS INNERHTML -->
                <div id="text-vs-html">
                    <MethodCard
                        methodName="textContent vs innerHTML"
                        signature="element.textContent / innerHTML"
                        description="Set element content as text or HTML"
                        mutates={true}
                    >
                        <div class="p-6 bg-gray-800 rounded">
                            <div class="space-y-4">
                                <!-- textContent -->
                                <div>
                                    <div class="text-green-400 font-bold text-sm mb-2">textContent (safe):</div>
                                    <div class="bg-green-500/20 border border-green-500 rounded p-3">
                                        <div class="text-green-300 font-mono text-xs space-y-0.5">
                                            <div>el.textContent = '&lt;b&gt;Bold&lt;/b&gt;'</div>
                                            <div class="text-gray-400 text-[10px] mt-1">Renders as: &lt;b&gt;Bold&lt;/b&gt; (literal text)</div>
                                        </div>
                                    </div>
                                </div>

                                <!-- innerHTML -->
                                <div>
                                    <div class="text-red-400 font-bold text-sm mb-2">innerHTML (unsafe):</div>
                                    <div class="bg-red-500/20 border border-red-500 rounded p-3">
                                        <div class="text-red-300 font-mono text-xs space-y-0.5">
                                            <div>el.innerHTML = '&lt;b&gt;Bold&lt;/b&gt;'</div>
                                            <div class="text-gray-400 text-[10px] mt-1">Renders as: <strong>Bold</strong> (parsed HTML)</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="text-gray-300 text-sm mt-3 p-3 bg-gray-800/50 rounded border border-gray-700">
                            <strong>textContent</strong> = plain text (safe), <strong>innerHTML</strong> = HTML (XSS risk with user input).
                        </div>

                        <ProTip>
                            <div>⚠️ <strong>Never use innerHTML with user input:</strong></div>
                            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                                <div class="font-mono text-[10px]"><span class="text-red-400">// Dangerous - XSS vulnerability ❌</span></div>
                                <div class="font-mono text-[10px]">el.innerHTML = userInput</div>
                                <div class="font-mono text-[10px] mt-1"><span class="text-green-400">// Safe - escapes HTML ✅</span></div>
                                <div class="font-mono text-[10px]">el.textContent = userInput</div>
                            </div>
                        </ProTip>
                    </MethodCard>
                </div>

                <!-- ============================================ -->
                <!-- 🎨 STYLING & CLASSES -->
                <!-- ============================================ -->

                <h2 id="styling" class="text-green-300 text-xl my-4 pb-2 border-b-2 border-green-600">
                    🎨 Styling & Classes
                </h2>

                <!-- CLASSLIST -->
                <div id="class-list">
                    <MethodCard
                        methodName="classList"
                        signature="element.classList.add/remove/toggle()"
                        description="Manipulate element classes"
                        mutates={true}
                    >
                        <div class="p-6 bg-gray-800 rounded">
                            <div class="space-y-3">
                                <div class="bg-gray-800/50 border border-gray-700 rounded p-3">
                                    <div class="text-gray-300 font-mono text-[10px] space-y-0.5">
                                        <div>el.classList.add('active') <span class="text-gray-400">// add class</span></div>
                                        <div>el.classList.remove('hidden') <span class="text-gray-400">// remove class</span></div>
                                        <div>el.classList.toggle('dark') <span class="text-gray-400">// add if absent, remove if present</span></div>
                                        <div>el.classList.contains('active') <span class="text-gray-400">// true/false</span></div>
                                        <div>el.classList.replace('old', 'new') <span class="text-gray-400">// swap classes</span></div>
                                    </div>
                                </div>

                                <div class="bg-green-500/20 border border-green-500 rounded p-3">
                                    <div class="text-green-300 font-mono text-xs space-y-0.5">
                                        <div><span class="text-gray-400">// Add multiple</span></div>
                                        <div>el.classList.add('class1', 'class2', 'class3')</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <ProTip>
                            <div>Toggle with condition:</div>
                            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                                <div class="font-mono text-[10px]"><span class="text-gray-400">// Second param forces add/remove</span></div>
                                <div class="font-mono text-[10px]">el.classList.toggle('active', isActive)</div>
                                <div class="font-mono text-[10px]"><span class="text-gray-400">// Same as:</span></div>
                                <div class="font-mono text-[10px]">if (isActive) el.classList.add('active')</div>
                                <div class="font-mono text-[10px]">else el.classList.remove('active')</div>
                            </div>
                        </ProTip>
                    </MethodCard>
                </div>

                <!-- STYLE -->
                <div id="style">
                    <MethodCard
                        methodName="style"
                        signature="element.style.property = value"
                        description="Modify inline styles"
                        mutates={true}
                    >
                        <div class="p-6 bg-gray-800 rounded">
                            <div class="space-y-3">
                                <div class="bg-gray-800/50 border border-gray-700 rounded p-3">
                                    <div class="text-gray-300 font-mono text-[10px] space-y-0.5">
                                        <div>el.style.color = 'red'</div>
                                        <div>el.style.backgroundColor = '#000' <span class="text-gray-400">// camelCase!</span></div>
                                        <div>el.style.fontSize = '16px' <span class="text-gray-400">// include units</span></div>
                                        <div>el.style.display = 'none'</div>
                                    </div>
                                </div>

                                <div class="bg-yellow-500/20 border border-yellow-500 rounded p-3">
                                    <div class="text-yellow-300 font-mono text-xs space-y-0.5">
                                        <div><span class="text-gray-400">// Remove style</span></div>
                                        <div>el.style.color = ''</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="text-gray-300 text-sm mt-3 p-3 bg-gray-800/50 rounded border border-gray-700">
                            Sets inline styles. Prefer <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">classList</code> for better separation of concerns.
                        </div>

                        <ProTip>
                            <div>⚠️ <strong>Prefer classes over inline styles:</strong></div>
                            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                                <div class="font-mono text-[10px]"><span class="text-red-400">// Bad - hard to maintain ❌</span></div>
                                <div class="font-mono text-[10px]">el.style.color = 'red'</div>
                                <div class="font-mono text-[10px]">el.style.fontSize = '20px'</div>
                                <div class="font-mono text-[10px] mt-1"><span class="text-green-400">// Good - CSS in stylesheet ✅</span></div>
                                <div class="font-mono text-[10px]">el.classList.add('highlighted')</div>
                            </div>
                        </ProTip>
                    </MethodCard>
                </div>

                <!-- ============================================ -->
                <!-- 🏗️ CREATING & MODIFYING STRUCTURE -->
                <!-- ============================================ -->

                <h2 id="creating" class="text-orange-300 text-xl my-4 pb-2 border-b-2 border-orange-600">
                    🏗️ Creating & Modifying Structure
                </h2>

                <!-- CREATEELEMENT -->
                <div id="create-element">
                    <MethodCard
                        methodName="createElement() & appendChild()"
                        signature="document.createElement(tagName)"
                        description="Create new elements and add to DOM"
                        mutates={true}
                    >
                        <div class="p-6 bg-gray-800 rounded">
                            <div class="space-y-4">
                                <!-- Steps -->
                                <div class="space-y-3">
                                    <div class="flex items-center gap-3">
                                        <div class="w-6 text-gray-500 text-xs">1</div>
                                        <div class="flex-1 bg-blue-500/20 border border-blue-400 rounded px-3 py-2">
                                            <div class="text-blue-300 font-mono text-xs">const div = document.createElement('div')</div>
                                        </div>
                                    </div>

                                    <div class="flex items-center gap-3">
                                        <div class="w-6 text-gray-500 text-xs">2</div>
                                        <div class="flex-1 bg-purple-500/20 border border-purple-400 rounded px-3 py-2">
                                            <div class="text-purple-300 font-mono text-xs">div.textContent = 'Hello'</div>
                                        </div>
                                    </div>

                                    <div class="flex items-center gap-3">
                                        <div class="w-6 text-gray-500 text-xs">3</div>
                                        <div class="flex-1 bg-green-500/20 border border-green-500 rounded px-3 py-2">
                                            <div class="text-green-300 font-mono text-xs">document.body.appendChild(div)</div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Full example -->
                                <div class="bg-orange-500/20 border border-orange-400 rounded p-3">
                                    <div class="text-orange-300 font-mono text-xs space-y-0.5">
                                        <div>const button = document.createElement('button')</div>
                                        <div>button.textContent = 'Click me'</div>
                                        <div>button.classList.add('btn', 'btn-primary')</div>
                                        <div>button.onclick = () =&gt; alert('Clicked!')</div>
                                        <div>document.body.appendChild(button)</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <ProTip>
                            <div>Other insertion methods:</div>
                            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                                <div class="font-mono text-[10px]">parent.appendChild(child) <span class="text-gray-400">// end</span></div>
                                <div class="font-mono text-[10px]">parent.prepend(child) <span class="text-gray-400">// start</span></div>
                                <div class="font-mono text-[10px]">element.before(newEl) <span class="text-gray-400">// before sibling</span></div>
                                <div class="font-mono text-[10px]">element.after(newEl) <span class="text-gray-400">// after sibling</span></div>
                            </div>
                        </ProTip>
                    </MethodCard>
                </div>

                <!-- REMOVE -->
                <div id="remove">
                    <MethodCard
                        methodName="remove() & removeChild()"
                        signature="element.remove()"
                        description="Remove elements from DOM"
                        mutates={true}
                    >
                        <div class="p-6 bg-gray-800 rounded">
                            <div class="space-y-3">
                                <div class="bg-red-500/20 border border-red-500 rounded p-3">
                                    <div class="text-red-300 font-mono text-xs space-y-0.5">
                                        <div>element.remove() <span class="text-gray-400">// modern way</span></div>
                                    </div>
                                </div>

                                <div class="bg-gray-800/50 border border-gray-700 rounded p-3">
                                    <div class="text-gray-300 font-mono text-xs space-y-0.5">
                                        <div>parent.removeChild(child) <span class="text-gray-400">// old way</span></div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <ProTip>
                            <div>Remove all children:</div>
                            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                                <div class="font-mono text-[10px]"><span class="text-gray-400">// Fast way</span></div>
                                <div class="font-mono text-[10px]">element.innerHTML = ''</div>
                                <div class="font-mono text-[10px] mt-1"><span class="text-gray-400">// Better way (removes listeners)</span></div>
                                <div class="font-mono text-[10px]">element.replaceChildren()</div>
                                <div class="font-mono text-[10px] mt-1"><span class="text-gray-400">// Loop way</span></div>
                                <div class="font-mono text-[10px]">while (el.firstChild) el.firstChild.remove()</div>
                            </div>
                        </ProTip>
                    </MethodCard>
                </div>

                <!-- ============================================ -->
                <!-- 🎪 EVENTS -->
                <!-- ============================================ -->

                <h2 id="events" class="text-cyan-300 text-xl my-4 pb-2 border-b-2 border-cyan-600">
                    🎪 Events
                </h2>

                <!-- ADDEVENTLISTENER -->
                <div id="add-event-listener">
                    <MethodCard
                        methodName="addEventListener()"
                        signature="element.addEventListener(type, handler, options?)"
                        description="Listen for events on elements"
                        mutates={false}
                    >
                        <div class="p-6 bg-gray-800 rounded">
                            <div class="space-y-4">
                                <!-- Basic usage -->
                                <div class="bg-cyan-500/20 border border-cyan-400 rounded p-3">
                                    <div class="text-cyan-300 font-mono text-xs space-y-0.5">
                                        <div>button.addEventListener('click', (event) =&gt; &lbrace;</div>
                                        <div>&nbsp;&nbsp;console.log('Clicked!', event.target)</div>
                                        <div>&rbrace;)</div>
                                    </div>
                                </div>

                                <!-- Common events -->
                                <div class="bg-gray-800/50 border border-gray-700 rounded p-3">
                                    <div class="text-gray-300 font-mono text-[10px] space-y-0.5">
                                        <div>'click', 'dblclick', 'contextmenu'</div>
                                        <div>'mouseenter', 'mouseleave', 'mousemove'</div>
                                        <div>'keydown', 'keyup', 'keypress'</div>
                                        <div>'input', 'change', 'focus', 'blur'</div>
                                        <div>'submit', 'scroll', 'resize'</div>
                                    </div>
                                </div>

                                <!-- Options -->
                                <div class="bg-purple-500/20 border border-purple-400 rounded p-3">
                                    <div class="text-purple-300 font-mono text-xs space-y-0.5">
                                        <div>el.addEventListener('click', handler, &lbrace;</div>
                                        <div>&nbsp;&nbsp;once: true, <span class="text-gray-400">// remove after first call</span></div>
                                        <div>&nbsp;&nbsp;capture: false, <span class="text-gray-400">// bubble phase (default)</span></div>
                                        <div>&nbsp;&nbsp;passive: true <span class="text-gray-400">// won't call preventDefault</span></div>
                                        <div>&rbrace;)</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <ProTip>
                            <div>Remove event listeners:</div>
                            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                                <div class="font-mono text-[10px]">const handler = () =&gt; &lbrace; ... &rbrace;</div>
                                <div class="font-mono text-[10px]">el.addEventListener('click', handler)</div>
                                <div class="font-mono text-[10px]">el.removeEventListener('click', handler)</div>
                                <div class="font-mono text-[10px] mt-1"><span class="text-yellow-400">// Must be same function reference!</span></div>
                            </div>
                        </ProTip>
                    </MethodCard>
                </div>

                <!-- EVENT DELEGATION -->
                <div id="event-delegation">
                    <MethodCard
                        methodName="Event Delegation"
                        signature="Listen on parent, handle on children"
                        description="Efficient way to handle events on many elements"
                        mutates={false}
                    >
                        <div class="p-6 bg-gray-800 rounded">
                            <div class="space-y-4">
                                <!-- Bad way -->
                                <div>
                                    <div class="text-red-400 text-xs mb-2">❌ Bad - many listeners:</div>
                                    <div class="bg-red-500/20 border border-red-500 rounded p-3">
                                        <div class="text-red-300 font-mono text-xs space-y-0.5">
                                            <div>items.forEach(item =&gt; &lbrace;</div>
                                            <div>&nbsp;&nbsp;item.addEventListener('click', handler)</div>
                                            <div>&rbrace;)</div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Good way -->
                                <div>
                                    <div class="text-green-400 text-xs mb-2">✅ Good - one listener:</div>
                                    <div class="bg-green-500/20 border border-green-500 rounded p-3">
                                        <div class="text-green-300 font-mono text-xs space-y-0.5">
                                            <div>list.addEventListener('click', (e) =&gt; &lbrace;</div>
                                            <div>&nbsp;&nbsp;if (e.target.matches('.item')) &lbrace;</div>
                                            <div>&nbsp;&nbsp;&nbsp;&nbsp;// Handle item click</div>
                                            <div>&nbsp;&nbsp;&rbrace;</div>
                                            <div>&rbrace;)</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <ProTip>
                            <div>Benefits of delegation:</div>
                            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                                <div class="font-mono text-[10px]"><span class="text-green-400">✅ One listener instead of many</span></div>
                                <div class="font-mono text-[10px]"><span class="text-green-400">✅ Works for dynamically added elements</span></div>
                                <div class="font-mono text-[10px]"><span class="text-green-400">✅ Less memory usage</span></div>
                                <div class="font-mono text-[10px] mt-1"><span class="text-gray-400">Use e.target to find which child was clicked</span></div>
                            </div>
                        </ProTip>
                    </MethodCard>
                </div>

                <!-- ============================================ -->
                <!-- 📦 ATTRIBUTES & PROPERTIES -->
                <!-- ============================================ -->

                <h2 id="attributes" class="text-yellow-300 text-xl my-4 pb-2 border-b-2 border-yellow-600">
                    📦 Attributes & Properties
                </h2>

                <!-- GETATTRIBUTE / SETATTRIBUTE -->
                <div id="attributes-methods">
                    <MethodCard
                        methodName="getAttribute() / setAttribute()"
                        signature="element.getAttribute(name)"
                        description="Get/set HTML attributes"
                        mutates={true}
                    >
                        <div class="p-6 bg-gray-800 rounded">
                            <div class="space-y-3">
                                <div class="bg-gray-800/50 border border-gray-700 rounded p-3">
                                    <div class="text-gray-300 font-mono text-[10px] space-y-0.5">
                                        <div>el.getAttribute('data-id') <span class="text-gray-400">// get</span></div>
                                        <div>el.setAttribute('data-id', '123') <span class="text-gray-400">// set</span></div>
                                        <div>el.removeAttribute('data-id') <span class="text-gray-400">// remove</span></div>
                                        <div>el.hasAttribute('data-id') <span class="text-gray-400">// check</span></div>
                                    </div>
                                </div>

                                <div class="bg-yellow-500/20 border border-yellow-500 rounded p-3">
                                    <div class="text-yellow-300 font-mono text-xs space-y-0.5">
                                        <div><span class="text-gray-400">// Direct property access (modern)</span></div>
                                        <div>el.dataset.id = '123' <span class="text-gray-400">// sets data-id</span></div>
                                        <div>el.id = 'main' <span class="text-gray-400">// sets id</span></div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <ProTip>
                            <div>Attributes vs Properties:</div>
                            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                                <div class="font-mono text-[10px]"><span class="text-gray-400">// Attribute (string in HTML)</span></div>
                                <div class="font-mono text-[10px]">input.getAttribute('value') <span class="text-gray-400">// initial value</span></div>
                                <div class="font-mono text-[10px] mt-1"><span class="text-gray-400">// Property (JS value, can differ)</span></div>
                                <div class="font-mono text-[10px]">input.value <span class="text-gray-400">// current value</span></div>
                            </div>
                        </ProTip>
                    </MethodCard>
