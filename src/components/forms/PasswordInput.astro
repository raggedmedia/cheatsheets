---
interface Props {
    id: string;
    name: string;
    label: string;
    required?: boolean;
    placeholder?: string;
    autocomplete?: string;
    minlength?: number;
    helperText?: string;
    errorText?: string;
}

const {
    id,
    name,
    label,
    required = false,
    placeholder,
    autocomplete = "current-password",
    minlength = 10,
    helperText,
    errorText,
} = Astro.props;

// Only show helper text if explicitly provided
const finalErrorText =
    errorText || `Password must be at least ${minlength} characters`;
---

<div class="form-group">
    <label for={id} class="form-label">
        {label}
        {
            required && (
                <span class="required-indicator" aria-label="required">
                    *
                </span>
            )
        }
    </label>

    <input
        type="password"
        id={id}
        name={name}
        class="form-input"
        required={required}
        placeholder={placeholder}
        autocomplete={autocomplete}
        minlength={minlength}
        aria-describedby={`${id}-help`}
        aria-invalid="false"
    />

    <!-- Helper text - shown only if provided -->
    {
        helperText && (
            <div id={`${id}-help`} class="form-help-text password-help-text">
                {helperText}
            </div>
        )
    }

    <!-- Error text - shown when invalid and touched -->
    <div id={`${id}-error`} class="form-help-text password-error-text">
        {finalErrorText}
    </div>
</div>

<style>
    /* Component-specific styles only - shared styles are in _forms.css */
</style>
