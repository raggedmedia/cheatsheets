---
import MethodCard from '~components/visual-js/MethodCard.astro';
import MutableOrNot from '~components/visual-js/MutableOrNot.astro';
import ProTip from '~components/visual-js/ProTip.astro';
import SectionTitle from '~components/visual-js/SectionTitle.astro';
import VisualLayout from 'src/layouts/VisualLayout.astro';
import InfoBox from '~components/visual-js/InfoBox.astro';
---
<VisualLayout
    pageTitle="Javascript Loops"
>
                <InfoBox>
                    <div class="space-y-3">
                        <div>
                            <strong class="text-blue-300">🔄 When to Use Each Loop Type</strong>
                        </div>

                        <div class="space-y-2 text-sm">
                            <div class="border-l-2 border-blue-500/30 pl-3">
                                <div class="text-blue-300 font-semibold mb-1">Arrays (Iterable)</div>
                                <div class="space-y-1 text-xs">
                                    <div>• <code class="bg-black/40 px-1 py-0.5 rounded text-blue-300">.forEach()</code> — Best for simple iteration, very readable</div>
                                    <div>• <code class="bg-black/40 px-1 py-0.5 rounded text-blue-300">for...of</code> — When you need break/continue/return/await</div>
                                    <div>• <code class="bg-black/40 px-1 py-0.5 rounded text-blue-300">.map()</code> — Transform each item, returns NEW array</div>
                                    <div>• <code class="bg-black/40 px-1 py-0.5 rounded text-blue-300">for (i=0...)</code> — When you need index control or reverse iteration</div>
                                </div>
                            </div>

                            <div class="border-l-2 border-purple-500/30 pl-3">
                                <div class="text-purple-300 font-semibold mb-1">Objects (Key-Value Pairs)</div>
                                <div class="space-y-1 text-xs">
                                    <div>• <code class="bg-black/40 px-1 py-0.5 rounded text-purple-300">for...in</code> — Loop over object keys (includes inherited)</div>
                                    <div>• <code class="bg-black/40 px-1 py-0.5 rounded text-purple-300">Object.keys(obj)</code> — Convert to array, then use array methods</div>
                                    <div>• <code class="bg-black/40 px-1 py-0.5 rounded text-purple-300">Object.entries(obj)</code> — Get [key, value] pairs as array</div>
                                </div>
                            </div>

                            <div class="border-l-2 border-yellow-500/30 pl-3">
                                <div class="text-yellow-300 font-semibold mb-1">⚠️ Primitives (Strings, Numbers, Booleans)</div>
                                <div class="space-y-1 text-xs">
                                    <div>• <strong>Strings:</strong> Convert to array first: <code class="bg-black/40 px-1 py-0.5 rounded">[...str]</code> or <code class="bg-black/40 px-1 py-0.5 rounded">str.split('')</code></div>
                                    <div>• <strong>Numbers:</strong> Can't loop directly—use range helpers or Array(n)</div>
                                    <div>• <strong>Note:</strong> Strings ARE iterable with for...of, but array methods give more control</div>
                                </div>
                            </div>

                            <div class="border-l-2 border-orange-500/30 pl-3">
                                <div class="text-orange-300 font-semibold mb-1">While Loops</div>
                                <div class="space-y-1 text-xs">
                                    <div>• <code class="bg-black/40 px-1 py-0.5 rounded text-orange-300">while</code> — Unknown iterations, keep going until condition false</div>
                                    <div>• <code class="bg-black/40 px-1 py-0.5 rounded text-orange-300">do...while</code> — Same but guaranteed to run at least once</div>
                                </div>
                            </div>

                            <div class="border-l-2 border-red-500/30 pl-3">
                                <div class="text-red-300 font-semibold mb-1">Control Flow (break/continue)</div>
                                <div class="space-y-1 text-xs">
                                    <div>• <code class="bg-black/40 px-1 py-0.5 rounded text-red-300">break</code> — Exit loop completely</div>
                                    <div>• <code class="bg-black/40 px-1 py-0.5 rounded text-red-300">continue</code> — Skip to next iteration</div>
                                    <div>• <strong>⚠️ Don't work with .forEach()</strong> — Use for...of if you need these</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </InfoBox>

                <!-- ============================================ -->
                <!-- 🔄 ARRAY LOOPS -->
                <!-- ============================================ -->

                <SectionTitle id="array-loops" color="blue">
                    🔄 Array Loops
                </SectionTitle>

                <!-- FOR...OF -->
                <MethodCard
                        id="for-of"
                        methodName="for...of"
                        signature="for (const item of array) { }"
                        description="Loop over array values (modern, recommended)"
                        mutates={false}
                    >
                        <div class="p-4 bg-gray-800 rounded border border-gray-700">
                            <!-- Code -->
                            <div class="font-mono text-sm mb-4">
                                <span class="text-purple-300">for</span> <span class="text-purple-300">(</span><span class="text-gray-400">const</span> <span class="text-blue-300">item</span> <span class="text-purple-300">of</span> <span class="text-orange-300">['a', 'b', 'c']</span><span class="text-purple-300">) {'{'}</span>
                                <div class="ml-4"><span class="text-gray-400">console.log(item)</span></div>
                                <span class="text-purple-300">{'}'}</span>
                            </div>

                            <!-- Iteration visualization -->
                            <div class="space-y-2 text-xs">
                                <div class="text-gray-400 mb-2">Loops through each value directly:</div>

                                <div class="p-2 bg-purple-500/10 border border-purple-500/30 rounded">
                                    <div class="text-purple-300 text-[10px] mb-1">Iteration 1</div>
                                    <div class="font-mono text-sm">item = <span class="text-green-300">'a'</span></div>
                                    <div class="text-gray-400 text-[10px] mt-1">// executes loop body with 'a'</div>
                                </div>

                                <div class="p-2 bg-purple-500/10 border border-purple-500/30 rounded">
                                    <div class="text-purple-300 text-[10px] mb-1">Iteration 2</div>
                                    <div class="font-mono text-sm">item = <span class="text-green-300">'b'</span></div>
                                    <div class="text-gray-400 text-[10px] mt-1">// executes loop body with 'b'</div>
                                </div>

                                <div class="p-2 bg-purple-500/10 border border-purple-500/30 rounded">
                                    <div class="text-purple-300 text-[10px] mb-1">Iteration 3</div>
                                    <div class="font-mono text-sm">item = <span class="text-green-300">'c'</span></div>
                                    <div class="text-gray-400 text-[10px] mt-1">// executes loop body with 'c'</div>
                                </div>

                                <div class="mt-3 p-2 bg-gray-700/30 rounded text-center text-gray-400">
                                    Loop complete!
                                </div>
                            </div>
                        </div>

                        <MutableOrNot mutates={false} message="">
                            Modern, clean syntax. Works with arrays, strings, Maps, Sets. <strong>Cannot access index directly.</strong>
                        </MutableOrNot>

                        <ProTip>
                            <div>✨ <strong>Recommended for most array iteration:</strong></div>
                            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                                <div class="font-mono text-[10px]">for (const item of arr) {'{'}</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;console.log(item) <span class="text-gray-400">// clean & readable</span></div>
                                <div class="font-mono text-[10px]">{'}'}</div>
                                <div class="font-mono text-[10px] mt-1"><span class="text-gray-400">// Get index with entries()</span></div>
                                <div class="font-mono text-[10px]">for (const [i, item] of arr.entries()) {'{'}</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;console.log(i, item)</div>
                                <div class="font-mono text-[10px]">{'}'}</div>
                            </div>
                        </ProTip>
                    </MethodCard>

                <!-- FOREACH -->
                <MethodCard
                        id="forEach"
                        methodName="forEach()"
                        signature="arr.forEach((item, index) => { })"
                        description="Execute function for each array element"
                        mutates={false}
                    >
                        <div class="p-4 bg-gray-800 rounded border border-gray-700">
                            <!-- Code -->
                            <div class="font-mono text-sm mb-4">
                                <span class="text-orange-300">['a', 'b', 'c']</span><span class="text-purple-300">.forEach((</span><span class="text-blue-300">item</span><span class="text-purple-300">,</span> <span class="text-cyan-300">index</span><span class="text-purple-300">) => {'{'}</span>
                                <div class="ml-4"><span class="text-gray-400">console.log(index, item)</span></div>
                                <span class="text-purple-300">{'}'})</span>
                            </div>

                            <!-- Iteration visualization -->
                            <div class="space-y-2 text-xs">
                                <div class="text-gray-400 mb-2">Calls callback function for each element:</div>

                                <div class="p-2 bg-purple-500/10 border border-purple-500/30 rounded">
                                    <div class="text-purple-300 text-[10px] mb-1">Callback 1</div>
                                    <div class="font-mono text-sm">item = <span class="text-green-300">'a'</span>, index = <span class="text-cyan-300">0</span></div>
                                    <div class="text-gray-400 text-[10px] mt-1">// executes callback</div>
                                </div>

                                <div class="p-2 bg-purple-500/10 border border-purple-500/30 rounded">
                                    <div class="text-purple-300 text-[10px] mb-1">Callback 2</div>
                                    <div class="font-mono text-sm">item = <span class="text-green-300">'b'</span>, index = <span class="text-cyan-300">1</span></div>
                                    <div class="text-gray-400 text-[10px] mt-1">// executes callback</div>
                                </div>

                                <div class="p-2 bg-purple-500/10 border border-purple-500/30 rounded">
                                    <div class="text-purple-300 text-[10px] mb-1">Callback 3</div>
                                    <div class="font-mono text-sm">item = <span class="text-green-300">'c'</span>, index = <span class="text-cyan-300">2</span></div>
                                    <div class="text-gray-400 text-[10px] mt-1">// executes callback</div>
                                </div>

                                <div class="mt-3 p-2 bg-gray-700/30 rounded text-center text-gray-400">
                                    Returns undefined (no return value)
                                </div>
                            </div>
                        </div>

                        <MutableOrNot mutates={false} message="">
                            Returns <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">undefined</code>. ⚠️ Cannot break or return early. Cannot be chained.
                        </MutableOrNot>

                        <ProTip>
                            <div>⚠️ <strong>Gotchas:</strong></div>
                            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                                <div class="font-mono text-[10px]">arr.forEach(item =&gt; {'{'}</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;if (item === 'stop') return <span class="text-red-400">// only exits callback, not loop! ⚠️</span></div>
                                <div class="font-mono text-[10px]">{'}'})</div>
                                <div class="font-mono text-[10px] mt-1"><span class="text-green-400">// Use for...of if you need to break:</span></div>
                                <div class="font-mono text-[10px]">for (const item of arr) {'{'}</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;if (item === 'stop') break ✅ <span class="text-gray-400">// exits loop</span></div>
                                <div class="font-mono text-[10px]">{'}'}</div>
                            </div>
                        </ProTip>
                    </MethodCard>

                <!-- CLASSIC FOR LOOP -->
                <MethodCard
                        id="for-loop"
                        methodName="for loop"
                        signature="for (let i = 0; i < arr.length; i++) { }"
                        description="Classic indexed loop (C-style)"
                        mutates={false}
                    >
                        <div class="p-4 bg-gray-800 rounded border border-gray-700">
                            <!-- Code -->
                            <div class="font-mono text-sm mb-4">
                                <span class="text-gray-400">const</span> <span class="text-orange-300">arr</span> = <span class="text-orange-300">['a', 'b', 'c']</span>
                                <div class="mt-1"><span class="text-purple-300">for</span> <span class="text-purple-300">(</span><span class="text-gray-400">let</span> <span class="text-cyan-300">i</span> = <span class="text-green-300">0</span><span class="text-purple-300">;</span> <span class="text-cyan-300">i</span> <span class="text-purple-300">&lt;</span> <span class="text-orange-300">arr.length</span><span class="text-purple-300">;</span> <span class="text-cyan-300">i</span><span class="text-purple-300">++) {'{'}</span></div>
                                <div class="ml-4"><span class="text-gray-400">console.log(i, arr[i])</span></div>
                                <span class="text-purple-300">{'}'}</span>
                            </div>

                            <!-- Iteration visualization -->
                            <div class="space-y-2 text-xs">
                                <div class="text-gray-400 mb-2">Three-part loop structure: init; condition; increment</div>

                                <div class="p-2 bg-purple-500/10 border border-purple-500/30 rounded">
                                    <div class="text-purple-300 text-[10px] mb-1">Iteration 1</div>
                                    <div class="font-mono text-sm">i = <span class="text-cyan-300">0</span>, arr[<span class="text-cyan-300">0</span>] = <span class="text-green-300">'a'</span></div>
                                    <div class="text-gray-400 text-[10px] mt-1">// check: 0 &lt; 3 ✓, execute body, then i++</div>
                                </div>

                                <div class="p-2 bg-purple-500/10 border border-purple-500/30 rounded">
                                    <div class="text-purple-300 text-[10px] mb-1">Iteration 2</div>
                                    <div class="font-mono text-sm">i = <span class="text-cyan-300">1</span>, arr[<span class="text-cyan-300">1</span>] = <span class="text-green-300">'b'</span></div>
                                    <div class="text-gray-400 text-[10px] mt-1">// check: 1 &lt; 3 ✓, execute body, then i++</div>
                                </div>

                                <div class="p-2 bg-purple-500/10 border border-purple-500/30 rounded">
                                    <div class="text-purple-300 text-[10px] mb-1">Iteration 3</div>
                                    <div class="font-mono text-sm">i = <span class="text-cyan-300">2</span>, arr[<span class="text-cyan-300">2</span>] = <span class="text-green-300">'c'</span></div>
                                    <div class="text-gray-400 text-[10px] mt-1">// check: 2 &lt; 3 ✓, execute body, then i++</div>
                                </div>

                                <div class="mt-3 p-2 bg-gray-700/30 rounded">
                                    <div class="font-mono text-sm">i = <span class="text-cyan-300">3</span></div>
                                    <div class="text-gray-400 text-[10px] mt-1">// check: 3 &lt; 3 ✗, exit loop</div>
                                </div>
                            </div>
                        </div>

                        <MutableOrNot mutates={false} message="">
                            Full control over iteration. Can break/continue. Good for complex iteration patterns.
                        </MutableOrNot>

                        <ProTip>
                            <div>When to use classic for loop:</div>
                            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                                <div class="font-mono text-[10px]"><span class="text-gray-400">// Iterate backwards</span></div>
                                <div class="font-mono text-[10px]">for (let i = arr.length - 1; i &gt;= 0; i--) {'{'} ... {'}'}</div>
                                <div class="font-mono text-[10px] mt-1"><span class="text-gray-400">// Skip elements</span></div>
                                <div class="font-mono text-[10px]">for (let i = 0; i &lt; arr.length; i += 2) {'{'} ... {'}'}</div>
                                <div class="font-mono text-[10px] mt-1"><span class="text-gray-400">// Nested loops</span></div>
                                <div class="font-mono text-[10px]">for (let i = 0; i &lt; rows; i++) {'{'}</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;for (let j = 0; j &lt; cols; j++) {'{'} ... {'}'}</div>
                                <div class="font-mono text-[10px]">{'}'}</div>
                            </div>
                        </ProTip>
                    </MethodCard>

                <!-- MAP -->
                <MethodCard
                        id="map"
                        methodName="map()"
                        signature="arr.map(item => newItem)"
                        description="Transform each element, return new array"
                        mutates={false}
                    >
                        <div class="p-4 bg-gray-800 rounded border border-gray-700">
                            <!-- Code -->
                            <div class="font-mono text-sm mb-4">
                                <span class="text-gray-400">const</span> <span class="text-blue-300">doubled</span> =
                                <span class="text-orange-300 ml-2">[1, 2, 3]</span><span class="text-purple-300">.map(</span><span class="text-gray-400">x</span> <span class="text-purple-300">=&gt;</span> <span class="text-gray-400">x</span> <span class="text-purple-300">*</span> <span class="text-green-300">2</span><span class="text-purple-300">)</span>
                            </div>

                            <!-- Iteration visualization -->
                            <div class="space-y-2 text-xs">
                                <div class="text-gray-400 mb-2">Iterates through each item, transforms it:</div>

                                <div class="flex items-center gap-2">
                                    <div class="w-16 p-2 bg-blue-500/10 border border-blue-500/30 rounded text-center font-mono">1</div>
                                    <div class="text-purple-300">→</div>
                                    <div class="flex-1 p-2 bg-purple-500/10 border border-purple-500/30 rounded font-mono text-center">
                                        <span class="text-gray-400">x * 2</span>
                                    </div>
                                    <div class="text-purple-300">→</div>
                                    <div class="w-16 p-2 bg-green-500/10 border border-green-500/30 rounded text-center font-mono">2</div>
                                </div>

                                <div class="flex items-center gap-2">
                                    <div class="w-16 p-2 bg-blue-500/10 border border-blue-500/30 rounded text-center font-mono">2</div>
                                    <div class="text-purple-300">→</div>
                                    <div class="flex-1 p-2 bg-purple-500/10 border border-purple-500/30 rounded font-mono text-center">
                                        <span class="text-gray-400">x * 2</span>
                                    </div>
                                    <div class="text-purple-300">→</div>
                                    <div class="w-16 p-2 bg-green-500/10 border border-green-500/30 rounded text-center font-mono">4</div>
                                </div>

                                <div class="flex items-center gap-2">
                                    <div class="w-16 p-2 bg-blue-500/10 border border-blue-500/30 rounded text-center font-mono">3</div>
                                    <div class="text-purple-300">→</div>
                                    <div class="flex-1 p-2 bg-purple-500/10 border border-purple-500/30 rounded font-mono text-center">
                                        <span class="text-gray-400">x * 2</span>
                                    </div>
                                    <div class="text-purple-300">→</div>
                                    <div class="w-16 p-2 bg-green-500/10 border border-green-500/30 rounded text-center font-mono">6</div>
                                </div>

                                <!-- Result -->
                                <div class="mt-3 pt-3 border-t border-gray-700">
                                    <div class="text-gray-400 mb-1">Returns new array:</div>
                                    <div class="p-2 bg-green-500/10 border border-green-500/30 rounded font-mono text-center">
                                        [2, 4, 6]
                                    </div>
                                </div>
                            </div>
                        </div>

                        <MutableOrNot mutates={false} message="">
                            Returns <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">new array</code> with transformed elements. Original array unchanged. Can be chained.
                        </MutableOrNot>

                        <ProTip>
                            <div>💡 <strong>Use map() when you need a transformed array:</strong></div>
                            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                                <div class="font-mono text-[10px]">const doubled = arr.map(x =&gt; x * 2) ✅</div>
                                <div class="font-mono text-[10px]">const names = users.map(u =&gt; u.name) ✅</div>
                                <div class="font-mono text-[10px] mt-1"><span class="text-red-400">// Don't use map if you don't need the result:</span></div>
                                <div class="font-mono text-[10px]">arr.map(x =&gt; console.log(x)) ❌ <span class="text-gray-400">// use forEach instead</span></div>
                            </div>
                        </ProTip>
                    </MethodCard>

                <!-- FILTER -->
                <MethodCard
                        id="filter"
                        methodName="filter()"
                        signature="arr.filter(item => boolean)"
                        description="Keep only elements that pass the test"
                        mutates={false}
                    >
                        <div class="p-4 bg-gray-800 rounded border border-gray-700">
                            <!-- Code -->
                            <div class="font-mono text-sm mb-4">
                                <span class="text-gray-400">const</span> <span class="text-blue-300">filtered</span> =
                                <span class="text-orange-300 ml-2">[1, 2, 3, 4, 5]</span><span class="text-purple-300">.filter(</span><span class="text-gray-400">x</span> <span class="text-purple-300">=&gt;</span> <span class="text-gray-400">x</span> <span class="text-purple-300">&gt;</span> <span class="text-green-300">2</span><span class="text-purple-300">)</span>
                            </div>

                            <!-- Iteration visualization -->
                            <div class="space-y-2 text-xs">
                                <div class="text-gray-400 mb-2">Tests each item, keeps only those that pass:</div>

                                <div class="flex items-center gap-2">
                                    <div class="w-16 p-2 bg-blue-500/10 border border-blue-500/30 rounded text-center font-mono">1</div>
                                    <div class="text-purple-300">→</div>
                                    <div class="flex-1 p-2 bg-purple-500/10 border border-purple-500/30 rounded font-mono text-center text-xs">
                                        <span class="text-gray-400">1 &gt; 2?</span>
                                    </div>
                                    <div class="text-purple-300">→</div>
                                    <div class="w-20 p-2 bg-red-500/10 border border-red-500/30 rounded text-center font-mono text-red-300">false ✗</div>
                                </div>

                                <div class="flex items-center gap-2">
                                    <div class="w-16 p-2 bg-blue-500/10 border border-blue-500/30 rounded text-center font-mono">2</div>
                                    <div class="text-purple-300">→</div>
                                    <div class="flex-1 p-2 bg-purple-500/10 border border-purple-500/30 rounded font-mono text-center text-xs">
                                        <span class="text-gray-400">2 &gt; 2?</span>
                                    </div>
                                    <div class="text-purple-300">→</div>
                                    <div class="w-20 p-2 bg-red-500/10 border border-red-500/30 rounded text-center font-mono text-red-300">false ✗</div>
                                </div>

                                <div class="flex items-center gap-2">
                                    <div class="w-16 p-2 bg-blue-500/10 border border-blue-500/30 rounded text-center font-mono">3</div>
                                    <div class="text-purple-300">→</div>
                                    <div class="flex-1 p-2 bg-purple-500/10 border border-purple-500/30 rounded font-mono text-center text-xs">
                                        <span class="text-gray-400">3 &gt; 2?</span>
                                    </div>
                                    <div class="text-purple-300">→</div>
                                    <div class="w-20 p-2 bg-green-500/10 border border-green-500/30 rounded text-center font-mono text-green-300">true ✓</div>
                                </div>

                                <div class="flex items-center gap-2">
                                    <div class="w-16 p-2 bg-blue-500/10 border border-blue-500/30 rounded text-center font-mono">4</div>
                                    <div class="text-purple-300">→</div>
                                    <div class="flex-1 p-2 bg-purple-500/10 border border-purple-500/30 rounded font-mono text-center text-xs">
                                        <span class="text-gray-400">4 &gt; 2?</span>
                                    </div>
                                    <div class="text-purple-300">→</div>
                                    <div class="w-20 p-2 bg-green-500/10 border border-green-500/30 rounded text-center font-mono text-green-300">true ✓</div>
