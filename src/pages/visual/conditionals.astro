                                        <div class="font-mono text-[10px] space-y-0.5 text-gray-300">
                                            <div>!<span class="text-red-300">false</span> → <span class="text-green-300">true</span></div>
                                            <div>!<span class="text-red-300">null</span> → <span class="text-green-300">true</span></div>
                                            <div>!<span class="text-red-300">0</span> → <span class="text-green-300">true</span></div>
                                            <div>!<span class="text-red-300">''</span> → <span class="text-green-300">true</span></div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Double negation -->
                                <div class="p-3 bg-purple-500/5 border border-purple-500/30 rounded mt-3">
                                    <div class="text-purple-300 text-xs font-bold mb-1">Double Negation (!!) = Boolean Conversion</div>
                                    <div class="font-mono text-[10px] space-y-0.5 text-gray-300">
                                        <div>!!<span class="text-green-300">'hello'</span> → <span class="text-green-300">true</span></div>
                                        <div>!!<span class="text-red-300">0</span> → <span class="text-red-300">false</span></div>
                                        <div>!!<span class="text-green-300">[1,2,3]</span> → <span class="text-green-300">true</span></div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="text-gray-300 text-sm mt-3 p-3 bg-gray-800/50 rounded border border-gray-700">
                            Always returns <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">true</code> or <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">false</code>. Double negation (!!) converts to boolean.
                        </div>

                        <ProTip>
                            <div>Common patterns:</div>
                            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                                <div class="font-mono text-[10px]"><span class="text-gray-400">// Check if falsy</span></div>
                                <div class="font-mono text-[10px]">if (!user) return <span class="text-gray-400">// guard clause</span></div>
                                <div class="font-mono text-[10px] mt-1"><span class="text-gray-400">// Toggle boolean</span></div>
                                <div class="font-mono text-[10px]">isVisible = !isVisible</div>
                                <div class="font-mono text-[10px] mt-1"><span class="text-gray-400">// Convert to boolean (double negation)</span></div>
                                <div class="font-mono text-[10px]">const hasItems = !!arr.length <span class="text-gray-400">// true/false</span></div>
                            </div>
                        </ProTip>
                    </MethodCard>
                </div>

