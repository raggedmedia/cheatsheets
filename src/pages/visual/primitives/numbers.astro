---
import MethodCard from '~components/visual-js/MethodCard.astro';
import Node from '~components/visual-js/Node.astro';
import Arrow from '~components/visual-js/Arrow.astro';
import ReturnValue from '~components/visual-js/ReturnValue.astro';
import MutableOrNot from '~components/visual-js/MutableOrNot.astro';
import ProcessContent from '~components/visual-js/ProcessContent.astro';
import ProTip from '~components/visual-js/ProTip.astro';
import SectionTitle from '~components/visual-js/SectionTitle.astro';
import VisualLayout from 'src/layouts/VisualLayout.astro';
---
<VisualLayout
    pageTitle="Javascript Numbers"
>
    <ProTip>
        <div>⚡ <strong>Numbers are immutable!</strong> All methods return a new value — the original never changes.</div>
        <div class="pl-2 border-l-2 border-yellow-500/30 font-mono text-[10px] mt-1">
            const num = 3.14159<br/>
            num.toFixed(2) <span class="text-red-400">// returns '3.14' but num stays 3.14159</span><br/>
            const rounded = num.toFixed(2) ✅ <span class="text-gray-400">// always save the result!</span>
        </div>
    </ProTip>

    <ProTip>
        <div>⚡ <strong>Why is JavaScript bad at math?</strong> Computers store numbers in binary (1s and 0s), not decimals.</div>
        <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
            <div class="font-mono text-[10px]">0.1 + 0.2 === 0.3 <span class="text-red-400">// false! ❌ (0.30000000000000004)</span></div>
            <div class="font-mono text-[10px] mt-1"><span class="text-gray-400">// In binary, 0.1 = 0.00011001100110011... (infinite repeat)</span></div>
            <div class="font-mono text-[10px]"><span class="text-gray-400">// Computer cuts it off → tiny rounding error</span></div>
            <div class="font-mono text-[10px]"><span class="text-gray-400">// 0.1 + 0.2 = two tiny errors combined = 0.30000...4</span></div>
            <div class="font-mono text-[10px] mt-1">Number.MAX_SAFE_INTEGER <span class="text-gray-400">// 9007199254740991</span></div>
            <div class="font-mono text-[10px]"><span class="text-yellow-400">// Above this, integers skip numbers (9007199254740992 = 9007199254740993)</span></div>
        </div>
    </ProTip>

    <ProTip>
        <div>⚡ <strong>NaN = "Not a Number"</strong> but ironically <code class="bg-black/30 px-1 py-0.5 rounded text-yellow-400">typeof NaN === "number"</code> 🤦</div>
        <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
            <div class="font-mono text-[10px]">NaN === NaN <span class="text-red-400">// false ❌ (only value not equal to itself!)</span></div>
            <div class="font-mono text-[10px]">Number.isNaN(NaN) <span class="text-green-400">// true ✅ (use this!)</span></div>
            <div class="font-mono text-[10px] mt-1"><span class="text-gray-400">// When does NaN appear?</span></div>
            <div class="font-mono text-[10px]">0 / 0 <span class="text-gray-400">// NaN (invalid math)</span></div>
            <div class="font-mono text-[10px]">Math.sqrt(-1) <span class="text-gray-400">// NaN (impossible)</span></div>
            <div class="font-mono text-[10px]">parseInt('hello') <span class="text-gray-400">// NaN (failed parse)</span></div>
            <div class="font-mono text-[10px] mt-1"><span class="text-yellow-400">// It's JavaScript's "math operation failed" signal</span></div>
        </div>
    </ProTip>

    <!-- ============================================ -->
    <!-- 🔢 PARSING & CONVERTING -->
    <!-- ============================================ -->
    <SectionTitle id="parsing" color="blue">
        🔢 Parsing & Converting
    </SectionTitle>

    <!-- PARSEINT -->
    <MethodCard
        id="parse-int"
        methodName="parseInt()"
        signature="parseInt(string, radix?)"
        description="Parse a string and return an integer"
        mutates={false}
    >
        <div class="flex items-center gap-4 p-3 bg-gray-800 rounded overflow-x-auto">
                <Node label="Input" type="input">
                    <div class="text-center text-sm font-mono">'42px'</div>
                </Node>

                <Arrow label="parse" />

                <Node label="Method" type="process">
                    <ProcessContent name="parseInt('42px')" description="Extract digits" />
                </Node>

                <Arrow label="returns" />

                <Node label="Result" type="output">
                    <ReturnValue value="42" type="number" />
                </Node>
            </div>

            <MutableOrNot mutates={false} message="">
                Parses until it hits a non-digit. Returns <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">NaN</code> if no valid digits found.
            </MutableOrNot>

            <ProTip>
                <div>⚠️ <strong>Always specify radix (base 10):</strong></div>
                <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                    <div class="font-mono text-[10px]">parseInt('10') <span class="text-gray-400">// 10</span></div>
                    <div class="font-mono text-[10px]">parseInt('10', 10) <span class="text-green-400">// 10 ✅ explicit</span></div>
                    <div class="font-mono text-[10px]">parseInt('0x10') <span class="text-gray-400">// 16 (hex)</span></div>
                    <div class="font-mono text-[10px]">parseInt('08') <span class="text-gray-400">// 8 (but was 0 in old browsers!)</span></div>
                    <div class="font-mono text-[10px] mt-1">parseInt('42px') <span class="text-gray-400">// 42</span></div>
                    <div class="font-mono text-[10px]">parseInt('px42') <span class="text-red-400">// NaN (starts with non-digit)</span></div>
                </div>
            </ProTip>
        </MethodCard>

    <!-- PARSEFLOAT -->
    <MethodCard
        id="parse-float"
        methodName="parseFloat()"
            signature="parseFloat(string)"
            description="Parse a string and return a floating point number"
            mutates={false}
        >
            <div class="flex items-center gap-4 p-3 bg-gray-800 rounded overflow-x-auto">
                <Node label="Input" type="input">
                    <div class="text-center text-sm font-mono">'3.14rem'</div>
                </Node>

                <Arrow label="parse" />

                <Node label="Method" type="process">
                    <ProcessContent name="parseFloat('3.14rem')" description="Extract decimal" />
                </Node>

                <Arrow label="returns" />

                <Node label="Result" type="output">
                    <ReturnValue value="3.14" type="number" />
                </Node>
            </div>

            <MutableOrNot mutates={false} message="">
                Like <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">parseInt</code> but keeps decimal point.
            </MutableOrNot>

            <ProTip>
                <div>Examples:</div>
                <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                    <div class="font-mono text-[10px]">parseFloat('3.14') <span class="text-gray-400">// 3.14</span></div>
                    <div class="font-mono text-[10px]">parseFloat('3.14.15') <span class="text-gray-400">// 3.14 (stops at 2nd dot)</span></div>
                    <div class="font-mono text-[10px]">parseFloat('  3.14  ') <span class="text-gray-400">// 3.14 (trims whitespace)</span></div>
                </div>
            </ProTip>
        </MethodCard>

    <!-- NUMBER() CONSTRUCTOR -->
    <MethodCard
        id="number-constructor"
        methodName="Number()"
        signature="Number(value)"
        description="Convert any value to a number"
        mutates={false}
    >
            <div class="flex items-center gap-4 p-3 bg-gray-800 rounded overflow-x-auto">
                <Node label="Input" type="input">
                    <div class="text-center text-sm font-mono space-y-1">
                        <div>'42'</div>
                        <div>true</div>
                        <div>null</div>
                        <div>undefined</div>
                        <div>'42px'</div>
                    </div>
                </Node>

                <Arrow label="convert" />

                <Node label="Method" type="process">
                    <ProcessContent name="Number(value)" description="Type coercion" />
                </Node>

                <Arrow label="returns" />

                <Node label="Result" type="output">
                    <div class="text-center text-sm font-mono space-y-1">
                        <div class="text-green-400">42</div>
                        <div class="text-green-400">1</div>
                        <div class="text-green-400">0</div>
                        <div class="text-red-400">NaN</div>
                        <div class="text-red-400">NaN</div>
                    </div>
                </Node>
            </div>

            <MutableOrNot mutates={false} message="">
                More strict than <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">parseInt</code> - entire string must be a valid number.
            </MutableOrNot>

            <ProTip>
                <div>💡 <strong>Unary + operator does the same:</strong></div>
                <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                    <div class="font-mono text-[10px]">Number('42') <span class="text-gray-400">// 42</span></div>
                    <div class="font-mono text-[10px]">+'42' <span class="text-gray-400">// 42 (shorthand)</span></div>
                    <div class="font-mono text-[10px] mt-1">Number('42px') <span class="text-red-400">// NaN</span></div>
                    <div class="font-mono text-[10px]">parseInt('42px') <span class="text-green-400">// 42 ✅</span></div>
                </div>
            </ProTip>
        </MethodCard>

    <!-- ============================================ -->
    <!-- 🎯 CHECKING & VALIDATION -->
    <!-- ============================================ -->

    <SectionTitle id="checking" color="purple">
        🎯 Checking & Validation
    </SectionTitle>

    <!-- NUMBER.ISNAN -->
    <MethodCard
        id="is-nan"
        methodName="Number.isNaN()"
            signature="Number.isNaN(value)"
            description="Check if value is NaN (Not a Number)"
            mutates={false}
        >
            <div class="flex items-center gap-4 p-3 bg-gray-800 rounded overflow-x-auto">
                <Node label="Input" type="input">
                    <div class="text-center text-sm font-mono space-y-1">
                        <div>NaN</div>
                        <div>'hello'</div>
                        <div>42</div>
                    </div>
                </Node>

                <Arrow label="check" />

                <Node label="Method" type="process">
                    <ProcessContent name="Number.isNaN()" description="Strict NaN check" />
                </Node>

                <Arrow label="returns" />

                <Node label="Result" type="output">
                    <div class="text-center text-sm font-mono space-y-1">
                        <div class="text-green-400">true ✅</div>
                        <div class="text-red-400">false ❌</div>
                        <div class="text-red-400">false ❌</div>
                    </div>
                </Node>
            </div>

            <MutableOrNot mutates={false} message="">
                Only returns <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">true</code> if the value is actually <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">NaN</code>.
            </MutableOrNot>

            <ProTip>
                <div>⚠️ <strong>Don't use global isNaN():</strong></div>
                <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                    <div class="font-mono text-[10px]"><span class="text-red-400">// Global isNaN() coerces to number first ❌</span></div>
                    <div class="font-mono text-[10px]">isNaN('hello') <span class="text-gray-400">// true (coerces to NaN)</span></div>
                    <div class="font-mono text-[10px]">isNaN(undefined) <span class="text-gray-400">// true (coerces to NaN)</span></div>
                    <div class="font-mono text-[10px] mt-1"><span class="text-green-400">// Number.isNaN() is strict ✅</span></div>
                    <div class="font-mono text-[10px]">Number.isNaN('hello') <span class="text-gray-400">// false (not NaN)</span></div>
                    <div class="font-mono text-[10px]">Number.isNaN(NaN) <span class="text-gray-400">// true</span></div>
                </div>
            </ProTip>
        </MethodCard>

    <!-- NUMBER.ISINTEGER -->
    <MethodCard
        id="is-integer"
        methodName="Number.isInteger()"
        signature="Number.isInteger(value)"
        description="Check if value is an integer"
        mutates={false}
    >
            <div class="flex items-center gap-4 p-3 bg-gray-800 rounded overflow-x-auto">
                <Node label="Input" type="input">
                    <div class="text-center text-sm font-mono space-y-1">
                        <div>42</div>
                        <div>42.0</div>
                        <div>42.5</div>
                    </div>
                </Node>

                <Arrow label="check" />

                <Node label="Method" type="process">
                    <ProcessContent name="Number.isInteger()" description="Whole number?" />
                </Node>

                <Arrow label="returns" />

                <Node label="Result" type="output">
                    <div class="text-center text-sm font-mono space-y-1">
                        <div class="text-green-400">true ✅</div>
                        <div class="text-green-400">true ✅</div>
                        <div class="text-red-400">false ❌</div>
                    </div>
                </Node>
            </div>

            <MutableOrNot mutates={false} message="">
                Returns <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">true</code> if value is a number with no fractional part.
            </MutableOrNot>
        </MethodCard>

    <!-- ============================================ -->
    <!-- 📊 MATH OPERATIONS -->
    <!-- ============================================ -->

    <SectionTitle id="math" color="green">
        📊 Math Operations
    </SectionTitle>

    <!-- MATH.ROUND/FLOOR/CEIL -->
    <MethodCard
        id="rounding"
        methodName="Math.round() / floor() / ceil()"
        signature="Math.round/floor/ceil(number)"
        description="Round numbers to integers"
        mutates={false}
    >
            <div class="space-y-4">
                <!-- Math.floor -->
                <div class="flex items-center gap-4 p-3 bg-gray-800 rounded overflow-x-auto">
                    <Node label="Input" type="input">
                        <div class="text-center text-sm font-mono">3.7</div>
                    </Node>

                    <Arrow label="floor ⬇️" />

                    <Node label="Method" type="process">
                        <ProcessContent name="Math.floor(3.7)" description="Round down" />
                    </Node>

                    <Arrow label="returns" />

                    <Node label="Result" type="output">
                        <ReturnValue value="3" type="number" />
                    </Node>
                </div>

                <!-- Math.round -->
                <div class="flex items-center gap-4 p-3 bg-gray-800 rounded overflow-x-auto">
                    <Node label="Input" type="input">
                        <div class="text-center text-sm font-mono">3.7</div>
                    </Node>

                    <Arrow label="round" />

                    <Node label="Method" type="process">
                        <ProcessContent name="Math.round(3.7)" description="Round nearest" />
                    </Node>

                    <Arrow label="returns" />

                    <Node label="Result" type="output">
                        <ReturnValue value="4" type="number" />
                    </Node>
                </div>

                <!-- Math.ceil -->
                <div class="flex items-center gap-4 p-3 bg-gray-800 rounded overflow-x-auto">
                    <Node label="Input" type="input">
                        <div class="text-center text-sm font-mono">3.7</div>
                    </Node>

                    <Arrow label="ceil ⬆️" />

                    <Node label="Method" type="process">
                        <ProcessContent name="Math.ceil(3.7)" description="Round up" />
                    </Node>

                    <Arrow label="returns" />

                    <Node label="Result" type="output">
                        <ReturnValue value="4" type="number" />
                    </Node>
                </div>
            </div>

            <MutableOrNot mutates={false} message="">
                <strong>floor</strong> = down, <strong>round</strong> = nearest, <strong>ceil</strong> = up (ceiling). All return integers.
            </MutableOrNot>

            <ProTip>
                <div>Round to decimal places:</div>
                <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                    <div class="font-mono text-[10px]">Math.round(3.14159 * 100) / 100 <span class="text-gray-400">// 3.14</span></div>
                    <div class="font-mono text-[10px]">(3.14159).toFixed(2) <span class="text-gray-400">// '3.14' (string)</span></div>
                    <div class="font-mono text-[10px]">Number((3.14159).toFixed(2)) <span class="text-gray-400">// 3.14 (number)</span></div>
                </div>
            </ProTip>
        </MethodCard>

    <!-- MATH.TRUNC -->
    <MethodCard
        id="trunc"
        methodName="Math.trunc()"
        signature="Math.trunc(number)"
        description="Remove decimal part (truncate)"
        mutates={false}
    >
            <div class="space-y-4">
                <!-- Positive -->
                <div class="flex items-center gap-4 p-3 bg-gray-800 rounded overflow-x-auto">
                    <Node label="Input" type="input">
                        <div class="text-center text-sm font-mono">3.7</div>
                    </Node>

                    <Arrow label="truncate" />

                    <Node label="Method" type="process">
                        <ProcessContent name="Math.trunc(3.7)" description="Chop decimals" />
                    </Node>

                    <Arrow label="returns" />

                    <Node label="Result" type="output">
                        <ReturnValue value="3" type="number" />
                    </Node>
                </div>

                <!-- Negative -->
                <div class="flex items-center gap-4 p-3 bg-gray-800 rounded overflow-x-auto">
                    <Node label="Input" type="input">
                        <div class="text-center text-sm font-mono">-3.7</div>
                    </Node>

                    <Arrow label="truncate" />

                    <Node label="Method" type="process">
                        <ProcessContent name="Math.trunc(-3.7)" description="Chop decimals" />
                    </Node>

                    <Arrow label="returns" />

                    <Node label="Result" type="output">
                        <ReturnValue value="-3" type="number" />
                    </Node>
                </div>
            </div>

            <MutableOrNot mutates={false} message="">
                Simply removes everything after the decimal point. Always rounds toward zero (unlike <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">floor()</code>).
            </MutableOrNot>

            <ProTip>
                <div>💡 <strong>Difference from floor:</strong></div>
                <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                    <div class="font-mono text-[10px]">Math.trunc(3.7) → 3 <span class="text-gray-400">// same as floor</span></div>
                    <div class="font-mono text-[10px]">Math.floor(3.7) → 3</div>
                    <div class="font-mono text-[10px] mt-1">Math.trunc(-3.7) → -3 <span class="text-green-400">// toward zero</span></div>
                    <div class="font-mono text-[10px]">Math.floor(-3.7) → -4 <span class="text-yellow-400">// always down</span></div>
                </div>
            </ProTip>
        </MethodCard>

    <!-- MATH.ABS -->
    <MethodCard
        id="abs"
        methodName="Math.abs()"
        signature="Math.abs(number)"
        description="Get absolute value (remove negative sign)"
        mutates={false}
    >
            <div class="space-y-4">
                <!-- Negative -->
                <div class="flex items-center gap-4 p-3 bg-gray-800 rounded overflow-x-auto">
                    <Node label="Input" type="input">
                        <div class="text-center text-sm font-mono">-42</div>
                    </Node>

                    <Arrow label="absolute" />

                    <Node label="Method" type="process">
                        <ProcessContent name="Math.abs(-42)" description="Remove sign" />
                    </Node>

                    <Arrow label="returns" />

                    <Node label="Result" type="output">
                        <ReturnValue value="42" type="number" />
                    </Node>
                </div>

                <!-- Positive -->
                <div class="flex items-center gap-4 p-3 bg-gray-800 rounded overflow-x-auto">
                    <Node label="Input" type="input">
                        <div class="text-center text-sm font-mono">42</div>
                    </Node>

                    <Arrow label="absolute" />

                    <Node label="Method" type="process">
                        <ProcessContent name="Math.abs(42)" description="Already positive" />
                    </Node>

                    <Arrow label="returns" />

                    <Node label="Result" type="output">
                        <ReturnValue value="42" type="number" />
                    </Node>
                </div>
            </div>

            <MutableOrNot mutates={false} message="">
                Returns the distance from zero. Always positive (or zero).
            </MutableOrNot>

            <ProTip>
                <div>Common use cases:</div>
                <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                    <div class="font-mono text-[10px]"><span class="text-gray-400">// Calculate distance between two points</span></div>
                    <div class="font-mono text-[10px]">Math.abs(x1 - x2) <span class="text-gray-400">// distance on number line</span></div>
                    <div class="font-mono text-[10px] mt-1"><span class="text-gray-400">// Get magnitude regardless of direction</span></div>
                    <div class="font-mono text-[10px]">const speed = Math.abs(velocity)</div>
                </div>
            </ProTip>
        </MethodCard>

    <!-- MATH.SIGN -->
    <MethodCard
        id="sign"
        methodName="Math.sign()"
        signature="Math.sign(number)"
        description="Get the sign of a number (-1, 0, or 1)"
        mutates={false}
    >
            <div class="space-y-4">
                <!-- Positive -->
                <div class="flex items-center gap-4 p-3 bg-gray-800 rounded overflow-x-auto">
                    <Node label="Input" type="input">
                        <div class="text-center text-sm font-mono">42</div>
                    </Node>

                    <Arrow label="sign" />

                    <Node label="Result" type="output">
                        <ReturnValue value="1" type="number" />
                    </Node>
                </div>

                <!-- Negative -->
                <div class="flex items-center gap-4 p-3 bg-gray-800 rounded overflow-x-auto">
                    <Node label="Input" type="input">
                        <div class="text-center text-sm font-mono">-42</div>
                    </Node>

                    <Arrow label="sign" />

                    <Node label="Result" type="output">
                        <ReturnValue value="-1" type="number" />
                    </Node>
                </div>

                <!-- Zero -->
                <div class="flex items-center gap-4 p-3 bg-gray-800 rounded overflow-x-auto">
                    <Node label="Input" type="input">
                        <div class="text-center text-sm font-mono">0</div>
                    </Node>

                    <Arrow label="sign" />

                    <Node label="Result" type="output">
                        <ReturnValue value="0" type="number" />
                    </Node>
                </div>
            </div>

            <MutableOrNot mutates={false} message="">
                Returns <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">1</code> for positive, <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">-1</code> for negative, <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">0</code> for zero.
            </MutableOrNot>

            <ProTip>
                <div>Perfect for animations & game dev:</div>
                <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                    <div class="font-mono text-[10px]"><span class="text-gray-400">// Flip sprite based on movement direction</span></div>
                    <div class="font-mono text-[10px]">sprite.scaleX = Math.sign(velocity.x) <span class="text-gray-400">// -1 or 1</span></div>
                    <div class="font-mono text-[10px] mt-1"><span class="text-gray-400">// Preserve direction while clamping magnitude</span></div>
                    <div class="font-mono text-[10px]">const clamped = Math.sign(v) * Math.min(Math.abs(v), max)</div>
                </div>
            </ProTip>
        </MethodCard>

    <!-- MATH.POW -->
    <MethodCard
        id="pow"
        methodName="Math.pow() / **"
        signature="Math.pow(base, exponent) or base ** exponent"
        description="Raise number to a power (exponentiation)"
        mutates={false}
    >
            <div class="space-y-4">
                <!-- Square -->
                <div class="flex items-center gap-4 p-3 bg-gray-800 rounded overflow-x-auto">
                    <Node label="Base" type="input">
                        <div class="text-center text-sm font-mono">5</div>
                    </Node>

                    <Arrow label="²" />

                    <Node label="Method" type="process">
                        <ProcessContent name="5 ** 2" description="5 squared" />
                    </Node>

                    <Arrow label="returns" />

                    <Node label="Result" type="output">
                        <ReturnValue value="25" type="number" />
                    </Node>
                </div>

                <!-- Cube -->
                <div class="flex items-center gap-4 p-3 bg-gray-800 rounded overflow-x-auto">
                    <Node label="Base" type="input">
                        <div class="text-center text-sm font-mono">2</div>
                    </Node>

                    <Arrow label="³" />

                    <Node label="Method" type="process">
                        <ProcessContent name="2 ** 3" description="2 cubed" />
                    </Node>

                    <Arrow label="returns" />

                    <Node label="Result" type="output">
                        <ReturnValue value="8" type="number" />
                    </Node>
                </div>
            </div>

            <MutableOrNot mutates={false} message="">
                <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">**</code> operator is preferred over <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">Math.pow()</code> (cleaner syntax).
            </MutableOrNot>

            <ProTip>
                <div>Common patterns:</div>
                <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                    <div class="font-mono text-[10px]">x ** 2 <span class="text-gray-400">// square (x²)</span></div>
                    <div class="font-mono text-[10px]">x ** 3 <span class="text-gray-400">// cube (x³)</span></div>
                    <div class="font-mono text-[10px]">2 ** 8 <span class="text-gray-400">// 256 (powers of 2)</span></div>
                    <div class="font-mono text-[10px]">10 ** 6 <span class="text-gray-400">// 1000000 (scientific)</span></div>
                    <div class="font-mono text-[10px] mt-1"><span class="text-gray-400">// Fractional exponents = roots!</span></div>
                    <div class="font-mono text-[10px]">x ** 0.5 <span class="text-gray-400">// same as Math.sqrt(x)</span></div>
                </div>
            </ProTip>
        </MethodCard>

    <!-- MATH.SQRT -->
    <MethodCard
        id="sqrt"
        methodName="Math.sqrt()"
        signature="Math.sqrt(number)"
        description="Calculate square root"
        mutates={false}
    >
            <div class="flex items-center gap-4 p-3 bg-gray-800 rounded overflow-x-auto">
                <Node label="Input" type="input">
                    <div class="text-center text-sm font-mono">25</div>
                </Node>

                <Arrow label="√" />

                <Node label="Method" type="process">
                    <ProcessContent name="Math.sqrt(25)" description="Square root" />
                </Node>

                <Arrow label="returns" />

                <Node label="Result" type="output">
                    <ReturnValue value="5" type="number" />
                </Node>
            </div>

            <MutableOrNot mutates={false} message="">
                Returns <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">NaN</code> for negative numbers. The inverse of squaring: √(x²) = x.
            </MutableOrNot>

            <ProTip>
                <div>Common use: distance formula (Pythagorean theorem):</div>
                <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                    <div class="font-mono text-[10px]"><span class="text-gray-400">// Distance between two points</span></div>
                    <div class="font-mono text-[10px]">const dx = x2 - x1</div>
                    <div class="font-mono text-[10px]">const dy = y2 - y1</div>
                    <div class="font-mono text-[10px]">const distance = Math.sqrt(dx**2 + dy**2) ✅</div>
                    <div class="font-mono text-[10px] mt-1"><span class="text-yellow-400">// Pro tip: avoid sqrt if you only need to compare distances</span></div>
                    <div class="font-mono text-[10px]">if (dx**2 + dy**2 &lt; radius**2) <span class="text-gray-400">// faster!</span></div>
                </div>
            </ProTip>
        </MethodCard>

    <!-- MATH.MIN/MAX -->
    <MethodCard
        id="min-max"
        methodName="Math.min() / Math.max()"
        signature="Math.min/max(...numbers)"
        description="Find smallest or largest number"
        mutates={false}
    >
        <div class="space-y-4">
            <!-- Math.max -->
            <div class="flex items-center gap-4 p-3 bg-gray-800 rounded overflow-x-auto">
                <Node label="Input" type="input">
                    <div class="text-center text-sm font-mono">5, 2, 8, 1</div>
                </Node>

                <Arrow label="compare" />

                <Node label="Method" type="process">
                    <ProcessContent name="Math.max(5, 2, 8, 1)" description="Find largest" />
                </Node>

                <Arrow label="returns" />

                <Node label="Result" type="output">
                    <ReturnValue value="8" type="number" />
                </Node>
            </div>

            <!-- Math.min -->
            <div class="flex items-center gap-4 p-3 bg-gray-800 rounded overflow-x-auto">
                <Node label="Input" type="input">
                    <div class="text-center text-sm font-mono">5, 2, 8, 1</div>
                </Node>

                <Arrow label="compare" />

                <Node label="Method" type="process">
                    <ProcessContent name="Math.min(5, 2, 8, 1)" description="Find smallest" />
                </Node>

                <Arrow label="returns" />

                <Node label="Result" type="output">
                    <ReturnValue value="1" type="number" />
                </Node>
            </div>
        </div>

        <MutableOrNot mutates={false} message="">
            Takes multiple arguments. Use spread operator <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">...</code> to find min/max in arrays.
        </MutableOrNot>

        <ProTip>
            <div>Common use cases:</div>
            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                <div class="font-mono text-[10px]"><span class="text-gray-400">// Clamp value between min and max</span></div>
                <div class="font-mono text-[10px]">Math.min(Math.max(value, 0), 100) <span class="text-gray-400">// 0-100</span></div>
                <div class="font-mono text-[10px] mt-1"><span class="text-gray-400">// Find max in array</span></div>
                <div class="font-mono text-[10px]">Math.max(...prices)</div>
            </div>
        </ProTip>
    </MethodCard>

    <!-- MATH.RANDOM -->
    <MethodCard
        id="random"
        methodName="Math.random()"
        signature="Math.random()"
        description="Generate random number between 0 and 1"
        mutates={false}
    >
        <!-- Important callout -->
        <div class="bg-yellow-500/20 border border-yellow-500 rounded p-4 mb-4">
            <div class="text-yellow-300 font-bold text-sm mb-2">⚠️ Math.random() ONLY gives 0-1</div>
            <div class="text-gray-300 text-xs mb-3">For other ranges (1-10, 1-100, etc.) you MUST multiply and add:</div>

            <div class="bg-black/30 rounded p-3 space-y-0.5">
                <div class="font-mono text-[10px] text-gray-300">function randomInt(min, max) &lbrace;</div>
                <div class="font-mono text-[10px] text-gray-300">&nbsp;&nbsp;return Math.floor(Math.random() * (max - min + 1)) + min</div>
                <div class="font-mono text-[10px] text-gray-300">&rbrace;</div>
                <div class="font-mono text-[10px] mt-2"><span class="text-gray-400">// How it works for randomInt(1, 6):</span></div>
                <div class="font-mono text-[10px]"><span class="text-yellow-400">(max - min + 1)</span> <span class="text-gray-400">→ (6 - 1 + 1) = 6 possible values</span></div>
                <div class="font-mono text-[10px]"><span class="text-yellow-400">Math.random() * 6</span> <span class="text-gray-400">→ 0 to 5.999...</span></div>
                <div class="font-mono text-[10px]"><span class="text-yellow-400">Math.floor(...)</span> <span class="text-gray-400">→ 0, 1, 2, 3, 4, or 5</span></div>
                <div class="font-mono text-[10px]"><span class="text-yellow-400">+ min</span> <span class="text-gray-400">→ 1, 2, 3, 4, 5, or 6 ✅</span></div>
                <div class="font-mono text-[10px] mt-2">randomInt(1, 6) <span class="text-gray-400">// dice roll (1-6)</span></div>
                <div class="font-mono text-[10px]">randomInt(1, 100) <span class="text-gray-400">// 1-100</span></div>
                <div class="font-mono text-[10px]">randomInt(50, 100) <span class="text-gray-400">// 50-100</span></div>
            </div>
        </div>

        <MutableOrNot mutates={false} message="">
            Returns decimal from 0 (inclusive) to 1 (exclusive). Want 1-100? Do <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">Math.floor(Math.random() * 100) + 1</code>
        </MutableOrNot>
    </MethodCard>

    <!-- ============================================ -->
    <!-- 🔧 FORMATTING -->
    <!-- ============================================ -->

    <SectionTitle id="formatting" color="orange">
        🔧 Formatting
    </SectionTitle>

    <!-- TOFIXED -->
    <MethodCard
        id="to-fixed"
        methodName=".toFixed()"
        signature="number.toFixed(digits)"
        description="Format number with fixed decimal places"
        mutates={false}
    >
        <div class="flex items-center gap-4 p-3 bg-gray-800 rounded overflow-x-auto">
            <Node label="Input" type="input">
                <div class="text-center text-sm font-mono">3.14159</div>
            </Node>

            <Arrow label="format" />

            <Node label="Method" type="process">
                <ProcessContent name="(3.14159).toFixed(2)" description="2 decimal places" />
            </Node>

            <Arrow label="returns" />

            <Node label="Result" type="output">
                <ReturnValue value="'3.14'" type="string" />
            </Node>
        </div>

        <MutableOrNot mutates={false} message="">
            Returns <strong>string</strong> with specified decimal places. Rounds if necessary.
        </MutableOrNot>

        <ProTip>
            <div>⚠️ <strong>Returns string, not number!</strong></div>
            <div class="text-xs mt-2 mb-3">
                It's a <strong>formatting method</strong> for display, not math. Preserves trailing zeros like <span class="font-mono text-orange-400">"42.00"</span> that numbers can't have.
            </div>
            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-1 mt-2">
                <div class="text-[10px] text-gray-400">Perfect for UI:</div>
                <div class="font-mono text-[10px]">"$" + price.toFixed(2) <span class="text-gray-400">// "$42.00"</span></div>

                <div class="text-[10px] text-gray-400 mt-2">❌ Never for math:</div>
                <div class="font-mono text-[10px]">"10.50" + "2.30" <span class="text-gray-400">// "10.502.30" 😱</span></div>

                <div class="text-[10px] text-gray-400 mt-2">✅ Convert back if needed:</div>
                <div class="font-mono text-[10px]">Number((3.14).toFixed(2)) <span class="text-gray-400">// 3.14</span></div>
                <div class="font-mono text-[10px]">+(3.14).toFixed(2) <span class="text-gray-400">// 3.14 (shorthand)</span></div>
            </div>
        </ProTip>
    </MethodCard>

    <!-- TOLOCALESTRING -->
    <MethodCard
        id="to-locale-string"
        methodName=".toLocaleString()"
        signature="number.toLocaleString(locale, options)"
        description="Format number with locale-specific formatting"
        mutates={false}
    >
        <div class="flex items-center gap-4 p-3 bg-gray-800 rounded overflow-x-auto">
            <Node label="Input" type="input">
                <div class="text-center text-sm font-mono">1234567.89</div>
            </Node>

            <Arrow label="format" />

            <Node label="Method" type="process">
                <ProcessContent name=".toLocaleString('en-US')" description="Locale formatting" />
            </Node>

            <Arrow label="returns" />

            <Node label="Result" type="output">
                <ReturnValue value="'1,234,567.89'" type="string" />
            </Node>
        </div>

        <MutableOrNot mutates={false} message="">
            Format with thousands separators, currency, percentages. Returns <strong>string</strong>.
        </MutableOrNot>

        <ProTip>
            <div>Currency formatting:</div>
            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                <div class="font-mono text-[10px]">(1234.5).toLocaleString('en-US', &lbrace;</div>
                <div class="font-mono text-[10px]">&nbsp;&nbsp;style: 'currency',</div>
                <div class="font-mono text-[10px]">&nbsp;&nbsp;currency: 'USD'</div>
                <div class="font-mono text-[10px]">&rbrace;) <span class="text-gray-400">// '$1,234.50'</span></div>
                <div class="font-mono text-[10px] mt-1"><span class="text-gray-400">// Percentage</span></div>
                <div class="font-mono text-[10px]">(0.42).toLocaleString('en-US', &lbrace;</div>
                <div class="font-mono text-[10px]">&nbsp;&nbsp;style: 'percent'</div>
                <div class="font-mono text-[10px]">&rbrace;) <span class="text-gray-400">// '42%'</span></div>
            </div>
        </ProTip>
    </MethodCard>

