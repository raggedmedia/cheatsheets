---
interface Props {
    id: string;
    name: string;
    value: string;
    label: string;
    required?: boolean;
    checked?: boolean;
}

const {
    id,
    name,
    value,
    label,
    required = false,
    checked = false,
} = Astro.props;
---

<div class="form-checkbox">
    <input
        type="checkbox"
        id={id}
        name={name}
        value={value}
        class="checkbox-input"
        required={required}
        checked={checked}
    />
    <label for={id} class="checkbox-label">
        {label}
        {
            required && (
                <span class="required-indicator" aria-label="required">
                    *
                </span>
            )
        }
    </label>
</div>

<style>
    /* Component-specific styles only - shared styles are in _forms.css */
</style>
