                    <div>&nbsp;&nbsp;&nbsp;&nbsp;x: e.clientX,</div>
                    <div>&nbsp;&nbsp;&nbsp;&nbsp;y: e.clientY,</div>
                    <div>&nbsp;&nbsp;&nbsp;&nbsp;type: e.pointerType</div>
                    <div>&nbsp;&nbsp;{'}'})</div>
                    <div>&nbsp;&nbsp;</div>
                    <div>&nbsp;&nbsp;console.log(`Active pointers: ${'{'}activePointers.size{'}'}`)</div>
                    <div>{'}'})</div>
                    <div class="mt-2">element.addEventListener('pointermove', (e) =>{'{'}</div>
                    <div>&nbsp;&nbsp;if (activePointers.has(e.pointerId)){'{'}</div>
                    <div>&nbsp;&nbsp;&nbsp;&nbsp;// Update pointer position</div>
                    <div>&nbsp;&nbsp;&nbsp;&nbsp;activePointers.set(e.pointerId,{'{'}</div>
                    <div>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;x: e.clientX,</div>
                    <div>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;y: e.clientY,</div>
                    <div>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;type: e.pointerType</div>
                    <div>&nbsp;&nbsp;&nbsp;&nbsp;{'}'})</div>
                    <div>&nbsp;&nbsp;&nbsp;&nbsp;</div>
                    <div>&nbsp;&nbsp;&nbsp;&nbsp;// Detect multi-touch gestures</div>
                    <div>&nbsp;&nbsp;&nbsp;&nbsp;if (activePointers.size === 2){'{'}</div>
                    <div>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;// Could calculate pinch distance here</div>
                    <div>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;console.log('Two-finger gesture!')</div>
                    <div>&nbsp;&nbsp;&nbsp;&nbsp;}</div>
                    <div>&nbsp;&nbsp;}</div>
                    <div>{'}'})</div>
                    <div class="mt-2">element.addEventListener('pointerup', (e) =>{'{'}</div>
                    <div>&nbsp;&nbsp;activePointers.delete(e.pointerId)</div>
                    <div>{'}'})</div>
                    <div class="mt-2">element.addEventListener('pointercancel', (e) =>{'{'}</div>
                    <div>&nbsp;&nbsp;activePointers.delete(e.pointerId)</div>
                    <div>{'}'})</div>
                </div>
            </div>
        </div>

        <ProTip>
            <div>🤏 <strong>Pinch-to-zoom calculation:</strong></div>
            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                <div class="font-mono text-[10px]">if (activePointers.size === 2){'{'}</div>
                <div class="font-mono text-[10px]">&nbsp;&nbsp;const [p1, p2] = [...activePointers.values()]</div>
                <div class="font-mono text-[10px]">&nbsp;&nbsp;</div>
                <div class="font-mono text-[10px]">&nbsp;&nbsp;// Calculate distance between two pointers</div>
                <div class="font-mono text-[10px]">&nbsp;&nbsp;const dx = p2.x - p1.x</div>
                <div class="font-mono text-[10px]">&nbsp;&nbsp;const dy = p2.y - p1.y</div>
                <div class="font-mono text-[10px]">&nbsp;&nbsp;const distance = Math.sqrt(dx * dx + dy * dy)</div>
                <div class="font-mono text-[10px]">&nbsp;&nbsp;</div>
                <div class="font-mono text-[10px]">&nbsp;&nbsp;// Compare to initial distance to determine zoom</div>
                <div class="font-mono text-[10px]">}</div>
            </div>
        </ProTip>
    </MethodCard>

