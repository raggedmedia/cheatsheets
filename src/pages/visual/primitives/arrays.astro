                            </Node>

                            <Arrow label="returns" />

                            <Node label="Single Value" type="output">
                                <ReturnValue value="'cba'" type="string" />
                            </Node>
                        </div>

                        <MutableOrNot mutates={false} message="">
                            Like reduce() but processes from <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">right to left</code>. Returns a single value. ⚠️ Cannot be chained.
                        </MutableOrNot>
                    </MethodCard>

