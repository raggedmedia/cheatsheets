---
import EmailInput from "~components/forms/EmailInput.astro";
import PasswordInput from "~components/forms/PasswordInput.astro";
import FormMessage from "~components/forms/FormMessage.astro";
import Layout from "~layouts/Layout.astro";
import { supabase } from "../../lib/supabase";

const { cookies, redirect, url } = Astro;

const accessToken = cookies.get("sb-access-token");
const refreshToken = cookies.get("sb-refresh-token");

if (accessToken && refreshToken) {
    return redirect("/dashboard");
}

// Handle URL messages
const messageParam = url.searchParams.get("message");
const messageType = url.searchParams.get("type") || "info";

// Define message mappings
const messages = {
    "account-created":
        "Account created successfully! Please validate your email, then sign in with your new credentials.",
    "signin-required": "Please sign in to access that page.",
    "session-expired": "Your session has expired. Please sign in again.",
    "password-updated":
        "Your password has been updated successfully! Please sign in with your new password.",
};

const displayMessage =
    messageParam && messages[messageParam as keyof typeof messages]
        ? messages[messageParam as keyof typeof messages]
        : null;

// Handle form submission server-side
let errorMessage = "";

if (Astro.request.method === "POST") {
    try {
        const formData = await Astro.request.formData();
        const email = formData.get("email")?.toString();
        const password = formData.get("password")?.toString();

        if (!email || !password) {
            errorMessage = "Email and password are required";
        } else {
            const { data, error } = await supabase.auth.signInWithPassword({
                email,
                password,
            });

            if (error) {
                errorMessage = error.message;
            } else {
                // Success - set cookies and redirect
                const { access_token, refresh_token } = data.session;
                cookies.set("sb-access-token", access_token, { path: "/" });
                cookies.set("sb-refresh-token", refresh_token, { path: "/" });

                return redirect("/dashboard");
            }
        }
    } catch (error) {
        errorMessage = "An unexpected error occurred. Please try again.";
        console.error("Sign in error:", error);
    }
}

export const prerender = false;
---

<Layout pageTitle="Sign in">
    <div class="mx-auto w-96 mb-12">
        <div class="prose">
            <h1>Sign in</h1>
            <p>New here? <a href="/auth/register">Create an account</a></p>
            <p>
                Forgot password? <a href="/auth/reset-password"
                    >Reset password</a
                >
            </p>
        </div>
        <form
            method="post"
            class="flex flex-col gap-4"
            id="signin-form"
            data-validate
            data-form-id="signin-form"
            data-button-id="signin-button"
        >
            {
                errorMessage ? (
                    <FormMessage
                        id="signin-error-message"
                        type="error"
                        message={errorMessage}
                        hidden={false}
                    />
                ) : displayMessage ? (
                    <FormMessage
                        id="signin-success-message"
                        type={
                            messageType as
                                | "error"
                                | "success"
                                | "info"
                                | "warning"
                        }
                        message={displayMessage}
                        hidden={false}
                    />
                ) : null
            }

            <EmailInput
                id="signin-email"
                name="email"
                label="Email"
                required={true}
            />
            <PasswordInput
                id="signin-password"
                name="password"
                label="Password"
                required={true}
                autocomplete="current-password"
            />
            <button
                type="submit"
                class="form-button"
                id="signin-button"
                disabled
            >
                <span class="button-text">Login</span>
            </button>
        </form>
    </div>
</Layout>

<script src="~components/forms/form-validation.ts"></script>
