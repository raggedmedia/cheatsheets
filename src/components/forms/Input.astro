---
interface Props {
    id: string;
    name: string;
    label: string;
    type?: "text" | "email" | "password" | "tel" | "url" | "search";
    required?: boolean;
    placeholder?: string;
    autocomplete?: string;
    pattern?: string;
    minlength?: number;
    maxlength?: number;
    helperText?: string;
    errorText?: string;
}

const {
    id,
    name,
    label,
    type = "text",
    required = false,
    placeholder,
    autocomplete,
    pattern,
    minlength,
    maxlength,
    helperText,
    errorText,
} = Astro.props;
---

<div class="form-group">
    <label for={id} class="form-label">
        {label}
        {
            required && (
                <span class="required-indicator" aria-label="required">
                    *
                </span>
            )
        }
    </label>

    <input
        type={type}
        id={id}
        name={name}
        class="form-input"
        required={required}
        placeholder={placeholder}
        autocomplete={autocomplete}
        pattern={pattern}
        minlength={minlength}
        maxlength={maxlength}
        aria-describedby={helperText || errorText ? `${id}-help` : undefined}
        aria-invalid="false"
    />

    {
        (helperText || errorText) && (
            <div id={`${id}-help`} class="form-help-text">
                {helperText || errorText}
            </div>
        )
    }
</div>

<style>
    /* Component-specific styles only - shared styles are in _forms.css */
</style>
