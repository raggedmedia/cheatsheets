---
import "~styles/styles.css";
---

<style is:global>
    /* Canvas */
    #canvas {
        background-image: linear-gradient(
                to right,
                rgba(0, 0, 0, 0.05) 1px,
                transparent 1px
            ),
            linear-gradient(to bottom, rgba(0, 0, 0, 0.05) 1px, transparent 1px);
        background-size: 16px 16px;
    }

    /* Droppable containers */
    .droppable-container {
        position: relative;
        transition:
            outline 100ms ease-out,
            outline-offset 100ms ease-out;
        min-height: 50px;
    }

    .droppable-container.drag-over {
        outline: 1px solid #3b82f6;
        outline-offset: 2px;
        background-color: rgba(59, 130, 246, 0.05);
    }

    /* Blue line appears between sections */
    .drop-indicator {
        position: absolute;
        height: 3px;
        background: #3b82f6;
        left: 0;
        right: 0;
        pointer-events: none;
        z-index: 100;
    }

    /* Hide the empty canvas text when we have the button */
    #canvas:empty::after {
        content: none;
    }
    /*
    .droppable-container:empty::after {
        content: "Drop Section/s here";
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100px;
        color: #9ca3af;
        font-style: italic;
        font-size: 14px;
    } */

    /* Selected element */
    .selected {
        outline: 1px solid #3b82f6 !important;
        outline-offset: 2px;
    }

    /* Section insertion triggers */
    .add-section-trigger {
        width: 20px;
        height: 20px;
        /* padding: 2px 6px; */
        border-radius: 50%;
        border: 1px solid #cbd5e1;
        background: white;
        color: #cbd5e1;
        font-size: 16px;
        font-weight: 300;
        line-height: 1;
        cursor: pointer;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        justify-content: center;
        user-select: none;
    }

    .add-section-trigger:hover {
        border-color: #3b82f6;
        color: #3b82f6;
        transform: scale(1.1);
    }

    /* Top and bottom triggers - centered above/below canvas */
    .add-section-trigger.position-top,
    .add-section-trigger.position-bottom {
        position: absolute;
        left: 50%;
        transform: translateX(-50%);
    }

    .add-section-trigger.position-top {
        top: -28px;
    }

    .add-section-trigger.position-bottom {
        bottom: -28px;
    }

    .add-section-trigger.position-top:hover,
    .add-section-trigger.position-bottom:hover {
        transform: translateX(-50%) scale(1.1);
    }

    /* Between sections - positioned to the left of canvas */
    .add-section-trigger.position-between {
        position: absolute;
        left: -28px;
        transform: translateY(-50%);
    }

    .add-section-trigger.position-between:hover {
        transform: translateY(-50%) scale(1.1);
    }

    /* Big centered button for empty canvas */
    .add-section-trigger.add-section-empty {
        width: 200px;
        height: 200px;
        font-size: 48px;
        margin: 100px auto;
        position: relative;
        left: 0;
        transform: none;
    }

    .add-section-trigger.add-section-empty:hover {
        transform: scale(1.05);
    }

    /* Layout control buttons */
    .layout-buttons {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 6px;
        margin-bottom: 12px;
    }

    .layout-btn {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 4px;
        padding: 8px 4px;
        border: 1px solid #e5e7eb;
        border-radius: 6px;
        background: white;
        cursor: pointer;
        transition: all 0.15s;
        font-size: 11px;
        color: #6b7280;
    }

    .layout-btn:hover {
        border-color: #3b82f6;
        color: #3b82f6;
    }

    .layout-btn.active {
        border-color: #3b82f6;
        background: #eff6ff;
        color: #3b82f6;
    }

    .layout-btn .icon {
        font-size: 16px;
        line-height: 1;
    }

    /* Grid layouts for different numbers of options */
    .two-layout-options {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 6px;
        margin-bottom: 12px;
    }

    .three-layout-options {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 6px;
        margin-bottom: 12px;
    }

    .four-layout-options {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 6px;
        margin-bottom: 12px;
    }

    .two-layout-options.hidden,
    .three-layout-options.hidden,
    .four-layout-options.hidden {
        display: none;
    }

    .layout-option-btn {
        padding: 6px;
        border: 1px solid #e5e7eb;
        border-radius: 4px;
        background: white;
        cursor: pointer;
        transition: all 0.15s;
        font-size: 11px;
        color: #6b7280;
        text-align: center;
    }

    .layout-option-btn:hover {
        border-color: #3b82f6;
        color: #3b82f6;
    }

    /* Padding mode buttons */
    .padding-mode-buttons {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 6px;
        margin-bottom: 12px;
    }

    .padding-mode-btn {
        padding: 8px 4px;
        border: 1px solid #e5e7eb;
        border-radius: 6px;
        background: white;
        cursor: pointer;
        transition: all 0.15s;
        font-size: 11px;
        color: #6b7280;
        text-align: center;
    }

    .padding-mode-btn:hover {
        border-color: #3b82f6;
        color: #3b82f6;
    }

    .padding-mode-btn.active {
        border-color: #3b82f6;
        background: #eff6ff;
        color: #3b82f6;
    }

    .padding-values {
        margin-top: 8px;
    }

    .layout-option-btn.active {
        border-color: #3b82f6;
        background: #eff6ff;
        color: #3b82f6;
    }

    /* Palette items */
    .palette-item {
        cursor: grab;
        transition: all 0.2s;
    }

    .palette-item:hover {
        background-color: #e5e7eb !important;
        border-color: #9ca3af !important;
    }

    .palette-item:active {
        cursor: grabbing;
    }

    /* Properties panel field visibility */
    [data-show-for] {
        display: none;
    }

    /* Add to your <style> block in canvas.astro */
</style>

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
        <title>Visual Page Builder - MVP</title>
    </head>
    <body class="bg-gray-50">
        <!-- Left Sidebar - Palette -->
        <div
            class="fixed left-0 top-0 w-64 h-screen bg-white border-r border-gray-300 p-4 overflow-y-auto"
        >
            <h1 class="text-2xl font-bold mb-4">Elements</h1>

            <!-- Layout Elements -->
            <div class="mb-6">
                <h3 class="text-sm font-semibold text-gray-600 mb-2 uppercase">
                    Layout
                </h3>
                <div class="space-y-2">
                    <div
                        class="palette-item p-3 bg-gray-100 border border-gray-300 rounded text-sm text-center"
                        data-element-type="section"
                        data-drag-type="element"
                        draggable="true"
                    >
                        Section
                    </div>
                    <div
                        class="palette-item p-3 bg-gray-100 border border-gray-300 rounded text-sm text-center"
                        data-element-type="div"
                        data-drag-type="element"
                        draggable="true"
                    >
                        Div
                    </div>
                    <div
                        class="palette-item p-3 bg-gray-100 border border-gray-300 rounded text-sm text-center"
                        data-element-type="header"
                        data-drag-type="element"
                        draggable="true"
                    >
                        Header
                    </div>
                    <div
                        class="palette-item p-3 bg-gray-100 border border-gray-300 rounded text-sm text-center"
                        data-element-type="footer"
                        data-drag-type="element"
                        draggable="true"
                    >
                        Footer
                    </div>
                </div>
            </div>

            <!-- Text Elements -->
            <div class="mb-6">
                <h3 class="text-sm font-semibold text-gray-600 mb-2 uppercase">
                    Text
                </h3>
                <div class="space-y-2">
                    <div
                        class="palette-item p-3 bg-gray-100 border border-gray-300 rounded text-sm text-center"
                        data-element-type="h1"
                        data-drag-type="element"
                        draggable="true"
                    >
                        Heading
                    </div>
                    <div
                        class="palette-item p-3 bg-gray-100 border border-gray-300 rounded text-sm text-center"
                        data-element-type="p"
                        data-drag-type="element"
                        draggable="true"
                    >
                        Paragraph
                    </div>
                    <div
                        class="palette-item p-3 bg-gray-100 border border-gray-300 rounded text-sm text-center"
                        data-element-type="a"
                        data-drag-type="element"
                        draggable="true"
                    >
                        Link
                    </div>
                </div>
            </div>

            <!-- Actions -->
            <div class="mt-8 pt-4 border-t border-gray-300">
                <button
                    id="save-btn"
                    class="w-full bg-blue-500 text-white px-4 py-2 rounded hover:bg-blue-600 transition-colors mb-2"
                >
                    Save
                </button>
                <button
                    id="export-btn"
                    class="w-full bg-gray-500 text-white px-4 py-2 rounded hover:bg-gray-600 transition-colors mb-2"
                >
                    Export HTML
                </button>
                <button
                    id="reset-btn"
                    class="w-full bg-red-500 text-white px-4 py-2 rounded hover:bg-red-600 transition-colors"
                >
                    Reset canvas
                </button>
            </div>
        </div>

        <!-- Main Canvas Area -->
        <div id="canvas-wrapper" class="ml-64 mr-64 p-8 relative">
            <div
                id="canvas"
                class="droppable-container min-h-[600px] w-full bg-white shadow-lg border border-gray-300 relative"
            >
            </div>
        </div>

        <!-- Right Sidebar - Properties Panel -->
        <div
            id="properties-panel"
            class="fixed right-0 top-0 w-64 h-screen bg-white border-l border-gray-300 p-4 overflow-y-auto hidden"
        >
            <h3 class="text-lg font-bold mb-4">Properties</h3>
            <p class="text-sm text-gray-500 mb-4" id="selected-element-label">
                Select an element to edit
            </p>

            <!-- Layout (only for containers) -->
            <div class="mb-4" data-show-for="div,section">
                <label class="block text-sm font-medium mb-2">Layout</label>

                <!-- Layout Type Buttons -->
                <div class="layout-buttons">
                    <button class="layout-btn" data-layout="block">
                        <span>Block</span>
                    </button>
                    <button class="layout-btn" data-layout="flex-row">
                        <span>Flex →</span>
                    </button>
                    <button class="layout-btn" data-layout="flex-col">
                        <span>Flex ↓</span>
                    </button>
                    <button class="layout-btn" data-layout="grid">
                        <span>Grid</span>
                    </button>
                </div>

                <!-- Grid Columns (only shows when grid selected) -->
                <div id="grid-columns" class="three-layout-options hidden">
                    <button class="layout-option-btn" data-cols="2"
                        >2 Cols</button
                    >
                    <button class="layout-option-btn" data-cols="3"
                        >3 Cols</button
                    >
                    <button class="layout-option-btn" data-cols="4"
                        >4 Cols</button
                    >
                </div>

                <!-- Flex/Grid Options (shows when flex or grid selected) -->
                <div id="flex-grid-options" class="hidden">
                    <label class="block text-xs font-medium mb-1 text-gray-600"
                        >Gap</label
                    >
                    <div class="four-layout-options mb-2">
                        <button class="layout-option-btn" data-gap="0"
                            >None</button
                        >
                        <button class="layout-option-btn" data-gap="2"
                            >Small</button
                        >
                        <button class="layout-option-btn" data-gap="4"
                            >Medium</button
                        >
                        <button class="layout-option-btn" data-gap="6"
                            >Large</button
                        >
                    </div>
                </div>
            </div>

            <!-- Padding -->
            <div class="mb-4" data-show-for="div,section">
                <label class="block text-sm font-medium mb-2">Padding</label>

                <!-- Padding Mode Buttons -->
                <div class="padding-mode-buttons">
                    <button
                        class="padding-mode-btn active"
                        data-padding-mode="all"
                    >
                        <span>All</span>
                    </button>
                    <button
                        class="padding-mode-btn"
                        data-padding-mode="horizontal-vertical"
                    >
                        <span>↔ ↕</span>
                    </button>
                    <button
                        class="padding-mode-btn"
                        data-padding-mode="individual"
                    >
                        <span>Each</span>
                    </button>
                </div>

                <!-- All Sides -->
                <div id="padding-all" class="padding-values">
                    <div class="four-layout-options">
                        <button
                            class="layout-option-btn active"
                            data-padding-all="0">None</button
                        >
                        <button class="layout-option-btn" data-padding-all="4"
                            >Small</button
                        >
                        <button class="layout-option-btn" data-padding-all="6"
                            >Medium</button
                        >
                        <button class="layout-option-btn" data-padding-all="8"
                            >Large</button
                        >
                    </div>
                </div>

                <!-- Horizontal & Vertical -->
                <div id="padding-hv" class="padding-values hidden">
                    <label class="block text-xs font-medium mb-1 text-gray-600"
                        >Left & Right</label
                    >
                    <div class="four-layout-options mb-2">
                        <button
                            class="layout-option-btn active"
                            data-padding-x="0">None</button
                        >
                        <button class="layout-option-btn" data-padding-x="4"
                            >Small</button
                        >
                        <button class="layout-option-btn" data-padding-x="6"
                            >Medium</button
                        >
                        <button class="layout-option-btn" data-padding-x="8"
                            >Large</button
                        >
                    </div>
                    <label class="block text-xs font-medium mb-1 text-gray-600"
                        >Top & Bottom</label
                    >
                    <div class="four-layout-options">
                        <button
                            class="layout-option-btn active"
                            data-padding-y="0">None</button
                        >
                        <button class="layout-option-btn" data-padding-y="4"
                            >Small</button
                        >
                        <button class="layout-option-btn" data-padding-y="6"
                            >Medium</button
                        >
                        <button class="layout-option-btn" data-padding-y="8"
                            >Large</button
                        >
                    </div>
                </div>

                <!-- Individual Sides -->
                <div id="padding-individual" class="padding-values hidden">
                    <label class="block text-xs font-medium mb-1 text-gray-600"
                        >Top</label
                    >
                    <div class="four-layout-options mb-2">
                        <button
                            class="layout-option-btn active"
                            data-padding-top="0">None</button
                        >
                        <button class="layout-option-btn" data-padding-top="4"
                            >Small</button
                        >
                        <button class="layout-option-btn" data-padding-top="6"
                            >Medium</button
                        >
                        <button class="layout-option-btn" data-padding-top="8"
                            >Large</button
                        >
                    </div>
                    <label class="block text-xs font-medium mb-1 text-gray-600"
                        >Right</label
                    >
                    <div class="four-layout-options mb-2">
                        <button
                            class="layout-option-btn active"
                            data-padding-right="0">None</button
                        >
                        <button class="layout-option-btn" data-padding-right="4"
                            >Small</button
                        >
                        <button class="layout-option-btn" data-padding-right="6"
                            >Medium</button
                        >
                        <button class="layout-option-btn" data-padding-right="8"
                            >Large</button
                        >
                    </div>
                    <label class="block text-xs font-medium mb-1 text-gray-600"
                        >Bottom</label
                    >
                    <div class="four-layout-options mb-2">
                        <button
                            class="layout-option-btn active"
                            data-padding-bottom="0">None</button
                        >
                        <button
                            class="layout-option-btn"
                            data-padding-bottom="4">Small</button
                        >
                        <button
                            class="layout-option-btn"
                            data-padding-bottom="6">Medium</button
                        >
                        <button
                            class="layout-option-btn"
                            data-padding-bottom="8">Large</button
                        >
                    </div>
                    <label class="block text-xs font-medium mb-1 text-gray-600"
                        >Left</label
                    >
                    <div class="four-layout-options">
                        <button
                            class="layout-option-btn active"
                            data-padding-left="0">None</button
                        >
                        <button class="layout-option-btn" data-padding-left="4"
                            >Small</button
                        >
                        <button class="layout-option-btn" data-padding-left="6"
                            >Medium</button
                        >
                        <button class="layout-option-btn" data-padding-left="8"
                            >Large</button
                        >
                    </div>
                </div>
            </div>

            <!-- Background Color -->
            <div class="mb-4">
                <label class="block text-sm font-medium mb-1">Background</label>
                <select
                    id="prop-bg"
                    class="w-full border border-gray-300 rounded p-2 text-sm"
                >
                    <option value="">None</option>
                    <option value="bg-white">White</option>
                    <option value="bg-gray-50">Gray 50</option>
                    <option value="bg-gray-100">Gray 100</option>
                    <option value="bg-gray-200">Gray 200</option>
                    <option value="bg-blue-50">Blue 50</option>
                    <option value="bg-blue-100">Blue 100</option>
                    <option value="bg-blue-500">Blue 500</option>
                    <option value="bg-red-50">Red 50</option>
                    <option value="bg-red-100">Red 100</option>
                    <option value="bg-red-500">Red 500</option>
