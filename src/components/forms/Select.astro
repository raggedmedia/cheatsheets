---
interface Option {
    value: string;
    label: string;
}

interface Props {
    id: string;
    name: string;
    label: string;
    options: Option[];
    required?: boolean;
    helperText?: string;
}

const {
    id,
    name,
    label,
    options,
    required = false,
    helperText
} = Astro.props;
---

<div class="form-group">
    <label for={id} class="form-label">
        {label}
        {required && <span class="text-red-400" aria-label="required">*</span>}
    </label>

    <select
        id={id}
        name={name}
        class="form-select"
        required={required}
        aria-describedby={helperText ? `${id}-help` : undefined}
    >
        <option value="">Select an option</option>
        {options.map(option => (
            <option value={option.value}>{option.label}</option>
        ))}
    </select>

    {helperText && (
        <div id={`${id}-help`} class="form-help-text">
            {helperText}
        </div>
    )}
</div>

<style>
    .form-group {
        margin-bottom: 1rem;
    }

    .form-label {
        display: block;
        margin-bottom: 0.5rem;
        font-weight: 500;
        color: #e5e7eb;
        font-size: 0.875rem;
    }

    .form-select {
        width: 100%;
        padding: 0.5rem 0.75rem;
        background: #1f2937;
        border: 1px solid #374151;
        border-radius: 0.375rem;
        color: #f3f4f6;
        font-size: 0.875rem;
        cursor: pointer;
        transition: border-color 0.2s;
    }

    .form-select:focus {
        outline: none;
        border-color: #3b82f6;
        box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
    }

    .form-help-text {
        margin-top: 0.25rem;
        font-size: 0.75rem;
        color: #9ca3af;
    }
</style>
