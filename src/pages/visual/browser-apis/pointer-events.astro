    <SectionTitle id="comparison" color="red">
        🆚 Pointer vs Mouse vs Touch Events
    </SectionTitle>

    <MethodCard
        id="event-comparison"
        methodName="When to Use Which Events"
        signature="Pointer Events vs legacy events"
        description="Understanding the differences and when to use each"
        mutates={false}
    >
        <div class="p-6 bg-gray-800 rounded">
            <div class="space-y-4">
                <!-- Pointer Events -->
                <div class="bg-green-500/20 border border-green-500 rounded p-3">
                    <div class="text-green-300 space-y-1">
                        <div class="text-yellow-400 font-bold text-sm mb-1">✅ Pointer Events (Recommended)</div>
                        <div class="font-mono text-[10px]">pointerdown, pointermove, pointerup, etc.</div>
                        <div class="text-[10px] mt-2 space-y-0.5">
                            <div><span class="text-green-400">✓</span> Works for mouse, touch, and stylus</div>
                            <div><span class="text-green-400">✓</span> More information (pressure, tilt, etc.)</div>
                            <div><span class="text-green-400">✓</span> Multi-touch support via pointerId</div>
                            <div><span class="text-green-400">✓</span> Pointer capture for drag operations</div>
                            <div><span class="text-green-400">✓</span> Single codebase for all input types</div>
                            <div><span class="text-green-400">✓</span> Widely supported (all modern browsers)</div>
                        </div>
                    </div>
                </div>

                <!-- Mouse Events -->
                <div class="bg-blue-500/20 border border-blue-400 rounded p-3">
                    <div class="text-blue-300 space-y-1">
                        <div class="text-yellow-400 font-bold text-sm mb-1">🖱️ Mouse Events (Legacy)</div>
                        <div class="font-mono text-[10px]">mousedown, mousemove, mouseup, etc.</div>
                        <div class="text-[10px] mt-2 space-y-0.5">
                            <div><span class="text-blue-400">→</span> Only for mouse input</div>
                            <div><span class="text-blue-400">→</span> Simple, well-understood</div>
                            <div><span class="text-yellow-400">⚠</span> Doesn't work on touch devices</div>
                            <div><span class="text-yellow-400">⚠</span> Need separate touch handlers</div>
                            <div class="text-gray-400 mt-1">Use when: Desktop-only app, or with separate touch handling</div>
                        </div>
                    </div>
                </div>

                <!-- Touch Events -->
                <div class="bg-orange-500/20 border border-orange-400 rounded p-3">
                    <div class="text-orange-300 space-y-1">
                        <div class="text-yellow-400 font-bold text-sm mb-1">📱 Touch Events (Legacy)</div>
                        <div class="font-mono text-[10px]">touchstart, touchmove, touchend, etc.</div>
                        <div class="text-[10px] mt-2 space-y-0.5">
                            <div><span class="text-orange-400">→</span> Only for touch input</div>
                            <div><span class="text-orange-400">→</span> Access to touches array</div>
                            <div><span class="text-yellow-400">⚠</span> More complex API</div>
                            <div><span class="text-yellow-400">⚠</span> Need separate mouse handlers</div>
                            <div><span class="text-red-400">✗</span> Doesn't work with mouse or stylus</div>
                            <div class="text-gray-400 mt-1">Use when: Need very specific touch gesture handling</div>
                        </div>
                    </div>
                </div>

                <!-- Comparison table -->
                <div class="bg-gray-700/50 border border-gray-600 rounded p-3">
                    <div class="text-gray-300 text-[10px] space-y-1">
                        <div class="font-bold text-yellow-400 mb-2">Feature Comparison:</div>
                        <div class="grid grid-cols-4 gap-2">
                            <div class="font-bold">Feature</div>
                            <div class="font-bold">Pointer</div>
                            <div class="font-bold">Mouse</div>
                            <div class="font-bold">Touch</div>

                            <div>Works on mouse</div>
                            <div class="text-green-400">✓</div>
                            <div class="text-green-400">✓</div>
                            <div class="text-red-400">✗</div>

                            <div>Works on touch</div>
                            <div class="text-green-400">✓</div>
                            <div class="text-yellow-400">~</div>
                            <div class="text-green-400">✓</div>

                            <div>Works on stylus</div>
                            <div class="text-green-400">✓</div>
                            <div class="text-yellow-400">~</div>
                            <div class="text-yellow-400">~</div>

                            <div>Pressure support</div>
                            <div class="text-green-400">✓</div>
                            <div class="text-red-400">✗</div>
                            <div class="text-red-400">✗</div>

                            <div>Tilt support</div>
                            <div class="text-green-400">✓</div>
                            <div class="text-red-400">✗</div>
                            <div class="text-red-400">✗</div>

                            <div>Pointer capture</div>
                            <div class="text-green-400">✓</div>
                            <div class="text-red-400">✗</div>
                            <div class="text-red-400">✗</div>

                            <div>Multi-touch</div>
                            <div class="text-green-400">✓</div>
                            <div class="text-red-400">✗</div>
                            <div class="text-green-400">✓</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <ProTip>
            <div>🎯 <strong>Migration guide:</strong></div>
            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                <div class="font-mono text-[10px]"><span class="text-gray-400">// Replace these:</span></div>
                <div class="font-mono text-[10px]">mousedown → pointerdown</div>
                <div class="font-mono text-[10px]">mousemove → pointermove</div>
                <div class="font-mono text-[10px]">mouseup → pointerup</div>
                <div class="font-mono text-[10px]">mouseenter → pointerenter</div>
                <div class="font-mono text-[10px]">mouseleave → pointerleave</div>
                <div class="font-mono text-[10px] mt-1"><span class="text-gray-400">// Add this CSS to prevent default touch behavior:</span></div>
                <div class="font-mono text-[10px]">element{'{'} touch-action: none; }</div>
            </div>
        </ProTip>

        <InfoBox>
            <div>💡 <strong>Bottom Line</strong></div>
            <div class="pl-2 border-l-2 border-blue-500/30 space-y-1 mt-2">
                <div class="text-sm">For <strong>new projects</strong>: Always use Pointer Events</div>
                <div class="text-sm">For <strong>existing projects</strong>: Migrate when you can</div>
                <div class="text-sm">For <strong>desktop-only apps</strong>: Mouse events are okay, but Pointer Events don't hurt</div>
                <div class="text-sm">For <strong>mobile-only apps</strong>: Touch events work, but Pointer Events are better</div>
                <div class="text-sm mt-2 text-yellow-300">Pointer Events are the future-proof choice! 🚀</div>
            </div>
        </InfoBox>
    </MethodCard>

