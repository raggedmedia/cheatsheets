---
import "~styles/styles.css";
import GlobalNav from "~components/visual-js/GlobalNav.astro";

const { pageTitle } = Astro.props;
---

<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="icon" type="image/svg+xml" href="/gideon-skull.svg" />
        <title>{pageTitle} - Visual Cheatsheet</title>
    </head>
    <body class="m-0 p-4 bg-[#1a1d29] text-gray-200">
        <div class="flex gap-6 max-w-[1600px] mx-auto">
            <!-- Main Content -->
            <main class="flex-1 min-w-0">
                <h1 class="text-white mb-1 text-2xl font-bold">{pageTitle}</h1>

                <slot />
            </main>

            <!-- Sidebar Navigation -->
            <aside
                class="w-64 shrink-0 sticky top-4 self-start hidden lg:block max-h-[calc(100vh-2rem)] overflow-y-auto"
            >
                <!-- Global Navigation -->
                <GlobalNav />

                <!-- Page Navigation -->
                <nav class="bg-[#252936] rounded-lg p-4 border border-gray-700">
                    <h3
                        class="text-white text-sm font-bold mb-3 uppercase tracking-wide"
                    >
                        On This Page
                    </h3>
                    <slot name="page-nav" />
                </nav>
            </aside>
        </div>

        <style>
            html {
                scroll-behavior: smooth;
                scroll-padding-top: 20px;
            }
        </style>
    </body>
</html>
