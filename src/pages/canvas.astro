        <!-- Export Modal (hidden by default) -->
        <div
            id="export-modal"
            class="fixed inset-0 bg-black bg-opacity-50 items-center justify-center hidden z-50"
        >
            <div
                class="bg-white rounded-lg p-6 max-w-2xl w-full mx-4 max-h-[80vh] overflow-y-auto"
            >
                <div class="flex justify-between items-center mb-4">
                    <h2 class="text-xl font-bold">Export HTML</h2>
                    <button
                        id="close-modal"
                        class="text-gray-500 hover:text-gray-700 text-2xl"
                    >
                        &times;
                    </button>
                </div>
                <pre
                    id="export-output"
                    class="bg-gray-100 p-4 rounded border border-gray-300 text-sm overflow-x-auto"><code><!-- HTML will appear here --></code></pre>
                <button
                    id="copy-html-btn"
                    class="mt-4 w-full bg-blue-500 text-white px-4 py-2 rounded hover:bg-blue-600 transition-colors"
                >
                    Copy to Clipboard
                </button>
            </div>
        </div>
    </body>
</html>

<script>
    interface DragData {
        type: "element";
        elementType: string;
    }

    interface Element {
        id: string;
        tag: string;
        classes: string[];
        textContent?: string;
        children: Element[];
        attributes?: Record<string, string>;
    }

    interface CanvasState {
        version: string;
        elements: Element[];
    }

    let draggedData: DragData | null = null;
    let selectedElement: HTMLElement | null = null;
    let saveTimeout: ReturnType<typeof setTimeout>;
    let dropPosition: "above" | "below" | "inside" | null = null;
    let dropTargetElement: HTMLElement | null = null; // Track which element we're dropping on
    let dropIndicator: HTMLElement | null = null;

    const canvas = document.getElementById("canvas");
    const propertiesPanel = document.getElementById("properties-panel");

    // State Manager
    class StateManager {
        private storageKey = "canvas-state";

        save(state: CanvasState) {
            try {
                localStorage.setItem(this.storageKey, JSON.stringify(state));
                console.log("State saved");
            } catch (e) {
                console.error("Failed to save state:", e);
            }
        }

        load(): CanvasState | null {
            try {
                const saved = localStorage.getItem(this.storageKey);
                if (!saved) return null;
                return JSON.parse(saved);
            } catch (e) {
                console.error("Failed to load state:", e);
                return null;
            }
        }

        serializeElement(element: HTMLElement): Element {
            return {
                id: element.dataset.elementId || crypto.randomUUID(),
                tag: element.tagName.toLowerCase(),
                classes: Array.from(element.classList).filter(
                    (c) =>
                        c !== "droppable-container" &&
                        c !== "selected" &&
                        c !== "drag-over",
                ),
                textContent:
                    element.childNodes.length === 1 &&
                    element.childNodes[0].nodeType === Node.TEXT_NODE
                        ? element.textContent || undefined
                        : undefined,
                attributes: this.getAttributes(element),
                children: Array.from(element.children).map((child) =>
                    this.serializeElement(child as HTMLElement),
                ),
            };
        }

        private getAttributes(
            element: HTMLElement,
        ): Record<string, string> | undefined {
            const attrs: Record<string, string> = {};
            const skip = ["class", "style", "data-element-id"];

            Array.from(element.attributes).forEach((attr) => {
                if (!skip.includes(attr.name)) {
                    attrs[attr.name] = attr.value;
                }
            });

            return Object.keys(attrs).length > 0 ? attrs : undefined;
        }

        deserializeElement(data: Element): HTMLElement {
            const el = document.createElement(data.tag);
            el.dataset.elementId = data.id;

            if (data.classes.length > 0) {
                el.className = data.classes.join(" ");
            }

            if (data.attributes) {
                Object.entries(data.attributes).forEach(([key, val]) => {
                    el.setAttribute(key, val);
                });
            }

            if (data.textContent && data.children.length === 0) {
                el.textContent = data.textContent;
            }

            data.children.forEach((childData) => {
                const childEl = this.deserializeElement(childData);
                el.appendChild(childEl);
            });

            // Make it interactive
            const containerTags = [
                "div",
                "section",
                "header",
                "footer",
                "main",
                "nav",
                "aside",
            ];
            if (containerTags.includes(data.tag)) {
                el.classList.add("droppable-container");
                setupDroppable(el);
            }

            // Make text elements editable
            if (["h1", "h2", "p", "a", "span"].includes(data.tag)) {
                el.contentEditable = "true";
                el.addEventListener("input", () => {
                    autoSave();
                });
            }

            makeSelectable(el);

            return el;
        }

        captureState(): CanvasState {
            if (!canvas) return { version: "1.0", elements: [] };

            // Filter out the add-section-trigger buttons before serializing
            const elements: Element[] = Array.from(canvas.children)
                .filter(
                    (child) => !child.classList.contains("add-section-trigger"),
                )
                .map((child) => this.serializeElement(child as HTMLElement));

            return {
                version: "1.0",
                elements,
            };
        }

        restoreState(state: CanvasState) {
            if (!canvas) return;

            canvas.innerHTML = "";

            state.elements.forEach((elementData) => {
                const el = this.deserializeElement(elementData);
                canvas.appendChild(el);
            });

            updateSectionUI();
        }
    }

    const stateManager = new StateManager();

    // Auto-save with debounce
    function autoSave() {
        clearTimeout(saveTimeout);
        saveTimeout = setTimeout(() => {
            const state = stateManager.captureState();
            stateManager.save(state);
        }, 1000);
    }

    // Element Factory
    function createElement(elementType: string): HTMLElement {
        const el = document.createElement(elementType);
        el.dataset.elementId = crypto.randomUUID();

        switch (elementType) {
            case "section":
                el.className =
                    "w-full p-8 min-h-[200px] border border-dashed border-gray-300";
                break;
            case "div":
                el.className =
                    "min-h-[100px] border border-dashed border-gray-300";
                break;
            case "header":
                el.className = "w-full bg-gray-100 border-b border-gray-300";
                break;
            case "footer":
                el.className = "w-full bg-gray-100 border-t border-gray-300";
                break;
            case "h1":
                el.className = "text-4xl font-bold";
                el.textContent = "Heading";
                break;
            case "p":
                el.className = "text-base";
                el.textContent = "Paragraph text goes here.";
                break;
            case "a":
                el.className = "text-blue-500 underline";
                el.textContent = "Link";
                el.setAttribute("href", "#");
                break;
        }

        if (["h1", "p", "a"].includes(elementType)) {
            el.contentEditable = "true";
            el.addEventListener("input", () => {
                autoSave(); // Triggers 1 second after typing stops
            });
        }

        const containerTags = ["div", "section", "header", "footer"];
        if (containerTags.includes(elementType)) {
            el.classList.add("droppable-container");
            setupDroppable(el);
        }

        makeSelectable(el);

        return el;
    }

    // Update section insertion triggers
    function updateSectionUI() {
        updateSectionTriggers();
    }

    // Create a section trigger button
    function createSectionTrigger(
        onClick: () => void,
        position: "empty" | "top" | "bottom" | "between" = "between",
    ): HTMLButtonElement {
        const trigger = document.createElement("button");
        trigger.textContent = "+";

        if (position === "empty") {
            trigger.className = "add-section-trigger add-section-empty";
        } else {
            trigger.className = `add-section-trigger position-${position}`;
        }

        trigger.onclick = onClick;

        return trigger;
    }

    // Update section insertion triggers based on current canvas state
    function updateSectionTriggers() {
        if (!canvas) return;

        // Remove all existing triggers
        canvas
            .querySelectorAll(".add-section-trigger")
            .forEach((el) => el.remove());

        const sections = Array.from(canvas.querySelectorAll("section"));

        if (sections.length === 0) {
            // Empty canvas - show big centered button
            const emptyBtn = createSectionTrigger(() => {
                const newSection = createElement("section");
                canvas.appendChild(newSection);
                autoSave();
                updateSectionUI();
            }, "empty");
            canvas.appendChild(emptyBtn);
        } else {
            // Add trigger at top of canvas
            const topBtn = createSectionTrigger(() => {
                const newSection = createElement("section");
                canvas.insertBefore(newSection, canvas.firstChild);
                autoSave();
                updateSectionUI();
            }, "top");
            canvas.insertBefore(topBtn, canvas.firstChild);

            // Add trigger between each section (except after last)
            sections.forEach((section, index) => {
                if (index < sections.length - 1) {
                    const rect = section.getBoundingClientRect();
                    const canvasRect = canvas.getBoundingClientRect();
                    const nextSection = sections[index + 1];
                    const nextRect = nextSection.getBoundingClientRect();

                    // Position between this section and next
                    const midpoint =
                        (rect.bottom + nextRect.top) / 2 - canvasRect.top;

                    const betweenBtn = createSectionTrigger(() => {
                        const newSection = createElement("section");
                        section.insertAdjacentElement("afterend", newSection);
                        autoSave();
                        updateSectionUI();
                    }, "between");
                    betweenBtn.style.top = `${midpoint}px`;
                    canvas.appendChild(betweenBtn);
                }
            });

            // Add trigger at bottom of canvas
            const bottomBtn = createSectionTrigger(() => {
                const newSection = createElement("section");
                canvas.appendChild(newSection);
                autoSave();
                updateSectionUI();
            }, "bottom");
            canvas.appendChild(bottomBtn);
        }
    }

    // Show/hide drop indicator
    function showIndicator(yPosition: number) {
        if (!dropIndicator) {
            dropIndicator = document.createElement("div");
            dropIndicator.className = "drop-indicator";
            document.body.appendChild(dropIndicator);
        }
        dropIndicator.style.top = yPosition + "px";
        dropIndicator.style.display = "block";
    }

    function hideIndicator() {
        if (dropIndicator) {
            dropIndicator.style.display = "none";
        }
    }

    // Setup droppable
    function setupDroppable(element: HTMLElement) {
        element.addEventListener("dragover", (ev) => {
            ev.preventDefault();
            ev.stopPropagation();

            // Track which element we're targeting
            dropTargetElement = element;

            // Only sections support above/below insertion
            if (element.tagName.toLowerCase() !== "section") {
                element.classList.add("drag-over");
                dropPosition = "inside";
                hideIndicator();
                return;
            }

            // Calculate drop zone for sections
            const rect = element.getBoundingClientRect();
            const mouseY = ev.clientY;
            const threshold = rect.height * 0.25; // 25% top/bottom

            if (mouseY < rect.top + threshold) {
                dropPosition = "above";
                showIndicator(rect.top);
                element.classList.remove("drag-over");
            } else if (mouseY > rect.bottom - threshold) {
                dropPosition = "below";
                showIndicator(rect.bottom);
                element.classList.remove("drag-over");
            } else {
                dropPosition = "inside";
                element.classList.add("drag-over");
                hideIndicator();
            }
        });

        element.addEventListener("dragleave", (ev) => {
            const rect = element.getBoundingClientRect();
            const x = ev.clientX;
            const y = ev.clientY;

            if (
                x <= rect.left ||
                x >= rect.right ||
                y <= rect.top ||
                y >= rect.bottom
            ) {
                element.classList.remove("drag-over");
                hideIndicator();
                dropTargetElement = null;
            }
        });

        element.addEventListener("drop", (ev) => {
            ev.preventDefault();
            ev.stopPropagation();
            element.classList.remove("drag-over");
            hideIndicator();

            handleDrop(ev, element);
        });
    }

    // Make element selectable
    function makeSelectable(element: HTMLElement) {
        element.addEventListener("click", (e) => {
            e.stopPropagation();
            selectElement(element);
        });
    }

    // Select element
    function selectElement(element: HTMLElement) {
        selectedElement = element;

        document.querySelectorAll(".selected").forEach((el) => {
            el.classList.remove("selected");
        });
        element.classList.add("selected");

        propertiesPanel!.classList.remove("hidden");
        updatePropertiesPanel(element);

        console.log("Selected:", element.tagName, element);
    }

    // Update properties panel
    function updatePropertiesPanel(element: HTMLElement) {
        const tag = element.tagName.toLowerCase();
        const label = document.getElementById("selected-element-label");
        if (label) {
            label.textContent = `Editing: <${tag}>`;
        }

        // Show/hide fields based on element type
        document.querySelectorAll("[data-show-for]").forEach((field) => {
            const htmlField = field as HTMLElement;
            const showFor = htmlField.dataset.showFor?.split(",") || [];
            if (showFor.includes(tag)) {
                htmlField.style.display = "block";
            } else {
                htmlField.style.display = "none";
            }
        });

        // Populate current layout values
        const layoutButtons = document.querySelectorAll(".layout-btn");
        const gridColumnsDiv = document.getElementById("grid-columns");
        const flexGridOptionsDiv = document.getElementById("flex-grid-options");

        // Reset all
        layoutButtons.forEach((btn) => btn.classList.remove("active"));
        gridColumnsDiv?.classList.add("hidden");
        flexGridOptionsDiv?.classList.add("hidden");

        // Determine current layout
        if (element.classList.contains("flex")) {
            if (element.classList.contains("flex-col")) {
                document
                    .querySelector('[data-layout="flex-col"]')
                    ?.classList.add("active");
            } else {
                document
                    .querySelector('[data-layout="flex-row"]')
                    ?.classList.add("active");
            }
            // Show gap options only for flex (NOT grid columns)
            flexGridOptionsDiv?.classList.remove("hidden");
            gridColumnsDiv?.classList.add("hidden"); // Make sure grid cols stay hidden
        } else if (element.classList.contains("grid")) {
            document
                .querySelector('[data-layout="grid"]')
                ?.classList.add("active");
            gridColumnsDiv?.classList.remove("hidden");
            flexGridOptionsDiv?.classList.remove("hidden");

            // Set grid columns
            document
                .querySelectorAll("[data-cols]")
                .forEach((b) => b.classList.remove("active"));
            if (element.classList.contains("grid-cols-2")) {
                document
                    .querySelector('[data-cols="2"]')
                    ?.classList.add("active");
            } else if (element.classList.contains("grid-cols-3")) {
                document
                    .querySelector('[data-cols="3"]')
                    ?.classList.add("active");
            } else if (element.classList.contains("grid-cols-4")) {
                document
                    .querySelector('[data-cols="4"]')
                    ?.classList.add("active");
            }
        } else {
            document
                .querySelector('[data-layout="block"]')
                ?.classList.add("active");
        }

        // Set gap state
        document
            .querySelectorAll("[data-gap]")
            .forEach((b) => b.classList.remove("active"));
        if (element.classList.contains("gap-0")) {
            document.querySelector('[data-gap="0"]')?.classList.add("active");
        } else if (element.classList.contains("gap-2")) {
            document.querySelector('[data-gap="2"]')?.classList.add("active");
        } else if (element.classList.contains("gap-4")) {
            document.querySelector('[data-gap="4"]')?.classList.add("active");
        } else if (element.classList.contains("gap-6")) {
            document.querySelector('[data-gap="6"]')?.classList.add("active");
        }

        // Padding - detect mode and values
        const paddingAllDiv = document.getElementById("padding-all");
        const paddingHvDiv = document.getElementById("padding-hv");
        const paddingIndividualDiv =
            document.getElementById("padding-individual");
        const paddingModeButtons =
            document.querySelectorAll(".padding-mode-btn");

        // Reset all padding states
        paddingModeButtons.forEach((b) => b.classList.remove("active"));
        paddingAllDiv?.classList.add("hidden");
        paddingHvDiv?.classList.add("hidden");
        paddingIndividualDiv?.classList.add("hidden");

        // Check what padding classes exist
        const hasPAll = Array.from(element.classList).some((c) =>
            /^p-\d+$/.test(c),
        );
        const hasPx = Array.from(element.classList).some((c) =>
            /^px-\d+$/.test(c),
        );
        const hasPy = Array.from(element.classList).some((c) =>
            /^py-\d+$/.test(c),
        );
        const hasPt = Array.from(element.classList).some((c) =>
            /^pt-\d+$/.test(c),
        );
        const hasPr = Array.from(element.classList).some((c) =>
            /^pr-\d+$/.test(c),
        );
        const hasPb = Array.from(element.classList).some((c) =>
            /^pb-\d+$/.test(c),
        );
        const hasPl = Array.from(element.classList).some((c) =>
            /^pl-\d+$/.test(c),
        );

        if (hasPAll) {
            // All sides mode
            document
                .querySelector('[data-padding-mode="all"]')
                ?.classList.add("active");
            paddingAllDiv?.classList.remove("hidden");

            const value =
                Array.from(element.classList)
                    .find((c) => /^p-\d+$/.test(c))
                    ?.split("-")[1] || "0";
            document
                .querySelectorAll("[data-padding-all]")
                .forEach((b) => b.classList.remove("active"));
            document
                .querySelector(`[data-padding-all="${value}"]`)
                ?.classList.add("active");
        } else if ((hasPx || hasPy) && !hasPt && !hasPr && !hasPb && !hasPl) {
            // Horizontal/Vertical mode
            document
                .querySelector('[data-padding-mode="horizontal-vertical"]')
                ?.classList.add("active");
            paddingHvDiv?.classList.remove("hidden");

            const xValue =
                Array.from(element.classList)
                    .find((c) => /^px-\d+$/.test(c))
                    ?.split("-")[1] || "0";
            const yValue =
                Array.from(element.classList)
                    .find((c) => /^py-\d+$/.test(c))
                    ?.split("-")[1] || "0";

            document
                .querySelectorAll("[data-padding-x]")
                .forEach((b) => b.classList.remove("active"));
            document
                .querySelector(`[data-padding-x="${xValue}"]`)
                ?.classList.add("active");

            document
                .querySelectorAll("[data-padding-y]")
                .forEach((b) => b.classList.remove("active"));
            document
                .querySelector(`[data-padding-y="${yValue}"]`)
                ?.classList.add("active");
        } else if (hasPt || hasPr || hasPb || hasPl) {
            // Individual mode
            document
                .querySelector('[data-padding-mode="individual"]')
                ?.classList.add("active");
            paddingIndividualDiv?.classList.remove("hidden");

            const topValue =
                Array.from(element.classList)
                    .find((c) => /^pt-\d+$/.test(c))
                    ?.split("-")[1] || "0";
            const rightValue =
                Array.from(element.classList)
                    .find((c) => /^pr-\d+$/.test(c))
                    ?.split("-")[1] || "0";
            const bottomValue =
                Array.from(element.classList)
                    .find((c) => /^pb-\d+$/.test(c))
                    ?.split("-")[1] || "0";
            const leftValue =
                Array.from(element.classList)
                    .find((c) => /^pl-\d+$/.test(c))
                    ?.split("-")[1] || "0";

            document
                .querySelectorAll("[data-padding-top]")
                .forEach((b) => b.classList.remove("active"));
            document
                .querySelector(`[data-padding-top="${topValue}"]`)
                ?.classList.add("active");

            document
                .querySelectorAll("[data-padding-right]")
                .forEach((b) => b.classList.remove("active"));
            document
                .querySelector(`[data-padding-right="${rightValue}"]`)
                ?.classList.add("active");

            document
                .querySelectorAll("[data-padding-bottom]")
                .forEach((b) => b.classList.remove("active"));
            document
                .querySelector(`[data-padding-bottom="${bottomValue}"]`)
                ?.classList.add("active");

            document
                .querySelectorAll("[data-padding-left]")
                .forEach((b) => b.classList.remove("active"));
            document
                .querySelector(`[data-padding-left="${leftValue}"]`)
                ?.classList.add("active");
        } else {
            // Default to All mode with None
            document
                .querySelector('[data-padding-mode="all"]')
                ?.classList.add("active");
            paddingAllDiv?.classList.remove("hidden");
            document
                .querySelectorAll("[data-padding-all]")
                .forEach((b) => b.classList.remove("active"));
            document
                .querySelector('[data-padding-all="0"]')
                ?.classList.add("active");
        }

        // Background
        const bgSelect = document.getElementById(
            "prop-bg",
        ) as HTMLSelectElement;
        const bgClass = Array.from(element.classList).find((c) =>
            c.startsWith("bg-"),
        );
        bgSelect.value = bgClass || "";

        // Border Radius
        const radiusSelect = document.getElementById(
            "prop-radius",
        ) as HTMLSelectElement;
        const radiusClass = Array.from(element.classList).find((c) =>
            c.startsWith("rounded"),
        );
        radiusSelect.value = radiusClass || "";

        // Text Content
        const textInput = document.getElementById(
            "prop-text",
        ) as HTMLInputElement;
        if (textInput) {
            textInput.value = element.textContent || "";
        }
    }

    // Drag start handler
    function handlePaletteDragStart(ev: DragEvent) {
        const target = ev.currentTarget as HTMLElement;
        const elementType = target.dataset.elementType;

        if (!elementType) return;

        draggedData = {
            type: "element",
            elementType,
        };

        ev.dataTransfer!.effectAllowed = "copy";
        console.log("Drag started:", draggedData);
    }

    // Drop handler
    function handleDrop(ev: DragEvent, dropTarget: HTMLElement) {
        if (!draggedData) return;

        const newElement = createElement(draggedData.elementType);

        // Use the tracked target element if available (fixes multi-section bug)
        const targetElement = dropTargetElement || dropTarget;

        if (dropPosition === "above") {
            targetElement.insertAdjacentElement("beforebegin", newElement);
        } else if (dropPosition === "below") {
            targetElement.insertAdjacentElement("afterend", newElement);
        } else {
            targetElement.appendChild(newElement);
        }

        console.log(
            "Dropped:",
            draggedData.elementType,
            "position:",
            dropPosition,
        );

        dropPosition = null;
        dropTargetElement = null;
        hideIndicator();
        autoSave();
        updateSectionUI();
    }

    // Wire up palette items
    document.querySelectorAll('[draggable="true"]').forEach((item) => {
        item.addEventListener(
            "dragstart",
            handlePaletteDragStart as EventListener,
        );
    });

    // Setup canvas
    if (canvas) {
        setupDroppable(canvas);

        canvas.addEventListener("click", (e) => {
            if (e.target === canvas) {
                selectedElement = null;
                document.querySelectorAll(".selected").forEach((el) => {
                    el.classList.remove("selected");
                });
                propertiesPanel!.classList.add("hidden");
            }
        });
    }

    // Layout button controls
    const layoutButtons = document.querySelectorAll(".layout-btn");
    const gridColumnsDiv = document.getElementById("grid-columns");
    const flexGridOptionsDiv = document.getElementById("flex-grid-options");

    layoutButtons.forEach((btn) => {
        btn.addEventListener("click", () => {
            if (!selectedElement) return;

            const layout = (btn as HTMLElement).dataset.layout;

            // Update button states
            layoutButtons.forEach((b) => b.classList.remove("active"));
            btn.classList.add("active");

            // Remove all layout-related classes
            selectedElement.classList.remove(
                "flex",
                "flex-row",
                "flex-col",
                "grid",
                "grid-cols-2",
                "grid-cols-3",
                "grid-cols-4",
                "gap-0",
                "gap-2",
                "gap-4",
                "gap-6",
            );

            // Hide all options first
            gridColumnsDiv?.classList.add("hidden");
            flexGridOptionsDiv?.classList.add("hidden");

            // Apply layout and show appropriate options
            if (layout === "flex-row") {
                selectedElement.classList.add("flex", "flex-row", "gap-4");
                flexGridOptionsDiv?.classList.remove("hidden");
            } else if (layout === "flex-col") {
                selectedElement.classList.add("flex", "flex-col", "gap-4");
                flexGridOptionsDiv?.classList.remove("hidden");
            } else if (layout === "grid") {
                selectedElement.classList.add("grid", "grid-cols-2", "gap-4");
                gridColumnsDiv?.classList.remove("hidden");
                flexGridOptionsDiv?.classList.remove("hidden");
            }

            autoSave();
        });
    });

    // Grid column buttons
    document.querySelectorAll("[data-cols]").forEach((btn) => {
        btn.addEventListener("click", () => {
            if (!selectedElement) return;

            const cols = (btn as HTMLElement).dataset.cols;

            // Update button states
            document
                .querySelectorAll("[data-cols]")
                .forEach((b) => b.classList.remove("active"));
            btn.classList.add("active");

            // Remove old grid-cols classes
            selectedElement.classList.remove(
                "grid-cols-2",
                "grid-cols-3",
                "grid-cols-4",
            );
            selectedElement.classList.add(`grid-cols-${cols}`);

            autoSave();
        });
    });

    // Gap buttons
    document.querySelectorAll("[data-gap]").forEach((btn) => {
        btn.addEventListener("click", () => {
            if (!selectedElement) return;

            const gap = (btn as HTMLElement).dataset.gap;

            // Update button states
            document
                .querySelectorAll("[data-gap]")
                .forEach((b) => b.classList.remove("active"));
            btn.classList.add("active");

            // Remove old gap classes
            selectedElement.classList.remove(
                "gap-0",
                "gap-2",
                "gap-4",
                "gap-6",
            );
            if (gap !== "0") {
                selectedElement.classList.add(`gap-${gap}`);
            }

            autoSave();
        });
    });

    // Padding mode buttons
    const paddingModeButtons = document.querySelectorAll(".padding-mode-btn");
    const paddingAllDiv = document.getElementById("padding-all");
    const paddingHvDiv = document.getElementById("padding-hv");
    const paddingIndividualDiv = document.getElementById("padding-individual");

    paddingModeButtons.forEach((btn) => {
        btn.addEventListener("click", () => {
            const mode = (btn as HTMLElement).dataset.paddingMode;

            // Update button states
            paddingModeButtons.forEach((b) => b.classList.remove("active"));
            btn.classList.add("active");

            // Show/hide appropriate value sections
            paddingAllDiv?.classList.add("hidden");
            paddingHvDiv?.classList.add("hidden");
            paddingIndividualDiv?.classList.add("hidden");

            if (mode === "all") {
                paddingAllDiv?.classList.remove("hidden");
            } else if (mode === "horizontal-vertical") {
                paddingHvDiv?.classList.remove("hidden");
            } else if (mode === "individual") {
                paddingIndividualDiv?.classList.remove("hidden");
            }
        });
    });

    // Padding value buttons - All sides
    document.querySelectorAll("[data-padding-all]").forEach((btn) => {
        btn.addEventListener("click", () => {
            if (!selectedElement) return;

            const value = (btn as HTMLElement).dataset.paddingAll;

            // Update button states
            document
                .querySelectorAll("[data-padding-all]")
                .forEach((b) => b.classList.remove("active"));
            btn.classList.add("active");

            // Remove all padding classes
            selectedElement.classList.remove(
                "p-0",
                "p-2",
                "p-4",
                "p-6",
                "p-8",
                "px-0",
                "px-2",
                "px-4",
                "px-6",
                "px-8",
                "py-0",
                "py-2",
                "py-4",
                "py-6",
                "py-8",
                "pt-0",
                "pt-2",
                "pt-4",
                "pt-6",
                "pt-8",
                "pr-0",
                "pr-2",
                "pr-4",
                "pr-6",
                "pr-8",
                "pb-0",
                "pb-2",
                "pb-4",
                "pb-6",
                "pb-8",
                "pl-0",
                "pl-2",
                "pl-4",
                "pl-6",
                "pl-8",
            );

            // Add new padding
            if (value !== "0") {
                selectedElement.classList.add(`p-${value}`);
            }

            autoSave();
        });
    });

    // Padding value buttons - Horizontal
    document.querySelectorAll("[data-padding-x]").forEach((btn) => {
        btn.addEventListener("click", () => {
            if (!selectedElement) return;

            const value = (btn as HTMLElement).dataset.paddingX;

            // Update button states
            document
                .querySelectorAll("[data-padding-x]")
                .forEach((b) => b.classList.remove("active"));
            btn.classList.add("active");

            // Remove horizontal padding and all-sides padding
            selectedElement.classList.remove(
                "p-0",
                "p-2",
                "p-4",
                "p-6",
                "p-8",
                "px-0",
                "px-2",
                "px-4",
                "px-6",
                "px-8",
            );

            // Add new horizontal padding
            if (value !== "0") {
                selectedElement.classList.add(`px-${value}`);
            }

            autoSave();
        });
    });

    // Padding value buttons - Vertical
    document.querySelectorAll("[data-padding-y]").forEach((btn) => {
        btn.addEventListener("click", () => {
            if (!selectedElement) return;

            const value = (btn as HTMLElement).dataset.paddingY;

            // Update button states
            document
                .querySelectorAll("[data-padding-y]")
                .forEach((b) => b.classList.remove("active"));
            btn.classList.add("active");

            // Remove vertical padding and all-sides padding
            selectedElement.classList.remove(
                "p-0",
                "p-2",
                "p-4",
                "p-6",
                "p-8",
                "py-0",
                "py-2",
                "py-4",
                "py-6",
                "py-8",
            );

            // Add new vertical padding
            if (value !== "0") {
                selectedElement.classList.add(`py-${value}`);
            }

            autoSave();
        });
    });

    // Padding value buttons - Individual sides
    ["top", "right", "bottom", "left"].forEach((side) => {
        document.querySelectorAll(`[data-padding-${side}]`).forEach((btn) => {
            btn.addEventListener("click", () => {
                if (!selectedElement) return;

                const value = (btn as HTMLElement).dataset[
                    `padding${side.charAt(0).toUpperCase() + side.slice(1)}`
                ];
                const prefix = side.charAt(0); // t, r, b, l

                // Update button states
                document
                    .querySelectorAll(`[data-padding-${side}]`)
                    .forEach((b) => b.classList.remove("active"));
                btn.classList.add("active");

                // Remove this side's padding and all-sides/axis padding
                selectedElement.classList.remove(
                    "p-0",
                    "p-2",
                    "p-4",
                    "p-6",
                    "p-8",
                    `p${prefix}-0`,
                    `p${prefix}-2`,
                    `p${prefix}-4`,
                    `p${prefix}-6`,
                    `p${prefix}-8`,
                );

                // Remove axis-based padding if setting individual
                if (side === "top" || side === "bottom") {
                    selectedElement.classList.remove(
                        "py-0",
                        "py-2",
                        "py-4",
                        "py-6",
                        "py-8",
                    );
                } else {
                    selectedElement.classList.remove(
                        "px-0",
                        "px-2",
                        "px-4",
                        "px-6",
                        "px-8",
                    );
                }

                // Add new padding for this side
                if (value !== "0") {
                    selectedElement.classList.add(`p${prefix}-${value}`);
                }

                autoSave();
            });
        });
    });

    document.getElementById("prop-bg")?.addEventListener("change", (e) => {
        if (!selectedElement) return;

        const value = (e.target as HTMLSelectElement).value;

        // Remove old background classes
        Array.from(selectedElement.classList).forEach((c) => {
            if (c.startsWith("bg-")) {
                selectedElement!.classList.remove(c);
            }
        });

        // Add new background class
        if (value) {
            selectedElement.classList.add(value);
        }

        autoSave();
    });

    document.getElementById("prop-radius")?.addEventListener("change", (e) => {
        if (!selectedElement) return;

        const value = (e.target as HTMLSelectElement).value;

        // Remove old radius classes
        Array.from(selectedElement.classList).forEach((c) => {
            if (c.startsWith("rounded")) {
                selectedElement!.classList.remove(c);
            }
        });

        // Add new radius class
        if (value) {
            selectedElement.classList.add(value);
        }

        autoSave();
    });

    document.getElementById("prop-text")?.addEventListener("input", (e) => {
        if (!selectedElement) return;

        const value = (e.target as HTMLInputElement).value;
        selectedElement.textContent = value;

        autoSave();
    });

    // Delete button
    document.getElementById("delete-btn")?.addEventListener("click", () => {
        if (!selectedElement) return;

        selectedElement.remove();
        selectedElement = null;
        propertiesPanel!.classList.add("hidden");

        autoSave();
        updateSectionUI();
    });

    // Reset button
    document.getElementById("reset-btn")?.addEventListener("click", () => {
        // if (!selectedElement) return;
        if (!canvas) return;

        canvas.replaceChildren();

        // selectedElement.remove();
        // selectedElement = null;
        // propertiesPanel!.classList.add("hidden");

        autoSave();
        updateSectionUI();
    });

    // Save button
    document.getElementById("save-btn")?.addEventListener("click", () => {
        const state = stateManager.captureState();
        stateManager.save(state);
        alert("Saved!");
    });

    // Export button
    document.getElementById("export-btn")?.addEventListener("click", () => {
        // Clone canvas and remove trigger buttons before export
        const canvasClone = canvas?.cloneNode(true) as HTMLElement;
        canvasClone
            ?.querySelectorAll(".add-section-trigger")
            .forEach((el) => el.remove());

        const html = canvasClone?.innerHTML || "";
        const modal = document.getElementById("export-modal");
        const output = document.getElementById("export-output");

        if (output) {
            output.textContent = `<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <script src="https://cdn.tailwindcss.com"><\/script>
  <title>Exported Page</title>
</head>
<body>
${html}
</body>
</html>`;
        }

        modal?.classList.remove("hidden");
    });

    // Close modal
    document.getElementById("close-modal")?.addEventListener("click", () => {
        document.getElementById("export-modal")?.classList.add("hidden");
    });

    // Copy HTML
    document.getElementById("copy-html-btn")?.addEventListener("click", () => {
        const output = document.getElementById("export-output");
        if (output) {
            navigator.clipboard.writeText(output.textContent || "");
            alert("HTML copied to clipboard!");
        }
    });

    // Load state on page load
    document.addEventListener("DOMContentLoaded", () => {
        const state = stateManager.load();
        if (state && canvas) {
            stateManager.restoreState(state);
        } else {
            updateSectionUI(); // Show "Add Section" on empty canvas
        }
    });

    // Click on canvas wrapper (gray area around canvas) to deselect
    const canvasWrapper = document.getElementById("canvas-wrapper");
    canvasWrapper?.addEventListener("click", (e) => {
        const target = e.target as HTMLElement;

        // Only deselect if clicking directly on the wrapper itself (not canvas or its children)
        if (target === canvasWrapper) {
            if (selectedElement) {
                selectedElement.classList.remove("selected");
                selectedElement = null;
                propertiesPanel?.classList.add("hidden");
            }
        }
    });
    console.log("Visual Page Builder initialized");

    // okay you've dragged on section on the page,
    // now if you drag another section near the bottom or top of the existing section/s
    // we'd need to know where the mouse is in relation to the top and bottom of the canvas, and to the top and bottom of any section.
    // if they're near those zones, show a drop indicator.
    // if the user releases with a drop indicator highlighted selected, add the section at that spot.

    // start with botom of section.
</script>
