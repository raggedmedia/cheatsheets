    >
        <ProTip>
            <div>
                ⏱️ <strong>Pattern 1: Basic timeout with Promise.race()</strong>
            </div>
            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                <div class="font-mono text-[10px]">
                    function timeout(ms) {"{"}
                </div>
                <div class="font-mono text-[10px]">
                    &nbsp;&nbsp;return new Promise((_, reject) =&gt;
                </div>
                <div class="font-mono text-[10px]">
                    &nbsp;&nbsp;&nbsp;&nbsp;setTimeout(() =&gt; reject(new
                    Error('Timeout')), ms)
                </div>
                <div class="font-mono text-[10px]">&nbsp;&nbsp;)</div>
                <div class="font-mono text-[10px]">{"}"}</div>
                <div class="font-mono text-[10px] mt-1">
                    <span class="text-gray-400">// Usage:</span>
                </div>
                <div class="font-mono text-[10px]">try {"{"}</div>
                <div class="font-mono text-[10px]">
                    &nbsp;&nbsp;const data = await Promise.race([
                </div>
                <div class="font-mono text-[10px]">
                    &nbsp;&nbsp;&nbsp;&nbsp;fetch('/api/data'),
                </div>
                <div class="font-mono text-[10px]">
                    &nbsp;&nbsp;&nbsp;&nbsp;timeout(5000) <span
                        class="text-gray-400">// 5 second limit</span>
                </div>
                <div class="font-mono text-[10px]">&nbsp;&nbsp;])</div>
                <div class="font-mono text-[10px]">{"}"} catch (err) {"{"}</div>
                <div class="font-mono text-[10px]">
                    &nbsp;&nbsp;console.error('Request failed or timed out')
                </div>
                <div class="font-mono text-[10px]">{"}"}</div>
            </div>
        </ProTip>

        <ProTip>
            <div>⏱️ <strong>Pattern 2: Reusable timeout wrapper</strong></div>
            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                <div class="font-mono text-[10px]">
                    function withTimeout(promise, ms) {"{"}
                </div>
                <div class="font-mono text-[10px]">
                    &nbsp;&nbsp;const timeout = new Promise((_, reject) =&gt;
                </div>
                <div class="font-mono text-[10px]">
                    &nbsp;&nbsp;&nbsp;&nbsp;setTimeout(() =&gt; reject(new
                    Error(`Timeout after ${"{"}ms{"}"}ms`)), ms)
                </div>
                <div class="font-mono text-[10px]">&nbsp;&nbsp;)</div>
                <div class="font-mono text-[10px]">
                    &nbsp;&nbsp;return Promise.race([promise, timeout])
                </div>
                <div class="font-mono text-[10px]">{"}"}</div>
                <div class="font-mono text-[10px] mt-1">
                    <span class="text-gray-400">// Clean usage anywhere:</span>
                </div>
                <div class="font-mono text-[10px]">
                    const user = await withTimeout(fetchUser(id), 3000)
                </div>
                <div class="font-mono text-[10px]">
                    const posts = await withTimeout(fetchPosts(), 5000)
                </div>
            </div>
        </ProTip>

        <ProTip>
            <div>
                ⏱️ <strong
                    >Pattern 3: AbortController with fetch (Modern)</strong>
            </div>
            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                <div class="font-mono text-[10px]">
                    const controller = new AbortController()
                </div>
                <div class="font-mono text-[10px]">
                    const timeoutId = setTimeout(() =&gt; controller.abort(),
                    5000)
                </div>
                <div class="font-mono text-[10px] mt-1">try {"{"}</div>
                <div class="font-mono text-[10px]">
                    &nbsp;&nbsp;const response = await fetch('/api/data', {"{"}
                </div>
                <div class="font-mono text-[10px]">
                    &nbsp;&nbsp;&nbsp;&nbsp;signal: controller.signal <span
                        class="text-gray-400">// abort signal</span>
                </div>
                <div class="font-mono text-[10px]">&nbsp;&nbsp;{"}"})</div>
                <div class="font-mono text-[10px]">
                    &nbsp;&nbsp;clearTimeout(timeoutId) <span
                        class="text-gray-400"
                        >// cancel timeout if successful</span>
                </div>
                <div class="font-mono text-[10px]">
                    &nbsp;&nbsp;return await response.json()
                </div>
                <div class="font-mono text-[10px]">{"}"} catch (err) {"{"}</div>
                <div class="font-mono text-[10px]">
                    &nbsp;&nbsp;if (err.name === 'AbortError') {"{"}
                </div>
                <div class="font-mono text-[10px]">
                    &nbsp;&nbsp;&nbsp;&nbsp;console.error('Request timed out')
                </div>
                <div class="font-mono text-[10px]">&nbsp;&nbsp;{"}"}</div>
                <div class="font-mono text-[10px]">{"}"}</div>
                <div class="font-mono text-[10px] mt-1 text-gray-400">
                    ✓ Actually cancels the HTTP request (not just timing)
                </div>
            </div>
        </ProTip>

        <ProTip>
            <div>⚠️ <strong>Best Practices:</strong></div>
            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                <div class="font-mono text-[10px]">
                    <span class="text-green-400">✓</span> Use AbortController for
                    fetch requests (actually cancels)
                </div>
                <div class="font-mono text-[10px]">
                    <span class="text-green-400">✓</span> Clear timeout when operation
                    succeeds early
                </div>
                <div class="font-mono text-[10px]">
                    <span class="text-green-400">✓</span> Provide clear timeout error
                    messages with duration
                </div>
                <div class="font-mono text-[10px]">
                    <span class="text-green-400">✓</span> Set reasonable timeouts
