---
interface Props {
    mutates: boolean;
    message: string;
}

const { mutates, message } = Astro.props;
---

<div class={`border rounded p-2 mt-3 ${mutates ? 'bg-red-500/10 border-red-500' : 'bg-green-500/10 border-green-500'}`}>
    <div class={`font-semibold mb-1 text-[11px] ${mutates ? 'text-red-400' : 'text-green-400'}`}>
        {mutates ? '⚠️ Mutates Original' : '✅ Immutable'}
    </div>
    <div class="text-[11px] text-gray-300 leading-snug">
        <slot />
        {message}
    </div>
</div>
