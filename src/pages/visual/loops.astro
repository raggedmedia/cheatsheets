                                <div class="ml-4"><span class="text-purple-300">if</span> <span class="text-purple-300">(</span><span class="text-blue-300">item</span> <span class="text-purple-300">===</span> <span class="text-yellow-300">null</span><span class="text-purple-300">)</span> <span class="text-yellow-300">continue</span></div>
                                <div class="ml-4"><span class="text-gray-400">console.log(item)</span></div>
                                <span class="text-purple-300">}</span>
                            </div>

                            <!-- Flow visualization -->
                            <div class="space-y-2 text-xs">
                                <div class="text-gray-400 mb-2">Skips rest of iteration, moves to next:</div>

                                <div class="p-2 bg-green-500/10 border border-green-500/30 rounded">
                                    <div class="font-mono text-sm">item = <span class="text-green-300">'a'</span></div>
                                    <div class="text-gray-400 text-[10px] mt-1">✓ Not null, console.log('a')</div>
                                </div>

                                <div class="p-2 bg-yellow-500/10 border border-yellow-500/30 rounded">
                                    <div class="font-mono text-sm">item = <span class="text-yellow-300">null</span></div>
                                    <div class="text-yellow-300 text-[10px] mt-1 font-bold">⚠️ CONTINUE - Skip to next!</div>
                                    <div class="text-gray-400 text-[10px]">(console.log skipped)</div>
                                </div>

                                <div class="p-2 bg-green-500/10 border border-green-500/30 rounded">
                                    <div class="font-mono text-sm">item = <span class="text-green-300">'b'</span></div>
                                    <div class="text-gray-400 text-[10px] mt-1">✓ Not null, console.log('b')</div>
                                </div>

                                <div class="p-2 bg-yellow-500/10 border border-yellow-500/30 rounded">
                                    <div class="font-mono text-sm">item = <span class="text-yellow-300">null</span></div>
                                    <div class="text-yellow-300 text-[10px] mt-1 font-bold">⚠️ CONTINUE - Skip to next!</div>
                                    <div class="text-gray-400 text-[10px]">(console.log skipped)</div>
                                </div>

                                <div class="p-2 bg-green-500/10 border border-green-500/30 rounded">
                                    <div class="font-mono text-sm">item = <span class="text-green-300">'c'</span></div>
                                    <div class="text-gray-400 text-[10px] mt-1">✓ Not null, console.log('c')</div>
                                </div>

                                <div class="mt-3 p-2 bg-blue-500/10 border border-blue-500/30 rounded text-center">
                                    <div class="text-blue-300 font-bold">Loop completes normally</div>
                                </div>
                            </div>
                        </div>

                        <InfoBox mutates={false} message="">
                            Skips remaining code in current iteration, proceeds to next. Cannot be used in <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">forEach()</code>.
                        </InfoBox>

                        <ProTip>
                            <div>Common use case - skip unwanted items:</div>
                            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                                <div class="font-mono text-[10px]">for (const item of arr) &lbrace;</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;if (item === null) continue <span class="text-gray-400">// skip nulls</span></div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;console.log(item) <span class="text-gray-400">// only runs for non-null</span></div>
                                <div class="font-mono text-[10px]">&rbrace;</div>
                            </div>
                        </ProTip>
                    </MethodCard>
