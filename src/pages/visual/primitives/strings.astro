                            <ul class="ml-3 mt-1 space-y-1 border-l-2 border-red-500/30 pl-2">
                                <li><a href="#concat" class="text-gray-300 hover:text-blue-400 block">concat()</a></li>
                                <li><a href="#repeat" class="text-gray-300 hover:text-blue-400 block">repeat()</a></li>
                                <li><a href="#replace" class="text-gray-300 hover:text-blue-400 block">replace()</a></li>
                                <li><a href="#replaceAll" class="text-gray-300 hover:text-blue-400 block">replaceAll()</a></li>
                            </ul>
                        </li>

                        <li class="mt-4">
                            <a href="#pattern" class="text-pink-300 font-semibold hover:text-pink-200 block py-1">🔍 Pattern Matching</a>
                            <ul class="ml-3 mt-1 space-y-1 border-l-2 border-pink-500/30 pl-2">
                                <li><a href="#match" class="text-gray-300 hover:text-blue-400 block">match()</a></li>
