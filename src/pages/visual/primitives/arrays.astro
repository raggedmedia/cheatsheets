                <MutableOrNot mutates={false} message="">
                    Original array remains unchanged. Returns a <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">new array</code> containing the extracted section. End index is exclusive. Supports negative indices.
                </MutableOrNot>

                <ProTip>
                    <div class="pl-2 border-l-2 border-yellow-500/60">
                        <div class="font-mono text-[10px]">slice(1, -1) → removes first & last item</div>
                        <div class="font-mono text-[10px]">slice(-3) → gets last 3 items</div>
                        <div class="font-mono text-[10px]">slice(0) or [...arr] → shallow copy entire array</div>
                    </div>
                    <div class="mt-1.5 text-[10px]">
                        ⚠️ <strong>Shallow vs Deep Copy:</strong>
                    </div>
                    <div class="pl-2 border-l-2 border-yellow-500/60 mt-1 space-y-1">
                        <div class="font-mono text-[10px]">
                            <span class="text-gray-400">// Simple values (strings/numbers) - shallow copy is fine:</span><br/>
                            const copy = [1, 2, 3].slice(0)<br/>
                            copy[0] = 999 → original unaffected ✅
                        </div>
                        <div class="font-mono text-[10px]">
                            <span class="text-gray-400">// Nested objects - shallow copy shares references!</span><br/>
                            const users = [&lbrace;id:1&rbrace;, &lbrace;id:2&rbrace;]<br/>
                            const copy = users.slice(0)<br/>
                            copy[0].id = 999 → original[0].id is also 999 ❌
                        </div>
                        <div class="font-mono text-[10px]">
                            <span class="text-gray-400">// Deep copy - fully independent:</span><br/>
                            const deep = structuredClone(users)<br/>
                            deep[0].id = 999 → original unaffected ✅
                        </div>
                    </div>
                </ProTip>
