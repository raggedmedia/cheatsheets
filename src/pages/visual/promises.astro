---
import '~styles/styles.css'
import MethodCard from '~components/visual-js/MethodCard.astro';
import Node from '~components/visual-js/Node.astro';
import ArrayDisplay from '~components/visual-js/ArrayDisplay.astro';
import Arrow from '~components/visual-js/Arrow.astro';
import ReturnValue from '~components/visual-js/ReturnValue.astro';
import InfoBox from '~components/visual-js/InfoBox.astro';
import ProcessContent from '~components/visual-js/ProcessContent.astro';
import ProTip from '~components/visual-js/ProTip.astro';
import GlobalNav from '~components/visual-js/GlobalNav.astro';
---

<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>JavaScript Promises & Async - Visual Cheatsheet</title>
    </head>
    <body class="m-0 p-4 bg-[#1a1d29] text-gray-200">
        <div class="flex gap-6 max-w-[1600px] mx-auto">
            <!-- Main Content -->
            <main class="flex-1 min-w-0">
                <h1 class="text-white mb-1 text-2xl font-bold">JavaScript Promises & Async/Await</h1>
                <p class="text-gray-400 mb-6 text-sm">Visual blueprint-style reference for asynchronous operations</p>

                <ProTip>
                    <div>💡 <strong>3 Promise States:</strong></div>
                    <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                        <div class="font-mono text-[10px]"><strong>Pending</strong> - Initial state, not yet resolved or rejected</div>
                        <div class="font-mono text-[10px]"><strong>Fulfilled</strong> - Operation completed successfully (resolved)</div>
                        <div class="font-mono text-[10px]"><strong>Rejected</strong> - Operation failed with an error</div>
                        <div class="font-mono text-[10px] mt-1"><span class="text-gray-400">Once fulfilled or rejected, a promise cannot change state again</span></div>
                    </div>
                </ProTip>

                <!-- ============================================ -->
                <!-- 🎁 CREATING PROMISES -->
                <!-- ============================================ -->

                <h2 id="creating" class="text-blue-300 text-xl my-4 pb-2 border-b-2 border-blue-600">
                    🎁 Creating Promises
                </h2>

                <!-- NEW PROMISE -->
                <div id="new-promise">
                    <MethodCard
                        methodName="new Promise()"
                        signature="new Promise((resolve, reject) => { })"
                        description="Create a new promise with resolve/reject functions"
                        mutates={false}
                    >
                        <!-- State Machine Diagram -->
                        <div class="p-6 bg-gray-800 rounded">
                            <!-- Pending State -->
                            <div class="flex items-center justify-center mb-8">
                                <div class="bg-yellow-500/20 border-2 border-yellow-500 rounded-lg p-4 text-center">
                                    <div class="text-yellow-300 font-bold text-lg mb-1">⏳ PENDING</div>
                                    <div class="text-xs text-gray-300">Promise created, waiting...</div>
                                </div>
                            </div>

                            <!-- Arrows pointing down -->
                            <div class="flex justify-center gap-24 mb-4">
                                <div class="flex flex-col items-center">
                                    <div class="text-2xl mb-2">↓</div>
                                    <div class="text-xs text-green-400 font-mono">resolve(value)</div>
                                </div>
                                <div class="flex flex-col items-center">
                                    <div class="text-2xl mb-2">↓</div>
                                    <div class="text-xs text-red-400 font-mono">reject(error)</div>
                                </div>
                            </div>

                            <!-- Final States -->
                            <div class="flex justify-center gap-8">
                                <div class="bg-green-500/20 border-2 border-green-500 rounded-lg p-4 text-center flex-1 max-w-[200px]">
                                    <div class="text-green-300 font-bold text-lg mb-1">✅ FULFILLED</div>
                                    <div class="text-xs text-gray-300">Success! Has value</div>
                                </div>
                                <div class="bg-red-500/20 border-2 border-red-500 rounded-lg p-4 text-center flex-1 max-w-[200px]">
                                    <div class="text-red-300 font-bold text-lg mb-1">❌ REJECTED</div>
                                    <div class="text-xs text-gray-300">Failed! Has error</div>
                                </div>
                            </div>
                        </div>

                        <div class="text-gray-300 text-sm mt-3 p-3 bg-gray-800/50 rounded border border-gray-700">
                            Executor function runs immediately. Call <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">resolve(value)</code> on success, <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">reject(error)</code> on failure.
                        </div>

                        <ProTip>
                            <div>Basic promise creation:</div>
                            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                                <div class="font-mono text-[10px]">const promise = new Promise((resolve, reject) =&gt; &lbrace;</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;const success = true</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;if (success) &lbrace;</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;&nbsp;&nbsp;resolve('It worked!') <span class="text-green-400">// fulfills promise</span></div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;&rbrace; else &lbrace;</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;&nbsp;&nbsp;reject(new Error('Failed')) <span class="text-red-400">// rejects promise</span></div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;&rbrace;</div>
                                <div class="font-mono text-[10px]">&rbrace;)</div>
                            </div>
                        </ProTip>
                    </MethodCard>
                </div>

                <!-- PROMISE.RESOLVE -->
                <div id="promise-resolve">
                    <MethodCard
                        methodName="Promise.resolve()"
                        signature="Promise.resolve(value)"
                        description="Create an immediately fulfilled promise"
                        mutates={false}
                    >
                        <!-- Shortcut to Fulfilled State -->
                        <div class="p-6 bg-gray-800 rounded">
                            <div class="flex items-center justify-center gap-8">
                                <div class="bg-blue-500/20 border-2 border-blue-400 rounded-lg p-4 text-center">
                                    <div class="text-blue-300 font-mono text-sm mb-1">Promise.resolve('data')</div>
                                    <div class="text-xs text-gray-400">Skips pending state</div>
                                </div>

                                <div class="text-3xl text-green-400">→</div>

                                <div class="bg-green-500/20 border-2 border-green-500 rounded-lg p-4 text-center">
                                    <div class="text-green-300 font-bold text-lg mb-1">✅ FULFILLED</div>
                                    <div class="text-xs text-gray-300">Immediately resolved</div>
                                    <div class="text-xs text-yellow-400 font-mono mt-1">value: 'data'</div>
                                </div>
                            </div>
                        </div>

                        <div class="text-gray-300 text-sm mt-3 p-3 bg-gray-800/50 rounded border border-gray-700">
                            Returns a promise that's already fulfilled with the given value. Useful for converting sync values to promises.
                        </div>

                        <ProTip>
                            <div>Critical for API consistency - always return same type:</div>
                            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                                <div class="font-mono text-[10px]"><span class="text-green-400">// ✅ Good: Always returns promise</span></div>
                                <div class="font-mono text-[10px]">function getUserData(id) &lbrace;</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;const cached = cache.get(id)</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;if (cached) return Promise.resolve(cached)</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;return fetch(`/users/$&lbrace;id&rbrace;`).then(r =&gt; r.json())</div>
                                <div class="font-mono text-[10px]">&rbrace;</div>
                                <div class="font-mono text-[10px] mt-1.5"><span class="text-red-400">// ❌ Bad: Sometimes promise, sometimes not</span></div>
                                <div class="font-mono text-[10px]">function getUserData(id) &lbrace;</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;const cached = cache.get(id)</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;if (cached) return cached <span class="text-gray-400">// Not a promise!</span></div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;return fetch(`/users/$&lbrace;id&rbrace;`).then(r =&gt; r.json())</div>
                                <div class="font-mono text-[10px]">&rbrace;</div>
                            </div>
                        </ProTip>
                    </MethodCard>
                </div>

                <!-- PROMISE.REJECT -->
                <div id="promise-reject">
                    <MethodCard
                        methodName="Promise.reject()"
                        signature="Promise.reject(reason)"
                        description="Create an immediately rejected promise"
                        mutates={false}
                    >
                        <!-- Shortcut to Rejected State -->
                        <div class="p-6 bg-gray-800 rounded">
                            <div class="flex items-center justify-center gap-8">
                                <div class="bg-blue-500/20 border-2 border-blue-400 rounded-lg p-4 text-center">
                                    <div class="text-blue-300 font-mono text-sm mb-1">Promise.reject(error)</div>
                                    <div class="text-xs text-gray-400">Skips pending state</div>
                                </div>

                                <div class="text-3xl text-red-400">→</div>

                                <div class="bg-red-500/20 border-2 border-red-500 rounded-lg p-4 text-center">
                                    <div class="text-red-300 font-bold text-lg mb-1">❌ REJECTED</div>
                                    <div class="text-xs text-gray-300">Immediately rejected</div>
                                    <div class="text-xs text-yellow-400 font-mono mt-1">reason: Error</div>
                                </div>
                            </div>
                        </div>

                        <div class="text-gray-300 text-sm mt-3 p-3 bg-gray-800/50 rounded border border-gray-700">
                            Returns a promise that's already rejected with the given reason. Useful for early error returns.
                        </div>

                        <ProTip>
                            <div>Useful for early validation in async functions:</div>
                            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                                <div class="font-mono text-[10px]">async function updateUser(id, data) &lbrace;</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;<span class="text-gray-400">// Validate early, return rejected promise</span></div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;if (!id) return Promise.reject(new Error('ID required'))</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;if (!data) return Promise.reject(new Error('Data required'))</div>
                                <div class="font-mono text-[10px] mt-0.5">&nbsp;&nbsp;<span class="text-gray-400">// Continue with async work</span></div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;return fetch(`/users/$&lbrace;id&rbrace;`, &lbrace; method: 'PUT', body: data &rbrace;)</div>
                                <div class="font-mono text-[10px]">&rbrace;</div>
                            </div>
                        </ProTip>
                    </MethodCard>
                </div>

                <!-- ============================================ -->
                <!-- ⛓️ PROMISE CHAINING -->
                <!-- ============================================ -->

                <h2 id="chaining" class="text-purple-300 text-xl my-4 pb-2 border-b-2 border-purple-600">
                    ⛓️ Promise Chaining
                </h2>

                <!-- PROMISE CHAIN - .then() .catch() .finally() -->
                <div id="then">
                    <MethodCard
                        methodName=".then() / .catch() / .finally()"
                        signature="promise.then().catch().finally()"
                        description="Chain handlers for promise results, errors, and cleanup"
                        mutates={false}
                    >
                        <!-- Complete Chain Flow -->
                        <div class="p-6 bg-gray-800 rounded">
                            <div class="space-y-6">
                                <!-- SUCCESS PATH -->
                                <div>
                                    <div class="text-green-400 font-bold text-sm mb-3">✅ Success Path:</div>
                                    <div class="flex items-center gap-3">
                                        <!-- Initial Promise -->
                                        <div class="flex-1 text-center">
                                            <div class="bg-green-500/20 border-2 border-green-500 rounded-lg p-2.5">
                                                <div class="text-green-300 font-bold text-xs mb-1">Promise</div>
                                                <div class="text-yellow-400 font-mono text-[10px]">'data'</div>
                                            </div>
                                        </div>

                                        <div class="text-lg text-purple-400">→</div>

                                        <!-- .then() -->
                                        <div class="flex-1 text-center">
                                            <div class="bg-purple-500/20 border-2 border-purple-400 rounded-lg p-2.5">
                                                <div class="text-purple-300 font-mono text-[10px] mb-1">.then(d => d.toUpperCase())</div>
                                                <div class="text-yellow-400 font-mono text-[10px]">'DATA'</div>
                                            </div>
                                        </div>

                                        <div class="text-lg text-gray-500">→</div>

                                        <!-- .catch() skipped -->
                                        <div class="flex-1 text-center">
                                            <div class="bg-gray-700/30 border border-gray-600 rounded-lg p-2.5">
                                                <div class="text-gray-500 font-mono text-[10px] mb-1">.catch()</div>
                                                <div class="text-gray-500 text-[10px]">skipped</div>
                                            </div>
                                        </div>

                                        <div class="text-lg text-purple-400">→</div>

                                        <!-- .finally() -->
                                        <div class="flex-1 text-center">
                                            <div class="bg-purple-500/20 border-2 border-purple-400 rounded-lg p-2.5">
                                                <div class="text-purple-300 font-mono text-[10px] mb-1">.finally(cleanup)</div>
                                                <div class="text-gray-400 text-[10px]">runs</div>
                                            </div>
                                        </div>

                                        <div class="text-lg text-green-400">→</div>

                                        <!-- Result -->
                                        <div class="flex-1 text-center">
                                            <div class="bg-green-500/20 border-2 border-green-500 rounded-lg p-2.5">
                                                <div class="text-green-300 font-bold text-xs mb-1">Result</div>
                                                <div class="text-yellow-400 font-mono text-[10px]">'DATA'</div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- ERROR PATH -->
                                <div>
                                    <div class="text-red-400 font-bold text-sm mb-3">❌ Error Path:</div>
                                    <div class="flex items-center gap-3">
                                        <!-- Initial Promise -->
                                        <div class="flex-1 text-center">
                                            <div class="bg-red-500/20 border-2 border-red-500 rounded-lg p-2.5">
                                                <div class="text-red-300 font-bold text-xs mb-1">Promise</div>
                                                <div class="text-yellow-400 font-mono text-[10px]">Error</div>
                                            </div>
                                        </div>

                                        <div class="text-lg text-gray-500">→</div>

                                        <!-- .then() skipped -->
                                        <div class="flex-1 text-center">
                                            <div class="bg-gray-700/30 border border-gray-600 rounded-lg p-2.5">
                                                <div class="text-gray-500 font-mono text-[10px] mb-1">.then()</div>
                                                <div class="text-gray-500 text-[10px]">skipped</div>
                                            </div>
                                        </div>

                                        <div class="text-lg text-purple-400">→</div>

                                        <!-- .catch() handles error -->
                                        <div class="flex-1 text-center">
                                            <div class="bg-purple-500/20 border-2 border-purple-400 rounded-lg p-2.5">
                                                <div class="text-purple-300 font-mono text-[10px] mb-1">.catch(e => 'fallback')</div>
                                                <div class="text-yellow-400 font-mono text-[10px]">'fallback'</div>
                                            </div>
                                        </div>

                                        <div class="text-lg text-purple-400">→</div>

                                        <!-- .finally() -->
                                        <div class="flex-1 text-center">
                                            <div class="bg-purple-500/20 border-2 border-purple-400 rounded-lg p-2.5">
                                                <div class="text-purple-300 font-mono text-[10px] mb-1">.finally(cleanup)</div>
                                                <div class="text-gray-400 text-[10px]">runs</div>
                                            </div>
                                        </div>

                                        <div class="text-lg text-green-400">→</div>

                                        <!-- Result (recovered!) -->
                                        <div class="flex-1 text-center">
                                            <div class="bg-green-500/20 border-2 border-green-500 rounded-lg p-2.5">
                                                <div class="text-green-300 font-bold text-xs mb-1">Result</div>
                                                <div class="text-yellow-400 font-mono text-[10px]">'fallback'</div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="text-gray-300 text-sm mt-3 p-3 bg-gray-800/50 rounded border border-gray-700">
                            <strong>.then()</strong> handles success, <strong>.catch()</strong> handles errors and recovers the chain, <strong>.finally()</strong> always runs for cleanup (doesn't receive or modify values).
                        </div>

                        <ProTip>
                            <div>⚠️ <strong>Key behaviors:</strong></div>
                            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                                <div class="font-mono text-[10px]"><span class="text-gray-400">// .catch() recovers the chain</span></div>
                                <div class="font-mono text-[10px]">fetchUser()</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;.then(user =&gt; user.name)</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;.catch(err =&gt; 'Guest') <span class="text-gray-400">// returns 'Guest' if error</span></div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;.then(name =&gt; console.log(name)) <span class="text-gray-400">// runs with 'Guest'</span></div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;.finally(() =&gt; cleanup()) <span class="text-gray-400">// always runs</span></div>
                                <div class="font-mono text-[10px] mt-1"><span class="text-yellow-400">// Each .then() returns a new promise</span></div>
                            </div>
                        </ProTip>

                        <ProTip>
                            <div>💡 <strong>Common pattern - loading states:</strong></div>
                            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                                <div class="font-mono text-[10px]">setLoading(true)</div>
                                <div class="font-mono text-[10px]">fetchData()</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;.then(data =&gt; setData(data))</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;.catch(err =&gt; setError(err))</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;.finally(() =&gt; setLoading(false)) <span class="text-gray-400">// cleanup</span></div>
                            </div>
                        </ProTip>
                    </MethodCard>
                </div>

                <!-- ============================================ -->
                <!-- 🎭 ASYNC/AWAIT -->
                <!-- ============================================ -->

                <h2 id="async-await" class="text-green-300 text-xl my-4 pb-2 border-b-2 border-green-600">
                    🎭 Async/Await
                </h2>

                <!-- ASYNC FUNCTION -->
                <div id="async-function">
                    <MethodCard
                        methodName="async function"
                        signature="async function name() { }"
                        description="Declares a function that always returns a promise"
                        mutates={false}
                    >
                        <!-- Auto-wrap in Promise -->
                        <div class="p-6 bg-gray-800 rounded">
                            <div class="flex items-center gap-4">
                                <div class="flex-1 text-center">
                                    <div class="bg-blue-500/20 border-2 border-blue-400 rounded-lg p-3 mb-2">
                                        <div class="text-blue-300 font-mono text-xs mb-1">async function getData()</div>
                                        <div class="text-yellow-400 font-mono text-xs mb-1">&lbrace;</div>
                                        <div class="text-yellow-400 font-mono text-xs mb-1">&nbsp;&nbsp;return 'data'</div>
                                        <div class="text-yellow-400 font-mono text-xs">&rbrace;</div>
                                    </div>
                                    <div class="text-xs text-gray-400">Returns plain value</div>
                                </div>

                                <div class="text-2xl text-green-400">✨</div>

                                <div class="flex-1 text-center">
                                    <div class="bg-green-500/20 border-2 border-green-500 rounded-lg p-3 mb-2">
                                        <div class="text-green-300 font-bold text-sm mb-1">✅ Promise</div>
                                        <div class="text-xs text-yellow-400 font-mono">Promise&lt;'data'&gt;</div>
                                    </div>
                                    <div class="text-xs text-gray-400">Auto-wrapped!</div>
                                </div>
                            </div>
                        </div>

                        <div class="text-gray-300 text-sm mt-3 p-3 bg-gray-800/50 rounded border border-gray-700">
                            Automatically wraps return value in a promise. Allows use of <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">await</code> inside. If function throws, promise is rejected.
                        </div>

                        <ProTip>
                            <div>All async functions return promises:</div>
                            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                                <div class="font-mono text-[10px]">async function getData() &lbrace;</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;return 'data' <span class="text-gray-400">// automatically wrapped in Promise</span></div>
                                <div class="font-mono text-[10px]">&rbrace;</div>
                                <div class="font-mono text-[10px] mt-1">getData() <span class="text-gray-400">// returns Promise&lt;'data'&gt;</span></div>
                                <div class="font-mono text-[10px]">getData().then(d =&gt; console.log(d)) <span class="text-gray-400">// 'data'</span></div>
                            </div>
                        </ProTip>
                    </MethodCard>
                </div>

                <!-- AWAIT -->
                <div id="await">
                    <MethodCard
                        methodName="await"
                        signature="await promise"
                        description="Pause execution until promise resolves (async functions only)"
                        mutates={false}
                    >
                        <!-- Timeline showing pause -->
                        <div class="p-6 bg-gray-800 rounded">
                            <div class="space-y-3">
                                <!-- Line 1 -->
                                <div class="flex items-center gap-2">
                                    <div class="w-6 text-gray-500 text-xs">1</div>
                                    <div class="bg-blue-500/20 border border-blue-400 rounded px-3 py-1.5 flex-1">
                                        <div class="text-blue-300 font-mono text-xs">console.log('Start')</div>
                                    </div>
                                    <div class="text-xs text-gray-400 w-16">Runs</div>
                                </div>

                                <!-- Line 2 - await pauses here -->
                                <div class="flex items-center gap-2">
                                    <div class="w-6 text-gray-500 text-xs">2</div>
                                    <div class="bg-yellow-500/20 border-2 border-yellow-500 rounded px-3 py-1.5 flex-1">
                                        <div class="text-yellow-300 font-mono text-xs font-bold">const data = await fetchData()</div>
                                    </div>
                                    <div class="text-xs text-yellow-400 w-16">⏸️ Waits</div>
                                </div>

                                <!-- Line 3 -->
                                <div class="flex items-center gap-2">
                                    <div class="w-6 text-gray-500 text-xs">3</div>
                                    <div class="bg-green-500/20 border border-green-400 rounded px-3 py-1.5 flex-1">
                                        <div class="text-green-300 font-mono text-xs">console.log(data)</div>
                                    </div>
                                    <div class="text-xs text-green-400 w-16">Then runs</div>
                                </div>
                            </div>
                        </div>

                        <div class="text-gray-300 text-sm mt-3 p-3 bg-gray-800/50 rounded border border-gray-700">
                            Pauses execution until promise resolves. Returns the fulfilled value. If promise rejects, throws the error. <strong>Only works inside async functions</strong> (or top-level in modules).
                        </div>

                        <ProTip>
                            <div>✨ <strong>Cleaner than .then() chains:</strong></div>
                            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                                <div class="font-mono text-[10px]"><span class="text-red-400">// Old way - promise chains ❌</span></div>
                                <div class="font-mono text-[10px]">fetchUser().then(user =&gt; &lbrace;</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;return fetchPosts(user.id)</div>
                                <div class="font-mono text-[10px]">&rbrace;).then(posts =&gt; &lbrace;</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;console.log(posts)</div>
                                <div class="font-mono text-[10px]">&rbrace;)</div>
