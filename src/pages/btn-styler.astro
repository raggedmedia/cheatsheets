---
import '../styles/styles.css'
---
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Btn Builder</title>
        <style is:global>
            :root {
                --achilles-padding-left: var(--spacing-base);
                --achilles-padding-right: var(--spacing-base);
                --achilles-padding-top: var(--spacing-sm);
                --achilles-padding-bottom: var(--spacing-sm);
                --achilles-bg-color: var(--color-blue-500);
            }

            #achilles {
                padding-left: var(--achilles-padding-left);
                padding-right: var(--achilles-padding-right);
                padding-top: var(--achilles-padding-top);
                padding-bottom: var(--achilles-padding-bottom);
                background-color: var(--achilles-bg-color);
            }

            /* Color swatch radio button styling */
            .color-swatch {
                position: relative;
                display: inline-block;
            }

            .color-swatch input[type="radio"] {
                position: absolute;
                opacity: 0;
                width: 0;
                height: 0;
                pointer-events: none;
            }

            .color-swatch label {
                display: block;
                width: 36px;
                height: 36px;
                border-radius: 0.25rem;
                cursor: pointer;
                border: 1px solid rgba(0, 0, 0, 0.15);
                box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.2);
                transition: all 0.15s ease;
                position: relative;
            }

            .color-swatch input[type="radio"]:checked + label {
                border: 3px solid #000;
                box-shadow: 0 0 0 1px #000, 0 2px 8px rgba(0, 0, 0, 0.2);
                transform: scale(1.15);
                z-index: 10;
            }

            .color-swatch label:hover {
                transform: scale(1.08);
                border-color: rgba(0, 0, 0, 0.3);
                z-index: 5;
            }

            .color-swatch input[type="radio"]:checked + label:hover {
                transform: scale(1.15);
            }

            .color-group {
                margin-bottom: 1.5rem;
            }
        </style>
	</head>
	<body>
        <h1>Btn Builder</h1>
        <p>Use a <code>a</code> for navigation and a <code>button</code> for actions. Links are for 'going', buttons are for 'doing'.</p>
        <p>So while we call it a button style, it's a visual flair that applies to two different HTML elements.</p>

        <div class="controls space-y-4 max-w-2xl">
            <!-- Save/Reset Controls -->
            <div class="flex gap-2 mb-6">
                <button id="save-styles" class="px-4 py-2 bg-green-500 text-white rounded">Save Styles</button>
                <button id="reset-styles" class="px-4 py-2 bg-red-500 text-white rounded">Reset to Default</button>
                <span id="save-status" class="px-4 py-2 text-sm text-gray-600"></span>
            </div>

            <!-- Background Color -->
            <div class="mb-6">
                <label class="block mb-2 font-semibold">Background Color</label>
                <div class="border rounded p-4" style="max-height: 400px; overflow-y: auto;">
                    <div id="grouped-colors"></div>
                </div>
            </div>

            <!-- Padding Left -->
            <div class="flex items-center gap-2">
                <button id="decrease-pl" class="px-2 py-1 border">-</button>
                <label for="pl-range" class="min-w-[200px]">
                    Padding Left: <span id="pl-value">pl-4</span>
                </label>
                <input
                    type="range"
                    id="pl-range"
                    min="0"
                    step="1"
                    class="flex-1"
                />
                <button id="increase-pl" class="px-2 py-1 border">+</button>
            </div>

            <!-- Padding Right -->
            <div class="flex items-center gap-2">
                <button id="decrease-pr" class="px-2 py-1 border">-</button>
                <label for="pr-range" class="min-w-[200px]">
                    Padding Right: <span id="pr-value">pr-4</span>
                </label>
                <input
                    type="range"
                    id="pr-range"
                    min="0"
                    step="1"
                    class="flex-1"
                />
                <button id="increase-pr" class="px-2 py-1 border">+</button>
            </div>

            <!-- Padding Top -->
            <div class="flex items-center gap-2">
                <button id="decrease-pt" class="px-2 py-1 border">-</button>
                <label for="pt-range" class="min-w-[200px]">
                    Padding Top: <span id="pt-value">pt-2</span>
                </label>
                <input
                    type="range"
                    id="pt-range"
                    min="0"
                    step="1"
                    class="flex-1"
                />
                <button id="increase-pt" class="px-2 py-1 border">+</button>
            </div>

            <!-- Padding Bottom -->
            <div class="flex items-center gap-2">
                <button id="decrease-pb" class="px-2 py-1 border">-</button>
                <label for="p b-range" class="min-w-[200px]">
                    Padding Bottom: <span id="pb-value">pb-2</span>
                </label>
                <input
                    type="range"
                    id="pb-range"
                    min="0"
                    step="1"
                    class="flex-1"
                />
                <button id="increase-pb" class="px-2 py-1 border">+</button>
            </div>
        </div>

        <div class="example mx-auto mt-8 flex justify-center">
            <a id="achilles" href="" class="btn text-white">Hello, world!</a>
        </div>
	</body>
</html>

<script>
    // Read spacing scale dynamically from CSS custom properties
    const spacingNames = ['none', 'xs', 'sm', 'md', 'base', 'lg', '1xl', '2xl', '3xl', '4xl', '5xl', '6xl', '7xl', '8xl', '9xl'];
    const spacingScale: Array<{ name: string, var: string, px: number }> = [];

    spacingNames.forEach(name => {
        const varName = `--spacing-${name}`;
        const value = getComputedStyle(document.documentElement).getPropertyValue(varName).trim();
        const px = parseInt(value);

        if (!isNaN(px)) {
            spacingScale.push({ name, var: varName, px });
        }
    });

    console.log('Spacing scale loaded:', spacingScale);

    // Map to Tailwind reference for display (approximate)
    const pxToTailwind: Record<number, string> = {
        0: '0', 4: '1', 8: '2', 12: '3', 16: '4', 20: '5', 24: '6', 32: '8',
        40: '10', 48: '12', 64: '16', 80: '20', 96: '24', 128: '32', 160: '40'
    };

    const btn = document.getElementById('achilles') as HTMLElement;

    // Define defaults (these are your design system defaults)
    const DEFAULTS = {
        'pl': 4,  // base (16px)
        'pr': 4,  // base (16px)
        'pt': 2,  // sm (8px)
        'pb': 2,  // sm (8px)
    };

    const STORAGE_KEY = 'achilles-button-styles';

    // Map side to CSS custom property
    const sideToCSSVar: Record<string, string> = {
        'pl': '--achilles-padding-left',
        'pr': '--achilles-padding-right',
        'pt': '--achilles-padding-top',
        'pb': '--achilles-padding-bottom',
    };

    // Load saved styles from localStorage or use defaults
    const loadSavedStyles = (): Record<string, number> => {
        const saved = localStorage.getItem(STORAGE_KEY);
        if (saved) {
            try {
                return JSON.parse(saved);
            } catch (e) {
                console.error('Failed to parse saved styles', e);
            }
        }
        return { ...DEFAULTS };
    };

    // Save current styles to localStorage
    const saveStyles = () => {
        const currentIndices: Record<string, number> = {};
        sides.forEach(side => {
            const range = document.getElementById(`${side}-range`) as HTMLInputElement;
            if (range) {
                currentIndices[side] = parseInt(range.value);
            }
        });
        localStorage.setItem(STORAGE_KEY, JSON.stringify(currentIndices));

        const status = document.getElementById('save-status');
        if (status) {
            status.textContent = '✓ Saved!';
            setTimeout(() => status.textContent = '', 2000);
        }
    };

    // Reset to defaults
    const resetToDefaults = () => {
        localStorage.removeItem(STORAGE_KEY);
        sides.forEach(side => {
            const range = document.getElementById(`${side}-range`) as HTMLInputElement;
            if (range) {
                range.value = DEFAULTS[side].toString();
                range.dispatchEvent(new Event('input'));
            }
        });

        const status = document.getElementById('save-status');
        if (status) {
            status.textContent = '✓ Reset to defaults!';
            setTimeout(() => status.textContent = '', 2000);
        }
    };

    // Helper function to update CSS variables on :root
    const updateRootVariable = (varName: string, value: string) => {
        document.documentElement.style.setProperty(varName, value);
        console.log(`Updated ${varName} to ${value}`);
    };

    // Initialize all range inputs
    const sides = ['pl', 'pr', 'pt', 'pb'] as const;
    const defaultIndices = loadSavedStyles();

    sides.forEach(side => {
        const range = document.getElementById(`${side}-range`) as HTMLInputElement;
        const valueSpan = document.getElementById(`${side}-value`);
        const decreaseBtn = document.getElementById(`decrease-${side}`);
        const increaseBtn = document.getElementById(`increase-${side}`);

        if (range) {
            range.max = (spacingScale.length - 1).toString();
            range.value = defaultIndices[side].toString();
        }

        // Range input handler
        range?.addEventListener('input', (e) => {
            const target = e.target as HTMLInputElement;
            const index = parseInt(target.value);
            const spacing = spacingScale[index];
            const tailwindRef = pxToTailwind[spacing.px] || spacing.px.toString();

            // Update CSS custom property in the :root rule
            updateRootVariable(sideToCSSVar[side], `var(${spacing.var})`);

            // Update display with spacing name and Tailwind reference
            if (valueSpan) {
                valueSpan.textContent = `${spacing.name} (${spacing.px}px ≈ ${side}-${tailwindRef})`;
            }
        });

        // Decrease button
        decreaseBtn?.addEventListener('click', () => {
            if (range) {
                const currentValue = parseInt(range.value);
                const newValue = Math.max(0, currentValue - 1);
                range.value = newValue.toString();
                range.dispatchEvent(new Event('input'));
            }
        });

        // Increase button
        increaseBtn?.addEventListener('click', () => {
            if (range) {
                const currentValue = parseInt(range.value);
                const newValue = Math.min(spacingScale.length - 1, currentValue + 1);
                range.value = newValue.toString();
                range.dispatchEvent(new Event('input'));
            }
        });

        // Initialize display on page load
        range?.dispatchEvent(new Event('input'));
    });

    // Generate grouped color swatches (Figma-style)
    const colorFamilies = ['red', 'orange', 'amber', 'yellow', 'lime', 'green', 'emerald', 'teal', 'cyan', 'sky', 'blue', 'indigo', 'violet', 'purple', 'fuchsia', 'pink', 'rose', 'slate', 'gray', 'zinc', 'neutral', 'stone'];
    const shades = ['50', '100', '200', '300', '400', '500', '600', '700', '800', '900', '950'];

    const groupedColorsContainer = document.getElementById('grouped-colors');

    if (groupedColorsContainer) {
        colorFamilies.forEach(family => {
            const groupDiv = document.createElement('div');
            groupDiv.className = 'color-group mb-4';

            const labelDiv = document.createElement('div');
            labelDiv.className = 'text-sm font-semibold mb-2 capitalize';
            labelDiv.textContent = family;

            const shadesDiv = document.createElement('div');
            shadesDiv.className = 'flex gap-1 flex-wrap';

            shades.forEach(shade => {
                const colorVar = `--color-${family}-${shade}`;
                const swatchDiv = document.createElement('div');
                swatchDiv.className = 'color-swatch';

                // Check if this should be the default selected (blue-500)
                const isDefault = family === 'blue' && shade === '500';

                swatchDiv.innerHTML = `
                    <input type="radio" name="bg-color" value="${colorVar}" id="grouped-${family}-${shade}" ${isDefault ? 'checked' : ''} />
                    <label for="grouped-${family}-${shade}"
                           style="background: var(${colorVar});"
                           title="${family}-${shade}">
                    </label>
                `;

                const radio = swatchDiv.querySelector('input') as HTMLInputElement;
                radio.addEventListener('change', () => {
                    // Update the CSS custom property in the :root rule
                    updateRootVariable('--achilles-bg-color', `var(${colorVar})`);
                    console.log(`Updated background color to ${colorVar}`);
                });

                shadesDiv.appendChild(swatchDiv);
            });

            groupDiv.appendChild(labelDiv);
            groupDiv.appendChild(shadesDiv);
            groupedColorsContainer.appendChild(groupDiv);
        });
    }

    // Wire up save and reset buttons
    document.getElementById('save-styles')?.addEventListener('click', saveStyles);
    document.getElementById('reset-styles')?.addEventListener('click', resetToDefaults);

    // Show saved indicator on page load if there are saved styles
    const hasSavedStyles = localStorage.getItem(STORAGE_KEY) !== null;
    if (hasSavedStyles) {
        const status = document.getElementById('save-status');
        if (status) {
            status.textContent = '(using saved styles)';
        }
    }
</script>
