---
import "~styles/styles.css";
---

<style is:global>
    /* Canvas */
    #canvas {
        background-image: linear-gradient(
                to right,
                rgba(0, 0, 0, 0.05) 1px,
                transparent 1px
            ),
            linear-gradient(to bottom, rgba(0, 0, 0, 0.05) 1px, transparent 1px);
        background-size: 16px 16px;
    }

    /* Droppable containers */
    .droppable-container {
        position: relative;
        transition:
            outline 100ms ease-out,
            outline-offset 100ms ease-out;
        min-height: 50px;
    }

    .droppable-container.drag-over {
        outline: 1px solid #3b82f6;
        outline-offset: 2px;
        background-color: rgba(59, 130, 246, 0.05);
    }

    /* Blue line appears between sections */
    .drop-indicator {
        position: absolute;
        height: 3px;
        background: #3b82f6;
        left: 0;
        right: 0;
        pointer-events: none;
        z-index: 100;
    }

    /* Hide the empty canvas text when we have the button */
    #canvas:empty::after {
        content: none;
    }
    /*
    .droppable-container:empty::after {
        content: "Drop Section/s here";
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100px;
        color: #9ca3af;
        font-style: italic;
        font-size: 14px;
    } */

    /* Selected element */
    .selected {
        outline: 1px solid #3b82f6 !important;
        outline-offset: 2px;
    }

    /* Section insertion triggers */
    .add-section-trigger {
        position: relative;
        z-index: 10;
        cursor: pointer;
        opacity: 0;
        transition: opacity 0.25s ease;
    }

    .add-section-trigger:hover,
    .add-section-trigger.nearby {
        opacity: 1;
    }

    .add-section-trigger::before {
        content: "";
        position: absolute;
        left: 0;
        right: 0;
        top: 50%;
        transform: translateY(-50%);
        height: 2px;
        background: var(--color-blue-500);
    }

    .add-section-trigger:hover::before {
        background: linear-gradient(
            to right,
            transparent,
            #3b82f6 20%,
            #3b82f6 80%,
            transparent
        );
    }

    .add-section-bubble {
        position: absolute;
        left: 50%;
        top: 50%;
        transform: translate(-50%, -50%);
        background: white;
        border: 2px solid #cbd5e1;
        color: #64748b;
        padding: 4px 12px;
        border-radius: 12px;
        font-size: 12px;
        font-weight: 500;
        white-space: nowrap;
        transition: all 0.2s;
        pointer-events: none;
    }

    .add-section-trigger:hover .add-section-bubble {
        border-color: #3b82f6;
        color: #3b82f6;
        transform: translate(-50%, -50%) scale(1.05);
    }

    /* Big centered button for empty canvas */
    .add-section-empty {
        opacity: 1;
        height: auto;
        margin: 100px auto;
    }

    .add-section-empty::before {
        display: none;
    }

    .add-section-empty .add-section-bubble {
        position: static;
        transform: none;
        padding: 16px 32px;
        font-size: 16px;
        border-color: #3b82f6;
        color: #3b82f6;
        pointer-events: auto;
    }

    .add-section-empty:hover .add-section-bubble {
        background: #3b82f6;
        color: white;
    }

    /* Section labels */
    .section-label {
        font-size: 10px;
        color: #94a3b8;
        writing-mode: vertical-rl;
        text-orientation: mixed;
        white-space: nowrap;
        padding: 4px 0;
        cursor: pointer;
        transition: color 0.2s;
        user-select: none;
    }

    .section-label:hover {
        color: #3b82f6;
    }

    .section-label.active {
        color: #3b82f6;
        font-weight: 600;
    }

    /* Palette items */
    .palette-item {
        cursor: grab;
        transition: all 0.2s;
    }

    .palette-item:hover {
        background-color: #e5e7eb !important;
        border-color: #9ca3af !important;
    }

    .palette-item:active {
        cursor: grabbing;
    }

    /* Properties panel field visibility */
    [data-show-for] {
        display: none;
    }

    /* Add to your <style> block in canvas.astro */
</style>

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
        <title>Visual Page Builder - MVP</title>
    </head>
    <body class="bg-gray-50">
        <!-- Left Sidebar - Palette -->
        <div
            class="fixed left-0 top-0 w-64 h-screen bg-white border-r border-gray-300 p-4 overflow-y-auto"
        >
            <h1 class="text-2xl font-bold mb-4">Elements</h1>

            <!-- Layout Elements -->
            <div class="mb-6">
                <h3 class="text-sm font-semibold text-gray-600 mb-2 uppercase">
                    Layout
                </h3>
                <div class="space-y-2">
                    <div
                        class="palette-item p-3 bg-gray-100 border border-gray-300 rounded text-sm text-center"
                        data-element-type="section"
                        data-drag-type="element"
                        draggable="true"
                    >
                        Section
                    </div>
                    <div
                        class="palette-item p-3 bg-gray-100 border border-gray-300 rounded text-sm text-center"
                        data-element-type="div"
                        data-drag-type="element"
                        draggable="true"
                    >
                        Div
                    </div>
                    <div
                        class="palette-item p-3 bg-gray-100 border border-gray-300 rounded text-sm text-center"
                        data-element-type="header"
                        data-drag-type="element"
                        draggable="true"
                    >
                        Header
                    </div>
                    <div
                        class="palette-item p-3 bg-gray-100 border border-gray-300 rounded text-sm text-center"
                        data-element-type="footer"
                        data-drag-type="element"
                        draggable="true"
                    >
                        Footer
                    </div>
                </div>
            </div>

            <!-- Text Elements -->
            <div class="mb-6">
                <h3 class="text-sm font-semibold text-gray-600 mb-2 uppercase">
                    Text
                </h3>
                <div class="space-y-2">
                    <div
                        class="palette-item p-3 bg-gray-100 border border-gray-300 rounded text-sm text-center"
                        data-element-type="h1"
                        data-drag-type="element"
                        draggable="true"
                    >
                        Heading
                    </div>
                    <div
                        class="palette-item p-3 bg-gray-100 border border-gray-300 rounded text-sm text-center"
                        data-element-type="p"
                        data-drag-type="element"
                        draggable="true"
                    >
                        Paragraph
                    </div>
                    <div
                        class="palette-item p-3 bg-gray-100 border border-gray-300 rounded text-sm text-center"
                        data-element-type="a"
                        data-drag-type="element"
                        draggable="true"
                    >
                        Link
                    </div>
                </div>
            </div>

            <!-- Actions -->
            <div class="mt-8 pt-4 border-t border-gray-300">
                <button
                    id="save-btn"
                    class="w-full bg-blue-500 text-white px-4 py-2 rounded hover:bg-blue-600 transition-colors mb-2"
                >
                    Save
                </button>
                <button
                    id="export-btn"
                    class="w-full bg-gray-500 text-white px-4 py-2 rounded hover:bg-gray-600 transition-colors mb-2"
                >
                    Export HTML
                </button>
                <button
                    id="reset-btn"
                    class="w-full bg-red-500 text-white px-4 py-2 rounded hover:bg-red-600 transition-colors"
                >
                    Reset canvas
                </button>
            </div>
        </div>

        <!-- Main Canvas Area -->
        <div class="ml-64 mr-64 p-8 relative">
            <!-- Section Labels (left of canvas) -->
            <div
                id="section-labels"
                class="absolute left-0 top-0 w-8 pt-0"
                style="transform: translateX(-40px);"
            >
            </div>

            <div
                id="canvas"
                class="droppable-container min-h-[600px] w-full bg-white shadow-lg border border-gray-300 relative"
            >
            </div>
        </div>

        <!-- Right Sidebar - Properties Panel -->
        <div
            id="properties-panel"
            class="fixed right-0 top-0 w-64 h-screen bg-white border-l border-gray-300 p-4 overflow-y-auto hidden"
        >
            <h3 class="text-lg font-bold mb-4">Properties</h3>
            <p class="text-sm text-gray-500 mb-4" id="selected-element-label">
                Select an element to edit
            </p>

            <!-- Layout (only for containers) -->
            <div class="mb-4" data-show-for="div,section,header,footer">
                <label class="block text-sm font-medium mb-1">Layout</label>
                <select
                    id="prop-layout"
                    class="w-full border border-gray-300 rounded p-2 text-sm"
                >
                    <option value="">Block</option>
                    <option value="flex flex-col gap-4">Flex Vertical</option>
                    <option value="flex flex-row gap-4">Flex Horizontal</option>
                    <option value="grid grid-cols-2 gap-4"
                        >Grid 2 Columns</option
                    >
                </select>
            </div>

            <!-- Padding -->
            <div class="mb-4">
                <label class="block text-sm font-medium mb-1">Padding</label>
                <select
                    id="prop-padding"
                    class="w-full border border-gray-300 rounded p-2 text-sm"
                >
                    <option value="">None</option>
                    <option value="p-2">XSmall (8px)</option>
                    <option value="p-4">Small (16px)</option>
                    <option value="p-6">Medium (24px)</option>
                    <option value="p-8">Large (32px)</option>
                    <option value="p-12">XLarge (48px)</option>
                    <option value="p-16">XXLarge (64px)</option>
                </select>
            </div>

            <!-- Background Color -->
            <div class="mb-4">
                <label class="block text-sm font-medium mb-1">Background</label>
                <select
                    id="prop-bg"
                    class="w-full border border-gray-300 rounded p-2 text-sm"
                >
                    <option value="">None</option>
                    <option value="bg-white">White</option>
                    <option value="bg-gray-50">Gray 50</option>
                    <option value="bg-gray-100">Gray 100</option>
                    <option value="bg-gray-200">Gray 200</option>
                    <option value="bg-blue-50">Blue 50</option>
                    <option value="bg-blue-100">Blue 100</option>
                    <option value="bg-blue-500">Blue 500</option>
                    <option value="bg-red-50">Red 50</option>
                    <option value="bg-red-100">Red 100</option>
                    <option value="bg-red-500">Red 500</option>
                </select>
            </div>

            <!-- Border Radius -->
            <div class="mb-4">
                <label class="block text-sm font-medium mb-1"
                    >Border Radius</label
                >
                <select
                    id="prop-radius"
                    class="w-full border border-gray-300 rounded p-2 text-sm"
                >
                    <option value="">None</option>
                    <option value="rounded">Small (4px)</option>
                    <option value="rounded-md">Medium (6px)</option>
                    <option value="rounded-lg">Large (8px)</option>
                    <option value="rounded-xl">XLarge (12px)</option>
                    <option value="rounded-full">Full (Circle)</option>
                </select>
            </div>

            <!-- Text Content (only for text elements) -->
            <div class="mb-4" data-show-for="h1,h2,p,a,span">
                <label class="block text-sm font-medium mb-1"
                    >Text Content</label
                >
                <input
                    type="text"
                    id="prop-text"
                    class="w-full border border-gray-300 rounded p-2 text-sm"
                    placeholder="Enter text..."
                />
            </div>

            <!-- Delete Button -->
            <div class="mt-8 pt-4 border-t border-gray-300">
                <button
                    id="delete-btn"
                    class="w-full bg-red-500 text-white px-4 py-2 rounded hover:bg-red-600 transition-colors"
                >
                    Delete Element
                </button>
            </div>
        </div>

        <!-- Export Modal (hidden by default) -->
        <div
            id="export-modal"
            class="fixed inset-0 bg-black bg-opacity-50 items-center justify-center hidden z-50"
        >
            <div
                class="bg-white rounded-lg p-6 max-w-2xl w-full mx-4 max-h-[80vh] overflow-y-auto"
            >
                <div class="flex justify-between items-center mb-4">
                    <h2 class="text-xl font-bold">Export HTML</h2>
                    <button
                        id="close-modal"
                        class="text-gray-500 hover:text-gray-700 text-2xl"
                    >
                        &times;
                    </button>
                </div>
                <pre
                    id="export-output"
                    class="bg-gray-100 p-4 rounded border border-gray-300 text-sm overflow-x-auto"><code><!-- HTML will appear here --></code></pre>
                <button
                    id="copy-html-btn"
                    class="mt-4 w-full bg-blue-500 text-white px-4 py-2 rounded hover:bg-blue-600 transition-colors"
                >
                    Copy to Clipboard
                </button>
            </div>
        </div>
    </body>
</html>

<script>
    interface DragData {
        type: "element";
        elementType: string;
    }

    interface Element {
        id: string;
        tag: string;
        classes: string[];
        textContent?: string;
        children: Element[];
        attributes?: Record<string, string>;
    }

    interface CanvasState {
        version: string;
        elements: Element[];
    }

    let draggedData: DragData | null = null;
    let selectedElement: HTMLElement | null = null;
    let saveTimeout: ReturnType<typeof setTimeout>;
    let dropPosition: "above" | "below" | "inside" | null = null;
    let dropTargetElement: HTMLElement | null = null; // Track which element we're dropping on
    let dropIndicator: HTMLElement | null = null;
    let sectionCounter = 0;

    const canvas = document.getElementById("canvas");
    const propertiesPanel = document.getElementById("properties-panel");
    const sectionLabelsContainer = document.getElementById("section-labels");

    // Generate human-readable section names
    const sectionNames = [
        "Hero",
        "Features",
        "About",
        "Services",
        "Testimonials",
        "Pricing",
        "Team",
        "Contact",
        "Footer",
        "Header",
        "Gallery",
        "Blog",
        "FAQ",
        "CTA",
        "Stats",
    ];

    function generateSectionName(): string {
        const name = sectionNames[sectionCounter % sectionNames.length];
        const suffix = Math.floor(sectionCounter / sectionNames.length);
        sectionCounter++;
        return suffix > 0 ? `${name} ${suffix + 1}` : name;
    }

    // State Manager
    class StateManager {
        private storageKey = "canvas-state";

        save(state: CanvasState) {
            try {
                localStorage.setItem(this.storageKey, JSON.stringify(state));
                console.log("State saved");
            } catch (e) {
                console.error("Failed to save state:", e);
            }
        }

        load(): CanvasState | null {
            try {
                const saved = localStorage.getItem(this.storageKey);
                if (!saved) return null;
                return JSON.parse(saved);
            } catch (e) {
                console.error("Failed to load state:", e);
                return null;
            }
        }

        serializeElement(element: HTMLElement): Element {
            return {
                id: element.dataset.elementId || crypto.randomUUID(),
                tag: element.tagName.toLowerCase(),
                classes: Array.from(element.classList).filter(
                    (c) =>
                        c !== "droppable-container" &&
                        c !== "selected" &&
                        c !== "drag-over",
                ),
                textContent:
                    element.childNodes.length === 1 &&
                    element.childNodes[0].nodeType === Node.TEXT_NODE
                        ? element.textContent || undefined
                        : undefined,
                attributes: this.getAttributes(element),
                children: Array.from(element.children).map((child) =>
                    this.serializeElement(child as HTMLElement),
                ),
            };
        }

        private getAttributes(
            element: HTMLElement,
        ): Record<string, string> | undefined {
            const attrs: Record<string, string> = {};
            const skip = ["class", "style", "data-element-id"];

            // Always include data-section-name if it exists
            if (element.dataset.sectionName) {
                attrs["data-section-name"] = element.dataset.sectionName;
            }

            Array.from(element.attributes).forEach((attr) => {
                if (
                    !skip.includes(attr.name) &&
                    attr.name !== "data-section-name"
                ) {
                    attrs[attr.name] = attr.value;
                }
            });

            return Object.keys(attrs).length > 0 ? attrs : undefined;
        }

        deserializeElement(data: Element): HTMLElement {
            const el = document.createElement(data.tag);
            el.dataset.elementId = data.id;

            if (data.classes.length > 0) {
                el.className = data.classes.join(" ");
            }

            if (data.attributes) {
                Object.entries(data.attributes).forEach(([key, val]) => {
                    el.setAttribute(key, val);
                });
            }

            if (data.textContent && data.children.length === 0) {
                el.textContent = data.textContent;
            }

            data.children.forEach((childData) => {
                const childEl = this.deserializeElement(childData);
                el.appendChild(childEl);
            });

            // Make it interactive
            const containerTags = [
                "div",
                "section",
                "header",
                "footer",
                "main",
                "nav",
                "aside",
            ];
            if (containerTags.includes(data.tag)) {
                el.classList.add("droppable-container");
                setupDroppable(el);
            }

            // Make text elements editable
            if (["h1", "h2", "p", "a", "span"].includes(data.tag)) {
                el.contentEditable = "true";
                el.addEventListener("input", () => {
                    autoSave();
                });
            }

            makeSelectable(el);

            return el;
        }

        captureState(): CanvasState {
            if (!canvas) return { version: "1.0", elements: [] };

            // Filter out the add-section-trigger buttons before serializing
            const elements: Element[] = Array.from(canvas.children)
                .filter(
                    (child) => !child.classList.contains("add-section-trigger"),
                )
                .map((child) => this.serializeElement(child as HTMLElement));

            return {
                version: "1.0",
                elements,
            };
        }

        restoreState(state: CanvasState) {
            if (!canvas) return;

            canvas.innerHTML = "";

            state.elements.forEach((elementData) => {
                const el = this.deserializeElement(elementData);
                canvas.appendChild(el);
            });

            updateSectionUI();
        }
    }

    const stateManager = new StateManager();

    // Auto-save with debounce
    function autoSave() {
        clearTimeout(saveTimeout);
        saveTimeout = setTimeout(() => {
            const state = stateManager.captureState();
            stateManager.save(state);
        }, 1000);
    }

    // Element Factory
    function createElement(elementType: string): HTMLElement {
        const el = document.createElement(elementType);
        el.dataset.elementId = crypto.randomUUID();

        switch (elementType) {
            case "section":
                el.className =
                    "w-full p-8 min-h-[200px] border border-dashed border-gray-300";
                el.dataset.sectionName = generateSectionName();
                break;
            case "div":
                el.className =
                    "min-h-[100px] border border-dashed border-gray-300";
                break;
            case "header":
                el.className = "w-full bg-gray-100 border-b border-gray-300";
                break;
            case "footer":
                el.className = "w-full bg-gray-100 border-t border-gray-300";
                break;
            case "h1":
                el.className = "text-4xl font-bold";
                el.textContent = "Heading";
                break;
            case "p":
                el.className = "text-base";
                el.textContent = "Paragraph text goes here.";
                break;
            case "a":
                el.className = "text-blue-500 underline";
                el.textContent = "Link";
                el.setAttribute("href", "#");
                break;
        }

        if (["h1", "p", "a"].includes(elementType)) {
            el.contentEditable = "true";
            el.addEventListener("input", () => {
                autoSave(); // Triggers 1 second after typing stops
            });
        }

        const containerTags = ["div", "section", "header", "footer"];
        if (containerTags.includes(elementType)) {
            el.classList.add("droppable-container");
            setupDroppable(el);
        }

        makeSelectable(el);

        return el;
    }

    // Update section labels in the left gutter
    function updateSectionLabels() {
        if (!sectionLabelsContainer || !canvas) return;

        sectionLabelsContainer.innerHTML = "";
        const sections = Array.from(canvas.querySelectorAll("section"));

        sections.forEach((section) => {
            const sectionName = section.dataset.sectionName || "Section";
            const rect = section.getBoundingClientRect();
            const canvasRect = canvas.getBoundingClientRect();
            const offsetTop = rect.top - canvasRect.top;

            const label = document.createElement("div");
            label.className = "section-label";
            label.textContent = sectionName;
            label.style.position = "absolute";
            label.style.top = `${offsetTop}px`;
            label.style.height = `${rect.height}px`;
            label.dataset.sectionId = section.dataset.elementId;

            // Click to select section
            label.addEventListener("click", () => {
                selectElement(section as HTMLElement);
            });

            // Highlight when section is selected
            if (section === selectedElement) {
                label.classList.add("active");
            }

            sectionLabelsContainer.appendChild(label);
        });
    }

    // Update both section UI elements together
    function updateSectionUI() {
        updateSectionTriggers();
        updateSectionLabels();
    }

    // Create a section trigger with bubble
    function createSectionTrigger(
        onClick: () => void,
        isEmpty: boolean = false,
    ): HTMLDivElement {
        const trigger = document.createElement("div");
        trigger.className = isEmpty
            ? "add-section-trigger add-section-empty"
            : "add-section-trigger add-section-divider";

        const bubble = document.createElement("div");
        bubble.className = "add-section-bubble";
        bubble.textContent = "+ Add Section";

        trigger.appendChild(bubble);
        trigger.onclick = onClick;

        return trigger;
    }

    // Update section insertion triggers based on current canvas state
    function updateSectionTriggers() {
        if (!canvas) return;

        // Remove all existing triggers
        canvas
            .querySelectorAll(".add-section-trigger")
            .forEach((el) => el.remove());

        const sections = Array.from(canvas.querySelectorAll("section"));

        if (sections.length === 0) {
            // Empty canvas - show big centered button
            const emptyBtn = createSectionTrigger(() => {
                const newSection = createElement("section");
                canvas.appendChild(newSection);
                autoSave();
                updateSectionUI();
            }, true);
            canvas.appendChild(emptyBtn);
        } else {
            // Add trigger at top of canvas
            const topBtn = createSectionTrigger(() => {
                const newSection = createElement("section");
                canvas.insertBefore(newSection, canvas.firstChild);
                autoSave();
                updateSectionUI();
            });
            canvas.insertBefore(topBtn, canvas.firstChild);

            // Add trigger after each section (except last)
            sections.forEach((section, index) => {
                if (index < sections.length - 1) {
                    const dividerBtn = createSectionTrigger(() => {
                        const newSection = createElement("section");
                        section.insertAdjacentElement("afterend", newSection);
                        autoSave();
                        updateSectionUI();
                    });
                    section.insertAdjacentElement("afterend", dividerBtn);
                }
            });

            // Add trigger at bottom of canvas
            const bottomBtn = createSectionTrigger(() => {
                const newSection = createElement("section");
                canvas.appendChild(newSection);
                autoSave();
                updateSectionUI();
            });
            canvas.appendChild(bottomBtn);
        }
    }

    // Show/hide drop indicator
    function showIndicator(yPosition: number) {
        if (!dropIndicator) {
            dropIndicator = document.createElement("div");
            dropIndicator.className = "drop-indicator";
            document.body.appendChild(dropIndicator);
        }
        dropIndicator.style.top = yPosition + "px";
        dropIndicator.style.display = "block";
    }

    function hideIndicator() {
        if (dropIndicator) {
            dropIndicator.style.display = "none";
        }
    }

    // Setup droppable
    function setupDroppable(element: HTMLElement) {
        element.addEventListener("dragover", (ev) => {
            ev.preventDefault();
            ev.stopPropagation();

            // Track which element we're targeting
            dropTargetElement = element;

            // Only sections support above/below insertion
            if (element.tagName.toLowerCase() !== "section") {
                element.classList.add("drag-over");
                dropPosition = "inside";
                hideIndicator();
                return;
            }

            // Calculate drop zone for sections
            const rect = element.getBoundingClientRect();
            const mouseY = ev.clientY;
            const threshold = rect.height * 0.25; // 25% top/bottom

            if (mouseY < rect.top + threshold) {
                dropPosition = "above";
                showIndicator(rect.top);
                element.classList.remove("drag-over");
            } else if (mouseY > rect.bottom - threshold) {
                dropPosition = "below";
                showIndicator(rect.bottom);
                element.classList.remove("drag-over");
            } else {
                dropPosition = "inside";
                element.classList.add("drag-over");
                hideIndicator();
            }
        });

        element.addEventListener("dragleave", (ev) => {
            const rect = element.getBoundingClientRect();
            const x = ev.clientX;
            const y = ev.clientY;

            if (
                x <= rect.left ||
                x >= rect.right ||
                y <= rect.top ||
                y >= rect.bottom
            ) {
                element.classList.remove("drag-over");
                hideIndicator();
                dropTargetElement = null;
            }
        });

        element.addEventListener("drop", (ev) => {
            ev.preventDefault();
            ev.stopPropagation();
            element.classList.remove("drag-over");
            hideIndicator();

            handleDrop(ev, element);
        });
    }

    // Make element selectable
    function makeSelectable(element: HTMLElement) {
        element.addEventListener("click", (e) => {
            e.stopPropagation();
            selectElement(element);
        });
    }

    // Select element
    function selectElement(element: HTMLElement) {
        selectedElement = element;

        document.querySelectorAll(".selected").forEach((el) => {
            el.classList.remove("selected");
        });
        element.classList.add("selected");

        propertiesPanel!.classList.remove("hidden");
        updatePropertiesPanel(element);
        updateSectionLabels(); // Update label highlighting

        console.log("Selected:", element.tagName, element);
    }

    // Update properties panel
    function updatePropertiesPanel(element: HTMLElement) {
        const tag = element.tagName.toLowerCase();
        const label = document.getElementById("selected-element-label");
        if (label) {
            if (tag === "section" && element.dataset.sectionName) {
                label.textContent = `Editing: ${element.dataset.sectionName}`;
            } else {
                label.textContent = `Editing: <${tag}>`;
            }
        }

        // Show/hide fields based on element type
        document.querySelectorAll("[data-show-for]").forEach((field) => {
            const htmlField = field as HTMLElement;
            const showFor = htmlField.dataset.showFor?.split(",") || [];
            if (showFor.includes(tag)) {
                htmlField.style.display = "block";
            } else {
                htmlField.style.display = "none";
            }
        });

        // Populate current values
        const layoutSelect = document.getElementById(
            "prop-layout",
        ) as HTMLSelectElement;
        if (element.classList.contains("flex")) {
            if (element.classList.contains("flex-col")) {
                layoutSelect.value = "flex flex-col gap-4";
            } else {
                layoutSelect.value = "flex flex-row gap-4";
            }
        } else if (element.classList.contains("grid")) {
            layoutSelect.value = "grid grid-cols-2 gap-4";
        } else {
            layoutSelect.value = "";
        }

        // Padding
        const paddingSelect = document.getElementById(
            "prop-padding",
        ) as HTMLSelectElement;
        const paddingClass = Array.from(element.classList).find((c) =>
            c.startsWith("p-"),
        );
        paddingSelect.value = paddingClass || "";

        // Background
        const bgSelect = document.getElementById(
            "prop-bg",
        ) as HTMLSelectElement;
        const bgClass = Array.from(element.classList).find((c) =>
            c.startsWith("bg-"),
        );
        bgSelect.value = bgClass || "";

        // Border Radius
        const radiusSelect = document.getElementById(
            "prop-radius",
        ) as HTMLSelectElement;
        const radiusClass = Array.from(element.classList).find((c) =>
            c.startsWith("rounded"),
        );
        radiusSelect.value = radiusClass || "";

        // Text Content
        const textInput = document.getElementById(
            "prop-text",
        ) as HTMLInputElement;
        if (textInput) {
            textInput.value = element.textContent || "";
        }
    }

    // Drag start handler
    function handlePaletteDragStart(ev: DragEvent) {
        const target = ev.currentTarget as HTMLElement;
        const elementType = target.dataset.elementType;

        if (!elementType) return;

        draggedData = {
            type: "element",
            elementType,
        };

        ev.dataTransfer!.effectAllowed = "copy";
        console.log("Drag started:", draggedData);
    }

    // Drop handler
    function handleDrop(ev: DragEvent, dropTarget: HTMLElement) {
        if (!draggedData) return;

        const newElement = createElement(draggedData.elementType);

        // Use the tracked target element if available (fixes multi-section bug)
        const targetElement = dropTargetElement || dropTarget;

        if (dropPosition === "above") {
            targetElement.insertAdjacentElement("beforebegin", newElement);
        } else if (dropPosition === "below") {
            targetElement.insertAdjacentElement("afterend", newElement);
        } else {
            targetElement.appendChild(newElement);
        }

        console.log(
            "Dropped:",
            draggedData.elementType,
            "position:",
            dropPosition,
        );

        dropPosition = null;
        dropTargetElement = null;
        hideIndicator();
        autoSave();
        updateSectionUI();
    }

    // Wire up palette items
    document.querySelectorAll('[draggable="true"]').forEach((item) => {
        item.addEventListener(
            "dragstart",
            handlePaletteDragStart as EventListener,
        );
    });

    // Setup canvas
    if (canvas) {
        setupDroppable(canvas);

        canvas.addEventListener("click", (e) => {
            if (e.target === canvas) {
                selectedElement = null;
                document.querySelectorAll(".selected").forEach((el) => {
                    el.classList.remove("selected");
                });
                propertiesPanel!.classList.add("hidden");
            }
        });
    }

    // Properties panel event listeners
    document.getElementById("prop-layout")?.addEventListener("change", (e) => {
        if (!selectedElement) return;

        const value = (e.target as HTMLSelectElement).value;

        // Remove old layout classes
        selectedElement.classList.remove(
            "flex",
            "flex-row",
            "flex-col",
            "grid",
            "grid-cols-2",
            "gap-4",
        );

        // Add new layout classes
        if (value) {
            const classes = value.split(" ");
            selectedElement.classList.add(...classes);
        }

        autoSave();
    });

    document.getElementById("prop-padding")?.addEventListener("change", (e) => {
        if (!selectedElement) return;

        const value = (e.target as HTMLSelectElement).value;

        // Remove old padding classes
        Array.from(selectedElement.classList).forEach((c) => {
            if (c.startsWith("p-")) {
                selectedElement!.classList.remove(c);
            }
        });

        // Add new padding class
        if (value) {
            selectedElement.classList.add(value);
        }

        autoSave();
    });

    document.getElementById("prop-bg")?.addEventListener("change", (e) => {
        if (!selectedElement) return;

        const value = (e.target as HTMLSelectElement).value;

        // Remove old background classes
        Array.from(selectedElement.classList).forEach((c) => {
            if (c.startsWith("bg-")) {
                selectedElement!.classList.remove(c);
            }
        });

        // Add new background class
        if (value) {
            selectedElement.classList.add(value);
        }

        autoSave();
    });

    document.getElementById("prop-radius")?.addEventListener("change", (e) => {
        if (!selectedElement) return;

        const value = (e.target as HTMLSelectElement).value;

        // Remove old radius classes
        Array.from(selectedElement.classList).forEach((c) => {
            if (c.startsWith("rounded")) {
                selectedElement!.classList.remove(c);
            }
        });

        // Add new radius class
        if (value) {
            selectedElement.classList.add(value);
        }

        autoSave();
    });

    document.getElementById("prop-text")?.addEventListener("input", (e) => {
        if (!selectedElement) return;

        const value = (e.target as HTMLInputElement).value;
        selectedElement.textContent = value;

        autoSave();
    });

    // Delete button
    document.getElementById("delete-btn")?.addEventListener("click", () => {
        if (!selectedElement) return;

        selectedElement.remove();
        selectedElement = null;
        propertiesPanel!.classList.add("hidden");

        autoSave();
        updateSectionUI();
    });

    // Reset button
    document.getElementById("reset-btn")?.addEventListener("click", () => {
        // if (!selectedElement) return;
        if (!canvas) return;

        canvas.replaceChildren();

        // selectedElement.remove();
        // selectedElement = null;
        // propertiesPanel!.classList.add("hidden");

        autoSave();
        updateSectionUI();
    });

    // Save button
    document.getElementById("save-btn")?.addEventListener("click", () => {
        const state = stateManager.captureState();
        stateManager.save(state);
        alert("Saved!");
    });

    // Export button
    document.getElementById("export-btn")?.addEventListener("click", () => {
        // Clone canvas and remove trigger buttons before export
        const canvasClone = canvas?.cloneNode(true) as HTMLElement;
        canvasClone
            ?.querySelectorAll(".add-section-trigger")
            .forEach((el) => el.remove());

        const html = canvasClone?.innerHTML || "";
        const modal = document.getElementById("export-modal");
        const output = document.getElementById("export-output");

        if (output) {
            output.textContent = `<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <script src="https://cdn.tailwindcss.com"><\/script>
  <title>Exported Page</title>
</head>
<body>
${html}
</body>
</html>`;
        }

        modal?.classList.remove("hidden");
    });

    // Close modal
    document.getElementById("close-modal")?.addEventListener("click", () => {
        document.getElementById("export-modal")?.classList.add("hidden");
    });

    // Copy HTML
    document.getElementById("copy-html-btn")?.addEventListener("click", () => {
        const output = document.getElementById("export-output");
        if (output) {
            navigator.clipboard.writeText(output.textContent || "");
            alert("HTML copied to clipboard!");
        }
    });

    // Load state on page load
    document.addEventListener("DOMContentLoaded", () => {
        const state = stateManager.load();
        if (state && canvas) {
            stateManager.restoreState(state);
        } else {
            updateSectionUI(); // Show "Add Section" on empty canvas
        }
    });

    // Proximity detection for section triggers
    if (canvas) {
        canvas.addEventListener("mousemove", (e) => {
            const triggers = canvas.querySelectorAll(
                ".add-section-trigger:not(.add-section-empty)",
            );
            triggers.forEach((trigger) => {
                const rect = trigger.getBoundingClientRect();
                const distance = Math.abs(
                    e.clientY - (rect.top + rect.height / 2),
                );

                if (distance < 20) {
                    trigger.classList.add("nearby");
                } else {
                    trigger.classList.remove("nearby");
                }
            });
        });

        canvas.addEventListener("mouseleave", () => {
            const triggers = canvas.querySelectorAll(".add-section-trigger");
            triggers.forEach((trigger) => {
                trigger.classList.remove("nearby");
            });
        });
    }

    console.log("Visual Page Builder initialized");

    // okay you've dragged on section on the page,
    // now if you drag another section near the bottom or top of the existing section/s
    // we'd need to know where the mouse is in relation to the top and bottom of the canvas, and to the top and bottom of any section.
    // if they're near those zones, show a drop indicator.
    // if the user releases with a drop indicator highlighted selected, add the section at that spot.

    // start with botom of section.
</script>
