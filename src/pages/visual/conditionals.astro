                                    <div class="flex-1 p-2 bg-yellow-500/10 border border-yellow-500/30 rounded text-center">
                                        <div class="text-yellow-300 font-mono text-[10px] mb-1">If FALSY</div>
                                        <div class="text-gray-300 text-[10px]">Return <strong>value2</strong></div>
                                        <div class="text-gray-400 text-[10px] mt-1">(evaluate & return)</div>
