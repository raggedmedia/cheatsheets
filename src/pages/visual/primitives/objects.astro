---
import '~styles/styles.css'
import MethodCard from '~components/visual-js/MethodCard.astro'
import Node from '~components/visual-js/Node.astro'
import Arrow from '~components/visual-js/Arrow.astro'
import ReturnValue from '~components/visual-js/ReturnValue.astro'
import InfoBox from '~components/visual-js/InfoBox.astro'
import ProcessContent from '~components/visual-js/ProcessContent.astro'
import ProTip from '~components/visual-js/ProTip.astro'
import SectionTitle from '~components/visual-js/SectionTitle.astro'
import SubSectionTitle from '~components/visual-js/SubSectionTitle.astro'
import VisualLayout from 'src/layouts/VisualLayout.astro'
---
<VisualLayout
    pageTitle="Javascript Objects"
>

                <ProTip>
                    <div>⚡ Objects are <strong>mutable</strong> — you can change properties even with <code class="bg-black/30 px-1 py-0.5 rounded font-mono text-yellow-400">const</code></div>
                    <div class="pl-2 border-l-2 border-yellow-500/30 mt-1 font-mono text-[10px]">
                        const obj = &lbrace;a: 1&rbrace;; obj.a = 2 ✅ <span class="text-gray-400">// allowed!</span>
                    </div>
                    <div class="mt-1.5 text-[10px]">
                        Use spread (<code class="bg-black/30 px-1 py-0.5 rounded font-mono text-yellow-400">&lbrace; ...obj &rbrace;</code>) or <code class="bg-black/30 px-1 py-0.5 rounded font-mono text-yellow-400">structuredClone()</code> for safe, immutable copies.
                    </div>
                </ProTip>

                <ProTip>
                    <div>📏 <strong>Getting object "length":</strong> Objects don't have a <code class="bg-black/30 px-1 py-0.5 rounded font-mono text-yellow-400">.length</code> property, but you can count properties:</div>
                    <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                        <div class="font-mono text-[10px]">const user = &lbrace; name: "Alice", age: 25, city: "NYC" &rbrace;;</div>
                        <div class="font-mono text-[10px]">Object.keys(user).length → 3 <span class="text-green-400">// count of properties</span></div>
                        <div class="font-mono text-[10px] mt-1"><span class="text-blue-400">// Other ways to count:</span></div>
                        <div class="font-mono text-[10px]">Object.values(user).length → 3</div>
                        <div class="font-mono text-[10px]">Object.entries(user).length → 3</div>
                    </div>
                </ProTip>

                <!-- ============================================ -->
                <!-- 🛠 MUTATES THE OBJECT -->
                <!-- ============================================ -->

                <SectionTitle id="mutates" color="red">
                    🛠 Mutates the Object
                </SectionTitle>

                <!-- === ADD / REMOVE / CHANGE === -->
                <SubSectionTitle id="add-remove-change" parentColor="red">Add / Remove / Change</SubSectionTitle>

                <!-- PROPERTY ASSIGNMENT -->
                <MethodCard
                    id="property-assignment"
                    methodName="Property Assignment"
                    signature="obj.key = value"
                    description="Adds or overwrites a property on an object"
                    mutates={true}
                >
                        <!-- ADD EXAMPLE -->
                        <div class="flex items-center gap-4 p-3 bg-gray-800 rounded overflow-x-auto">
                            <Node label="Input Object" type="input">
                                <div class="text-center text-sm font-mono">&lbrace;a: 1&rbrace;</div>
                            </Node>

                            <Arrow label="mutates" />

                            <Node label="Operation" type="process">
                                <ProcessContent name="obj.b = 2" description="Add new property" />
                            </Node>

                            <Arrow />

                            <Node label="Modified Object" type="output">
                                <div class="text-center text-sm font-mono">&lbrace;a: 1, b: 2&rbrace;</div>
                            </Node>
                        </div>

                        <!-- CHANGE EXAMPLE -->
                        <div class="flex items-center gap-4 p-3 bg-gray-800 rounded overflow-x-auto mt-2">
                            <Node label="Input Object" type="input">
                                <div class="text-center text-sm font-mono">&lbrace;a: 1, b: 2&rbrace;</div>
                            </Node>

                            <Arrow label="mutates" />

                            <Node label="Operation" type="process">
                                <ProcessContent name="obj.a = 99" description="Change existing property" />
                            </Node>

                            <Arrow />

                            <Node label="Modified Object" type="output">
                                <div class="text-center text-sm font-mono">&lbrace;a: 99, b: 2&rbrace;</div>
                            </Node>
                        </div>

                        <!-- REMOVE EXAMPLE -->
                        <div class="flex items-center gap-4 p-3 bg-gray-800 rounded overflow-x-auto mt-2">
                            <Node label="Input Object" type="input">
                                <div class="text-center text-sm font-mono">&lbrace;a: 99, b: 2&rbrace;</div>
                            </Node>

                            <Arrow label="mutates" />

                            <Node label="Operation" type="process">
                                <ProcessContent name="delete obj.b" description="Remove property" />
                            </Node>

                            <Arrow />

                            <Node label="Modified Object" type="output">
                                <div class="text-center text-sm font-mono">&lbrace;a: 99&rbrace;</div>
                            </Node>
                        </div>

                        <InfoBox mutates={true} message="">
                            Modifies the original object. Returns the assigned value (or true for delete).
                        </InfoBox>
                    </MethodCard>

                <!-- DELETE -->
                <MethodCard
                    id="delete"
                    methodName="delete"
                    signature="delete obj.key"
                    description="Removes a property from an object"
                    mutates={true}
                >
                        <div class="flex items-center gap-4 p-3 bg-gray-800 rounded overflow-x-auto">
                            <Node label="Input Object" type="input">
                                <div class="text-center text-sm font-mono">&lbrace;a: 1, b: 2&rbrace;</div>
                            </Node>

                            <Arrow label="mutates" />

                            <Node label="Operation" type="process">
                                <ProcessContent name="delete obj.b" description="Remove property" />
                            </Node>

                            <Arrow />

                            <Node label="Modified Object" type="output">
                                <div class="text-center text-sm font-mono">&lbrace;a: 1&rbrace;</div>
                            </Node>

                            <Arrow label="returns" />

                            <Node label="Return Value" type="output">
                                <ReturnValue value="true" type="boolean" />
                            </Node>
                        </div>

                        <InfoBox mutates={true} message="">
                            Removes property from original object. Returns <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">true</code> if deleted successfully.
                        </InfoBox>
                    </MethodCard>

                <!-- PROPERTY SHORTHAND -->
                <MethodCard
                    id="property-shorthand"
                    methodName="Property Shorthand"
                    signature="{ name, age }"
                    description="Create object properties from variables with same name"
                    mutates={false}
                >
                        <div class="flex items-center gap-4 p-3 bg-gray-800 rounded overflow-x-auto">
                            <Node label="Variables" type="input">
                                <div class="text-center text-sm font-mono">name = "Alice"</div>
                                <div class="text-center text-sm font-mono">age = 25</div>
                            </Node>

                            <Arrow label="shorthand" />

                            <Node label="Syntax" type="process">
                                <ProcessContent name="{ name, age }" description="ES6 shorthand" />
                            </Node>

                            <Arrow label="creates" />

                            <Node label="New Object" type="output">
                                <div class="text-center text-sm font-mono">&lbrace;name: "Alice", age: 25&rbrace;</div>
                            </Node>
                        </div>

                        <InfoBox mutates={false} message="">
                            ES6 shorthand: <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">&lbrace; name &rbrace;</code> is equivalent to <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">&lbrace; name: name &rbrace;</code>.
                        </InfoBox>

                        <ProTip>
                            <div><strong>Common in function returns and destructuring:</strong></div>
                            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                                <div class="font-mono text-[10px]">function getUser() &lbrace;</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;const name = "Bob", age = 30;</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;return &lbrace; name, age &rbrace;; <span class="text-green-400">// instead of &lbrace;name: name, age: age&rbrace;</span></div>
                                <div class="font-mono text-[10px]">&rbrace;</div>
                            </div>
                        </ProTip>
                    </MethodCard>

                <!-- COMPUTED PROPERTY NAMES -->
                <MethodCard
                    id="computed-property"
                    methodName="Computed Property Names"
                    signature="{ [key]: value }"
                    description="Use dynamic expressions as property keys"
                    mutates={false}
                >
                        <div class="flex items-center gap-4 p-3 bg-gray-800 rounded overflow-x-auto">
                            <Node label="Dynamic Key" type="input">
                                <div class="text-center text-sm font-mono">key = "username"</div>
                            </Node>

                            <Arrow label="computed" />

                            <Node label="Syntax" type="process">
                                <ProcessContent name="{ [key]: 'Alice' }" description="Dynamic key in []" />
                            </Node>

                            <Arrow label="creates" />

                            <Node label="New Object" type="output">
                                <div class="text-center text-sm font-mono">&lbrace;username: "Alice"&rbrace;</div>
                            </Node>
                        </div>

                        <InfoBox mutates={false} message="">
                            Returns a <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">new object</code> with property key computed from expression in <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">[brackets]</code>.
                        </InfoBox>

                        <ProTip>
                            <div><strong>Useful for dynamic object building:</strong></div>
                            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                                <div class="font-mono text-[10px]">const field = "email";</div>
                                <div class="font-mono text-[10px]">const user = &lbrace;</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;name: "Alice",</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;[field]: "alice@email.com" <span class="text-green-400">// key is "email"</span></div>
                                <div class="font-mono text-[10px]">&rbrace;;</div>
                            </div>
                        </ProTip>
                    </MethodCard>

                <!-- OBJECT.ASSIGN -->
                <MethodCard
                    id="assign"
                    methodName="Object.assign()"
                    signature="Object.assign(target, ...sources)"
                    description="Copies properties from source objects into target"
                    mutates={true}
                >
                        <div class="flex items-center gap-4 p-3 bg-gray-800 rounded overflow-x-auto">
                            <Node label="Target" type="input">
                                <div class="text-center text-sm font-mono">&lbrace;a: 1&rbrace;</div>
                            </Node>

                            <Arrow label="merges with" />

                            <Node label="Method" type="process">
                                <ProcessContent name="Object.assign(target, {b: 2})" description="Copy props to target" />
                            </Node>

                            <Arrow label="returns" />

                            <Node label="Modified Target" type="output">
                                <div class="text-center text-sm font-mono">&lbrace;a: 1, b: 2&rbrace;</div>
                            </Node>
                        </div>

                        <InfoBox mutates={true} message="">
                            Mutates the target object. Returns the modified target. Later sources overwrite earlier ones.
                        </InfoBox>

                        <ProTip>
                            <div>Use empty object as target for immutable merge:</div>
                            <div class="pl-2 border-l-2 border-yellow-500/30 font-mono text-[10px]">
                                Object.assign(&lbrace;&rbrace;, obj1, obj2) → new merged object ✅
                            </div>
                        </ProTip>
                    </MethodCard>

                <!-- === LOCK OR PROTECT === -->
                <SubSectionTitle id="lock-protect" parentColor="red">Lock or Protect</SubSectionTitle>

                <!-- OBJECT.FREEZE -->
                <MethodCard
                    id="freeze"
                    methodName="Object.freeze()"
                    signature="Object.freeze(obj)"
                    description="Makes object immutable (shallow) - no add/remove/edit"
                    mutates={true}
                >
                        <div class="flex items-center gap-4 p-3 bg-gray-800 rounded overflow-x-auto">
                            <Node label="Input Object" type="input">
                                <div class="text-center text-sm font-mono">&lbrace;a: 1&rbrace;</div>
                            </Node>

                            <Arrow label="freezes" />

                            <Node label="Method" type="process">
                                <ProcessContent name="Object.freeze(obj)" description="Lock all changes" />
                            </Node>

                            <Arrow label="returns" />

                            <Node label="Frozen Object" type="output">
                                <div class="text-center text-sm font-mono">&lbrace;a: 1&rbrace; 🔒</div>
                            </Node>
                        </div>

                        <InfoBox mutates={true} message="">
                            Modifies object to be immutable. Returns the same object. Silently fails in non-strict mode.
                        </InfoBox>

                        <ProTip>
                            <div><strong>What happens if you try to modify?</strong></div>
                            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                                <div class="font-mono text-[10px]">const obj = Object.freeze(&lbrace;a: 1&rbrace;)</div>
                                <div class="font-mono text-[10px]">obj.a = 99 <span class="text-red-400">// silently ignored (non-strict mode)</span></div>
                                <div class="font-mono text-[10px]">obj.b = 2 <span class="text-red-400">// silently ignored (non-strict mode)</span></div>
                                <div class="font-mono text-[10px]">delete obj.a <span class="text-red-400">// silently ignored (non-strict mode)</span></div>
                                <div class="font-mono text-[10px] mt-1">'use strict'; obj.a = 99 <span class="text-red-400">// TypeError ❌</span></div>
                            </div>
                        </ProTip>

                        <ProTip>
                            <div>⚠️ <strong>Shallow freeze</strong> - nested objects can still be modified:</div>
                            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                                <div class="font-mono text-[10px]">const obj = Object.freeze(&lbrace;user: &lbrace;id: 1&rbrace;&rbrace;)</div>
                                <div class="font-mono text-[10px]">obj.user.id = 999 ✅ <span class="text-gray-400">// nested still mutable!</span></div>
                            </div>
                        </ProTip>
                    </MethodCard>

                <!-- OBJECT.SEAL -->
                <MethodCard
                    id="seal"
                    methodName="Object.seal()"
                    signature="Object.seal(obj)"
                    description="Prevents add/remove but allows editing existing properties"
                    mutates={true}
                >
                        <div class="flex items-center gap-4 p-3 bg-gray-800 rounded overflow-x-auto">
                            <Node label="Input Object" type="input">
                                <div class="text-center text-sm font-mono">&lbrace;a: 1&rbrace;</div>
                            </Node>

                            <Arrow label="seals" />

                            <Node label="Method" type="process">
                                <ProcessContent name="Object.seal(obj)" description="Lock structure" />
                            </Node>

                            <Arrow label="returns" />

                            <Node label="Sealed Object" type="output">
                                <div class="text-center text-sm font-mono">&lbrace;a: 1&rbrace; 🔐</div>
                            </Node>
                        </div>

                        <InfoBox mutates={true} message="">
                            Prevents adding/removing properties but allows editing values. Returns the same object.
                        </InfoBox>

                        <ProTip>
                            <div><strong>What happens if you try to add/remove?</strong></div>
                            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                                <div class="font-mono text-[10px]">const obj = Object.seal(&lbrace;a: 1&rbrace;)</div>
                                <div class="font-mono text-[10px]">obj.a = 99 ✅ <span class="text-green-400">// editing works!</span></div>
                                <div class="font-mono text-[10px]">obj.b = 2 <span class="text-red-400">// silently ignored (can't add)</span></div>
                                <div class="font-mono text-[10px]">delete obj.a <span class="text-red-400">// silently ignored (can't remove)</span></div>
                                <div class="font-mono text-[10px] mt-1">'use strict'; obj.b = 2 <span class="text-red-400">// TypeError ❌</span></div>
                            </div>
                        </ProTip>
                    </MethodCard>
                </div>

                <!-- ============================================ -->
                <!-- 🚫 DOES NOT MUTATE -->
                <!-- ============================================ -->

                <SectionTitle id="immutable" color="green">
                    🚫 Does Not Mutate (returns new value)
                </SectionTitle>

                <ProTip>
                    <div>Use spread or <code class="bg-black/30 px-1 py-0.5 rounded font-mono text-yellow-400">Object.assign(&lbrace;&rbrace;, obj)</code> for shallow copies</div>
                    <div class="pl-2 border-l-2 border-yellow-500/30 font-mono text-[10px] mt-1">
                        const copy = &lbrace; ...original &rbrace; <span class="text-gray-400">// cleaner than Object.assign</span>
                    </div>
                </ProTip>

                <!-- === CLONE / MERGE === -->
                <SubSectionTitle id="clone-merge" parentColor="green">Clone / Merge</SubSectionTitle>

                <!-- SPREAD -->
                <MethodCard
                    id="spread"
                    methodName="Spread { ...obj }"
                    signature="{ ...obj }"
                    description="Creates a shallow copy of an object"
                    mutates={false}
                >
                        <div class="flex items-center gap-4 p-3 bg-gray-800 rounded overflow-x-auto">
                            <Node label="Input Object" type="input">
                                <div class="text-center text-sm font-mono">&lbrace;a: 1, b: 2&rbrace;</div>
                            </Node>

                            <Arrow label="spreads" />

                            <Node label="Syntax" type="process">
                                <ProcessContent name="{ ...obj }" description="Shallow copy" />
                            </Node>

                            <Arrow label="returns" />

                            <Node label="New Object" type="output">
                                <div class="text-center text-sm font-mono">&lbrace;a: 1, b: 2&rbrace;</div>
                            </Node>
                        </div>

                        <InfoBox mutates={false} message="">
                            Creates a <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">new object</code> with copied properties. Original unchanged.
                        </InfoBox>

                        <ProTip>
                            <div>Spread is the modern way to clone and merge objects:</div>
                            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                                <div class="font-mono text-[10px]">const merged = &lbrace; ...obj1, ...obj2 &rbrace; <span class="text-gray-400">// merge</span></div>
                                <div class="font-mono text-[10px]">const updated = &lbrace; ...obj, key: newValue &rbrace; <span class="text-gray-400">// update</span></div>
                            </div>
                        </ProTip>
                    </MethodCard>

                <!-- STRUCTURED CLONE -->
                <MethodCard
                    id="structuredClone"
                    methodName="structuredClone()"
                    signature="structuredClone(obj)"
                    description="Creates a deep copy of an object (all nested levels)"
                    mutates={false}
                >
                        <div class="flex items-center gap-4 p-3 bg-gray-800 rounded overflow-x-auto">
                            <Node label="Input Object" type="input">
                                <div class="text-center text-sm font-mono">&lbrace;user: &lbrace;id: 1&rbrace;&rbrace;</div>
                            </Node>

                            <Arrow label="deep clones" />

                            <Node label="Method" type="process">
                                <ProcessContent name="structuredClone(obj)" description="Deep copy all levels" />
                            </Node>

                            <Arrow label="returns" />

                            <Node label="New Object" type="output">
                                <div class="text-center text-sm font-mono">&lbrace;user: &lbrace;id: 1&rbrace;&rbrace;</div>
                            </Node>
                        </div>

                        <InfoBox mutates={false} message="">
                            Creates fully independent <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">deep copy</code>. Nested objects are also cloned.
                        </InfoBox>
                    </MethodCard>
                </div>

                <!-- === INSPECT / READ === -->
                <SubSectionTitle id="inspect-read" parentColor="green">Inspect / Read</SubSectionTitle>

                <!-- OBJECT.KEYS -->
                <MethodCard
                    id="keys"
                    methodName="Object.keys()"
                    signature="Object.keys(obj)"
                    description="Returns array of object's own property names"
                    mutates={false}
                >
                        <div class="flex items-center gap-4 p-3 bg-gray-800 rounded overflow-x-auto">
                            <Node label="Input Object" type="input">
                                <div class="text-center text-sm font-mono">&lbrace;a: 1, b: 2, c: 3&rbrace;</div>
                            </Node>

                            <Arrow label="extracts keys" />

                            <Node label="Method" type="process">
                                <ProcessContent name="Object.keys(obj)" description="Get property names" />
                            </Node>

                            <Arrow label="returns" />

                            <Node label="Array" type="output">
                                <div class="text-center text-sm font-mono">['a', 'b', 'c']</div>
                            </Node>
                        </div>

                        <InfoBox mutates={false} message="">
                            Returns <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">array</code> of own enumerable property names. ⚠️ Cannot be chained.
                        </InfoBox>
                    </MethodCard>

                <!-- OBJECT.VALUES -->
                <MethodCard
                    id="values"
                    methodName="Object.values()"
                    signature="Object.values(obj)"
                    description="Returns array of object's own property values"
                    mutates={false}
                >
                        <div class="flex items-center gap-4 p-3 bg-gray-800 rounded overflow-x-auto">
                            <Node label="Input Object" type="input">
                                <div class="text-center text-sm font-mono">&lbrace;a: 1, b: 2, c: 3&rbrace;</div>
                            </Node>

                            <Arrow label="extracts values" />

                            <Node label="Method" type="process">
                                <ProcessContent name="Object.values(obj)" description="Get property values" />
                            </Node>

                            <Arrow label="returns" />

                            <Node label="Array" type="output">
                                <div class="text-center text-sm font-mono">[1, 2, 3]</div>
                            </Node>
                        </div>

                        <InfoBox mutates={false} message="">
                            Returns <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">array</code> of own enumerable property values. ⚠️ Cannot be chained.
                        </InfoBox>
                    </MethodCard>

                <!-- OBJECT.ENTRIES -->
                <MethodCard
                    id="entries"
                    methodName="Object.entries()"
                    signature="Object.entries(obj)"
                    description="Returns array of [key, value] pairs"
                    mutates={false}
                >
                        <div class="flex items-center gap-4 p-3 bg-gray-800 rounded overflow-x-auto">
                            <Node label="Input Object" type="input">
                                <div class="text-center text-sm font-mono">&lbrace;a: 1, b: 2&rbrace;</div>
                            </Node>

                            <Arrow label="converts" />

                            <Node label="Method" type="process">
                                <ProcessContent name="Object.entries(obj)" description="Get [k,v] pairs" />
                            </Node>

                            <Arrow label="returns" />

                            <Node label="Array" type="output">
                                <div class="text-center text-sm font-mono">[['a', 1], ['b', 2]]</div>
                            </Node>
                        </div>

                        <InfoBox mutates={false} message="">
                            Returns <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">array</code> of [key, value] pairs. ⚠️ Cannot be chained. Perfect for iteration and transformation.
                        </InfoBox>

                        <ProTip>
                            <div>Combo with <code class="bg-black/30 px-1 py-0.5 rounded font-mono text-yellow-400">Object.fromEntries()</code> for map/filter on objects:</div>
                            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                                <div class="font-mono text-[10px]"><span class="text-gray-400">// Double all values</span></div>
                                <div class="font-mono text-[10px]">Object.fromEntries(</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;Object.entries(obj).map(([k,v]) =&gt; [k, v*2])</div>
                                <div class="font-mono text-[10px]">)</div>
                            </div>
                        </ProTip>
                    </MethodCard>
                </div>

                <!-- OBJECT.HASOWN -->
                <MethodCard
                    id="hasOwn"
                    methodName="Object.hasOwn()"
                    signature="Object.hasOwn(obj, key)"
                    description="Checks if object has its own property (not inherited)"
                    mutates={false}
                >
                        <div class="flex items-center gap-4 p-3 bg-gray-800 rounded overflow-x-auto">
                            <Node label="Input Object" type="input">
                                <div class="text-center text-sm font-mono">&lbrace;a: 1&rbrace;</div>
                            </Node>

                            <Arrow label="checks for" />

                            <Node label="Method" type="process">
                                <ProcessContent name="Object.hasOwn(obj, 'a')" description="Has own property?" />
                            </Node>

                            <Arrow label="returns" />

                            <Node label="Boolean" type="output">
                                <ReturnValue value="true" type="boolean" />
                            </Node>
                        </div>

                        <InfoBox mutates={false} message="">
