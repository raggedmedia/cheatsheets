---
import '~styles/styles.css'
import MethodCard from '~components/visual-js/MethodCard.astro'
import Node from '~components/visual-js/Node.astro'
import ArrayDisplay from '~components/visual-js/ArrayDisplay.astro'
import Arrow from '~components/visual-js/Arrow.astro'
import ReturnValue from '~components/visual-js/ReturnValue.astro'
import MutableOrNot from '~components/visual-js/MutableOrNot.astro';
import ProcessContent from '~components/visual-js/ProcessContent.astro'
import ProTip from '~components/visual-js/ProTip.astro'
import SectionTitle from '~components/visual-js/SectionTitle.astro'
import SubSectionTitle from '~components/visual-js/SubSectionTitle.astro'
import VisualLayout from 'src/layouts/VisualLayout.astro'
---
<VisualLayout
    pageTitle="Javascript Arrays"
>

                <ProTip>
                    <div>📏 <strong>Array length property:</strong> Get the number of elements with <code class="bg-black/30 px-1 py-0.5 rounded font-mono text-yellow-400">arr.length</code></div>
                    <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                        <div class="font-mono text-[10px]">const nums = [1, 2, 3, 4, 5];</div>
                        <div class="font-mono text-[10px]">nums.length → 5</div>
                        <div class="font-mono text-[10px] mt-1"><span class="text-green-400">// Writable! Set length to truncate:</span></div>
                        <div class="font-mono text-[10px]">nums.length = 3 → [1, 2, 3]</div>
                    </div>
                </ProTip>

                <!-- ============================================ -->
                <!-- � CONVERTING TO ARRAYS -->
                <!-- ============================================ -->

                <SectionTitle id="converting" color="blue">
                    🔄 Converting to Arrays
                </SectionTitle>

                <!-- === STRING TO ARRAY === -->
                <SubSectionTitle id="string-to-array" parentColor="blue">String to Array</SubSectionTitle>

                <!-- SPLIT -->
                <MethodCard
                    id="split"
                    methodName="split()"
                        signature="str.split(separator)"
                        description="Splits a string into an array of substrings"
                        mutates={false}
                    >
                        <div class="flex items-center gap-4 p-3 bg-gray-800 rounded overflow-x-auto">
                            <Node label="String" type="input">
                                <div class="text-center text-sm font-mono">"hello"</div>
                            </Node>

                            <Arrow label="splits" />

                            <Node label="Method" type="process">
                                <ProcessContent name="split('')" description="Split into chars" />
                            </Node>

                            <Arrow label="returns" />

                            <Node label="Array" type="output">
                                <ArrayDisplay values={['h', 'e', 'l', 'l', 'o']} highlightIndices={[0, 1, 2, 3, 4]} highlightType="added" />
                            </Node>
                        </div>

                        <MutableOrNot mutates={false} message="">
                            Returns a <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">new array</code>. Use <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">split('')</code> for chars, <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">split(' ')</code> for words.
                        </MutableOrNot>
                    </MethodCard>

                <!-- ARRAY.FROM STRING -->
                <MethodCard
                    id="array-from-string"
                    methodName="Array.from()"
                        signature="Array.from(string)"
                        description="Creates array from string or iterable"
                        mutates={false}
                    >
                        <div class="flex items-center gap-4 p-3 bg-gray-800 rounded overflow-x-auto">
                            <Node label="String" type="input">
                                <div class="text-center text-sm font-mono">"abc"</div>
                            </Node>

                            <Arrow label="converts" />

                            <Node label="Method" type="process">
                                <ProcessContent name="Array.from(str)" description="String to array" />
                            </Node>

                            <Arrow label="returns" />

                            <Node label="Array" type="output">
                                <ArrayDisplay values={['a', 'b', 'c']} highlightIndices={[0, 1, 2]} highlightType="added" />
                            </Node>
                        </div>

                        <MutableOrNot mutates={false} message="">
                            Static method. Returns a <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">new array</code> from any iterable or array-like object.
                        </MutableOrNot>
                    </MethodCard>

                <!-- SPREAD STRING -->
                <MethodCard
                    id="spread-string"
                    methodName="Spread [...str]"
                        signature="[...string]"
                        description="Uses spread operator to convert string to array"
                        mutates={false}
                    >
                        <div class="flex items-center gap-4 p-3 bg-gray-800 rounded overflow-x-auto">
                            <Node label="String" type="input">
                                <div class="text-center text-sm font-mono">"hello"</div>
                            </Node>

                            <Arrow label="spreads" />

                            <Node label="Syntax" type="process">
                                <ProcessContent name="[...str]" description="Spread into array" />
                            </Node>

                            <Arrow label="returns" />

                            <Node label="Array" type="output">
                                <ArrayDisplay values={['h', 'e', 'l', 'l', 'o']} highlightIndices={[0, 1, 2, 3, 4]} highlightType="added" />
                            </Node>
                        </div>

                        <MutableOrNot mutates={false} message="">
                            Modern syntax. Creates a <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">new array</code> with each character as an element.
                        </MutableOrNot>
                    </MethodCard>

                <!-- === NUMBER TO ARRAY === -->
                <SubSectionTitle id="number-to-array" parentColor="blue">Number to Array</SubSectionTitle>

                <!-- NUMBER TO DIGITS -->
                <MethodCard
                    id="number-to-digits"
                    methodName="String() + split()"
                        signature="String(num).split('')"
                        description="Converts number to array of digit strings"
                        mutates={false}
                    >
                        <div class="flex items-center gap-4 p-3 bg-gray-800 rounded overflow-x-auto">
                            <Node label="Number" type="input">
                                <div class="text-center text-sm font-mono">12345</div>
                            </Node>

                            <Arrow label="converts" />

                            <Node label="Method" type="process">
                                <ProcessContent name="String(num).split('')" description="To string, then split" />
                            </Node>

                            <Arrow label="returns" />

                            <Node label="Array" type="output">
                                <ArrayDisplay values={['1', '2', '3', '4', '5']} highlightIndices={[0, 1, 2, 3, 4]} highlightType="added" />
                            </Node>
                        </div>

                        <MutableOrNot mutates={false} message="">
                            Returns array of <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">digit strings</code>. Use <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">.map(Number)</code> to convert to numbers.
                        </MutableOrNot>
                    </MethodCard>

                <!-- ARRAY.FROM NUMBER -->
                <MethodCard
                        id="array-from-number"
                        methodName="Array.from() + map"
                        signature="Array.from(String(num), Number)"
                        description="Converts number to array of digit numbers"
                        mutates={false}
                    >
                        <div class="flex items-center gap-4 p-3 bg-gray-800 rounded overflow-x-auto">
                            <Node label="Number" type="input">
                                <div class="text-center text-sm font-mono">123</div>
                            </Node>

                            <Arrow label="converts" />

                            <Node label="Method" type="process">
                                <ProcessContent name="Array.from(String(num), Number)" description="String then map to numbers" />
                            </Node>

                            <Arrow label="returns" />

                            <Node label="Array" type="output">
                                <ArrayDisplay values={[1, 2, 3]} highlightIndices={[0, 1, 2]} highlightType="added" />
                            </Node>
                        </div>

                        <MutableOrNot mutates={false} message="">
                            Returns array of <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">digit numbers</code>. Second parameter is mapping function.
                        </MutableOrNot>
                    </MethodCard>

                <!-- ============================================ -->
                <!-- �🛠 MUTATES THE ARRAY -->
                <!-- ============================================ -->

                <SectionTitle id="mutates" color="red">
                    🛠 Mutates the Array
                </SectionTitle>

                <!-- === INSERT / REMOVE === -->
                <SubSectionTitle id="insert-remove" parentColor="red">Insert / Remove</SubSectionTitle>

                <!-- PUSH -->
                <MethodCard
                        id="push"
                        methodName="push()"
                        signature="arr.push(...items)"
                        description="Adds elements to the end of an array and returns the new length"
                        mutates={true}
                    >
                <div class="flex items-center gap-4 p-3 bg-gray-800 rounded overflow-x-auto">
                    <Node label="Input Array" type="input">
                        <ArrayDisplay values={['a', 'b', 'c']} />
                    </Node>

                    <Arrow label="mutates" />

                    <Node label="Method" type="process">
                        <ProcessContent name="push('d')" description="Add to end" />
                    </Node>

                    <Arrow />

                    <Node label="Modified Array" type="output">
                        <ArrayDisplay values={['a', 'b', 'c', 'd']} highlightIndices={[3]} highlightType="added" />
                    </Node>

                    <Arrow label="returns" />

                    <Node label="Return Value" type="output">
                        <ReturnValue value={4} type="new length" />
                    </Node>
                </div>

                        <MutableOrNot mutates={true} message="">
                            The original array is modified in place. Returns <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">number</code> (new length), not the array. ⚠️ Cannot be chained with other array methods.
                        </MutableOrNot>
                    </MethodCard>

                <!-- POP -->
                <MethodCard
                id="pop"
                methodName="pop()"
                signature="arr.pop()"
                description="Removes and returns the last element from an array"
                mutates={true}
            >
                <div class="flex items-center gap-4 p-3 bg-gray-800 rounded overflow-x-auto">
                    <Node label="Input Array" type="input">
                        <ArrayDisplay values={['a', 'b', 'c']} />
                    </Node>

                    <Arrow label="mutates" />

                    <Node label="Method" type="process">
                        <ProcessContent name="pop()" description="Remove last" />
                    </Node>

                    <Arrow />

                    <Node label="Modified Array" type="output">
                        <ArrayDisplay values={['a', 'b']} />
                    </Node>

                    <Arrow label="returns" />

                    <Node label="Return Value" type="output">
                        <ReturnValue value="'c'" type="removed item" />
                    </Node>
                </div>

                <MutableOrNot mutates={true} message="">
                    The original array is shortened. Returns the removed <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">element</code> (or undefined if empty). ⚠️ Cannot be chained with other array methods.
                </MutableOrNot>
            </MethodCard>

                <!-- UNSHIFT -->
                <MethodCard
                id="unshift"
                methodName="unshift()"
                signature="arr.unshift(...items)"
                description="Adds elements to the beginning of an array and returns the new length"
                mutates={true}
            >
                <div class="flex items-center gap-4 p-3 bg-gray-800 rounded overflow-x-auto">
                    <Node label="Input Array" type="input">
                        <ArrayDisplay values={['b', 'c', 'd']} />
                    </Node>

                    <Arrow label="mutates" />

                    <Node label="Method" type="process">
                        <ProcessContent name="unshift('a')" description="Add to beginning" />
                    </Node>

                    <Arrow />

                    <Node label="Modified Array" type="output">
                        <ArrayDisplay values={['a', 'b', 'c', 'd']} highlightIndices={[0]} highlightType="added" />
                    </Node>

                    <Arrow label="returns" />

                    <Node label="Return Value" type="output">
                        <ReturnValue value={4} type="new length" />
                    </Node>
                </div>

                <MutableOrNot mutates={true} message="">
                    The original array is modified in place. All existing elements shift to higher indices. Returns <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">number</code> (new length). ⚠️ Cannot be chained with other array methods.
                </MutableOrNot>
            </MethodCard>

                <!-- SHIFT -->
                <MethodCard
                id="shift"
                methodName="shift()"
                signature="arr.shift()"
                description="Removes and returns the first element from an array"
                mutates={true}
            >
                <div class="flex items-center gap-4 p-3 bg-gray-800 rounded overflow-x-auto">
                    <Node label="Input Array" type="input">
                        <ArrayDisplay values={['a', 'b', 'c']} />
                    </Node>

                    <Arrow label="mutates" />

                    <Node label="Method" type="process">
                        <ProcessContent name="shift()" description="Remove first" />
                    </Node>

                    <Arrow />

                    <Node label="Modified Array" type="output">
                        <ArrayDisplay values={['b', 'c']} />
                    </Node>

                    <Arrow label="returns" />

                    <Node label="Return Value" type="output">
                        <ReturnValue value="'a'" type="removed item" />
                    </Node>
                </div>

                <MutableOrNot mutates={true} message="">
                    The original array is shortened. All remaining elements shift to lower indices. Returns the removed <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">element</code> (or undefined if empty). ⚠️ Cannot be chained with other array methods.
                </MutableOrNot>
            </MethodCard>

                <!-- SPLICE -->
                <MethodCard
                id="splice"
                methodName="splice()"
                signature="arr.splice(start, deleteCount, ...items)"
                description="Removes, replaces, or adds elements at any position in the array"
                mutates={true}
            >
                <div class="flex items-center gap-4 p-3 bg-gray-800 rounded overflow-x-auto">
                    <Node label="Input Array" type="input">
                        <ArrayDisplay values={['a', 'b', 'c', 'd']} />
                    </Node>

                    <Arrow label="mutates" />

                    <Node label="Method" type="process">
                        <ProcessContent name="splice(1, 2, 'X', 'Y')" description="At index 1, remove 2, insert 'X', 'Y'" />
                    </Node>

                    <Arrow />

                    <Node label="Modified Array" type="output">
                        <ArrayDisplay values={['a', 'X', 'Y', 'd']} highlightIndices={[1, 2]} highlightType="added" />
                    </Node>

                    <Arrow label="returns" />

                    <Node label="Return Value" type="output">
                        <ArrayDisplay values={['b', 'c']} highlightIndices={[0, 1]} highlightType="removed" />
                    </Node>
                </div>

                <MutableOrNot mutates={true} message="">
                    The Swiss Army knife of array methods. Returns an <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">array</code> of removed elements. Can remove, add, or replace items at any index.
                </MutableOrNot>

                <ProTip>
                    <div>Insert without deleting by setting deleteCount to 0:</div>
                    <div class="pl-2 border-l-2 border-yellow-500/60 font-mono text-[10px]">
                        arr.splice(2, 0, 'x', 'y') → inserts 'x', 'y' at index 2
                    </div>
                </ProTip>
            </MethodCard>

            <!-- === REORDER === -->
            <SubSectionTitle id="reorder" parentColor="red">Reorder</SubSectionTitle>

                <!-- SORT -->
                <MethodCard
                id="sort"
                methodName="sort()"
                signature="arr.sort(compareFn?)"
                description="Sorts the array in place and returns the same array"
                mutates={true}
            >
                <div class="flex items-center gap-4 p-3 bg-gray-800 rounded overflow-x-auto">
                    <Node label="Input Array" type="input">
                        <ArrayDisplay values={[3, 1, 4, 2]} />
                    </Node>

                    <Arrow label="mutates" />

                    <Node label="Method" type="process">
                        <ProcessContent name="sort((a, b) => a - b)" description="Ascending order" />
                    </Node>

                    <Arrow label="returns" />

                    <Node label="Same Array (Sorted)" type="output">
                        <ArrayDisplay values={[1, 2, 3, 4]} highlightIndices={[0, 1, 2, 3]} highlightType="transformed" />
                    </Node>
                </div>

                <MutableOrNot mutates={true} message="">
                    Sorts in place. Returns the <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">same array</code> (not a copy).
                </MutableOrNot>

                <ProTip>
                    <div>Without a compare function, sort treats values as strings!</div>

                    <div class="pl-2 border-l-2 border-yellow-500/60">
                        <div class="font-mono text-[10px]">['b','d','a','c'].sort() → ['a','b','c','d']</div>
                        <div class="font-mono text-[10px]">['b','d','a','c'].sort().reverse() → ['d','c','b','a']</div>
                    </div>

                    <div>For numbers, use compare function:</div>

                    <div class="pl-2 border-l-2 border-yellow-500/60">
                        <div class="font-mono text-[10px]">[2,4,1,3].sort((a,b) => a-b) → [1,2,3,4] <span class="text-gray-400">// ascending</span></div>
                        <div class="font-mono text-[10px]">[2,4,1,3].sort((a,b) => b-a) → [4,3,2,1] <span class="text-gray-400">// descending</span></div>
                        <div class="font-mono text-[10px] text-gray-400">// OR: .sort((a,b) => a-b).reverse() → [4,3,2,1]</div>
                    </div>
                </ProTip>
            </MethodCard>

                <!-- REVERSE -->
                <MethodCard
                id="reverse"
                methodName="reverse()"
                signature="arr.reverse()"
                description="Reverses the array in place and returns the same array"
                mutates={true}
            >
                <div class="flex items-center gap-4 p-3 bg-gray-800 rounded overflow-x-auto">
                    <Node label="Input Array" type="input">
                        <ArrayDisplay values={['a', 'b', 'c']} />
                    </Node>

                    <Arrow label="mutates" />

                    <Node label="Method" type="process">
                        <ProcessContent name="reverse()" description="Flip order" />
                    </Node>

                    <Arrow label="returns" />

                    <Node label="Same Array (Reversed)" type="output">
                        <ArrayDisplay values={['c', 'b', 'a']} highlightIndices={[0, 1, 2]} highlightType="transformed" />
                    </Node>
                </div>

                <MutableOrNot mutates={true} message="">
                    Reverses in place. Returns the <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">same array</code> (not a copy).
                </MutableOrNot>
            </MethodCard>

                <!-- === OVERWRITE / MOVE === -->
                <SubSectionTitle id="overwrite-move" parentColor="red">Overwrite / Move</SubSectionTitle>

                <!-- FILL -->
                <MethodCard
                        id="fill"
                        methodName="fill()"
                        signature="arr.fill(value, start?, end?)"
                        description="Overwrites a section of the array with a static value"
                        mutates={true}
                    >
                        <div class="flex items-center gap-4 p-3 bg-gray-800 rounded overflow-x-auto">
                            <Node label="Input Array" type="input">
                                <ArrayDisplay values={[1, 2, 3, 4, 5]} />
                            </Node>

                            <Arrow label="mutates" />

                            <Node label="Method" type="process">
                                <ProcessContent name="fill(0, 1, 4)" description="Fill indices 1-3 with 0" />
                            </Node>

                            <Arrow label="returns" />

                            <Node label="Same Array (Modified)" type="output">
                                <ArrayDisplay values={[1, 0, 0, 0, 5]} highlightIndices={[1, 2, 3]} highlightType="transformed" />
                            </Node>
                        </div>

                        <MutableOrNot mutates={true} message="">
                            Overwrites in place. Returns the <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">same array</code>. End index is exclusive.
                        </MutableOrNot>

                        <ProTip>
                            <div>Useful for filling array holes (empty slots):</div>
                            <div class="pl-2 border-l-2 border-yellow-500/60 space-y-0.5">
                                <div class="font-mono text-[10px]">Array(5).fill(0) → [0, 0, 0, 0, 0] <span class="text-gray-400">// no holes!</span></div>
                                <div class="font-mono text-[10px]">Array(5) → [empty × 5] <span class="text-gray-400">// has holes, methods skip these</span></div>
                            </div>
                        </ProTip>
                    </MethodCard>

                <!-- COPYWITHIN -->
                <MethodCard
                        id="copyWithin"
                        methodName="copyWithin()"
                        signature="arr.copyWithin(target, start, end?)"
                        description="Copies part of array to another location within same array"
                        mutates={true}
                    >
                        <div class="flex items-center gap-4 p-3 bg-gray-800 rounded overflow-x-auto">
                            <Node label="Input Array" type="input">
                                <ArrayDisplay values={[1, 2, 3, 4, 5]} />
                            </Node>

                            <Arrow label="mutates" />

                            <Node label="Method" type="process">
                                <ProcessContent name="copyWithin(0, 3)" description="Copy from index 3 to start" />
                            </Node>

                            <Arrow label="returns" />

                            <Node label="Same Array (Modified)" type="output">
                                <ArrayDisplay values={[4, 5, 3, 4, 5]} highlightIndices={[0, 1]} highlightType="transformed" />
                            </Node>
                        </div>

                        <MutableOrNot mutates={true} message="">
                            Copies within the same array. Returns the <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">same array</code>. Doesn't change array length.
                        </MutableOrNot>
                    </MethodCard>

                <!-- ============================================ -->
                <!-- 🚫 DOES NOT MUTATE (returns new value) -->
                <!-- ============================================ -->
                <SectionTitle id="immutable" color="green">
                    🚫 Does Not Mutate (returns new value)
                </SectionTitle>

                <ProTip>
                    <div>💪 Chain immutable methods together for cleaner, functional code:</div>
                    <div class="pl-2 border-l-2 border-yellow-500/60 space-y-0.5">
                        <div class="font-mono text-[10px]">users.filter(u =&gt; u.active).map(u =&gt; u.name).slice(0, 10)</div>
                        <div class="font-mono text-[10px] text-gray-400">// Filter → transform → take first 10 (all chainable!)</div>
                    </div>
                </ProTip>

                <!-- === BUILD NEW ARRAYS === -->
                <SubSectionTitle id="build-arrays" parentColor="green">Build New Arrays</SubSectionTitle>

                <!-- MAP -->
                <MethodCard
                id="map"
                methodName="map()"
                signature="arr.map(fn)"
                description="Creates a new array by transforming each element with a function"
                mutates={false}
            >
                <div class="flex items-center gap-4 p-3 bg-gray-800 rounded overflow-x-auto">
                    <Node label="Input Array" type="input">
                        <ArrayDisplay values={[1, 2, 3]} />
                    </Node>

                    <Arrow label="transforms" />

                    <Node label="Method" type="process">
                        <ProcessContent name="map(n => n * 2)" description="Double each value" />
                    </Node>

                    <Arrow label="returns" />

                    <Node label="New Array" type="output">
                        <ArrayDisplay values={[2, 4, 6]} highlightIndices={[0, 1, 2]} highlightType="transformed" />
                    </Node>
                </div>

                <MutableOrNot mutates={false} message="">
                    Original array remains unchanged. Returns a <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">new array</code> with same length, transformed values.
                </MutableOrNot>

                <ProTip>
                    <div>Need the results? Use <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">map()</code>. Just doing side effects? Use <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">forEach()</code>.</div>
                    <div class="pl-2 border-l-2 border-yellow-500/60 font-mono text-[10px]">
                        const ids = users.map(u => u.id) ✅<br/>
                        users.forEach(u => console.log(u)) ✅
                    </div>
                </ProTip>
            </MethodCard>

                <!-- FILTER -->
                <MethodCard
                id="filter"
                methodName="filter()"
                signature="arr.filter(fn)"
                description="Creates a new array with elements that pass a test function"
                mutates={false}
            >
                <div class="flex items-center gap-4 p-3 bg-gray-800 rounded overflow-x-auto">
                    <Node label="Input Array" type="input">
                        <ArrayDisplay values={[1, 2, 3, 4, 5]} />
                    </Node>

                    <Arrow label="filters" />

                    <Node label="Method" type="process">
                        <ProcessContent name="filter(n => n % 2 === 0)" description="Keep even numbers" />
                    </Node>

                    <Arrow label="returns" />

                    <Node label="New Array" type="output">
                        <ArrayDisplay values={[2, 4]} highlightIndices={[0, 1]} highlightType="added" />
                    </Node>
                </div>

                <MutableOrNot mutates={false} message="">
                    Original array remains unchanged. Returns a <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">new array</code> (may be shorter) with only passing items.
                </MutableOrNot>

                <ProTip>
                    <div>Use <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">filter(Boolean)</code> to remove all falsy values in one go!</div>
                    <div class="pl-2 border-l-2 border-yellow-500/60 font-mono text-[10px]">
                        [0, 1, false, 2, '', 3, null].filter(Boolean) → [1, 2, 3]
                    </div>
                </ProTip>
            </MethodCard>

                <!-- SLICE -->
                <MethodCard
                id="slice"
                methodName="slice()"
                signature="arr.slice(start, end)"
                description="Returns a shallow copy of a portion of an array"
                mutates={false}
