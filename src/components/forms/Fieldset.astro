---
interface Props {
    legend: string;
    required?: boolean;
    helperText?: string;
}

const { legend, required = false, helperText } = Astro.props;
---

<fieldset class="form-fieldset">
    <legend class="form-legend">
        {legend}
        {
            required && (
                <span class="required-indicator" aria-label="required">
                    *
                </span>
            )
        }
    </legend>

    {helperText && <div class="fieldset-help-text">{helperText}</div>}

    <div class="fieldset-content">
        <slot />
    </div>
</fieldset>

<style>
    /* Component-specific styles only - shared styles are in _forms.css */
</style>
