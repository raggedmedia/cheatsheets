                <!-- ============================================ -->
                <!-- 🔗 LOGICAL OPERATORS -->
                <!-- ============================================ -->

                <h2 id="logical" class="text-orange-300 text-xl my-4 pb-2 border-b-2 border-orange-600">
                    🔗 Logical Operators
                </h2>

                <!-- AND (&&) -->
                <div id="and">
                    <MethodCard
                        methodName="AND (&&)"
                        signature="value1 && value2"
                        description="Return first falsy value, or last value if all truthy"
                        mutates={false}
                    >
                        <div class="p-4 bg-gray-800 rounded border border-gray-700">
                            <!-- Expression -->
                            <div class="font-mono text-sm mb-4">
                                <span class="text-orange-300">value1</span>
                                <span class="text-purple-300 mx-2">&&</span>
                                <span class="text-orange-300">value2</span>
                            </div>

                            <!-- Evaluation logic -->
                            <div class="space-y-2 text-xs">
                                <div class="p-3 bg-orange-500/5 border border-orange-500/30 rounded">
                                    <div class="text-orange-300 font-bold mb-1">1. Evaluate left side (value1)</div>
                                    <div class="text-gray-300">Check if truthy or falsy</div>
                                </div>

                                <div class="flex items-center justify-center gap-4">
                                    <div class="flex-1 p-2 bg-red-500/10 border border-red-500/30 rounded text-center">
                                        <div class="text-red-300 font-mono text-[10px] mb-1">If FALSY</div>
                                        <div class="text-gray-300 text-[10px]">Return <strong>value1</strong></div>
                                        <div class="text-gray-400 text-[10px] mt-1">(short-circuit)</div>
                                    </div>
                                    <div class="flex-1 p-2 bg-green-500/10 border border-green-500/30 rounded text-center">
                                        <div class="text-green-300 font-mono text-[10px] mb-1">If TRUTHY</div>
                                        <div class="text-gray-300 text-[10px]">Return <strong>value2</strong></div>
                                        <div class="text-gray-400 text-[10px] mt-1">(evaluate & return)</div>
                                    </div>
                                </div>

                                <!-- Examples -->
                                <div class="mt-3 p-3 bg-gray-700/30 rounded space-y-1">
                                    <div class="font-mono text-[10px]">
                                        <span class="text-green-300">true</span> <span class="text-purple-300">&&</span> <span class="text-green-300">'hello'</span>
                                        <span class="text-gray-400 ml-3">→ 'hello'</span>
                                    </div>
                                    <div class="font-mono text-[10px]">
                                        <span class="text-red-300">false</span> <span class="text-purple-300">&&</span> <span class="text-green-300">'hello'</span>
                                        <span class="text-gray-400 ml-3">→ false</span>
                                    </div>
                                    <div class="font-mono text-[10px]">
                                        <span class="text-red-300">0</span> <span class="text-purple-300">&&</span> <span class="text-green-300">'hello'</span>
                                        <span class="text-gray-400 ml-3">→ 0</span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="text-gray-300 text-sm mt-3 p-3 bg-gray-800/50 rounded border border-gray-700">
                            Short-circuits: if left is falsy, <strong>doesn't evaluate right side</strong>. Returns actual values, not booleans.
                        </div>

                        <ProTip>
                            <div>💡 <strong>Common patterns:</strong></div>
                            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                                <div class="font-mono text-[10px]"><span class="text-gray-400">// Conditional execution</span></div>
                                <div class="font-mono text-[10px]">user && console.log(user.name) <span class="text-gray-400">// only log if user exists</span></div>
                                <div class="font-mono text-[10px] mt-1"><span class="text-gray-400">// Conditional rendering (React)</span></div>
                                <div class="font-mono text-[10px]">&lbrace;isLoggedIn && &lt;Dashboard /&gt;&rbrace;</div>
                                <div class="font-mono text-[10px] mt-1"><span class="text-gray-400">// Guard with multiple conditions</span></div>
                                <div class="font-mono text-[10px]">if (user && user.isActive && user.role === 'admin') &lbrace; ... &rbrace;</div>
                            </div>
                        </ProTip>
                    </MethodCard>
                </div>

                <!-- OR (||) -->
                <div id="or">
                    <MethodCard
                        methodName="OR (||)"
