                                    <div class="text-purple-300 font-mono text-[10px] space-y-0.5">
                                        <div class="text-yellow-400 mb-1">Naming conversion:</div>
                                        <div>data-user-id → dataset.userId <span class="text-gray-400">// camelCase</span></div>
                                        <div>data-max-value → dataset.maxValue</div>
                                        <div>data-api-key → dataset.apiKey</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <ProTip>
                            <div>💡 <strong>Common use cases:</strong></div>
                            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                                <div class="font-mono text-[10px]"><span class="text-gray-400">// Store IDs for API calls</span></div>
                                <div class="font-mono text-[10px]">btn.dataset.userId = user.id</div>
                                <div class="font-mono text-[10px]">await deleteUser(btn.dataset.userId)</div>
                                <div class="font-mono text-[10px] mt-1"><span class="text-gray-400">// Config/options</span></div>
                                <div class="font-mono text-[10px]">modal.dataset.closable = 'true'</div>
                                <div class="font-mono text-[10px]">modal.dataset.animation = 'fade'</div>
                                <div class="font-mono text-[10px] mt-1"><span class="text-gray-400">// State tracking</span></div>
                                <div class="font-mono text-[10px]">tab.dataset.active = 'false'</div>
                            </div>
                        </ProTip>
                    </MethodCard>
                </div>

                <!-- COMMON ATTRIBUTES -->
                <div id="common-attributes">
                    <MethodCard
                        methodName="Common Attributes"
                        signature="Quick reference for frequent attributes"
                        description="Most commonly manipulated attributes"
                        mutates={true}
                    >
                        <div class="p-6 bg-gray-800 rounded">
                            <div class="space-y-3">
                                <!-- Form inputs -->
                                <div class="bg-blue-500/20 border border-blue-400 rounded p-3">
                                    <div class="text-blue-300 font-mono text-[10px] space-y-0.5">
                                        <div class="text-yellow-400 mb-1">Form inputs:</div>
                                        <div>input.value = 'text' <span class="text-gray-400">// input value</span></div>
                                        <div>input.checked = true <span class="text-gray-400">// checkbox/radio</span></div>
                                        <div>input.disabled = true <span class="text-gray-400">// disable input</span></div>
                                        <div>input.placeholder = 'Enter...' <span class="text-gray-400">// placeholder</span></div>
                                        <div>select.selectedIndex = 2 <span class="text-gray-400">// select option</span></div>
                                    </div>
                                </div>

                                <!-- Links & Images -->
                                <div class="bg-green-500/20 border border-green-500 rounded p-3">
                                    <div class="text-green-300 font-mono text-[10px] space-y-0.5">
                                        <div class="text-yellow-400 mb-1">Links & Images:</div>
                                        <div>link.href = '/page' <span class="text-gray-400">// URL</span></div>
                                        <div>link.target = '_blank' <span class="text-gray-400">// open in new tab</span></div>
                                        <div>img.src = 'photo.jpg' <span class="text-gray-400">// image source</span></div>
                                        <div>img.alt = 'Description' <span class="text-gray-400">// alt text</span></div>
                                    </div>
                                </div>

                                <!-- General -->
                                <div class="bg-purple-500/20 border border-purple-400 rounded p-3">
                                    <div class="text-purple-300 font-mono text-[10px] space-y-0.5">
                                        <div class="text-yellow-400 mb-1">General:</div>
                                        <div>el.id = 'main' <span class="text-gray-400">// element ID</span></div>
                                        <div>el.title = 'Tooltip' <span class="text-gray-400">// hover tooltip</span></div>
                                        <div>el.hidden = true <span class="text-gray-400">// hide element</span></div>
                                        <div>el.tabIndex = 0 <span class="text-gray-400">// keyboard focus</span></div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <ProTip>
                            <div>🎯 <strong>Real examples:</strong></div>
                            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                                <div class="font-mono text-[10px]"><span class="text-gray-400">// Disable submit button</span></div>
                                <div class="font-mono text-[10px]">submitBtn.disabled = !form.checkValidity()</div>
                                <div class="font-mono text-[10px] mt-1"><span class="text-gray-400">// Toggle password visibility</span></div>
                                <div class="font-mono text-[10px]">input.type = showPassword ? 'text' : 'password'</div>
                                <div class="font-mono text-[10px] mt-1"><span class="text-gray-400">// Dynamic image loading</span></div>
                                <div class="font-mono text-[10px]">img.src = {"`/photos/${photoId}.jpg`"}</div>
                                <div class="font-mono text-[10px]">img.alt = {"`Photo of ${userName}`"}</div>
                            </div>
                        </ProTip>
                    </MethodCard>
                </div>
