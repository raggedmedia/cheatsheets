---
import PasswordInput from "~components/forms/PasswordInput.astro";
import FormMessage from "~components/forms/FormMessage.astro";
import Layout from "~layouts/Layout.astro";
import { supabase } from "../../lib/supabase";

export const prerender = false;

// Check if user is authenticated (this page should only be accessible to authenticated users)
const {
    data: { user },
    error: userError,
} = await supabase.auth.getUser();

if (!user) {
    // User is not authenticated, redirect to reset password page
    return Astro.redirect("/auth/signin?message=signin-required&type=error");
}

let errorMessage = "";
let successMessage = "";

// Handle form submission server-side
if (Astro.request.method === "POST") {
    try {
        const formData = await Astro.request.formData();
        const password = formData.get("password")?.toString();
        const confirmPassword = formData.get("confirmPassword")?.toString();

        if (!password || !confirmPassword) {
            errorMessage = "Both password fields are required";
        } else if (password !== confirmPassword) {
            errorMessage = "Passwords do not match";
        } else if (password.length < 8) {
            errorMessage = "Password must be at least 8 characters long";
        } else {
            // Update the password - Supabase handles the authentication automatically
            const { error: updateError } = await supabase.auth.updateUser({
                password: password,
            });

            if (updateError) {
                errorMessage = updateError.message;
            } else {
                // Success - redirect to signin with success message
                return Astro.redirect(
                    "/auth/signin?message=password-updated&type=success",
                );
            }
        }
    } catch (error) {
        errorMessage = "An unexpected error occurred. Please try again.";
        console.error("Password update error:", error);
    }
}
---

<Layout pageTitle="Update Password">
    <div class="mx-auto w-96">
        <div class="prose mb-6">
            <h1>Update Password</h1>
            <p>Enter your new password below.</p>
        </div>

        <form
            method="post"
            class="flex flex-col gap-4"
            id="update-password-form"
            data-validate
            data-form-id="update-password-form"
            data-button-id="update-password-button"
        >
            {
                errorMessage && (
                    <FormMessage
                        id="update-password-error-message"
                        type="error"
                        message={errorMessage}
                        hidden={false}
                    />
                )
            }

            {
                successMessage && (
                    <FormMessage
                        id="update-password-success-message"
                        type="success"
                        message={successMessage}
                        hidden={false}
                    />
                )
            }

            <PasswordInput
                id="password"
                name="password"
                label="New Password"
                required={true}
                autocomplete="new-password"
                minlength={8}
            />

            <PasswordInput
                id="confirmPassword"
                name="confirmPassword"
                label="Confirm New Password"
                required={true}
                autocomplete="new-password"
                minlength={8}
            />

            <button
                type="submit"
                class="form-button"
                id="update-password-button"
                disabled
            >
                <span class="button-text">Update Password</span>
            </button>
        </form>

        <div class="mt-6 text-center">
            <p class="text-sm">
                <a href="/auth/signin" class="text-blue-600 hover:underline"
                    >Back to Sign In</a
                >
            </p>
        </div>
    </div>
</Layout>

<script src="~components/forms/form-validation.ts"></script>
