---
import '../styles/styles.css'
import MethodCard from '../components/visual-js/MethodCard.astro'
import Node from '../components/visual-js/Node.astro'
import ArrayDisplay from '../components/visual-js/ArrayDisplay.astro'
import Arrow from '../components/visual-js/Arrow.astro'
import ReturnValue from '../components/visual-js/ReturnValue.astro'
import InfoBox from '../components/visual-js/InfoBox.astro'
import ProcessContent from '../components/visual-js/ProcessContent.astro'
---
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>JS Array Methods - Blueprint Style</title>
        <style>
            /* Smooth scrolling */
            html {
                scroll-behavior: smooth;
                scroll-padding-top: 20px;
            }

            /* Blueprint Card */
            .blueprint {
                background: #252936;
                border-radius: 0.75rem;
                padding: 2rem;
                margin-bottom: 2.5rem;
                border: 1px solid #374151;
                position: relative;
            }

            .blueprint-header {
                margin-bottom: 2rem;
                padding-bottom: 1rem;
                border-bottom: 2px solid #374151;
            }

            .method-name {
                font-family: 'Monaco', 'Courier New', monospace;
                font-size: 1.8rem;
                font-weight: 700;
                color: #60a5fa;
                margin-bottom: 0.5rem;
            }

            .method-signature {
                font-family: 'Monaco', 'Courier New', monospace;
                font-size: 0.95rem;
                color: #9ca3af;
                margin-bottom: 0.75rem;
            }

            .method-desc {
                color: #d1d5db;
                font-size: 0.95rem;
                line-height: 1.6;
            }

            .badge {
                display: inline-block;
                padding: 0.25rem 0.75rem;
                border-radius: 0.25rem;
                font-size: 0.75rem;
                font-weight: 600;
                text-transform: uppercase;
                margin-left: 1rem;
            }

            .badge-mutates {
                background: rgba(239, 68, 68, 0.2);
                color: #fca5a5;
                border: 1px solid #ef4444;
            }

            .badge-immutable {
                background: rgba(34, 197, 94, 0.2);
                color: #86efac;
                border: 1px solid #22c55e;
            }

            /* Flow Diagram */
            .flow-diagram {
                display: flex;
                align-items: center;
                gap: 2rem;
                padding: 2rem;
                background: #1f2937;
                border-radius: 0.5rem;
                overflow-x: auto;
            }

            /* Nodes */
            .node {
                position: relative;
                min-width: 180px;
                flex-shrink: 0;
            }

            .node-label {
                font-size: 0.75rem;
                font-weight: 600;
                text-transform: uppercase;
                letter-spacing: 0.05em;
                color: #9ca3af;
                margin-bottom: 0.5rem;
                text-align: center;
            }

            .node-content {
                background: #374151;
                border: 2px solid #4b5563;
                border-radius: 0.25rem;
                padding: 0.5rem;
                position: relative;
            }

            /* Custom gradient backgrounds */
            .node-input .node-content {
                background: linear-gradient(135deg, #1e3a8a 0%, #1e40af 100%);
                border-color: #3b82f6;
            }

            .node-process .node-content {
                background: linear-gradient(135deg, #4c1d95 0%, #5b21b6 100%);
                border-color: #8b5cf6;
                padding: 0.75rem 0.5rem;
            }

            .node-output .node-content {
                background: linear-gradient(135deg, #166534 0%, #15803d 100%);
                border-color: #22c55e;
            }

            .process-name {
                font-family: 'Monaco', 'Courier New', monospace;
                font-weight: 700;
                font-size: 0.875rem;
                color: #fff;
                text-align: center;
                margin-bottom: 0.25rem;
            }

            .process-desc {
                font-size: 0.688rem;
                color: #e9d5ff;
                text-align: center;
                line-height: 1.3;
            }

            /* Array Display */
            .array-display {
                display: flex;
                gap: 0.375rem;
                justify-content: center;
                flex-wrap: wrap;
            }

            .array-item {
                min-width: 32px;
                padding: 0.375rem 0.5rem;
                background: rgba(255, 255, 255, 0.1);
                border: 1px solid rgba(255, 255, 255, 0.3);
                border-radius: 0.25rem;
                text-align: center;
                font-family: 'Monaco', 'Courier New', monospace;
                font-weight: 600;
                font-size: 0.813rem;
                position: relative;
            }

            .array-index {
                position: absolute;
                top: -6px;
                left: 50%;
                transform: translateX(-50%);
                font-size: 0.563rem;
                color: #9ca3af;
                background: #1f2937;
                padding: 0 0.25rem;
            }

            /* Value Display */
            .value-display {
                padding: 0.5rem 0.75rem;
                background: rgba(255, 255, 255, 0.1);
                border: 1px solid rgba(255, 255, 255, 0.3);
                border-radius: 0.25rem;
                text-align: center;
                font-family: 'Monaco', 'Courier New', monospace;
                font-weight: 600;
                font-size: 0.875rem;
            }

            .value-type {
                font-size: 0.625rem;
                color: #9ca3af;
                margin-top: 0.125rem;
            }

            /* Arrow styling */
            .arrow {
                flex-shrink: 0;
                width: 40px;
                height: 2px;
                background: #4b5563;
                position: relative;
            }

            .arrow::after {
                content: '';
                position: absolute;
                right: -5px;
                top: -3px;
                width: 0;
                height: 0;
                border-left: 8px solid #4b5563;
                border-top: 4px solid transparent;
                border-bottom: 4px solid transparent;
            }

            .arrow-label {
                position: absolute;
                top: -14px;
                left: 50%;
                transform: translateX(-50%);
                font-size: 0.563rem;
                color: #6b7280;
                white-space: nowrap;
            }

            /* Special highlights */
            .highlight-added {
                background: rgba(34, 197, 94, 0.4) !important;
                border-color: #22c55e !important;
                box-shadow: 0 0 6px rgba(34, 197, 94, 0.3);
                animation: pulse 1s ease-in-out infinite;
            }

            .highlight-removed {
                background: rgba(239, 68, 68, 0.3) !important;
                border-color: #ef4444 !important;
                opacity: 0.6;
                text-decoration: line-through;
            }

            .highlight-transformed {
                background: rgba(251, 146, 60, 0.4) !important;
                border-color: #fb923c !important;
                box-shadow: 0 0 6px rgba(251, 146, 60, 0.3);
            }

            /* Pulse animation */
            @keyframes pulse {
                0%, 100% { opacity: 1; }
                50% { opacity: 0.7; }
            }

            /* Info box */
            .info-box {
                background: rgba(59, 130, 246, 0.1);
                border: 1px solid #3b82f6;
                border-radius: 0.5rem;
                padding: 1rem;
                margin-top: 1.5rem;
            }

            .info-title {
                font-weight: 600;
                color: #60a5fa;
                margin-bottom: 0.5rem;
                font-size: 0.9rem;
            }

            .info-content {
                font-size: 0.85rem;
                color: #d1d5db;
                line-height: 1.5;
            }

            .info-content code {
                background: rgba(0, 0, 0, 0.3);
                padding: 0.125rem 0.375rem;
                border-radius: 0.25rem;
                font-family: 'Monaco', 'Courier New', monospace;
                color: #fbbf24;
            }
        </style>
	</head>
	<body class="m-0 p-4 bg-[#1a1d29] text-gray-200">
        <div class="flex gap-6 max-w-[1600px] mx-auto">
            <!-- Main Content -->
            <main class="flex-1 min-w-0">
                <h1 class="text-white mb-1 text-2xl font-bold">JavaScript Array Methods</h1>
                <p class="text-gray-400 mb-6 text-sm">Visual blueprint-style reference for array operations</p>

                <!-- ============================================ -->
                <!-- � CONVERTING TO ARRAYS -->
                <!-- ============================================ -->

                <h2 id="converting" class="text-blue-300 text-xl my-4 pb-2 border-b-2 border-blue-500">
                    🔄 Converting to Arrays
                </h2>

                <!-- === STRING TO ARRAY === -->
                <h3 id="string-to-array" class="text-gray-300 text-lg mt-4 mb-2">String to Array</h3>

                <!-- SPLIT -->
                <div id="split">
                    <MethodCard
                        methodName="split()"
                        signature="str.split(separator)"
                        description="Splits a string into an array of substrings"
                        mutates={false}
                    >
                        <div class="flex items-center gap-4 p-3 bg-gray-800 rounded overflow-x-auto">
                            <Node label="String" type="input">
                                <div class="text-center text-sm font-mono">"hello"</div>
                            </Node>

                            <Arrow label="splits" />

                            <Node label="Method" type="process">
                                <ProcessContent name="split('')" description="Split into chars" />
                            </Node>

                            <Arrow label="returns" />

                            <Node label="Array" type="output">
                                <ArrayDisplay values={['h', 'e', 'l', 'l', 'o']} highlightIndices={[0, 1, 2, 3, 4]} highlightType="added" />
                            </Node>
                        </div>

                        <InfoBox mutates={false} message="">
                            Returns a <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">new array</code>. Use <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">split('')</code> for chars, <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">split(' ')</code> for words.
                        </InfoBox>
                    </MethodCard>
                </div>

                <!-- ARRAY.FROM STRING -->
                <div id="array-from-string">
                    <MethodCard
                        methodName="Array.from()"
                        signature="Array.from(string)"
                        description="Creates array from string or iterable"
                        mutates={false}
                    >
                        <div class="flex items-center gap-4 p-3 bg-gray-800 rounded overflow-x-auto">
                            <Node label="String" type="input">
                                <div class="text-center text-sm font-mono">"abc"</div>
                            </Node>

                            <Arrow label="converts" />

                            <Node label="Method" type="process">
                                <ProcessContent name="Array.from(str)" description="String to array" />
                            </Node>

                            <Arrow label="returns" />

                            <Node label="Array" type="output">
                                <ArrayDisplay values={['a', 'b', 'c']} highlightIndices={[0, 1, 2]} highlightType="added" />
                            </Node>
                        </div>

                        <InfoBox mutates={false} message="">
                            Static method. Returns a <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">new array</code> from any iterable or array-like object.
                        </InfoBox>
                    </MethodCard>
                </div>

                <!-- SPREAD STRING -->
                <div id="spread-string">
                    <MethodCard
                        methodName="Spread [...str]"
                        signature="[...string]"
                        description="Uses spread operator to convert string to array"
                        mutates={false}
                    >
                        <div class="flex items-center gap-4 p-3 bg-gray-800 rounded overflow-x-auto">
                            <Node label="String" type="input">
                                <div class="text-center text-sm font-mono">"hello"</div>
                            </Node>

                            <Arrow label="spreads" />

                            <Node label="Syntax" type="process">
                                <ProcessContent name="[...str]" description="Spread into array" />
                            </Node>

                            <Arrow label="returns" />

                            <Node label="Array" type="output">
                                <ArrayDisplay values={['h', 'e', 'l', 'l', 'o']} highlightIndices={[0, 1, 2, 3, 4]} highlightType="added" />
                            </Node>
                        </div>

                        <InfoBox mutates={false} message="">
                            Modern syntax. Creates a <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">new array</code> with each character as an element.
                        </InfoBox>
                    </MethodCard>
                </div>

                <!-- === NUMBER TO ARRAY === -->
                <h3 id="number-to-array" class="text-gray-300 text-lg mt-4 mb-2">Number to Array</h3>

                <!-- NUMBER TO DIGITS -->
                <div id="number-to-digits">
                    <MethodCard
                        methodName="String() + split()"
                        signature="String(num).split('')"
                        description="Converts number to array of digit strings"
                        mutates={false}
                    >
                        <div class="flex items-center gap-4 p-3 bg-gray-800 rounded overflow-x-auto">
                            <Node label="Number" type="input">
                                <div class="text-center text-sm font-mono">12345</div>
                            </Node>

                            <Arrow label="converts" />

                            <Node label="Method" type="process">
                                <ProcessContent name="String(num).split('')" description="To string, then split" />
                            </Node>

                            <Arrow label="returns" />

                            <Node label="Array" type="output">
                                <ArrayDisplay values={['1', '2', '3', '4', '5']} highlightIndices={[0, 1, 2, 3, 4]} highlightType="added" />
                            </Node>
                        </div>

                        <InfoBox mutates={false} message="">
                            Returns array of <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">digit strings</code>. Use <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">.map(Number)</code> to convert to numbers.
                        </InfoBox>
                    </MethodCard>
                </div>

                <!-- ARRAY.FROM NUMBER -->
                <div id="array-from-number">
                    <MethodCard
                        methodName="Array.from() + map"
                        signature="Array.from(String(num), Number)"
                        description="Converts number to array of digit numbers"
                        mutates={false}
                    >
                        <div class="flex items-center gap-4 p-3 bg-gray-800 rounded overflow-x-auto">
                            <Node label="Number" type="input">
                                <div class="text-center text-sm font-mono">123</div>
                            </Node>

                            <Arrow label="converts" />

                            <Node label="Method" type="process">
                                <ProcessContent name="Array.from(String(num), Number)" description="String then map to numbers" />
                            </Node>

                            <Arrow label="returns" />

                            <Node label="Array" type="output">
                                <ArrayDisplay values={[1, 2, 3]} highlightIndices={[0, 1, 2]} highlightType="added" />
                            </Node>
                        </div>

                        <InfoBox mutates={false} message="">
                            Returns array of <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">digit numbers</code>. Second parameter is mapping function.
                        </InfoBox>
                    </MethodCard>
                </div>

                <!-- ============================================ -->
                <!-- �🛠 MUTATES THE ARRAY -->
                <!-- ============================================ -->

                <h2 id="mutates" class="text-red-300 text-xl my-4 pb-2 border-b-2 border-red-500">
                    🛠 Mutates the Array
                </h2>

                <!-- === INSERT / REMOVE === -->
                <h3 id="insert-remove" class="text-gray-300 text-lg mt-4 mb-2">Insert / Remove</h3>

                <!-- PUSH -->
                <div id="push">
                    <MethodCard
                        methodName="push()"
                        signature="arr.push(...items)"
                        description="Adds elements to the end of an array and returns the new length"
                        mutates={true}
                    >
                <div class="flex items-center gap-4 p-3 bg-gray-800 rounded overflow-x-auto">
                    <Node label="Input Array" type="input">
                        <ArrayDisplay values={['a', 'b', 'c']} />
                    </Node>

                    <Arrow label="mutates" />

                    <Node label="Method" type="process">
                        <ProcessContent name="push('d')" description="Add to end" />
                    </Node>

                    <Arrow />

                    <Node label="Modified Array" type="output">
                        <ArrayDisplay values={['a', 'b', 'c', 'd']} highlightIndices={[3]} highlightType="added" />
                    </Node>

                    <Arrow label="returns" />

                    <Node label="Return Value" type="output">
                        <ReturnValue value={4} type="new length" />
                    </Node>
                </div>

                        <InfoBox mutates={true} message="">
                            The original array is modified in place. Returns <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">number</code> (new length), not the array. ⚠️ Cannot be chained with other array methods.
                        </InfoBox>
                    </MethodCard>
                </div>

                <!-- POP -->
                <div id="pop">
                    <MethodCard
                methodName="pop()"
                signature="arr.pop()"
                description="Removes and returns the last element from an array"
                mutates={true}
            >
                <div class="flex items-center gap-4 p-3 bg-gray-800 rounded overflow-x-auto">
                    <Node label="Input Array" type="input">
                        <ArrayDisplay values={['a', 'b', 'c']} />
                    </Node>

                    <Arrow label="mutates" />

                    <Node label="Method" type="process">
                        <ProcessContent name="pop()" description="Remove last" />
                    </Node>

                    <Arrow />

                    <Node label="Modified Array" type="output">
                        <ArrayDisplay values={['a', 'b']} />
                    </Node>

                    <Arrow label="returns" />

                    <Node label="Return Value" type="output">
                        <ReturnValue value="'c'" type="removed item" />
                    </Node>
                </div>

                <InfoBox mutates={true} message="">
                    The original array is shortened. Returns the removed <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">element</code> (or undefined if empty). ⚠️ Cannot be chained with other array methods.
                </InfoBox>
            </MethodCard>
                </div>

                <!-- UNSHIFT -->
                <div id="unshift">
            <MethodCard
                methodName="unshift()"
                signature="arr.unshift(...items)"
                description="Adds elements to the beginning of an array and returns the new length"
                mutates={true}
            >
                <div class="flex items-center gap-4 p-3 bg-gray-800 rounded overflow-x-auto">
                    <Node label="Input Array" type="input">
                        <ArrayDisplay values={['b', 'c', 'd']} />
                    </Node>

                    <Arrow label="mutates" />

                    <Node label="Method" type="process">
                        <ProcessContent name="unshift('a')" description="Add to beginning" />
                    </Node>

                    <Arrow />

                    <Node label="Modified Array" type="output">
                        <ArrayDisplay values={['a', 'b', 'c', 'd']} highlightIndices={[0]} highlightType="added" />
                    </Node>

                    <Arrow label="returns" />

                    <Node label="Return Value" type="output">
                        <ReturnValue value={4} type="new length" />
                    </Node>
                </div>

                <InfoBox mutates={true} message="">
                    The original array is modified in place. All existing elements shift to higher indices. Returns <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">number</code> (new length). ⚠️ Cannot be chained with other array methods.
                </InfoBox>
            </MethodCard>
                </div>

                <!-- SHIFT -->
                <div id="shift">
            <MethodCard
                methodName="shift()"
                signature="arr.shift()"
                description="Removes and returns the first element from an array"
                mutates={true}
            >
                <div class="flex items-center gap-4 p-3 bg-gray-800 rounded overflow-x-auto">
                    <Node label="Input Array" type="input">
                        <ArrayDisplay values={['a', 'b', 'c']} />
                    </Node>

                    <Arrow label="mutates" />

                    <Node label="Method" type="process">
                        <ProcessContent name="shift()" description="Remove first" />
                    </Node>

                    <Arrow />

                    <Node label="Modified Array" type="output">
                        <ArrayDisplay values={['b', 'c']} />
                    </Node>

                    <Arrow label="returns" />

                    <Node label="Return Value" type="output">
                        <ReturnValue value="'a'" type="removed item" />
                    </Node>
                </div>

                <InfoBox mutates={true} message="">
                    The original array is shortened. All remaining elements shift to lower indices. Returns the removed <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">element</code> (or undefined if empty). ⚠️ Cannot be chained with other array methods.
                </InfoBox>
            </MethodCard>
                </div>

                <!-- SPLICE -->
                <div id="splice">
            <MethodCard
                methodName="splice()"
                signature="arr.splice(start, deleteCount, ...items)"
                description="Removes, replaces, or adds elements at any position in the array"
                mutates={true}
            >
                <div class="flex items-center gap-4 p-3 bg-gray-800 rounded overflow-x-auto">
                    <Node label="Input Array" type="input">
                        <ArrayDisplay values={['a', 'b', 'c', 'd']} />
                    </Node>

                    <Arrow label="mutates" />

                    <Node label="Method" type="process">
                        <ProcessContent name="splice(1, 2, 'X', 'Y')" description="At index 1, remove 2, insert 'X', 'Y'" />
                    </Node>

                    <Arrow />

                    <Node label="Modified Array" type="output">
                        <ArrayDisplay values={['a', 'X', 'Y', 'd']} highlightIndices={[1, 2]} highlightType="added" />
                    </Node>

                    <Arrow label="returns" />

                    <Node label="Return Value" type="output">
                        <ArrayDisplay values={['b', 'c']} highlightIndices={[0, 1]} highlightType="removed" />
                    </Node>
                </div>

                <InfoBox mutates={true} message="">
                    The Swiss Army knife of array methods. Returns an <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">array</code> of removed elements. Can remove, add, or replace items at any index.
                </InfoBox>

                <div class="mt-2 p-2 bg-purple-900/20 border border-purple-500/30 rounded text-[11px] leading-snug">
                    <div class="text-purple-300 font-bold mb-1">💡 Pro tip:</div>
                    <div class="text-gray-300 space-y-1">
                        <div>Insert without deleting by setting deleteCount to 0:</div>
                        <div class="pl-2 border-l-2 border-purple-500/30 font-mono text-[10px]">
                            arr.splice(2, 0, 'x', 'y') → inserts 'x', 'y' at index 2
                        </div>
                    </div>
                </div>
            </MethodCard>
                </div>

            <!-- === REORDER === -->
            <h3 id="reorder" class="text-gray-300 text-lg mt-4 mb-2">Reorder</h3>

                <!-- SORT -->
                <div id="sort">
            <MethodCard
                methodName="sort()"
                signature="arr.sort(compareFn?)"
                description="Sorts the array in place and returns the same array"
                mutates={true}
            >
                <div class="flex items-center gap-4 p-3 bg-gray-800 rounded overflow-x-auto">
                    <Node label="Input Array" type="input">
                        <ArrayDisplay values={[3, 1, 4, 2]} />
                    </Node>

                    <Arrow label="mutates" />

                    <Node label="Method" type="process">
                        <ProcessContent name="sort((a, b) => a - b)" description="Ascending order" />
                    </Node>

                    <Arrow label="returns" />

                    <Node label="Same Array (Sorted)" type="output">
                        <ArrayDisplay values={[1, 2, 3, 4]} highlightIndices={[0, 1, 2, 3]} highlightType="transformed" />
                    </Node>
                </div>

                <InfoBox mutates={true} message="">
                    Sorts in place. Returns the <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">same array</code> (not a copy).
                </InfoBox>

                <div class="mt-2 p-2 bg-purple-900/20 border border-purple-500/30 rounded text-[11px] leading-snug">
                    <div class="text-purple-300 font-bold mb-1">💡 Pro tip:</div>
                    <div class="text-gray-300 space-y-1.5">
                        <div>Without a compare function, sort treats values as strings!</div>

                        <div class="pl-2 border-l-2 border-purple-500/30">
                            <div class="font-mono text-[10px]">['b','d','a','c'].sort() → ['a','b','c','d']</div>
                            <div class="font-mono text-[10px]">['b','d','a','c'].sort().reverse() → ['d','c','b','a']</div>
                        </div>

                        <div>For numbers, use compare function:</div>

                        <div class="pl-2 border-l-2 border-purple-500/30">
                            <div class="font-mono text-[10px]">[2,4,1,3].sort((a,b) => a-b) → [1,2,3,4] <span class="text-gray-400">// ascending</span></div>
                            <div class="font-mono text-[10px]">[2,4,1,3].sort((a,b) => b-a) → [4,3,2,1] <span class="text-gray-400">// descending</span></div>
                            <div class="font-mono text-[10px] text-gray-400">// OR: .sort((a,b) => a-b).reverse() → [4,3,2,1]</div>
                        </div>
                    </div>
                </div>
