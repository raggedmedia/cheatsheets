                                div.dataset.status = 'active' <span
                                    class="text-gray-400"
                                    >// adds data-status</span>
                            </div>
                            <div>
                                delete div.dataset.role <span
                                    class="text-gray-400"
                                    >// removes data-role</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Naming -->
                <div
                    class="bg-purple-500/20 border border-purple-400 rounded p-3"
                >
                    <div
                        class="text-purple-300 font-mono text-[10px] space-y-0.5"
                    >
                        <div class="text-yellow-400 mb-1">
                            Naming conversion:
