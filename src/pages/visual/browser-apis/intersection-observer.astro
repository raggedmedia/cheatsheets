    <SectionTitle id="cleanup" color="red">
        🛠️ Cleanup & Performance
    </SectionTitle>

    <MethodCard
        id="cleanup-patterns"
        methodName="Proper Cleanup"
            signature="disconnect(), unobserve()"
            description="Prevent memory leaks"
            mutates={false}
        >
            <div class="p-6 bg-gray-800 rounded space-y-4">
                <!-- Unobserve vs disconnect -->
                <div class="bg-slate-700 border border-slate-600 rounded p-4">
                    <div class="text-slate-300 text-[11px] space-y-2">
                        <div class="text-yellow-400 mb-2">Two cleanup methods:</div>
                        <div>• <code class="bg-slate-800 px-1 py-0.5 rounded">observer.unobserve(element)</code> - Stop watching one element</div>
                        <div>• <code class="bg-slate-800 px-1 py-0.5 rounded">observer.disconnect()</code> - Stop watching all elements</div>
                    </div>
                </div>

                <!-- When to unobserve -->
                <div class="bg-green-500/20 border border-green-500 rounded p-4">
                    <div class="text-green-300 font-mono text-[11px] space-y-1">
                        <div class="text-yellow-400 mb-2">Unobserve after one-time animations:</div>
                        <div>if (entry.isIntersecting) {`{`}</div>
                        <div>&nbsp;&nbsp;entry.target.classList.add('visible');</div>
                        <div>&nbsp;&nbsp;observer.unobserve(entry.target); <span class="text-gray-400">// Done, stop watching</span></div>
                        <div>{'}'}</div>
                    </div>
                </div>

                <!-- When to disconnect -->
                <div class="bg-blue-500/20 border border-blue-400 rounded p-4">
                    <div class="text-blue-300 font-mono text-[11px] space-y-1">
                        <div class="text-yellow-400 mb-2">Disconnect when component unmounts:</div>
                        <div><span class="text-gray-400">// React example</span></div>
                        <div>useEffect(() => {`{`}</div>
                        <div>&nbsp;&nbsp;const observer = new IntersectionObserver(callback);</div>
                        <div>&nbsp;&nbsp;observer.observe(element);</div>
                        <div>&nbsp;&nbsp;</div>
                        <div>&nbsp;&nbsp;return () => observer.disconnect(); <span class="text-gray-400">// Cleanup</span></div>
                        <div>{'}'}, [])</div>
                    </div>
                </div>

                <!-- Performance tips -->
                <div class="bg-purple-500/20 border border-purple-400 rounded p-4">
                    <div class="text-purple-300 text-[11px] space-y-2">
                        <div class="text-yellow-400 mb-2">Performance tips:</div>
                        <div>• Use <strong>one observer</strong> for multiple elements of the same type</div>
                        <div>• <strong>Unobserve</strong> elements you're done with (fade-ins, lazy load)</div>
                        <div>• <strong>Keep observing</strong> for repeated interactions (video pause/play)</div>
                        <div>• Avoid <strong>heavy calculations</strong> in the callback</div>
                    </div>
                </div>
            </div>

            <ProTip>
                <div>💡 <strong>Memory leak prevention:</strong> Always disconnect observers when removing elements from DOM or unmounting components.</div>
            </ProTip>
        </MethodCard>

