<script>
    // function that returns a promise which resolves after 1s
    // function that sometimes rejects a promise with an error, 50% chance
    // use .then and catch for both cases.

    // a similar one but async await

    function blah() {
        const blah = new Promise((resolve, reject) => {
            const autoReject = true;

            if (autoReject === false) {
                reject('oops');
                return;
            } else {
                setTimeout(() => {
                    resolve('hello');
                    return;
                }, 1000);
            }
        })

        blah.then((response) => {
            console.log(response);
        }).catch((error) => {
            console.log(error);

            console.error(error);
        });
    }

    blah();

    async function pizza() {
        const pizza = new Promise((resolve, reject) => {
            setTimeout(() => {
                console.log('blam');
                resolve('we did it!');
                return;

            }, 300);
        });

        await pizza;
    }

    pizza();

    function promisesDemo() {
        const egData = fetch('https://jsonplaceholder.typicode.com/posts/');

        console.log(egData);

        egData
            .then(response => response.json())
            .then((data) => {
                console.log(egData);

            })
           console.log(egData);
    }

    // promisesDemo();
</script>

<h2>Okay now for a promises practice, let's fetch some data</h2>
