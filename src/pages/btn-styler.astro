---
import '../styles/styles.css'
---
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Btn Builder</title>
        <style id="achilles-styles">
            #achilles {
                --achilles-padding-left: var(--spacing-base);
                --achilles-padding-right: var(--spacing-base);
                --achilles-padding-top: var(--spacing-sm);
                --achilles-padding-bottom: var(--spacing-sm);

                padding-left: var(--achilles-padding-left);
                padding-right: var(--achilles-padding-right);
                padding-top: var(--achilles-padding-top);
                padding-bottom: var(--achilles-padding-bottom);
            }
        </style>
	</head>
	<body>
        <h1>Btn Builder</h1>
        <p>Use a <code>a</code> for navigation and a <code>button</code> for actions. Links are for 'going', buttons are for 'doing'.</p>
        <p>So while we call it a button style, it's a visual flair that applies to two different HTML elements.</p>

        <div class="controls space-y-4 max-w-2xl">
            <!-- Padding Left -->
            <div class="flex items-center gap-2">
                <button id="decrease-pl" class="px-2 py-1 border">-</button>
                <label for="pl-range" class="min-w-[200px]">
                    Padding Left: <span id="pl-value">pl-4</span>
                </label>
                <input
                    type="range"
                    id="pl-range"
                    min="0"
                    step="1"
                    class="flex-1"
                />
                <button id="increase-pl" class="px-2 py-1 border">+</button>
            </div>

            <!-- Padding Right -->
            <div class="flex items-center gap-2">
                <button id="decrease-pr" class="px-2 py-1 border">-</button>
                <label for="pr-range" class="min-w-[200px]">
                    Padding Right: <span id="pr-value">pr-4</span>
                </label>
                <input
                    type="range"
                    id="pr-range"
                    min="0"
                    step="1"
                    class="flex-1"
                />
                <button id="increase-pr" class="px-2 py-1 border">+</button>
            </div>

            <!-- Padding Top -->
            <div class="flex items-center gap-2">
                <button id="decrease-pt" class="px-2 py-1 border">-</button>
                <label for="pt-range" class="min-w-[200px]">
                    Padding Top: <span id="pt-value">pt-2</span>
                </label>
                <input
                    type="range"
                    id="pt-range"
                    min="0"
                    step="1"
                    class="flex-1"
                />
                <button id="increase-pt" class="px-2 py-1 border">+</button>
            </div>

            <!-- Padding Bottom -->
            <div class="flex items-center gap-2">
                <button id="decrease-pb" class="px-2 py-1 border">-</button>
                <label for="p b-range" class="min-w-[200px]">
                    Padding Bottom: <span id="pb-value">pb-2</span>
                </label>
                <input
                    type="range"
                    id="pb-range"
                    min="0"
                    step="1"
                    class="flex-1"
                />
                <button id="increase-pb" class="px-2 py-1 border">+</button>
            </div>
        </div>

        <div class="example mx-auto mt-8 flex justify-center">
            <a id="achilles" href="" class="btn bg-blue-500 text-white">Hello, world!</a>
        </div>
	</body>
</html>

<script>
    // Read spacing scale dynamically from CSS custom properties
    const spacingNames = ['none', 'xs', 'sm', 'md', 'base', 'lg', '1xl', '2xl', '3xl', '4xl', '5xl', '6xl', '7xl', '8xl', '9xl'];
    const spacingScale: Array<{ name: string, var: string, px: number }> = [];

    spacingNames.forEach(name => {
        const varName = `--spacing-${name}`;
        const value = getComputedStyle(document.documentElement).getPropertyValue(varName).trim();
        const px = parseInt(value);

        if (!isNaN(px)) {
            spacingScale.push({ name, var: varName, px });
        }
    });

    console.log('Spacing scale loaded:', spacingScale);

    // Map to Tailwind reference for display (approximate)
    const pxToTailwind: Record<number, string> = {
        0: '0', 4: '1', 8: '2', 12: '3', 16: '4', 20: '5', 24: '6', 32: '8',
        40: '10', 48: '12', 64: '16', 80: '20', 96: '24', 128: '32', 160: '40'
    };

    const btn = document.getElementById('achilles') as HTMLElement;

    // Map side to CSS custom property
    const sideToCSSVar: Record<string, string> = {
        'pl': '--achilles-padding-left',
        'pr': '--achilles-padding-right',
        'pt': '--achilles-padding-top',
        'pb': '--achilles-padding-bottom',
    };

    // Initialize all range inputs
    const sides = ['pl', 'pr', 'pt', 'pb'] as const;
    const defaultIndices: Record<string, number> = {
        'pl': 4,  // base (16px)
        'pr': 4,  // base (16px)
        'pt': 2,  // sm (8px)
        'pb': 2,  // sm (8px)
    };

    sides.forEach(side => {
        const range = document.getElementById(`${side}-range`) as HTMLInputElement;
        const valueSpan = document.getElementById(`${side}-value`);
        const decreaseBtn = document.getElementById(`decrease-${side}`);
        const increaseBtn = document.getElementById(`increase-${side}`);

        if (range) {
            range.max = (spacingScale.length - 1).toString();
            range.value = defaultIndices[side].toString();
        }

        // Range input handler
        range?.addEventListener('input', (e) => {
            const target = e.target as HTMLInputElement;
            const index = parseInt(target.value);
            const spacing = spacingScale[index];
            const tailwindRef = pxToTailwind[spacing.px] || spacing.px.toString();

            // Update CSS custom property on the element itself
            // This keeps the CSS variables scoped to the element, clean and semantic
            if (btn) {
                btn.style.setProperty(sideToCSSVar[side], `var(${spacing.var})`);
                console.log(`Updated ${sideToCSSVar[side]} to var(${spacing.var})`);
            }

            // Update display with spacing name and Tailwind reference
            if (valueSpan) {
                valueSpan.textContent = `${spacing.name} (${spacing.px}px ≈ ${side}-${tailwindRef})`;
            }
        });

        // Decrease button
        decreaseBtn?.addEventListener('click', () => {
            if (range) {
                const currentValue = parseInt(range.value);
                const newValue = Math.max(0, currentValue - 1);
                range.value = newValue.toString();
                range.dispatchEvent(new Event('input'));
            }
        });

        // Increase button
        increaseBtn?.addEventListener('click', () => {
            if (range) {
                const currentValue = parseInt(range.value);
                const newValue = Math.min(spacingScale.length - 1, currentValue + 1);
                range.value = newValue.toString();
                range.dispatchEvent(new Event('input'));
            }
        });

        // Initialize display on page load
        range?.dispatchEvent(new Event('input'));
    });
</script>
