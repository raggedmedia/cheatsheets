                            <!-- Conversion table -->
                            <div class="space-y-3">
                                <div class="text-xs text-gray-300 mb-2">Converts to boolean, then negates:</div>

                                <div class="grid grid-cols-2 gap-2">
                                    <!-- Truthy values -->
                                    <div class="p-2 bg-green-500/5 border border-green-500/30 rounded">
                                        <div class="text-green-300 text-[10px] font-bold mb-1">Truthy → false</div>
                                        <div class="font-mono text-[10px] space-y-0.5 text-gray-300">
                                            <div>!<span class="text-green-300">true</span> → <span class="text-red-300">false</span></div>
