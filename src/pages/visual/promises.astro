                                <div class="font-mono text-[10px]">const [user, settings, posts] = await Promise.all([</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;getUser(), getPosts(), getSettings()</div>
                                <div class="font-mono text-[10px]">]) <span class="text-gray-400">// all run at once</span></div>
                            </div>
                        </ProTip>
                    </MethodCard>
                </div>

                <!-- ERROR HANDLING -->
                <div id="error-handling">
                    <MethodCard
                        methodName="Error Handling Strategies"
                        signature="try/catch vs .catch() vs default values"
                        description="Different approaches to handling failures"
                        mutates={false}
                    >
                        <ProTip>
                            <div>🛡️ <strong>Strategy 1: Try/Catch</strong></div>
                            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                                <div class="font-mono text-[10px]">try &lbrace;</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;const data = await fetchData()</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;return data</div>
                                <div class="font-mono text-[10px]">&rbrace; catch (error) &lbrace;</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;console.error(error)</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;return null <span class="text-gray-400">// fallback</span></div>
                                <div class="font-mono text-[10px]">&rbrace;</div>
                            </div>
                        </ProTip>

                        <ProTip>
                            <div>🛡️ <strong>Strategy 2: .catch() with default</strong></div>
                            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                                <div class="font-mono text-[10px]">const data = await fetchData()</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;.catch(err =&gt; &lbrace;</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;&nbsp;&nbsp;console.error(err)</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;&nbsp;&nbsp;return [] <span class="text-gray-400">// default value</span></div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;&rbrace;)</div>
                            </div>
                        </ProTip>

                        <ProTip>
                            <div>🛡️ <strong>Strategy 3: Conditional error handling</strong></div>
                            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                                <div class="font-mono text-[10px]">const result = await fetchData().catch(err =&gt; &lbrace;</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;if (err.code === 'NOT_FOUND') return null</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;throw err <span class="text-gray-400">// re-throw other errors</span></div>
                                <div class="font-mono text-[10px]">&rbrace;)</div>
                            </div>
                        </ProTip>
                    </MethodCard>
                </div>

