---
import MethodCard from '../../components/visual-js/MethodCard.astro';
import ProTip from '../../components/visual-js/ProTip.astro';
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Fetch API - Browser APIs</title>
    <link rel="stylesheet" href="/src/styles/styles.css">
</head>
<body class="bg-slate-900 text-slate-50 p-8">

<div class="max-w-5xl mx-auto">
    <h1 class="text-4xl mb-2 text-blue-400">🌐 Fetch API</h1>
    <p class="text-slate-400 mb-12">Modern HTTP requests - Quick reference + best practices</p>

    <!-- ============================================ -->
    <!-- ⚠️ CRITICAL GOTCHA -->
    <!-- ============================================ -->

    <div class="bg-red-500/10 border-l-4 border-red-500 p-6 rounded mb-8">
        <h3 class="text-red-400 font-bold text-lg mb-3">⚠️ Critical: fetch() only rejects on network errors!</h3>
        <div class="space-y-4">
            <div class="grid grid-cols-2 gap-4">
                <div class="bg-slate-800 p-4 rounded">
                    <div class="text-red-400 font-bold text-sm mb-2">❌ Network Errors (fetch rejects)</div>
                    <ul class="text-xs text-slate-300 space-y-1 list-disc ml-4">
                        <li>No internet connection</li>
                        <li>DNS lookup failed</li>
                        <li>Server unreachable</li>
                        <li>Request timeout</li>
                        <li>CORS blocked</li>
                    </ul>
                </div>
                <div class="bg-slate-800 p-4 rounded">
                    <div class="text-orange-400 font-bold text-sm mb-2">📊 HTTP Errors (fetch succeeds!)</div>
                    <ul class="text-xs text-slate-300 space-y-1 list-disc ml-4">
                        <li>400 Bad Request</li>
                        <li>401 Unauthorized</li>
                        <li>404 Not Found</li>
                        <li>500 Server Error</li>
                        <li>503 Service Unavailable</li>
                    </ul>
                </div>
            </div>

            <div class="bg-slate-800 p-4 rounded">
                <div class="text-yellow-400 text-xs mb-2">✅ Always check response.ok:</div>
                <pre class="text-green-300 font-mono text-[10px] leading-relaxed"><code>const response = await fetch('https://api.example.com/users');

if (!response.ok) {'{'}
  throw new Error(`HTTP error! status: ${'{'}response.status{'}'}`);
{'}'}

const data = await response.json();</code></pre>
            </div>
        </div>
    </div>

    <!-- ============================================ -->
    <!-- 🚀 QUICK START -->
    <!-- ============================================ -->

    <h2 id="quick-start" class="text-cyan-300 text-xl my-4 pb-2 border-b-2 border-cyan-600">
        🚀 Quick Start
    </h2>

    <div id="basic-examples">
        <MethodCard
            methodName="Basic Fetch Patterns"
            signature="GET, POST, error handling, loading states"
            description="Everything you need for 90% of use cases"
            mutates={false}
        >
            <div class="p-6 bg-gray-800 rounded space-y-4">
                <!-- GET with error handling -->
                <div class="bg-blue-500/20 border border-blue-400 rounded p-4">
                    <div class="text-blue-300 font-mono text-[11px] space-y-1">
                        <div class="text-yellow-400 mb-2">✅ GET Request (with proper error handling):</div>
                        <div>async function getUsers() {`{`}</div>
                        <div>&nbsp;&nbsp;try {`{`}</div>
                        <div>&nbsp;&nbsp;&nbsp;&nbsp;const response = await fetch('https://api.example.com/users');</div>
                        <div>&nbsp;&nbsp;&nbsp;&nbsp;</div>
                        <div>&nbsp;&nbsp;&nbsp;&nbsp;<span class="text-red-300">// ⚠️ CRITICAL: Check response.ok for HTTP errors!</span></div>
                        <div>&nbsp;&nbsp;&nbsp;&nbsp;if (!response.ok) {`{`}</div>
                        <div>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;throw new Error(`HTTP error! status: ${'{'}response.status{'}'}`);</div>
                        <div>&nbsp;&nbsp;&nbsp;&nbsp;{'}'}</div>
                        <div>&nbsp;&nbsp;&nbsp;&nbsp;</div>
                        <div>&nbsp;&nbsp;&nbsp;&nbsp;const data = await response.json();</div>
                        <div>&nbsp;&nbsp;&nbsp;&nbsp;return data;</div>
                        <div>&nbsp;&nbsp;{'}'} catch (error) {`{`}</div>
                        <div>&nbsp;&nbsp;&nbsp;&nbsp;console.error('Fetch failed:', error.message);</div>
                        <div>&nbsp;&nbsp;&nbsp;&nbsp;throw error;</div>
                        <div>&nbsp;&nbsp;{'}'}</div>
                        <div>{'}'}</div>
                    </div>
                </div>

                <!-- POST with JSON -->
                <div class="bg-green-500/20 border border-green-500 rounded p-4">
                    <div class="text-green-300 font-mono text-[11px] space-y-1">
                        <div class="text-yellow-400 mb-2">✅ POST Request (create data):</div>
                        <div>async function createUser(userData) {`{`}</div>
                        <div>&nbsp;&nbsp;const response = await fetch('https://api.example.com/users', {`{`}</div>
                        <div>&nbsp;&nbsp;&nbsp;&nbsp;method: 'POST',</div>
                        <div>&nbsp;&nbsp;&nbsp;&nbsp;headers: {`{`} 'Content-Type': 'application/json' {'}'},</div>
                        <div>&nbsp;&nbsp;&nbsp;&nbsp;body: JSON.stringify(userData)</div>
                        <div>&nbsp;&nbsp;{'}'})</div>
                        <div></div>
                        <div>&nbsp;&nbsp;if (!response.ok) throw new Error('Failed to create user');</div>
                        <div>&nbsp;&nbsp;return await response.json();</div>
                        <div>{'}'}</div>
                        <div></div>
                        <div><span class="text-gray-400">// Usage:</span></div>
                        <div>await createUser({`{`} name: 'Alice', email: 'alice@example.com' {'}'})</div>
                    </div>
                </div>

                <!-- With loading state -->
                <div class="bg-purple-500/20 border border-purple-400 rounded p-4">
                    <div class="text-purple-300 font-mono text-[11px] space-y-1">
                        <div class="text-yellow-400 mb-2">✅ With Loading State (for UI):</div>
                        <div>let loading = false;</div>
                        <div>let error = null;</div>
                        <div>let users = null;</div>
                        <div></div>
                        <div>async function loadUsers() {`{`}</div>
                        <div>&nbsp;&nbsp;loading = true;</div>
                        <div>&nbsp;&nbsp;error = null;</div>
                        <div>&nbsp;&nbsp;</div>
                        <div>&nbsp;&nbsp;try {`{`}</div>
                        <div>&nbsp;&nbsp;&nbsp;&nbsp;const response = await fetch('https://api.example.com/users');</div>
                        <div>&nbsp;&nbsp;&nbsp;&nbsp;if (!response.ok) throw new Error('Failed to load');</div>
                        <div>&nbsp;&nbsp;&nbsp;&nbsp;users = await response.json();</div>
                        <div>&nbsp;&nbsp;{'}'} catch (err) {`{`}</div>
                        <div>&nbsp;&nbsp;&nbsp;&nbsp;error = err.message;</div>
                        <div>&nbsp;&nbsp;{'}'} finally {`{`}</div>
                        <div>&nbsp;&nbsp;&nbsp;&nbsp;loading = false;</div>
                        <div>&nbsp;&nbsp;{'}'}</div>
                        <div>{'}'}</div>
                    </div>
                </div>

                <!-- Response types -->
                <div class="bg-orange-500/20 border border-orange-400 rounded p-4">
                    <div class="text-orange-300 font-mono text-[11px] space-y-1">
                        <div class="text-yellow-400 mb-2">Response parsing methods:</div>
                        <div>await response.json() <span class="text-gray-400">// Parse JSON → JavaScript object</span></div>
                        <div>await response.text() <span class="text-gray-400">// Get as plain text</span></div>
                        <div>await response.blob() <span class="text-gray-400">// Binary data (images, files)</span></div>
                        <div>await response.formData() <span class="text-gray-400">// FormData object</span></div>
                        <div>await response.arrayBuffer() <span class="text-gray-400">// Raw binary buffer</span></div>
                        <div></div>
                        <div class="text-red-300">// ⚠️ Can only call once! Pick one.</div>
                    </div>
                </div>
            </div>

            <ProTip>
                <div>💡 <strong>Response properties you'll use:</strong></div>
                <div class="text-[10px] mt-1 space-y-1 ml-2">
                    <div>• <code class="bg-slate-800 px-1 py-0.5 rounded">response.ok</code> - true if status 200-299</div>
                    <div>• <code class="bg-slate-800 px-1 py-0.5 rounded">response.status</code> - 200, 404, 500, etc.</div>
                    <div>• <code class="bg-slate-800 px-1 py-0.5 rounded">response.statusText</code> - "OK", "Not Found", etc.</div>
                    <div>• <code class="bg-slate-800 px-1 py-0.5 rounded">response.headers</code> - Headers object</div>
                </div>
            </ProTip>
        </MethodCard>
    </div>

    <!-- ============================================ -->
    <!-- � HTTP Methods & Headers -->
    <!-- ============================================ -->

    <h2 id="http-methods" class="text-orange-300 text-xl my-4 pb-2 border-b-2 border-orange-600">
        � HTTP Methods & Headers
    </h2>

    <div id="methods-headers-card">
        <MethodCard
            methodName="Complete CRUD + Auth"
            signature="POST, PUT, PATCH, DELETE + headers"
            description="Everything you need for API communication"
            mutates={true}
        >
            <div class="p-6 bg-gray-800 rounded space-y-4">
                <!-- Quick reference table -->
                <div class="bg-slate-700 border border-slate-600 rounded p-4">
                    <div class="text-slate-300 text-[11px] space-y-2">
                        <div class="text-yellow-400 mb-2">HTTP Methods Quick Reference:</div>
                        <div class="grid grid-cols-3 gap-x-4 gap-y-1">
                            <div class="text-blue-400">GET</div>
                            <div>→</div>
                            <div>Read data (no body needed)</div>

                            <div class="text-green-400">POST</div>
                            <div>→</div>
                            <div>Create new resource</div>

                            <div class="text-yellow-400">PUT</div>
                            <div>→</div>
                            <div>Replace entire resource</div>

                            <div class="text-orange-400">PATCH</div>
                            <div>→</div>
                            <div>Update specific fields</div>

                            <div class="text-red-400">DELETE</div>
                            <div>→</div>
                            <div>Remove resource</div>
                        </div>
                    </div>
                </div>

                <!-- POST, PUT, PATCH, DELETE -->
                <div class="bg-purple-500/20 border border-purple-400 rounded p-4">
                    <div class="text-purple-300 font-mono text-[11px] space-y-1">
                        <div class="text-yellow-400 mb-2">Complete CRUD:</div>
                        <div><span class="text-gray-400">// CREATE</span></div>
                        <div>await fetch('/api/users', {`{`}</div>
                        <div>&nbsp;&nbsp;method: 'POST',</div>
                        <div>&nbsp;&nbsp;headers: {`{`} 'Content-Type': 'application/json' {'}'},</div>
                        <div>&nbsp;&nbsp;body: JSON.stringify({`{`} name: 'Alice' {'}'})</div>
                        <div>{'}'})</div>
                        <div></div>
                        <div><span class="text-gray-400">// UPDATE (partial)</span></div>
                        <div>await fetch('/api/users/123', {`{`}</div>
                        <div>&nbsp;&nbsp;method: 'PATCH',</div>
                        <div>&nbsp;&nbsp;headers: {`{`} 'Content-Type': 'application/json' {'}'},</div>
                        <div>&nbsp;&nbsp;body: JSON.stringify({`{`} name: 'Alice Updated' {'}'})</div>
                        <div>{'}'})</div>
                        <div></div>
                        <div><span class="text-gray-400">// UPDATE (full replace)</span></div>
                        <div>await fetch('/api/users/123', {`{`}</div>
                        <div>&nbsp;&nbsp;method: 'PUT',</div>
                        <div>&nbsp;&nbsp;headers: {`{`} 'Content-Type': 'application/json' {'}'},</div>
                        <div>&nbsp;&nbsp;body: JSON.stringify({`{`} name: 'Alice', email: 'alice@example.com' {'}'})</div>
                        <div>{'}'})</div>
                        <div></div>
                        <div><span class="text-gray-400">// DELETE</span></div>
                        <div>await fetch('/api/users/123', {`{`} method: 'DELETE' {'}'})</div>
                    </div>
                </div>

                <!-- Authentication -->
                <div class="bg-green-500/20 border border-green-500 rounded p-4">
                    <div class="text-green-300 font-mono text-[11px] space-y-1">
                        <div class="text-yellow-400 mb-2">Authentication with Bearer Token:</div>
                        <div>const token = 'your-jwt-token';</div>
                        <div></div>
                        <div>await fetch('/api/protected', {`{`}</div>
                        <div>&nbsp;&nbsp;headers: {`{`}</div>
                        <div>&nbsp;&nbsp;&nbsp;&nbsp;'Authorization': `Bearer ${'{'}token{'}'}`,</div>
                        <div>&nbsp;&nbsp;&nbsp;&nbsp;'Content-Type': 'application/json'</div>
                        <div>&nbsp;&nbsp;{'}'}</div>
                        <div>{'}'})</div>
                    </div>
                </div>

                <!-- File upload -->
                <div class="bg-blue-500/20 border border-blue-400 rounded p-4">
                    <div class="text-blue-300 font-mono text-[11px] space-y-1">
                        <div class="text-yellow-400 mb-2">File Upload with FormData:</div>
                        <div>const formData = new FormData();</div>
                        <div>formData.append('avatar', fileInput.files[0]);</div>
                        <div></div>
                        <div>await fetch('/api/upload', {`{`}</div>
                        <div>&nbsp;&nbsp;method: 'POST',</div>
                        <div>&nbsp;&nbsp;body: formData <span class="text-gray-400">// No Content-Type header!</span></div>
                        <div>{'}'})</div>
                    </div>
                </div>

                <!-- Common headers -->
                <div class="bg-slate-700 border border-slate-600 rounded p-4">
                    <div class="text-slate-300 text-[10px] space-y-1">
                        <div class="text-yellow-400 mb-2">Common Headers:</div>
                        <div>• <code class="bg-slate-800 px-1 py-0.5 rounded">Authorization: Bearer TOKEN</code> - JWT auth</div>
                        <div>• <code class="bg-slate-800 px-1 py-0.5 rounded">Content-Type: application/json</code> - JSON data</div>
                        <div>• <code class="bg-slate-800 px-1 py-0.5 rounded">Accept: application/json</code> - Expected response type</div>
                        <div>• <code class="bg-slate-800 px-1 py-0.5 rounded">X-API-Key: KEY</code> - API key auth</div>
                    </div>
                </div>
            </div>

            <ProTip>
                <div>💡 <strong>Key tips:</strong></div>
                <div class="text-[10px] mt-1 space-y-1 ml-2">
                    <div>• <strong>JSON:</strong> Always set <code class="bg-slate-800 px-1 py-0.5 rounded">Content-Type: application/json</code></div>
                    <div>• <strong>FormData:</strong> Omit Content-Type (browser sets it with boundary)</div>
                    <div>• <strong>PUT vs PATCH:</strong> PUT = replace all, PATCH = update specific fields</div>
                    <div>• <strong>DELETE:</strong> Often returns 204 No Content (no response body)</div>
                </div>
            </ProTip>
        </MethodCard>
    </div>
                    </div>
                </div>

                <!-- API Key -->
                <div class="bg-blue-500/20 border border-blue-400 rounded p-4">
                    <div class="text-blue-300 font-mono text-[11px] space-y-1">
                        <div class="text-yellow-400 mb-2">API Key:</div>
                        <div>const response = await fetch('https://api.example.com/data', {`{`}</div>
                        <div>&nbsp;&nbsp;headers: {`{`}</div>
                        <div>&nbsp;&nbsp;&nbsp;&nbsp;'X-API-Key': 'your-api-key'</div>
                        <div>&nbsp;&nbsp;{'}'}</div>
                        <div>{'}'})</div>
                    </div>
                </div>

                <!-- Custom headers -->
                <div class="bg-purple-500/20 border border-purple-400 rounded p-4">
                    <div class="text-purple-300 font-mono text-[11px] space-y-1">
                        <div class="text-yellow-400 mb-2">Multiple custom headers:</div>
                        <div>const response = await fetch('https://api.example.com/data', {`{`}</div>
                        <div>&nbsp;&nbsp;headers: {`{`}</div>
                        <div>&nbsp;&nbsp;&nbsp;&nbsp;'Content-Type': 'application/json',</div>
                        <div>&nbsp;&nbsp;&nbsp;&nbsp;'Authorization': 'Bearer token',</div>
                        <div>&nbsp;&nbsp;&nbsp;&nbsp;'Accept': 'application/json',</div>
                        <div>&nbsp;&nbsp;&nbsp;&nbsp;'X-Custom-Header': 'custom-value'</div>
                        <div>&nbsp;&nbsp;{'}'}</div>
                        <div>{'}'})</div>
                    </div>
                </div>

                <!-- Reading response headers -->
                <div class="bg-orange-500/20 border border-orange-400 rounded p-4">
                    <div class="text-orange-300 font-mono text-[11px] space-y-1">
                        <div class="text-yellow-400 mb-2">Reading response headers:</div>
                        <div>const response = await fetch('https://api.example.com/data');</div>
                        <div></div>
                        <div>const contentType = response.headers.get('Content-Type');</div>
                        <div>const rateLimit = response.headers.get('X-RateLimit-Remaining');</div>
                        <div></div>
                        <div><span class="text-gray-400">// Iterate all headers</span></div>
                        <div>response.headers.forEach((value, key) =&gt; {`{`}</div>
                        <div>&nbsp;&nbsp;console.log(`${'{'}key{'}'}: ${'{'}value{'}'}`);</div>
                        <div>{'}'})</div>
                    </div>
                </div>
            </div>

            <ProTip>
                <div>💡 <strong>Common headers:</strong></div>
                <div class="text-[10px] mt-1 space-y-1">
                    <div>• <code class="bg-slate-800 px-1 py-0.5 rounded">Authorization</code> - Bearer tokens, API keys</div>
                    <div>• <code class="bg-slate-800 px-1 py-0.5 rounded">Content-Type</code> - Format of request body</div>
                    <div>• <code class="bg-slate-800 px-1 py-0.5 rounded">Accept</code> - Expected response format</div>
                    <div>• <code class="bg-slate-800 px-1 py-0.5 rounded">User-Agent</code> - Client identification</div>
                </div>
            </ProTip>
        </MethodCard>
    </div>

    <!-- ============================================ -->
    <!-- ⏱️ Timeout & Cancellation -->
    <!-- ============================================ -->

    <h2 id="timeout" class="text-red-300 text-xl my-4 pb-2 border-b-2 border-red-600">
        ⏱️ Timeout & Cancellation
    </h2>

    <div id="abort-controller">
        <MethodCard
            methodName="AbortController"
            signature="Cancel requests or add timeouts"
            description="Prevent hanging requests"
            mutates={false}
        >
            <div class="p-6 bg-gray-800 rounded space-y-4">
                <!-- Timeout -->
                <div class="bg-red-500/20 border border-red-400 rounded p-4">
                    <div class="text-red-300 font-mono text-[11px] space-y-1">
                        <div class="text-yellow-400 mb-2">Add timeout to request:</div>
                        <div>const controller = new AbortController();</div>
                        <div>const timeoutId = setTimeout(() =&gt; controller.abort(), 5000);</div>
                        <div></div>
                        <div>try {`{`}</div>
                        <div>&nbsp;&nbsp;const response = await fetch('https://api.example.com/data', {`{`}</div>
                        <div>&nbsp;&nbsp;&nbsp;&nbsp;signal: controller.signal</div>
                        <div>&nbsp;&nbsp;{'}'})</div>
                        <div>&nbsp;&nbsp;clearTimeout(timeoutId);</div>
                        <div>&nbsp;&nbsp;const data = await response.json();</div>
                        <div>{'}'} catch (error) {`{`}</div>
                        <div>&nbsp;&nbsp;if (error.name === 'AbortError') console.log('Request timed out');</div>
                        <div>{'}'}</div>
                    </div>
                </div>

                <!-- Manual cancel -->
                <div class="bg-yellow-500/20 border border-yellow-400 rounded p-4">
                    <div class="text-yellow-300 font-mono text-[11px] space-y-1">
                        <div class="text-yellow-400 mb-2">Cancel manually:</div>
                        <div>const controller = new AbortController();</div>
                        <div></div>
                        <div>cancelBtn.addEventListener('click', () =&gt; controller.abort());</div>
                        <div></div>
                        <div>try {`{`}</div>
                        <div>&nbsp;&nbsp;await fetch('/large-file', {`{`} signal: controller.signal {'}'})</div>
                        <div>{'}'} catch (error) {`{`}</div>
                        <div>&nbsp;&nbsp;if (error.name === 'AbortError') console.log('Cancelled');</div>
                        <div>{'}'}</div>
                    </div>
                </div>
            </div>

            <ProTip>
                <div>💡 <strong>Production apps should always use timeouts!</strong> Don't let slow APIs hang your app.</div>
            </ProTip>
        </MethodCard>
    </div>

    <!-- ============================================ -->
    <!-- 🏭 Production-Ready Utility -->
    <!-- ============================================ -->

    <h2 id="production" class="text-green-300 text-xl my-4 pb-2 border-b-2 border-green-600">
        🏭 Production-Ready Utility
    </h2>

    <div id="api-client">
        <MethodCard
            methodName="APIClient Class"
            signature="Reusable fetch wrapper with best practices"
            description="Everything you need for real-world apps"
            mutates={false}
        >
            <div class="p-6 bg-gray-800 rounded space-y-4">
                <!-- Link to utility file -->
                <div class="bg-green-500/20 border-2 border-green-400 rounded p-6">
                    <div class="text-green-300 space-y-3">
                        <div class="text-yellow-400 font-bold text-sm">📦 Check out the production-ready utility:</div>
                        <div class="text-sm">
                            <code class="bg-slate-800 px-2 py-1 rounded text-cyan-300">src/lib/api-client.js</code>
                        </div>
                        <div class="text-xs leading-relaxed">
                            Fully annotated <strong>APIClient</strong> class with:
                            <div class="ml-4 mt-2 space-y-1">
                                <div>✅ Automatic response.ok checking</div>
                                <div>✅ Timeout with AbortController (default 10s)</div>
                                <div>✅ User-friendly error messages</div>
                                <div>✅ HTTP methods: get(), post(), put(), patch(), delete()</div>
                                <div>✅ File upload support</div>
                                <div>✅ Loading state management</div>
                                <div>✅ Retry logic with exponential backoff</div>
                                <div>✅ Parallel requests helper</div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Quick usage example -->
                <div class="bg-blue-500/20 border border-blue-400 rounded p-4">
                    <div class="text-blue-300 font-mono text-[11px] space-y-1">
                        <div class="text-yellow-400 mb-2">Usage (import the singleton):</div>
                        <div>import {`{`} api {'}'} from '@/lib/api-client.js';</div>
                        <div></div>
                        <div><span class="text-gray-400">// Automatic error handling, timeout, response.ok check!</span></div>
                        <div>const users = await api.get('/users');</div>
                        <div></div>
                        <div>const newUser = await api.post('/users', {`{`}</div>
                        <div>&nbsp;&nbsp;name: 'Alice', email: 'alice@example.com'</div>
                        <div>{'}'})</div>
                        <div></div>
                        <div><span class="text-gray-400">// With loading state for UI</span></div>
                        <div>const {`{`} data, loading, error {'}'} = await api.getWithState('/users');</div>
                    </div>
                </div>

                <!-- What's included -->
                <div class="bg-purple-500/20 border border-purple-400 rounded p-4">
                    <div class="text-purple-300 text-[10px] space-y-2">
                        <div class="text-yellow-400 mb-2">What's included:</div>
                        <div class="grid grid-cols-2 gap-x-4 gap-y-1">
                            <div>• Singleton pattern</div>
                            <div>• Environment variables</div>
                            <div>• Error categorization</div>
                            <div>• JSDoc annotations</div>
                            <div>• Retry with backoff</div>
                            <div>• Parallel requests</div>
                            <div>• Loading states</div>
                            <div>• Production patterns</div>
                        </div>
                    </div>
                </div>
            </div>

            <ProTip>
                <div>💡 <strong>Why use a utility class?</strong> Write error handling once, use everywhere. Consistent behavior. Easy testing. Copy to any project.</div>
            </ProTip>
        </MethodCard>
    </div>

    <!-- ============================================ -->
    <!-- 📚 Common Patterns -->
    <!-- ============================================ -->

    <h2 id="patterns" class="text-purple-300 text-xl my-4 pb-2 border-b-2 border-purple-600">
        📚 Common Patterns
    </h2>

    <div id="common-patterns">
        <MethodCard
            methodName="Real-world patterns"
            signature="Parallel, sequential, cookies"
            description="Patterns you'll use constantly"
            mutates={false}
        >
            <div class="p-6 bg-gray-800 rounded space-y-4">
                <!-- Parallel requests -->
                <div class="bg-blue-500/20 border border-blue-400 rounded p-4">
                    <div class="text-blue-300 font-mono text-[11px] space-y-1">
                        <div class="text-yellow-400 mb-2">Parallel requests (faster!):</div>
                        <div>const [users, posts, comments] = await Promise.all([</div>
                        <div>&nbsp;&nbsp;fetch('/api/users').then(r =&gt; r.json()),</div>
                        <div>&nbsp;&nbsp;fetch('/api/posts').then(r =&gt; r.json()),</div>
                        <div>&nbsp;&nbsp;fetch('/api/comments').then(r =&gt; r.json())</div>
                        <div>]);</div>
                    </div>
                </div>

                <!-- Sequential -->
                <div class="bg-green-500/20 border border-green-500 rounded p-4">
                    <div class="text-green-300 font-mono text-[11px] space-y-1">
                        <div class="text-yellow-400 mb-2">Sequential (when one depends on another):</div>
                        <div>const user = await fetch('/api/user').then(r =&gt; r.json());</div>
                        <div>const posts = await fetch(`/api/users/${'{'}user.id{'}'}/posts`).then(r =&gt; r.json());</div>
                    </div>
                </div>

                <!-- Cookies -->
                <div class="bg-orange-500/20 border border-orange-400 rounded p-4">
                    <div class="text-orange-300 font-mono text-[11px] space-y-1">
                        <div class="text-yellow-400 mb-2">Send cookies:</div>
                        <div>await fetch('/api/data', {`{`}</div>
                        <div>&nbsp;&nbsp;credentials: 'include' <span class="text-gray-400">// Send cookies</span></div>
                        <div>{'}'})</div>
                        <div></div>
                        <div><span class="text-gray-400">// 'omit' | 'same-origin' | 'include'</span></div>
                    </div>
                </div>
            </div>

            <ProTip>
                <div>💡 Use <code class="bg-slate-800 px-1 py-0.5 rounded">Promise.all()</code> for independent requests. Sequential only when one needs data from another.</div>
            </ProTip>
        </MethodCard>
    </div>

</Layout>
