    <!-- BOUNDING CLIENT RECT -->
    <MethodCard
        id="bounding-rect"
        methodName="getBoundingClientRect()"
        signature="element.getBoundingClientRect()"
        description="Get element's size and position relative to viewport"
        mutates={false}
    >
        <div class="p-6 bg-gray-800 rounded">
            <div class="space-y-4">
                <!-- Return value -->
                <div
                    class="bg-indigo-500/20 border border-indigo-400 rounded p-3"
                >
                    <div class="text-indigo-300 font-mono text-xs space-y-0.5">
                        <div>const rect = el.getBoundingClientRect()</div>
                        <div class="text-gray-400 text-[10px] mt-1">
                            Returns DOMRect with:
                        </div>
                        <div class="text-gray-300 text-[10px] ml-2 mt-0.5">
                            rect.top, rect.bottom <span class="text-gray-400"
                                >// Y position</span>
                        </div>
                        <div class="text-gray-300 text-[10px] ml-2">
                            rect.left, rect.right <span class="text-gray-400"
                                >// X position</span>
                        </div>
                        <div class="text-gray-300 text-[10px] ml-2">
                            rect.width, rect.height <span class="text-gray-400"
                                >// dimensions</span>
                        </div>
                        <div class="text-gray-300 text-[10px] ml-2">
                            rect.x, rect.y <span class="text-gray-400"
                                >// same as left/top</span>
                        </div>
                    </div>
                </div>

                <!-- Example -->
                <div
                    class="bg-green-500/20 border border-green-500 rounded p-3"
                >
                    <div class="text-green-300 font-mono text-xs space-y-0.5">
                        <div>
                            <span class="text-gray-400"
                                >// Check if element is in viewport</span>
                        </div>
                        <div>const rect = el.getBoundingClientRect()</div>
                        <div>const inView = rect.top &gt;= 0 &&</div>
                        <div>
                            &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;rect.bottom
                            &lt;= window.innerHeight
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <ProTip>
            <div>⚠️ <strong>Relative to viewport, not document:</strong></div>
            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                <div class="font-mono text-[10px]">
                    <span class="text-gray-400"
                        >// Changes when you scroll!</span>
                </div>
                <div class="font-mono text-[10px]">
                    rect.top <span class="text-gray-400"
                        >// distance from top of viewport</span>
                </div>
                <div class="font-mono text-[10px] mt-1">
                    <span class="text-gray-400"
                        >// For position in document:</span>
                </div>
                <div class="font-mono text-[10px]">
                    const topInDoc = rect.top + window.scrollY
                </div>
                <div class="font-mono text-[10px]">
                    const leftInDoc = rect.left + window.scrollX
                </div>
            </div>
        </ProTip>
    </MethodCard>

    <!-- DIMENSIONS & SCROLL -->
    <MethodCard
        id="dimensions-scroll"
        methodName="Element Dimensions & Scroll"
        signature="Width, height, and scroll properties"
        description="Access element size and scroll position"
        mutates={false}
    >
        <div class="p-6 bg-gray-800 rounded">
            <div class="space-y-3">
                <!-- Dimensions -->
                <div class="bg-blue-500/20 border border-blue-400 rounded p-3">
                    <div
                        class="text-blue-300 font-mono text-[10px] space-y-0.5"
                    >
                        <div class="text-yellow-400 mb-1">
                            Dimensions (read-only):
                        </div>
                        <div>
                            el.offsetWidth, el.offsetHeight <span
                                class="text-gray-400">// includes border</span>
                        </div>
                        <div>
                            el.clientWidth, el.clientHeight <span
                                class="text-gray-400">// excludes border</span>
                        </div>
                        <div>
                            el.scrollWidth, el.scrollHeight <span
                                class="text-gray-400"
                                >// full content size</span>
                        </div>
                    </div>
                </div>

                <!-- Scroll position -->
                <div
                    class="bg-purple-500/20 border border-purple-400 rounded p-3"
                >
                    <div
                        class="text-purple-300 font-mono text-[10px] space-y-0.5"
                    >
                        <div class="text-yellow-400 mb-1">
                            Scroll position (read/write):
                        </div>
                        <div>
                            el.scrollTop <span class="text-gray-400"
                                >// vertical scroll position</span>
                        </div>
                        <div>
                            el.scrollLeft <span class="text-gray-400"
                                >// horizontal scroll position</span>
                        </div>
                        <div>
                            el.scrollTop = 0 <span class="text-gray-400"
                                >// scroll to top</span>
                        </div>
                    </div>
                </div>

                <!-- Window -->
                <div
                    class="bg-green-500/20 border border-green-500 rounded p-3"
                >
                    <div
                        class="text-green-300 font-mono text-[10px] space-y-0.5"
                    >
                        <div class="text-yellow-400 mb-1">Window/document:</div>
                        <div>
                            window.innerWidth, window.innerHeight <span
                                class="text-gray-400">// viewport</span>
                        </div>
                        <div>
                            window.scrollX, window.scrollY <span
                                class="text-gray-400">// page scroll</span>
                        </div>
                        <div>
                            document.documentElement.scrollTop <span
                                class="text-gray-400">// alternative</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <ProTip>
            <div>🎯 <strong>Common use cases:</strong></div>
            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                <div class="font-mono text-[10px]">
                    <span class="text-gray-400"
                        >// Check if scrolled to bottom</span>
                </div>
                <div class="font-mono text-[10px]">
                    const atBottom = el.scrollTop + el.clientHeight &gt;=
                    el.scrollHeight
                </div>
                <div class="font-mono text-[10px] mt-1">
                    <span class="text-gray-400"
                        >// Smooth scroll element into view</span>
                </div>
                <div class="font-mono text-[10px]">
                    el.scrollIntoView({"{"} behavior: 'smooth' {"}"})
                </div>
                <div class="font-mono text-[10px] mt-1">
                    <span class="text-gray-400">// Scroll to top of page</span>
                </div>
                <div class="font-mono text-[10px]">
                    window.scrollTo({"{"} top: 0, behavior: 'smooth' {"}"})
                </div>
            </div>
        </ProTip>
    </MethodCard>

