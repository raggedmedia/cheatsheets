                            </Node>

                            <Arrow label="returns" />

                            <Node label="Return Value" type="output">
                                <ReturnValue value="undefined" type="undefined" />
                            </Node>
                        </div>

                        <MutableOrNot mutates={false} message="">
                            Always returns <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">undefined</code>. Cannot be chained. Use for side effects only.
                        </MutableOrNot>

                        <ProTip>
                            <div>For large arrays (10,000+ items), regular <code class="bg-black/30 px-1 py-0.5 rounded font-mono text-yellow-400">for</code> loops are faster:</div>
                            <div class="pl-2 border-l-2 border-yellow-500/60 space-y-0.5">
                                <div class="font-mono text-[10px]">for (let i = 0; i &lt; arr.length; i++) &lbrace; ... &rbrace; <span class="text-gray-400">// fastest</span></div>
                                <div class="font-mono text-[10px]">arr.forEach(item =&gt; &lbrace; ... &rbrace;) <span class="text-gray-400">// cleaner, slightly slower</span></div>
                            </div>
                        </ProTip>
                    </MethodCard>

