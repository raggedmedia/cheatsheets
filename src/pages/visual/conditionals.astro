                </div>

                <!-- ============================================ -->
                <!-- 🛡️ NULLISH & OPTIONAL -->
                <!-- ============================================ -->

                <h2 id="nullish" class="text-cyan-300 text-xl my-4 pb-2 border-b-2 border-cyan-600">
                    🛡️ Nullish & Optional
                </h2>

                <!-- NULLISH COALESCING -->
                <div id="nullish-coalescing">
                    <MethodCard
                        methodName="Nullish Coalescing (??)"
                        signature="value ?? fallback"
                        description="Return fallback only if value is null or undefined"
                        mutates={false}
                    >
                        <div class="p-4 bg-gray-800 rounded border border-gray-700">
                            <!-- Inline expression -->
                            <div class="font-mono text-sm mb-4">
                                <span class="text-gray-400">const</span> <span class="text-blue-300">name</span> =
                                <span class="text-orange-300 ml-2">username</span>
                                <span class="text-purple-300 mx-2">??</span>
                                <span class="text-green-300">'Guest'</span>
                            </div>

                            <!-- Comparison with || -->
                            <div class="space-y-3">
                                <div class="p-3 bg-cyan-500/5 border border-cyan-500/30 rounded">
                                    <div class="text-xs text-cyan-300 font-bold mb-2">?? (Nullish Coalescing)</div>
                                    <div class="text-[10px] text-gray-300 space-y-1">
                                        <div>Returns fallback <strong>only</strong> if value is:</div>
                                        <div class="ml-3">• <code class="text-yellow-300">null</code></div>
                                        <div class="ml-3">• <code class="text-yellow-300">undefined</code></div>
                                        <div class="mt-2 text-green-300">✅ Keeps: <code>0</code>, <code>false</code>, <code>""</code></div>
                                    </div>
                                </div>

                                <div class="p-3 bg-orange-500/5 border border-orange-500/30 rounded">
                                    <div class="text-xs text-orange-300 font-bold mb-2">|| (Logical OR)</div>
                                    <div class="text-[10px] text-gray-300 space-y-1">
                                        <div>Returns fallback if value is <strong>any falsy</strong> value:</div>
                                        <div class="ml-3">• <code class="text-yellow-300">null</code>, <code class="text-yellow-300">undefined</code></div>
                                        <div class="ml-3">• <code class="text-yellow-300">0</code>, <code class="text-yellow-300">false</code>, <code class="text-yellow-300">""</code>, <code class="text-yellow-300">NaN</code></div>
                                        <div class="mt-2 text-red-300">⚠️ Replaces ALL falsy values</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="text-gray-300 text-sm mt-3 p-3 bg-gray-800/50 rounded border border-gray-700">
                            Only treats <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">null</code> and <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">undefined</code> as nullish. <strong>0, false, "" are valid values.</strong>
                        </div>

                        <ProTip>
                            <div>💡 <strong>?? vs || difference:</strong></div>
                            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                                <div class="font-mono text-[10px]">const count = 0</div>
                                <div class="font-mono text-[10px] mt-1">count || 10 <span class="text-red-400">// 10 (0 is falsy) ❌</span></div>
                                <div class="font-mono text-[10px]">count ?? 10 <span class="text-green-400">// 0 (0 is valid) ✅</span></div>
                                <div class="font-mono text-[10px] mt-1">const name = ''</div>
                                <div class="font-mono text-[10px]">name || 'Guest' <span class="text-red-400">// 'Guest' (empty string is falsy) ❌</span></div>
                                <div class="font-mono text-[10px]">name ?? 'Guest' <span class="text-green-400">// '' (empty string is valid) ✅</span></div>
                                <div class="font-mono text-[10px] mt-1"><span class="text-gray-400">// Use ?? when 0, false, "" are meaningful values</span></div>
                            </div>
                        </ProTip>
                    </MethodCard>
                </div>

                <!-- OPTIONAL CHAINING -->
                <div id="optional-chaining">
                    <MethodCard
                        methodName="Optional Chaining (?.)"
                        signature="obj?.prop?.nested"
                        description="Safely access nested properties (returns undefined if null)"
                        mutates={false}
                    >
                        <div class="p-4 bg-gray-800 rounded border border-gray-700">
                            <!-- Chain visualization -->
                            <div class="font-mono text-sm mb-4">
                                <span class="text-gray-400">const</span> <span class="text-blue-300">city</span> =
                                <span class="text-orange-300 ml-2">user</span><span class="text-purple-300">?.</span><span class="text-orange-300">address</span><span class="text-purple-300">?.</span><span class="text-orange-300">city</span>
                            </div>

                            <!-- Step-by-step evaluation -->
                            <div class="space-y-2 text-xs">
                                <div class="p-2 bg-gray-700/30 rounded border-l-4 border-cyan-500">
                                    <div class="text-cyan-300 font-bold mb-1">1. Check user</div>
                                    <div class="text-gray-300">If <code class="text-yellow-300">null</code> or <code class="text-yellow-300">undefined</code> → return <code class="text-yellow-300">undefined</code></div>
                                    <div class="text-gray-300">Otherwise → continue to next property</div>
                                </div>

                                <div class="p-2 bg-gray-700/30 rounded border-l-4 border-cyan-500">
                                    <div class="text-cyan-300 font-bold mb-1">2. Check user.address</div>
                                    <div class="text-gray-300">If <code class="text-yellow-300">null</code> or <code class="text-yellow-300">undefined</code> → return <code class="text-yellow-300">undefined</code></div>
                                    <div class="text-gray-300">Otherwise → continue to next property</div>
                                </div>

                                <div class="p-2 bg-green-500/10 rounded border-l-4 border-green-500">
                                    <div class="text-green-300 font-bold mb-1">3. Access city</div>
                                    <div class="text-gray-300">Return the value (or <code class="text-yellow-300">undefined</code> if doesn't exist)</div>
                                </div>
                            </div>

                            <!-- Without vs With -->
                            <div class="mt-4 pt-4 border-t border-gray-700">
                                <div class="text-xs space-y-2">
                                    <div>
                                        <span class="text-red-300">❌ Without:</span>
                                        <div class="font-mono text-[10px] text-gray-400 mt-1">user && user.address && user.address.city</div>
                                    </div>
                                    <div>
                                        <span class="text-green-300">✅ With:</span>
                                        <div class="font-mono text-[10px] text-gray-400 mt-1">user?.address?.city</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="text-gray-300 text-sm mt-3 p-3 bg-gray-800/50 rounded border border-gray-700">
                            Stops evaluation and returns <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">undefined</code> if left side is nullish. <strong>Prevents "Cannot read property" errors.</strong>
                        </div>

                        <ProTip>
                            <div>🛡️ <strong>Safe property access:</strong></div>
                            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                                <div class="font-mono text-[10px]"><span class="text-gray-400">// Works with methods too</span></div>
                                <div class="font-mono text-[10px]">user?.getName?.()</div>
                                <div class="font-mono text-[10px] mt-1"><span class="text-gray-400">// And array indexes</span></div>
                                <div class="font-mono text-[10px]">arr?.[0]?.property</div>
                                <div class="font-mono text-[10px] mt-1"><span class="text-gray-400">// Combine with function calls</span></div>
                                <div class="font-mono text-[10px]">obj.method?.() <span class="text-gray-400">// only call if method exists</span></div>
                            </div>
                        </ProTip>
                    </MethodCard>
                </div>

                <!-- COMBINING ?? AND ?. -->
                <div id="combining">
                    <MethodCard
                        methodName="Combining ?? and ?."
                        signature="obj?.prop ?? defaultValue"
                        description="Safe access with fallback"
                        mutates={false}
                    >
                        <div class="p-4 bg-gray-800 rounded border border-gray-700">
                            <!-- Full expression -->
                            <div class="font-mono text-sm mb-4">
                                <span class="text-gray-400">const</span> <span class="text-blue-300">city</span> =
                                <span class="text-orange-300 ml-2">user</span><span class="text-cyan-300">?.</span><span class="text-orange-300">address</span><span class="text-cyan-300">?.</span><span class="text-orange-300">city</span>
                                <span class="text-purple-300 mx-2">??</span>
                                <span class="text-green-300">'Unknown'</span>
                            </div>

                            <!-- Two operators working together -->
                            <div class="space-y-3">
                                <div class="p-3 bg-cyan-500/5 border border-cyan-500/30 rounded">
                                    <div class="text-xs text-cyan-300 font-bold mb-2">Step 1: Optional Chaining (?.) → Safe Navigation</div>
                                    <div class="text-[10px] text-gray-300 space-y-1">
                                        <div class="font-mono">user<span class="text-cyan-300">?.</span>address<span class="text-cyan-300">?.</span>city</div>
                                        <div class="ml-3 mt-1">
                                            <div>• If any part is null/undefined → <code class="text-yellow-300">undefined</code></div>
                                            <div>• Otherwise → the actual value</div>
                                        </div>
                                    </div>
                                </div>

                                <div class="flex items-center justify-center text-purple-300 text-2xl">↓</div>

                                <div class="p-3 bg-purple-500/5 border border-purple-500/30 rounded">
                                    <div class="text-xs text-purple-300 font-bold mb-2">Step 2: Nullish Coalescing (??) → Provide Fallback</div>
                                    <div class="text-[10px] text-gray-300 space-y-1">
                                        <div class="font-mono">(result) <span class="text-purple-300">??</span> 'Unknown'</div>
