---
interface Props {
    legend: string;
    required?: boolean;
    helperText?: string;
}

const {
    legend,
    required = false,
    helperText
} = Astro.props;
---

<fieldset class="form-fieldset">
    <legend class="form-legend">
        {legend}
        {required && <span class="text-red-400" aria-label="required">*</span>}
    </legend>

    {helperText && (
        <div class="fieldset-help-text">
            {helperText}
        </div>
    )}

    <div class="fieldset-content">
        <slot />
    </div>
</fieldset>

<style>
    .form-fieldset {
        border: 1px solid #374151;
        border-radius: 0.375rem;
        padding: 1rem;
        margin-bottom: 1rem;
    }

    .form-legend {
        font-weight: 600;
        color: #f3f4f6;
        font-size: 0.875rem;
        padding: 0 0.5rem;
    }

    .fieldset-help-text {
        margin-top: -0.5rem;
        margin-bottom: 0.75rem;
        font-size: 0.75rem;
        color: #9ca3af;
    }

    .fieldset-content {
        margin-top: 0.75rem;
    }
</style>
