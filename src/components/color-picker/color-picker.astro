---
interface Props {
    id: string;
    name: string;
    defaultColor?: string;
}

const { id, name, defaultColor = '--color-blue-500' } = Astro.props;

const colorFamilies = ['red', 'orange', 'amber', 'yellow', 'lime', 'green', 'emerald', 'teal', 'cyan', 'sky', 'blue', 'indigo', 'violet', 'purple', 'fuchsia', 'pink', 'rose', 'slate', 'gray', 'zinc', 'neutral', 'stone'];
const shades = ['50', '100', '200', '300', '400', '500', '600', '700', '800', '900', '950'];
const miscColors = [
    { name: 'Black', var: '--color-black' },
    { name: 'White', var: '--color-white' },
    { name: 'Transparent', var: '--color-transparent' }
];
---

<style is:global>
    /* Color swatch radio button styling */
    .color-swatch {
        position: relative;
        display: inline-block;
    }

    .color-swatch input[type="radio"] {
        position: absolute;
        opacity: 0;
        width: 0;
        height: 0;
        pointer-events: none;
    }

    .color-swatch label {
        display: block;
        width: 36px;
        height: 36px;
        border-radius: 0.25rem;
        cursor: pointer;
        border: 1px solid rgba(0, 0, 0, 0.15);
        box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.2);
        transition: all 0.15s ease;
        position: relative;
    }

    .color-swatch input[type="radio"]:checked + label {
        border: 3px solid #000;
        box-shadow: 0 0 0 1px #000, 0 2px 8px rgba(0, 0, 0, 0.2);
        transform: scale(1.15);
        z-index: 10;
    }

    .color-swatch label:hover {
        transform: scale(1.08);
        border-color: rgba(0, 0, 0, 0.3);
        z-index: 5;
    }

    .color-swatch input[type="radio"]:checked + label:hover {
        transform: scale(1.15);
    }

    /* Transparent color swatch pattern */
    label[for*="-transparent"] {
        background:
            linear-gradient(0deg, #e0e0e0 50%, transparent 50%),
            linear-gradient(90deg, #fff 50%, #e0e0e0 50%) !important;
        background-size: 10px 10px !important;
        background-position: 0 0 !important;
    }

    .color-group {
        margin-bottom: 1.5rem;
    }

    .color-picker-container {
        border: 1px solid #e5e7eb;
        border-radius: 0.375rem;
        padding: 1rem;
        max-height: 300px;
        overflow-y: auto;
    }
</style>

<div class="color-picker-container">
    <div class="color-picker" data-picker-id={id}>
    <!-- Misc Colors -->
    <div class="color-group mb-4">
        <div class="text-sm font-semibold mb-2">Misc</div>
        <div class="flex gap-1 flex-wrap">
            {miscColors.map(color => {
                const colorId = color.var.replace('--color-', '');
                const uniqueId = `${id}-${colorId}`;
                const isDefault = color.var === defaultColor;

                return (
                    <div class="color-swatch">
                        <input
                            type="radio"
                            name={name}
                            value={color.var}
                            id={uniqueId}
                            checked={isDefault}
                        />
                        <label
                            for={uniqueId}
                            style={`background: var(${color.var});`}
                            title={color.name}>
                        </label>
                    </div>
                );
            })}
        </div>
    </div>

    <!-- Color Families -->
    {colorFamilies.map(family => (
        <div class="color-group mb-4">
            <div class="text-sm font-semibold mb-2 capitalize">{family}</div>
            <div class="flex gap-1 flex-wrap">
                {shades.map(shade => {
                    const colorVar = `--color-${family}-${shade}`;
                    const uniqueId = `${id}-${family}-${shade}`;
                    const isDefault = colorVar === defaultColor;

                    return (
                        <div class="color-swatch">
                            <input
                                type="radio"
                                name={name}
                                value={colorVar}
                                id={uniqueId}
                                checked={isDefault}
                            />
                            <label
                                for={uniqueId}
                                style={`background: var(${colorVar});`}
                                title={`${family}-${shade}`}>
                            </label>
                        </div>
                    );
                })}
            </div>
        </div>
    ))}
    </div>
</div>
