                </div>

                <!-- Good way -->
                <div>
                    <div class="text-green-400 text-xs mb-2">
                        ✅ Good - one listener:
                    </div>
                    <div
                        class="bg-green-500/20 border border-green-500 rounded p-3"
                    >
                        <div
                            class="text-green-300 font-mono text-xs space-y-0.5"
                        >
                            <div>
                                list.addEventListener('click', (e) =&gt; {"{"}
                            </div>
                            <div>
                                &nbsp;&nbsp;if (e.target.matches('.item')) {"{"}
                            </div>
                            <div>
                                &nbsp;&nbsp;&nbsp;&nbsp;// Handle item click
                            </div>
                            <div>&nbsp;&nbsp;{"}"}</div>
                            <div>{"}"})</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <ProTip>
            <div>Benefits of delegation:</div>
            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                <div class="font-mono text-[10px]">
                    <span class="text-green-400"
                        >✅ One listener instead of many</span>
                </div>
                <div class="font-mono text-[10px]">
                    <span class="text-green-400"
                        >✅ Works for dynamically added elements</span>
                </div>
                <div class="font-mono text-[10px]">
                    <span class="text-green-400">✅ Less memory usage</span>
                </div>
                <div class="font-mono text-[10px] mt-1">
                    <span class="text-gray-400"
                        >Use e.target to find which child was clicked</span>
                </div>
            </div>
        </ProTip>
    </MethodCard>

    <!-- EVENT PROPAGATION -->
    <MethodCard
        id="event-propagation"
        methodName="Event Propagation (Bubbling)"
        signature="event.stopPropagation() / event.stopImmediatePropagation()"
        description="Control how events flow through the DOM tree"
        mutates={false}
    >
        <div class="p-6 bg-gray-800 rounded">
            <div class="space-y-4">
                <!-- Bubbling flow -->
                <div class="bg-blue-500/20 border border-blue-400 rounded p-3">
                    <div
                        class="text-blue-300 font-mono text-[10px] space-y-0.5"
                    >
                        <div class="text-yellow-400 mb-1">
                            Event flows from target → parents:
                        </div>
                        <div>
                            &lt;div id="outer"&gt; <span class="text-gray-400"
                                >// 3. Bubbles here last</span>
                        </div>
                        <div>
                            &nbsp;&nbsp;&lt;div id="middle"&gt; <span
                                class="text-gray-400"
                                >// 2. Bubbles here second</span>
                        </div>
                        <div>
                            &nbsp;&nbsp;&nbsp;&nbsp;&lt;button&gt;Click&lt;/button&gt;
                            <span class="text-gray-400"
                                >// 1. Event starts here</span>
                        </div>
                        <div>&nbsp;&nbsp;&lt;/div&gt;</div>
                        <div>&lt;/div&gt;</div>
                    </div>
                </div>

                <!-- stopPropagation -->
                <div class="bg-red-500/20 border border-red-500 rounded p-3">
                    <div class="text-red-300 font-mono text-xs space-y-0.5">
                        <div>
                            button.addEventListener('click', (e) =&gt; {"{"}
                        </div>
                        <div>
                            &nbsp;&nbsp;e.stopPropagation() <span
                                class="text-gray-400">// stops bubbling</span>
                        </div>
                        <div>&nbsp;&nbsp;console.log('Button clicked')</div>
                        <div>{"}"})</div>
                        <div class="text-gray-400 text-[10px] mt-1">
                            Parent listeners won't fire
                        </div>
                    </div>
                </div>

                <!-- stopImmediatePropagation -->
                <div
                    class="bg-purple-500/20 border border-purple-400 rounded p-3"
                >
                    <div class="text-purple-300 font-mono text-xs space-y-0.5">
                        <div>el.addEventListener('click', (e) =&gt; {"{"}</div>
                        <div>&nbsp;&nbsp;e.stopImmediatePropagation()</div>
                        <div>&nbsp;&nbsp;console.log('First handler')</div>
                        <div>{"}"})</div>
                        <div class="mt-1">
                            el.addEventListener('click', () =&gt; {"{"}
                        </div>
                        <div>&nbsp;&nbsp;console.log('Never runs! ❌')</div>
                        <div>{"}"})</div>
                    </div>
                </div>
            </div>
        </div>

        <ProTip>
            <div>
                ⚠️ <strong
                    >Common gotcha - event.target vs event.currentTarget:</strong>
            </div>
            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                <div class="font-mono text-[10px]">
                    outer.addEventListener('click', (e) =&gt; {"{"}
                </div>
                <div class="font-mono text-[10px]">
                    &nbsp;&nbsp;e.target <span class="text-gray-400"
                        >// element that was actually clicked</span>
                </div>
                <div class="font-mono text-[10px]">
                    &nbsp;&nbsp;e.currentTarget <span class="text-gray-400"
                        >// element with the listener (outer)</span>
                </div>
                <div class="font-mono text-[10px]">{"}"})</div>
                <div class="font-mono text-[10px] mt-1">
                    <span class="text-yellow-400"
                        >// Click button inside outer → target=button,
                        currentTarget=outer</span>
                </div>
            </div>
        </ProTip>

        <ProTip>
            <div>🎯 <strong>When to use stopPropagation:</strong></div>
            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                <div class="font-mono text-[10px]">
                    <span class="text-gray-400"
                        >// Prevent modal close when clicking content</span>
                </div>
                <div class="font-mono text-[10px]">
                    modalContent.addEventListener('click', (e) =&gt; {"{"}
                </div>
                <div class="font-mono text-[10px]">
                    &nbsp;&nbsp;e.stopPropagation() <span class="text-gray-400"
                        >// don't bubble to overlay</span>
                </div>
                <div class="font-mono text-[10px]">{"}"})</div>
                <div class="font-mono text-[10px]">
                    overlay.addEventListener('click', () =&gt; modal.close())
                </div>
            </div>
        </ProTip>
    </MethodCard>

