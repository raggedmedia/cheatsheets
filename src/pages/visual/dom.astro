---
import '~styles/styles.css'
import MethodCard from '~components/visual-js/MethodCard.astro';
import ProTip from '~components/visual-js/ProTip.astro';
import GlobalNav from '~components/visual-js/GlobalNav.astro';
---

<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>JavaScript DOM Manipulation - Visual Cheatsheet</title>
    </head>
    <body class="m-0 p-4 bg-[#1a1d29] text-gray-200">
        <div class="flex gap-6 max-w-[1600px] mx-auto">
            <!-- Main Content -->
            <main class="flex-1 min-w-0">
                <h1 class="text-white mb-1 text-2xl font-bold">JavaScript DOM Manipulation</h1>
                <p class="text-gray-400 mb-6 text-sm">Visual blueprint-style reference for working with the DOM</p>

                <ProTip>
                    <div>💡 <strong>DOM = Document Object Model:</strong></div>
                    <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                        <div class="font-mono text-[10px]"><span class="text-gray-400">// HTML represents a tree structure of nodes</span></div>
                        <div class="font-mono text-[10px]">document <span class="text-gray-400">// root of the DOM tree</span></div>
                        <div class="font-mono text-[10px]">document.documentElement <span class="text-gray-400">// &lt;html&gt;</span></div>
                        <div class="font-mono text-[10px]">document.body <span class="text-gray-400">// &lt;body&gt;</span></div>
                    </div>
                </ProTip>

                <!-- ============================================ -->
                <!-- 🔍 SELECTING ELEMENTS -->
                <!-- ============================================ -->

                <h2 id="selecting" class="text-blue-300 text-xl my-4 pb-2 border-b-2 border-blue-600">
                    🔍 Selecting Elements
                </h2>

                <!-- QUERYSELECTOR -->
                <div id="query-selector">
                    <MethodCard
                        methodName="querySelector() / querySelectorAll()"
                        signature="document.querySelector(selector)"
                        description="Find element(s) using CSS selectors"
                        mutates={false}
                    >
                        <div class="p-6 bg-gray-800 rounded">
                            <div class="space-y-4">
                                <!-- querySelector flow -->
                                <div class="flex items-center gap-3">
                                    <div class="bg-blue-500/20 border border-blue-400 rounded px-4 py-2 flex-1">
                                        <div class="text-blue-300 font-mono text-xs">'.button'</div>
                                        <div class="text-gray-400 text-[10px] mt-0.5">CSS Selector (string)</div>
                                    </div>
                                    <div class="text-gray-400 text-xl">→</div>
                                    <div class="bg-purple-500/20 border border-purple-400 rounded px-4 py-2 flex-1">
                                        <div class="text-purple-300 font-mono text-xs">querySelector()</div>
                                        <div class="text-gray-400 text-[10px] mt-0.5">Function</div>
                                    </div>
                                    <div class="text-gray-400 text-xl">→</div>
                                    <div class="bg-green-500/20 border border-green-500 rounded px-4 py-2 flex-1">
                                        <div class="text-green-300 font-mono text-xs">Element</div>
                                        <div class="text-gray-400 text-[10px] mt-0.5">or null</div>
                                    </div>
                                </div>

                                <!-- querySelectorAll flow -->
                                <div class="flex items-center gap-3">
                                    <div class="bg-blue-500/20 border border-blue-400 rounded px-4 py-2 flex-1">
                                        <div class="text-blue-300 font-mono text-xs">'.button'</div>
                                        <div class="text-gray-400 text-[10px] mt-0.5">CSS Selector (string)</div>
                                    </div>
                                    <div class="text-gray-400 text-xl">→</div>
                                    <div class="bg-purple-500/20 border border-purple-400 rounded px-4 py-2 flex-1">
                                        <div class="text-purple-300 font-mono text-xs">querySelectorAll()</div>
                                        <div class="text-gray-400 text-[10px] mt-0.5">Function</div>
                                    </div>
                                    <div class="text-gray-400 text-xl">→</div>
                                    <div class="bg-orange-500/20 border border-orange-400 rounded px-4 py-2 flex-1">
                                        <div class="text-orange-300 font-mono text-xs">NodeList</div>
                                        <div class="text-gray-400 text-[10px] mt-0.5">array-like collection</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <ProTip>
                            <div>📘 <strong>What is an Element?</strong></div>
                            <div class="pl-2 border-l-2 border-blue-500/30 space-y-0.5 mt-1">
                                <div class="text-[10px]">An <strong>Element</strong> is a JavaScript object representing an HTML element in the DOM tree.</div>
                                <div class="text-[10px]">It has properties and methods to manipulate the element:</div>
                                <div class="font-mono text-[10px] mt-1">element.textContent <span class="text-gray-400">// get/set text</span></div>
                                <div class="font-mono text-[10px]">element.classList <span class="text-gray-400">// modify classes</span></div>
                                <div class="font-mono text-[10px]">element.style <span class="text-gray-400">// modify styles</span></div>
                                <div class="font-mono text-[10px]">element.addEventListener() <span class="text-gray-400">// listen for events</span></div>
                            </div>
                        </ProTip>

                        <ProTip>
                            <div>📘 <strong>What is a NodeList?</strong></div>
                            <div class="pl-2 border-l-2 border-orange-500/30 space-y-0.5 mt-1">
                                <div class="text-[10px]">A <strong>NodeList</strong> is an array-like collection of DOM nodes (usually Elements).</div>
                                <div class="text-[10px] mt-1"><strong>Why not just an Array?</strong> NodeList is an older DOM API that predates modern JavaScript.</div>
                                <div class="text-[10px]">It can be "live" (auto-updates) or "static". querySelectorAll returns a <strong>static</strong> NodeList.</div>
                            </div>
                        </ProTip>

                        <ProTip>
                            <div>⚠️ <strong>NodeList vs Array - Critical difference!</strong></div>
                            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                                <div class="font-mono text-[10px]">const items = querySelectorAll('.item')</div>
                                <div class="font-mono text-[10px] mt-1"><span class="text-green-400">// ✅ Works - forEach is available</span></div>
                                <div class="font-mono text-[10px]">items.forEach(item =&gt; console.log(item))</div>
                                <div class="font-mono text-[10px] mt-1"><span class="text-red-400">// ❌ Fails - no map, filter, reduce, etc.</span></div>
                                <div class="font-mono text-[10px]">items.map(item =&gt; item.id) <span class="text-red-400">// TypeError!</span></div>
                                <div class="font-mono text-[10px] mt-1"><span class="text-green-400">// ✅ Convert to real Array for array methods</span></div>
                                <div class="font-mono text-[10px]">const arr = [...items] <span class="text-gray-400">// or Array.from(items)</span></div>
                                <div class="font-mono text-[10px]">arr.map(item =&gt; item.id) <span class="text-green-400">// works!</span></div>
                            </div>
                        </ProTip>

                        <ProTip>
                            <div>💡 <strong>When to use NodeList directly:</strong></div>
                            <div class="pl-2 border-l-2 border-blue-500/30 space-y-0.5 mt-1">
                                <div class="text-[10px]">NodeList has <code>.forEach()</code> built-in, so if that's all you need:</div>
                                <div class="font-mono text-[10px] mt-1"><span class="text-green-400">// ✅ Fine - just looping</span></div>
                                <div class="font-mono text-[10px]">querySelectorAll('.item').forEach(item =&gt; item.remove())</div>
                                <div class="font-mono text-[10px] mt-1"><span class="text-yellow-400">// ⚠️ Convert if you need array methods</span></div>
                                <div class="font-mono text-[10px]">const ids = [...querySelectorAll('.item')].map(item =&gt; item.id)</div>
                                <div class="text-[10px] mt-1"><strong>Practical tip:</strong> If you're just using forEach, keep it as NodeList. Otherwise, convert immediately.</div>
                            </div>
                        </ProTip>

                        <ProTip>
                            <div>🗂️ <strong>Legacy selectors (don't use these):</strong></div>
                            <div class="pl-2 border-l-2 border-gray-500/30 space-y-0.5 mt-1">
                                <div class="font-mono text-[10px]">getElementById('main') <span class="text-gray-400">// returns single element</span></div>
                                <div class="font-mono text-[10px]">getElementsByClassName('active') <span class="text-gray-400">// returns live HTMLCollection</span></div>
                                <div class="font-mono text-[10px]">getElementsByTagName('div') <span class="text-gray-400">// returns live HTMLCollection</span></div>
                                <div class="text-[10px] mt-1"><strong>Why avoid?</strong> querySelector/All are more flexible (any CSS selector). HTMLCollections are "live" which can cause bugs.</div>
                                <div class="text-[10px]">You'll see these in old code, but use <code>querySelector/All</code> in new code.</div>
                            </div>
                        </ProTip>
                    </MethodCard>
                </div>

                <!-- ============================================ -->
                <!-- ✏️ MODIFYING CONTENT -->
                <!-- ============================================ -->

                <h2 id="content" class="text-purple-300 text-xl my-4 pb-2 border-b-2 border-purple-600">
                    ✏️ Modifying Content
                </h2>

                <!-- TEXTCONTENT VS INNERHTML -->
                <div id="text-vs-html">
                    <MethodCard
                        methodName="textContent vs innerHTML"
                        signature="element.textContent / innerHTML"
                        description="Set element content as text or HTML"
                        mutates={true}
                    >
                        <div class="p-6 bg-gray-800 rounded">
                            <div class="space-y-4">
                                <!-- textContent -->
                                <div>
                                    <div class="text-green-400 font-bold text-sm mb-2">textContent (safe):</div>
                                    <div class="bg-green-500/20 border border-green-500 rounded p-3">
                                        <div class="text-green-300 font-mono text-xs space-y-0.5">
                                            <div>el.textContent = '&lt;b&gt;Bold&lt;/b&gt;'</div>
                                            <div class="text-gray-400 text-[10px] mt-1">Renders as: &lt;b&gt;Bold&lt;/b&gt; (literal text)</div>
                                        </div>
                                    </div>
                                </div>

                                <!-- innerHTML -->
                                <div>
                                    <div class="text-red-400 font-bold text-sm mb-2">innerHTML (unsafe):</div>
                                    <div class="bg-red-500/20 border border-red-500 rounded p-3">
                                        <div class="text-red-300 font-mono text-xs space-y-0.5">
                                            <div>el.innerHTML = '&lt;b&gt;Bold&lt;/b&gt;'</div>
                                            <div class="text-gray-400 text-[10px] mt-1">Renders as: <strong>Bold</strong> (parsed HTML)</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="text-gray-300 text-sm mt-3 p-3 bg-gray-800/50 rounded border border-gray-700">
                            <strong>textContent</strong> = plain text (safe), <strong>innerHTML</strong> = HTML (XSS risk with user input).
                        </div>

                        <ProTip>
                            <div>⚠️ <strong>Never use innerHTML with user input:</strong></div>
                            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                                <div class="font-mono text-[10px]"><span class="text-red-400">// Dangerous - XSS vulnerability ❌</span></div>
                                <div class="font-mono text-[10px]">el.innerHTML = userInput</div>
                                <div class="font-mono text-[10px] mt-1"><span class="text-green-400">// Safe - escapes HTML ✅</span></div>
                                <div class="font-mono text-[10px]">el.textContent = userInput</div>
                            </div>
                        </ProTip>
                    </MethodCard>
                </div>

                <!-- ============================================ -->
                <!-- 🎨 STYLING & CLASSES -->
                <!-- ============================================ -->

                <h2 id="styling" class="text-green-300 text-xl my-4 pb-2 border-b-2 border-green-600">
                    🎨 Styling & Classes
                </h2>

                <!-- CLASSLIST -->
                <div id="class-list">
                    <MethodCard
                        methodName="classList"
                        signature="element.classList.add/remove/toggle()"
                        description="Manipulate element classes"
                        mutates={true}
                    >
                        <div class="p-6 bg-gray-800 rounded">
                            <div class="space-y-3">
                                <!-- add -->
                                <div class="flex items-center gap-3">
                                    <div class="bg-green-500/20 border border-green-500 rounded px-4 py-2 flex-1">
                                        <div class="text-green-300 font-mono text-xs">classList.add('active')</div>
                                        <div class="text-gray-400 text-[10px] mt-0.5">Adds class to element</div>
                                        <div class="text-green-300 font-mono text-[10px] mt-1">.add('btn', 'primary') <span class="text-gray-400">// multiple</span></div>
                                    </div>
                                    <div class="text-gray-400 text-xl">→</div>
                                    <div class="bg-blue-500/20 border border-blue-400 rounded px-4 py-2 w-32">
                                        <div class="text-blue-300 font-mono text-[10px]">class="active"</div>
                                    </div>
                                </div>

                                <!-- remove -->
                                <div class="flex items-center gap-3">
                                    <div class="bg-red-500/20 border border-red-500 rounded px-4 py-2 flex-1">
                                        <div class="text-red-300 font-mono text-xs">classList.remove('hidden')</div>
                                        <div class="text-gray-400 text-[10px] mt-0.5">Removes class from element</div>
                                        <div class="text-red-300 font-mono text-[10px] mt-1">.remove('a', 'b') <span class="text-gray-400">// multiple</span></div>
                                    </div>
                                    <div class="text-gray-400 text-xl">→</div>
                                    <div class="bg-blue-500/20 border border-blue-400 rounded px-4 py-2 w-32">
                                        <div class="text-blue-300 font-mono text-[10px]">class=""</div>
                                    </div>
                                </div>

                                <!-- toggle -->
                                <div class="flex items-center gap-3">
                                    <div class="bg-purple-500/20 border border-purple-400 rounded px-4 py-2 flex-1">
                                        <div class="text-purple-300 font-mono text-xs">classList.toggle('dark')</div>
                                        <div class="text-gray-400 text-[10px] mt-0.5">Adds if absent, removes if present</div>
                                    </div>
                                    <div class="text-gray-400 text-xl">⇄</div>
                                    <div class="bg-blue-500/20 border border-blue-400 rounded px-4 py-2 w-32">
                                        <div class="text-blue-300 font-mono text-[10px]">on/off</div>
                                    </div>
                                </div>

                                <!-- contains -->
                                <div class="flex items-center gap-3">
                                    <div class="bg-cyan-500/20 border border-cyan-400 rounded px-4 py-2 flex-1">
                                        <div class="text-cyan-300 font-mono text-xs">classList.contains('active')</div>
                                        <div class="text-gray-400 text-[10px] mt-0.5">Check if class exists</div>
                                    </div>
                                    <div class="text-gray-400 text-xl">→</div>
                                    <div class="bg-yellow-500/20 border border-yellow-400 rounded px-4 py-2 w-32">
                                        <div class="text-yellow-300 font-mono text-[10px]">true/false</div>
                                    </div>
                                </div>

                                <!-- replace -->
                                <div class="flex items-center gap-3">
                                    <div class="bg-orange-500/20 border border-orange-400 rounded px-4 py-2 flex-1">
                                        <div class="text-orange-300 font-mono text-xs">classList.replace('old', 'new')</div>
                                        <div class="text-gray-400 text-[10px] mt-0.5">Swap classes</div>
                                    </div>
                                    <div class="text-gray-400 text-xl">→</div>
                                    <div class="bg-blue-500/20 border border-blue-400 rounded px-4 py-2 w-32">
                                        <div class="text-blue-300 font-mono text-[10px]">class="new"</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <ProTip>
                            <div>💡 <strong>Toggle with condition (force add/remove):</strong></div>
                            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                                <div class="text-[10px]">The second parameter of <code>toggle()</code> is a boolean that forces add or remove:</div>
                                <div class="font-mono text-[10px] mt-1">el.classList.toggle('active', true) <span class="text-gray-400">// always adds</span></div>
                                <div class="font-mono text-[10px]">el.classList.toggle('active', false) <span class="text-gray-400">// always removes</span></div>
                                <div class="font-mono text-[10px]">el.classList.toggle('active', isActive) <span class="text-gray-400">// dynamic</span></div>
                                <div class="font-mono text-[10px] mt-1"><span class="text-gray-400">// This is cleaner than:</span></div>
                                <div class="font-mono text-[10px]">if (isActive) {'{'} el.classList.add('active') {'}'}</div>
                                <div class="font-mono text-[10px]">else {'{'} el.classList.remove('active') {'}'}</div>
                                <div class="font-mono text-[10px] mt-1"><span class="text-green-400">// Real example: enable/disable button based on form validity</span></div>
                                <div class="font-mono text-[10px]">submitBtn.classList.toggle('disabled', !form.checkValidity())</div>
                            </div>
                        </ProTip>

                        <ProTip>
                            <div>⚠️ <strong>Avoid inline styles - use element.style sparingly:</strong></div>
                            <div class="pl-2 border-l-2 border-red-500/30 space-y-0.5 mt-1">
                                <div class="text-[10px]">You <em>can</em> modify styles directly, but it's usually better to use classes:</div>
                                <div class="font-mono text-[10px] mt-1"><span class="text-red-400">// ❌ Bad - hard to maintain</span></div>
                                <div class="font-mono text-[10px]">el.style.color = 'red'</div>
                                <div class="font-mono text-[10px]">el.style.backgroundColor = '#000' <span class="text-gray-400">// camelCase!</span></div>
                                <div class="font-mono text-[10px]">el.style.fontSize = '16px' <span class="text-gray-400">// include units</span></div>
                                <div class="font-mono text-[10px] mt-1"><span class="text-green-400">// ✅ Good - define styles in CSS</span></div>
                                <div class="font-mono text-[10px]">el.classList.add('highlighted')</div>
                                <div class="text-[10px] mt-1"><strong>When to use .style:</strong> Dynamic values that can't be in CSS (e.g., element.style.width = {"`${dynamicWidth}px`"})</div>
                                <div class="font-mono text-[10px] mt-1">el.style.color = '' <span class="text-gray-400">// remove inline style</span></div>
                            </div>
                        </ProTip>
                    </MethodCard>
                </div>

                <!-- ============================================ -->
                <!-- 🏗️ CREATING & MODIFYING STRUCTURE -->
                <!-- ============================================ -->

                <h2 id="creating" class="text-orange-300 text-xl my-4 pb-2 border-b-2 border-orange-600">
                    🏗️ Creating & Modifying Structure
                </h2>

                <!-- CREATEELEMENT -->
                <div id="create-element">
                    <MethodCard
                        methodName="createElement() & appendChild()"
                        signature="document.createElement(tagName)"
                        description="Create new elements and add to DOM"
                        mutates={true}
                    >
                        <div class="p-6 bg-gray-800 rounded">
                            <div class="space-y-4">
                                <!-- Steps -->
                                <div class="space-y-3">
                                    <div class="flex items-center gap-3">
                                        <div class="w-6 text-gray-500 text-xs">1</div>
                                        <div class="flex-1 bg-blue-500/20 border border-blue-400 rounded px-3 py-2">
                                            <div class="text-blue-300 font-mono text-xs">const div = document.createElement('div')</div>
                                        </div>
                                    </div>

                                    <div class="flex items-center gap-3">
                                        <div class="w-6 text-gray-500 text-xs">2</div>
                                        <div class="flex-1 bg-purple-500/20 border border-purple-400 rounded px-3 py-2">
                                            <div class="text-purple-300 font-mono text-xs">div.textContent = 'Hello'</div>
                                        </div>
                                    </div>

                                    <div class="flex items-center gap-3">
                                        <div class="w-6 text-gray-500 text-xs">3</div>
                                        <div class="flex-1 bg-green-500/20 border border-green-500 rounded px-3 py-2">
                                            <div class="text-green-300 font-mono text-xs">document.body.appendChild(div)</div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Full example -->
                                <div class="bg-orange-500/20 border border-orange-400 rounded p-3">
                                    <div class="text-orange-300 font-mono text-xs space-y-0.5">
                                        <div>const button = document.createElement('button')</div>
                                        <div>button.textContent = 'Click me'</div>
                                        <div>button.classList.add('btn', 'btn-primary')</div>
                                        <div>button.onclick = () =&gt; alert('Clicked!')</div>
                                        <div>document.body.appendChild(button)</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <ProTip>
                            <div>Other insertion methods:</div>
                            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                                <div class="font-mono text-[10px]">parent.appendChild(child) <span class="text-gray-400">// end</span></div>
                                <div class="font-mono text-[10px]">parent.prepend(child) <span class="text-gray-400">// start</span></div>
                                <div class="font-mono text-[10px]">element.before(newEl) <span class="text-gray-400">// before sibling</span></div>
                                <div class="font-mono text-[10px]">element.after(newEl) <span class="text-gray-400">// after sibling</span></div>
                            </div>
                        </ProTip>
                    </MethodCard>
                </div>

                <!-- REMOVE -->
                <div id="remove">
                    <MethodCard
                        methodName="remove() & removeChild()"
                        signature="element.remove()"
                        description="Remove elements from DOM"
                        mutates={true}
                    >
                        <div class="p-6 bg-gray-800 rounded">
                            <div class="space-y-3">
                                <div class="bg-red-500/20 border border-red-500 rounded p-3">
                                    <div class="text-red-300 font-mono text-xs space-y-0.5">
                                        <div>element.remove() <span class="text-gray-400">// modern way</span></div>
                                    </div>
                                </div>

                                <div class="bg-gray-800/50 border border-gray-700 rounded p-3">
                                    <div class="text-gray-300 font-mono text-xs space-y-0.5">
                                        <div>parent.removeChild(child) <span class="text-gray-400">// old way</span></div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <ProTip>
                            <div>Remove all children:</div>
                            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                                <div class="font-mono text-[10px]"><span class="text-gray-400">// Fast way</span></div>
                                <div class="font-mono text-[10px]">element.innerHTML = ''</div>
                                <div class="font-mono text-[10px] mt-1"><span class="text-gray-400">// Better way (removes listeners)</span></div>
                                <div class="font-mono text-[10px]">element.replaceChildren()</div>
                                <div class="font-mono text-[10px] mt-1"><span class="text-gray-400">// Loop way</span></div>
                                <div class="font-mono text-[10px]">while (el.firstChild) el.firstChild.remove()</div>
                            </div>
                        </ProTip>
                    </MethodCard>
                </div>

                <!-- ============================================ -->
                <!-- 🎪 EVENTS -->
                <!-- ============================================ -->

                <h2 id="events" class="text-cyan-300 text-xl my-4 pb-2 border-b-2 border-cyan-600">
                    🎪 Events
                </h2>

                <!-- ADDEVENTLISTENER -->
                <div id="add-event-listener">
                    <MethodCard
                        methodName="addEventListener()"
                        signature="element.addEventListener(type, handler, options?)"
                        description="Listen for events on elements"
                        mutates={false}
                    >
                        <div class="p-6 bg-gray-800 rounded">
                            <div class="space-y-4">
