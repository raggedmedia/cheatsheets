---
import EmailInput from "~components/forms/EmailInput.astro";
import FormMessage from "~components/forms/FormMessage.astro";
import Layout from "~layouts/Layout.astro";
import { supabase } from "../../lib/supabase";

export const prerender = false;

const { url } = Astro;

// Handle URL messages (like invalid reset links)
const messageParam = url.searchParams.get("message");
const messageType = url.searchParams.get("type") || "info";

const messages = {
    "invalid-link":
        "The reset link is invalid or has expired. Please request a new one.",
};

const displayMessage =
    messageParam && messages[messageParam as keyof typeof messages]
        ? messages[messageParam as keyof typeof messages]
        : null;

// Handle form submission server-side
let errorMessage = "";
let successMessage = "";

if (Astro.request.method === "POST") {
    try {
        const formData = await Astro.request.formData();
        const email = formData.get("email")?.toString();

        if (!email) {
            errorMessage = "Email is required";
        } else {
            const { error } = await supabase.auth.resetPasswordForEmail(email, {
                redirectTo: `${Astro.url.origin}/auth/update-password`,
            });

            if (error) {
                errorMessage = error.message;
            } else {
                successMessage =
                    "Check your email for a password reset link. The link will expire in 1 hour.";
            }
        }
    } catch (error) {
        errorMessage = "An unexpected error occurred. Please try again.";
        console.error("Password reset error:", error);
    }
}
---

<Layout pageTitle="Reset Password">
    <div class="mx-auto w-96">
        <div class="prose mb-6">
            <h1>Reset Password</h1>
            <p>
                Enter your email address and we'll send you a link to reset your
                password.
            </p>
        </div>

        <form
            method="post"
            class="flex flex-col gap-4"
            id="reset-form"
            data-validate
            data-form-id="reset-form"
            data-button-id="reset-button"
        >
            {
                errorMessage ? (
                    <FormMessage
                        id="reset-error-message"
                        type="error"
                        message={errorMessage}
                        hidden={false}
                    />
                ) : successMessage ? (
                    <FormMessage
                        id="reset-success-message"
                        type="success"
                        message={successMessage}
                        hidden={false}
                    />
                ) : displayMessage ? (
                    <FormMessage
                        id="reset-url-message"
                        type={
                            messageType as
                                | "error"
                                | "success"
                                | "info"
                                | "warning"
                        }
                        message={displayMessage}
                        hidden={false}
                    />
                ) : null
            }

            <EmailInput
                id="reset-email"
                name="email"
                label="Email Address"
                required={true}
                placeholder="Enter your email address"
            />

            <button
                type="submit"
                class="form-button"
                id="reset-button"
                disabled
            >
                <span class="button-text">Send Reset Link</span>
            </button>
        </form>

        <div class="mt-6 text-center">
            <p class="text-sm">
                Remember your password? <a
                    href="/auth/signin"
                    class="text-blue-600 hover:underline">Sign in</a
                >
            </p>
        </div>
    </div>
</Layout>

<script src="~components/forms/form-validation.ts"></script>
