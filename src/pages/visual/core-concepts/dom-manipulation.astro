---
import "~styles/styles.css";
import MethodCard from "~components/visual-js/MethodCard.astro";
import Node from "~components/visual-js/Node.astro";
import Arrow from "~components/visual-js/Arrow.astro";
import ReturnValue from "~components/visual-js/ReturnValue.astro";
import ProcessContent from "~components/visual-js/ProcessContent.astro";
import InfoBox from "~components/visual-js/InfoBox.astro";
import ProTip from "~components/visual-js/ProTip.astro";
import SectionTitle from "~components/visual-js/SectionTitle.astro";
import SubSectionTitle from "~components/visual-js/SubSectionTitle.astro";
import VisualLayout from "src/layouts/VisualLayout.astro";
---

<VisualLayout pageTitle="DOM Manipulation">
    <!-- ============================================ -->
    <!-- 🔍 SELECTING ELEMENTS -->
    <!-- ============================================ -->

    <SectionTitle id="selecting" color="blue">
        🔍 Selecting Elements
    </SectionTitle>

    <!-- QUERYSELECTOR -->
    <MethodCard
        id="query-selector"
        methodName="querySelector() / querySelectorAll()"
        signature="document.querySelector(selector)"
        description="Find element(s) using CSS selectors"
        mutates={false}
    >
        <!-- querySelector visualization -->
        <div
            class="flex items-center gap-4 p-3 bg-gray-800 rounded overflow-x-auto mb-4"
        >
            <Node label="Input" type="input">
                <div class="text-center text-sm font-mono">'.button'</div>
            </Node>

            <Arrow label="finds" />

            <Node label="Method" type="process">
                <ProcessContent
                    name="querySelector()"
                    description="First match only"
                />
            </Node>

            <Arrow label="returns" />

            <Node label="Result" type="output">
                <ReturnValue value="Element" type="object" />
                <div class="text-gray-400 text-[10px] mt-1">
                    or null if not found
                </div>
            </Node>
        </div>

        <!-- querySelectorAll visualization -->
        <div
            class="flex items-center gap-4 p-3 bg-gray-800 rounded overflow-x-auto"
        >
            <Node label="Input" type="input">
                <div class="text-center text-sm font-mono">'.button'</div>
            </Node>

            <Arrow label="finds" />

            <Node label="Method" type="process">
                <ProcessContent
                    name="querySelectorAll()"
                    description="All matches"
                />
            </Node>

            <Arrow label="returns" />

            <Node label="Result" type="output">
                <ReturnValue value="NodeList" type="object" />
                <div class="text-gray-400 text-[10px] mt-1">
                    array-like collection
                </div>
            </Node>
        </div>

        <ProTip>
            <div>📘 <strong>What is an Element?</strong></div>
            <div class="pl-2 border-l-2 border-blue-500/30 space-y-0.5 mt-1">
                <div class="text-[10px]">
                    An <strong>Element</strong> is a JavaScript object representing
                    an HTML element in the DOM tree.
                </div>
                <div class="text-[10px]">
                    It has properties and methods to manipulate the element:
                </div>
                <div class="font-mono text-[10px] mt-1">
                    element.textContent <span class="text-gray-400"
                        >// get/set text</span>
                </div>
                <div class="font-mono text-[10px]">
                    element.classList <span class="text-gray-400"
                        >// modify classes</span>
                </div>
                <div class="font-mono text-[10px]">
                    element.style <span class="text-gray-400"
                        >// modify styles</span>
                </div>
                <div class="font-mono text-[10px]">
                    element.addEventListener() <span class="text-gray-400"
                        >// listen for events</span>
                </div>
            </div>
        </ProTip>

        <ProTip>
            <div>📘 <strong>What is a NodeList?</strong></div>
            <div class="pl-2 border-l-2 border-orange-500/30 space-y-0.5 mt-1">
                <div class="text-[10px]">
                    A <strong>NodeList</strong> is an array-like collection of DOM
                    nodes (usually Elements).
                </div>
                <div class="text-[10px] mt-1">
                    <strong>Why not just an Array?</strong> NodeList is an older
                    DOM API that predates modern JavaScript.
                </div>
                <div class="text-[10px]">
                    It can be "live" (auto-updates) or "static".
                    querySelectorAll returns a <strong>static</strong> NodeList.
                </div>
            </div>
        </ProTip>

        <ProTip>
            <div>
                ⚠️ <strong>NodeList vs Array - Critical difference!</strong>
            </div>
            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                <div class="font-mono text-[10px]">
                    const items = querySelectorAll('.item')
                </div>
                <div class="font-mono text-[10px] mt-1">
                    <span class="text-green-400"
                        >// ✅ Works - forEach is available</span>
                </div>
                <div class="font-mono text-[10px]">
                    items.forEach(item =&gt; console.log(item))
                </div>
                <div class="font-mono text-[10px] mt-1">
                    <span class="text-red-400"
                        >// ❌ Fails - no map, filter, reduce, etc.</span>
                </div>
                <div class="font-mono text-[10px]">
                    items.map(item =&gt; item.id) <span class="text-red-400"
                        >// TypeError!</span>
                </div>
                <div class="font-mono text-[10px] mt-1">
                    <span class="text-green-400"
                        >// ✅ Convert to real Array for array methods</span>
                </div>
                <div class="font-mono text-[10px]">
                    const arr = [...items] <span class="text-gray-400"
                        >// or Array.from(items)</span>
                </div>
                <div class="font-mono text-[10px]">
                    arr.map(item =&gt; item.id) <span class="text-green-400"
                        >// works!</span>
                </div>
            </div>
        </ProTip>

        <ProTip>
            <div>💡 <strong>When to use NodeList directly:</strong></div>
            <div class="pl-2 border-l-2 border-blue-500/30 space-y-0.5 mt-1">
                <div class="text-[10px]">
                    NodeList has <code>.forEach()</code> built-in, so if that's all
                    you need:
                </div>
                <div class="font-mono text-[10px] mt-1">
                    <span class="text-green-400"
                        >// ✅ Fine - just looping</span>
                </div>
                <div class="font-mono text-[10px]">
                    querySelectorAll('.item').forEach(item =&gt; item.remove())
                </div>
                <div class="font-mono text-[10px] mt-1">
                    <span class="text-yellow-400"
                        >// ⚠️ Convert if you need array methods</span>
                </div>
                <div class="font-mono text-[10px]">
                    const ids = [...querySelectorAll('.item')].map(item =&gt;
                    item.id)
                </div>
                <div class="text-[10px] mt-1">
                    <strong>Practical tip:</strong> If you're just using forEach,
                    keep it as NodeList. Otherwise, convert immediately.
                </div>
            </div>
        </ProTip>

        <ProTip>
            <div>🗂️ <strong>Legacy selectors (don't use these):</strong></div>
            <div class="pl-2 border-l-2 border-gray-500/30 space-y-0.5 mt-1">
                <div class="font-mono text-[10px]">
                    getElementById('main') <span class="text-gray-400"
                        >// returns single element</span>
                </div>
                <div class="font-mono text-[10px]">
                    getElementsByClassName('active') <span class="text-gray-400"
                        >// returns live HTMLCollection</span>
                </div>
                <div class="font-mono text-[10px]">
                    getElementsByTagName('div') <span class="text-gray-400"
                        >// returns live HTMLCollection</span>
                </div>
                <div class="text-[10px] mt-1">
                    <strong>Why avoid?</strong> querySelector/All are more flexible
                    (any CSS selector). HTMLCollections are "live" which can cause
                    bugs.
                </div>
                <div class="text-[10px]">
                    You'll see these in old code, but use <code
                        >querySelector/All</code
                    > in new code.
                </div>
            </div>
        </ProTip>
    </MethodCard>

    <!-- ============================================ -->
    <!-- 🧭 DOM TRAVERSAL -->
    <!-- ============================================ -->

    <SectionTitle id="traversing" color="pink"> 🌳 DOM Traversal </SectionTitle>

    <SubSectionTitle id="traversal-up" parentColor="pink"
        >⬆️ Moving Up (Parents)</SubSectionTitle
    >

    <!-- PARENTELEMENT -->
    <MethodCard
        id="parent-element"
        methodName="parentElement"
        signature="element.parentElement"
        description="Get the direct parent element"
        mutates={false}
    >
        <div class="p-6 bg-gray-800 rounded">
            <div class="space-y-4">
                <div class="bg-pink-500/20 border border-pink-400 rounded p-3">
                    <div class="text-pink-300 font-mono text-xs space-y-0.5">
                        <div>const parent = button.parentElement</div>
                        <div class="text-gray-400 text-[10px] mt-1">
                            Returns immediate parent or null if at document root
                        </div>
                    </div>
                </div>

                <!-- Example -->
                <div class="bg-cyan-500/20 border border-cyan-400 rounded p-3">
                    <div
                        class="text-cyan-300 font-mono text-[10px] space-y-0.5"
                    >
                        <div class="text-yellow-400 mb-1">Example:</div>
                        <div>&lt;div class="card"&gt;</div>
                        <div>
                            &nbsp;&nbsp;&lt;button
                            id="btn"&gt;Click&lt;/button&gt;
                        </div>
                        <div>&lt;/div&gt;</div>
                        <div class="mt-2">
                            btn.parentElement <span class="text-gray-400"
                                >// &lt;div class="card"&gt;</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <ProTip>
            <div>⚠️ <strong>parentElement vs parentNode:</strong></div>
            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                <div class="font-mono text-[10px]">
                    el.parentElement <span class="text-green-400"
                        >// ✅ Returns Element or null</span>
                </div>
                <div class="font-mono text-[10px]">
                    el.parentNode <span class="text-yellow-400"
                        >// ⚠️ Can return Document node</span>
                </div>
                <div class="font-mono text-[10px] mt-1">
                    <span class="text-yellow-400"
                        >// Always use parentElement!</span>
                </div>
            </div>
        </ProTip>
    </MethodCard>

    <!-- CLOSEST -->
    <MethodCard
        id="closest"
        methodName="closest()"
        signature="element.closest(selector)"
        description="Find nearest ancestor matching CSS selector"
        mutates={false}
    >
        <div class="p-6 bg-gray-800 rounded">
            <div class="space-y-4">
                <div class="bg-pink-500/20 border border-pink-400 rounded p-3">
                    <div class="text-pink-300 font-mono text-xs space-y-0.5">
                        <div>const card = button.closest('.card')</div>
                        <div>const form = input.closest('form')</div>
                        <div>const row = cell.closest('tr')</div>
                        <div class="mt-2 text-[10px] text-gray-400">
                            Searches UP the tree (including self) until match
                            found
                        </div>
                    </div>
                </div>

                <!-- Real-world example -->
                <div
                    class="bg-orange-500/20 border border-orange-400 rounded p-3"
                >
                    <div class="text-orange-300 font-mono text-xs space-y-0.5">
                        <div class="text-yellow-400 mb-1">
                            Perfect for event delegation:
                        </div>
                        <div>
                            deleteBtn.addEventListener('click', (e) =&gt; {"{"}
                        </div>
                        <div>
                            &nbsp;&nbsp;const row = e.target.closest('tr')
                        </div>
                        <div>&nbsp;&nbsp;row.remove()</div>
                        <div>{"}"})</div>
                    </div>
                </div>
            </div>
        </div>

        <ProTip>
            <div>💡 <strong>closest() is incredibly useful:</strong></div>
            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                <div class="text-[10px]">
                    Works like querySelector but searches <strong>UP</strong> the
                    tree instead of down
                </div>
                <div class="text-[10px]">
                    Includes the element itself in the search (checks self
                    first)
                </div>
                <div class="text-[10px]">
                    Returns null if no ancestor matches
                </div>
                <div class="font-mono text-[10px] mt-1">
                    <span class="text-gray-400"
                        >// Find card containing clicked button</span>
                </div>
                <div class="font-mono text-[10px]">
                    button.addEventListener('click', (e) =&gt; {"{"}
                </div>
                <div class="font-mono text-[10px]">
                    &nbsp;&nbsp;const card = e.target.closest('.card')
                </div>
                <div class="font-mono text-[10px]">
                    &nbsp;&nbsp;const title = card.querySelector('.title')
                </div>
                <div class="font-mono text-[10px]">{"}"})</div>
            </div>
        </ProTip>
    </MethodCard>

    <SubSectionTitle id="traversal-down" parentColor="pink"
        >⬇️ Moving Down (Children)</SubSectionTitle
    >

    <!-- CHILDREN -->
    <MethodCard
        id="children"
        methodName="children & childElementCount"
        signature="element.children"
        description="Access child elements"
        mutates={false}
    >
        <div class="p-6 bg-gray-800 rounded">
            <div class="space-y-4">
                <div class="bg-pink-500/20 border border-pink-400 rounded p-3">
                    <div class="text-pink-300 font-mono text-xs space-y-0.5">
                        <div>
                            el.children <span class="text-gray-400"
                                >// HTMLCollection of child elements</span>
                        </div>
                        <div>
                            el.firstElementChild <span class="text-gray-400"
                                >// first child element</span>
                        </div>
                        <div>
                            el.lastElementChild <span class="text-gray-400"
                                >// last child element</span>
                        </div>
                        <div>
                            el.childElementCount <span class="text-gray-400"
                                >// number of children</span>
                        </div>
                    </div>
                </div>

                <!-- Example -->
                <div class="bg-cyan-500/20 border border-cyan-400 rounded p-3">
                    <div
                        class="text-cyan-300 font-mono text-[10px] space-y-0.5"
                    >
                        <div class="text-yellow-400 mb-1">Example:</div>
                        <div>const list = document.querySelector('ul')</div>
                        <div>
                            list.childElementCount <span class="text-gray-400"
                                >// 3</span>
                        </div>
                        <div>
                            list.firstElementChild <span class="text-gray-400"
                                >// &lt;li&gt;First&lt;/li&gt;</span>
                        </div>
                        <div>
                            list.lastElementChild <span class="text-gray-400"
                                >// &lt;li&gt;Last&lt;/li&gt;</span>
                        </div>
                        <div class="mt-2">
                            [...list.children].forEach(li =&gt; console.log(li))
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <ProTip>
            <div>⚠️ <strong>children vs childNodes:</strong></div>
            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                <div class="font-mono text-[10px]">
                    el.children <span class="text-green-400"
                        >// ✅ Only element nodes</span>
                </div>
                <div class="font-mono text-[10px]">
                    el.childNodes <span class="text-red-400"
                        >// ❌ Includes text/comment nodes</span>
                </div>
                <div class="font-mono text-[10px] mt-1">
                    <span class="text-yellow-400"
                        >// Always use "Element" versions!</span>
                </div>
            </div>
        </ProTip>
    </MethodCard>

    <SubSectionTitle id="traversal-sideways" parentColor="pink"
        >↔️ Moving Sideways (Siblings)</SubSectionTitle
    >

    <!-- SIBLINGS -->
    <MethodCard
        id="siblings"
        methodName="nextElementSibling & previousElementSibling"
        signature="element.nextElementSibling"
        description="Navigate to sibling elements"
        mutates={false}
    >
        <div class="p-6 bg-gray-800 rounded">
            <div class="space-y-4">
                <div class="bg-pink-500/20 border border-pink-400 rounded p-3">
                    <div class="text-pink-300 font-mono text-xs space-y-0.5">
                        <div>
                            el.nextElementSibling <span class="text-gray-400"
                                >// next sibling element</span>
                        </div>
                        <div>
                            el.previousElementSibling <span
                                class="text-gray-400"
                                >// previous sibling element</span>
                        </div>
                    </div>
                </div>

                <!-- Example -->
                <div class="bg-cyan-500/20 border border-cyan-400 rounded p-3">
                    <div
                        class="text-cyan-300 font-mono text-[10px] space-y-0.5"
                    >
                        <div class="text-yellow-400 mb-1">
                            Example - Tab navigation:
                        </div>
                        <div>
                            const currentTab =
                            document.querySelector('.tab.active')
                        </div>
                        <div>const nextTab = currentTab.nextElementSibling</div>
                        <div>if (nextTab) {"{"}</div>
                        <div>
                            &nbsp;&nbsp;currentTab.classList.remove('active')
                        </div>
                        <div>&nbsp;&nbsp;nextTab.classList.add('active')</div>
                        <div>{"}"}</div>
                    </div>
                </div>
            </div>
        </div>

        <ProTip>
            <div>⚠️ <strong>Element vs Node versions:</strong></div>
            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                <div class="font-mono text-[10px]">
                    el.nextElementSibling <span class="text-green-400"
                        >// ✅ Next element</span>
                </div>
                <div class="font-mono text-[10px]">
                    el.nextSibling <span class="text-red-400"
                        >// ❌ Might be whitespace text node</span>
                </div>
                <div class="font-mono text-[10px] mt-1">
                    <span class="text-yellow-400"
                        >// Whitespace between tags counts as text nodes!</span>
                </div>
            </div>
        </ProTip>
    </MethodCard>

    <SubSectionTitle id="traversal-testing" parentColor="pink"
        >✅ Testing Selectors</SubSectionTitle
    >

    <!-- MATCHES -->
    <MethodCard
        id="matches"
        methodName="matches()"
        signature="element.matches(selector)"
        description="Check if element matches CSS selector"
        mutates={false}
    >
        <div class="p-6 bg-gray-800 rounded">
            <div class="space-y-4">
                <div class="bg-pink-500/20 border border-pink-400 rounded p-3">
                    <div class="text-pink-300 font-mono text-xs space-y-0.5">
                        <div>if (el.matches('.active')) {"{"} ... {"}"}</div>
                        <div>
                            if (e.target.matches('button')) {"{"} ... {"}"}
                        </div>
                        <div>
                            if (el.matches('[data-id="123"]')) {"{"} ... {"}"}
                        </div>
                        <div class="mt-2 text-[10px] text-gray-400">
                            Returns true/false - perfect for conditional logic
                        </div>
                    </div>
                </div>

                <!-- Combining closest and matches -->
                <div
                    class="bg-purple-500/20 border border-purple-400 rounded p-3"
                >
                    <div class="text-purple-300 font-mono text-xs space-y-0.5">
                        <div class="text-yellow-400 mb-1">
                            Powerful with closest():
                        </div>
                        <div>
                            list.addEventListener('click', (e) =&gt; {"{"}
                        </div>
                        <div>
                            &nbsp;&nbsp;if (e.target.matches('.delete-btn')) {
                                "{"
                            }
                        </div>
                        <div>
                            &nbsp;&nbsp;&nbsp;&nbsp;const item =
                            e.target.closest('.list-item')
                        </div>
                        <div>&nbsp;&nbsp;&nbsp;&nbsp;item.remove()</div>
                        <div>&nbsp;&nbsp;{"}"}</div>
                        <div>{"}"})</div>
                    </div>
                </div>
            </div>
        </div>

        <ProTip>
            <div>🎯 <strong>closest() vs matches():</strong></div>
            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                <div class="font-mono text-[10px]">
                    <span class="text-green-400">matches():</span> Check if current
                    element matches selector (true/false)
                </div>
                <div class="font-mono text-[10px]">
                    <span class="text-green-400">closest():</span> Find nearest parent
                    matching selector (Element/null)
                </div>
                <div class="font-mono text-[10px] mt-1">
                    <span class="text-yellow-400"
                        >// Perfect combo for event delegation!</span>
                </div>
                <div class="font-mono text-[10px]">
                    e.target.matches('.btn') <span class="text-gray-400"
                        >// is it a button?</span>
                </div>
                <div class="font-mono text-[10px]">
                    e.target.closest('.card') <span class="text-gray-400"
                        >// find parent card</span>
                </div>
            </div>
        </ProTip>
    </MethodCard>

    <!-- ============================================ -->
    <!-- 🏗️ CREATING & MODIFYING STRUCTURE -->
    <!-- ============================================ -->

    <SectionTitle id="creating" color="orange">
        ➕ Creating & Removing Elements
    </SectionTitle>

    <!-- CREATEELEMENT -->
    <MethodCard
        id="create-element"
        methodName="createElement() & appendChild()"
        signature="document.createElement(tagName)"
        description="Create new elements and add to DOM"
        mutates={true}
    >
        <div class="p-6 bg-gray-800 rounded">
            <div class="space-y-4">
                <!-- Steps -->
                <div class="space-y-3">
                    <div class="flex items-center gap-3">
                        <div class="w-6 text-gray-500 text-xs">1</div>
                        <div
                            class="flex-1 bg-blue-500/20 border border-blue-400 rounded px-3 py-2"
                        >
                            <div class="text-blue-300 font-mono text-xs">
                                const div = document.createElement('div')
                            </div>
                        </div>
                    </div>

                    <div class="flex items-center gap-3">
                        <div class="w-6 text-gray-500 text-xs">2</div>
                        <div
                            class="flex-1 bg-purple-500/20 border border-purple-400 rounded px-3 py-2"
                        >
                            <div class="text-purple-300 font-mono text-xs">
                                div.textContent = 'Hello'
                            </div>
                        </div>
                    </div>

                    <div class="flex items-center gap-3">
                        <div class="w-6 text-gray-500 text-xs">3</div>
                        <div
                            class="flex-1 bg-green-500/20 border border-green-500 rounded px-3 py-2"
                        >
                            <div class="text-green-300 font-mono text-xs">
                                document.body.appendChild(div)
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Full example -->
                <div
                    class="bg-orange-500/20 border border-orange-400 rounded p-3"
                >
                    <div class="text-orange-300 font-mono text-xs space-y-0.5">
                        <div>
                            const button = document.createElement('button')
                        </div>
                        <div>button.textContent = 'Click me'</div>
                        <div>button.classList.add('btn', 'btn-primary')</div>
                        <div>button.onclick = () =&gt; alert('Clicked!')</div>
                        <div>document.body.appendChild(button)</div>
                    </div>
                </div>
            </div>
        </div>

        <ProTip>
            <div>Other insertion methods:</div>
            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                <div class="font-mono text-[10px]">
                    parent.appendChild(child) <span class="text-gray-400"
                        >// end</span>
                </div>
                <div class="font-mono text-[10px]">
                    parent.prepend(child) <span class="text-gray-400"
                        >// start</span>
                </div>
                <div class="font-mono text-[10px]">
                    element.before(newEl) <span class="text-gray-400"
                        >// before sibling</span>
                </div>
                <div class="font-mono text-[10px]">
                    element.after(newEl) <span class="text-gray-400"
                        >// after sibling</span>
                </div>
            </div>
        </ProTip>
    </MethodCard>

    <!-- REMOVE -->
    <MethodCard
        id="remove"
        methodName="remove() & removeChild()"
        signature="element.remove()"
        description="Remove elements from DOM"
        mutates={true}
    >
        <div class="p-6 bg-gray-800 rounded">
            <div class="space-y-3">
                <div class="bg-red-500/20 border border-red-500 rounded p-3">
                    <div class="text-red-300 font-mono text-xs space-y-0.5">
                        <div>
                            element.remove() <span class="text-gray-400"
                                >// modern way</span>
                        </div>
                    </div>
                </div>

                <div class="bg-gray-800/50 border border-gray-700 rounded p-3">
                    <div class="text-gray-300 font-mono text-xs space-y-0.5">
                        <div>
                            parent.removeChild(child) <span
                                class="text-gray-400">// old way</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <ProTip>
            <div>Remove all children:</div>
            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                <div class="font-mono text-[10px]">
                    <span class="text-gray-400">// Fast way</span>
                </div>
                <div class="font-mono text-[10px]">element.innerHTML = ''</div>
                <div class="font-mono text-[10px] mt-1">
                    <span class="text-gray-400"
                        >// Better way (removes listeners)</span>
                </div>
                <div class="font-mono text-[10px]">
                    element.replaceChildren()
                </div>
                <div class="font-mono text-[10px] mt-1">
                    <span class="text-gray-400">// Loop way</span>
                </div>
                <div class="font-mono text-[10px]">
                    while (el.firstChild) el.firstChild.remove()
                </div>
            </div>
        </ProTip>
    </MethodCard>

    <!-- CLONENODE -->
    <MethodCard
        id="clone-node"
        methodName="cloneNode()"
        signature="element.cloneNode(deep)"
        description="Create a duplicate copy of an element"
        mutates={false}
    >
        <div class="p-6 bg-gray-800 rounded">
            <div class="space-y-4">
                <!-- Shallow clone -->
                <div
                    class="bg-orange-500/20 border border-orange-400 rounded p-3"
                >
                    <div class="text-orange-300 font-mono text-xs space-y-0.5">
                        <div class="text-yellow-400 mb-1">
                            Shallow clone (false):
                        </div>
                        <div>const clone = element.cloneNode(false)</div>
                        <div class="text-gray-400 text-[10px] mt-1">
                            Copies element only, no children
                        </div>
                    </div>
                </div>

                <!-- Deep clone -->
                <div
                    class="bg-green-500/20 border border-green-500 rounded p-3"
                >
                    <div class="text-green-300 font-mono text-xs space-y-0.5">
                        <div class="text-yellow-400 mb-1">
                            Deep clone (true):
                        </div>
                        <div>const clone = element.cloneNode(true)</div>
                        <div class="text-gray-400 text-[10px] mt-1">
                            Copies element + all descendants
                        </div>
                    </div>
                </div>

                <!-- Example -->
                <div class="bg-cyan-500/20 border border-cyan-400 rounded p-3">
                    <div class="text-cyan-300 font-mono text-xs space-y-0.5">
                        <div class="text-yellow-400 mb-1">
                            Practical example - duplicate card:
                        </div>
                        <div>const card = document.querySelector('.card')</div>
                        <div>const clone = card.cloneNode(true)</div>
                        <div>
                            clone.querySelector('.title').textContent = 'New'
                        </div>
                        <div>card.after(clone)</div>
                    </div>
                </div>
            </div>
        </div>

        <ProTip>
            <div>⚠️ <strong>Important notes:</strong></div>
            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                <div class="font-mono text-[10px]">
                    <span class="text-red-400">✗</span> Event listeners are NOT copied
                </div>
                <div class="font-mono text-[10px]">
                    <span class="text-red-400">✗</span> IDs are copied (change them
                    to avoid duplicates!)
                </div>
                <div class="font-mono text-[10px]">
                    <span class="text-green-400">✓</span> Inline event handlers (onclick=)
                    ARE copied
                </div>
                <div class="font-mono text-[10px]">
                    <span class="text-green-400">✓</span> Data attributes are copied
                </div>
                <div class="font-mono text-[10px] mt-1 text-yellow-400">
                    // Always use deep clone (true) for elements with children
                </div>
            </div>
        </ProTip>
    </MethodCard>

    <!-- INSERTADJACENTELEMENT -->
    <MethodCard
        id="insert-adjacent"
        methodName="insertAdjacentElement() / insertAdjacentHTML()"
        signature="element.insertAdjacentElement(position, el)"
        description="Insert elements at specific positions"
        mutates={true}
    >
        <div class="p-6 bg-gray-800 rounded">
            <div class="space-y-4">
                <!-- Position diagram -->
                <div class="bg-gray-700 border border-gray-600 rounded p-4">
                    <div class="font-mono text-[10px] space-y-1">
                        <div class="text-blue-400"><!-- beforebegin --></div>
                        <div>&lt;div id="target"&gt;</div>
                        <div class="pl-4 text-green-400">
                            <!-- afterbegin -->
                        </div>
                        <div class="pl-4 text-gray-400">...content...</div>
                        <div class="pl-4 text-purple-400">
                            <!-- beforeend -->
                        </div>
                        <div>&lt;/div&gt;</div>
                        <div class="text-orange-400"><!-- afterend --></div>
                    </div>
                </div>

                <!-- Examples -->
                <div class="bg-cyan-500/20 border border-cyan-400 rounded p-3">
                    <div class="text-cyan-300 font-mono text-xs space-y-0.5">
                        <div class="text-yellow-400 mb-1">
                            insertAdjacentElement:
                        </div>
                        <div>const newEl = document.createElement('div')</div>
                        <div>
                            target.insertAdjacentElement('beforebegin', newEl)
                        </div>
                        <div class="mt-2 text-yellow-400">
                            insertAdjacentHTML:
                        </div>
                        <div>
                            target.insertAdjacentHTML('afterbegin',
                            '&lt;p&gt;Text&lt;/p&gt;')
                        </div>
                    </div>
                </div>

                <!-- Position options -->
                <div
                    class="bg-purple-500/20 border border-purple-400 rounded p-3"
                >
                    <div
                        class="text-purple-300 font-mono text-[10px] space-y-0.5"
                    >
                        <div>
                            <span class="text-blue-400">'beforebegin'</span> - Before
                            element (as previous sibling)
                        </div>
                        <div>
                            <span class="text-green-400">'afterbegin'</span> - Inside
                            element, before first child
                        </div>
                        <div>
                            <span class="text-purple-400">'beforeend'</span> - Inside
                            element, after last child
                        </div>
                        <div>
                            <span class="text-orange-400">'afterend'</span> - After
                            element (as next sibling)
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <ProTip>
            <div>🎯 <strong>When to use:</strong></div>
            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                <div class="font-mono text-[10px]">
                    <span class="text-green-400">insertAdjacentElement:</span> When
                    you have an element object
                </div>
                <div class="font-mono text-[10px]">
                    <span class="text-green-400">insertAdjacentHTML:</span> When
                    you have HTML string
                </div>
                <div class="font-mono text-[10px] mt-1">
                    <span class="text-yellow-400"
                        >// More flexible than appendChild!</span>
                </div>
                <div class="font-mono text-[10px]">
                    el.appendChild(child) <span class="text-gray-400"
                        >// only inserts at end</span>
                </div>
                <div class="font-mono text-[10px]">
                    el.insertAdjacentElement('afterbegin', child) <span
                        class="text-gray-400">// at start</span>
                </div>
            </div>
        </ProTip>
    </MethodCard>

    <!-- ============================================ -->
    <!-- ✏️ MODIFYING CONTENT -->
    <!-- ============================================ -->

    <SectionTitle id="content" color="purple">
        ✏️ Modifying Content
    </SectionTitle>

    <!-- TEXTCONTENT VS INNERHTML -->
    <MethodCard
        id="text-vs-html"
        methodName="textContent vs innerHTML"
        signature="element.textContent / innerHTML"
        description="Set element content as text or HTML"
        mutates={true}
    >
        <div class="p-6 bg-gray-800 rounded">
            <div class="space-y-4">
                <!-- textContent -->
                <div>
                    <div class="text-green-400 font-bold text-sm mb-2">
                        textContent (safe):
                    </div>
                    <div
                        class="bg-green-500/20 border border-green-500 rounded p-3"
                    >
                        <div
                            class="text-green-300 font-mono text-xs space-y-0.5"
                        >
                            <div>
                                el.textContent = '&lt;b&gt;Bold&lt;/b&gt;'
                            </div>
                            <div class="text-gray-400 text-[10px] mt-1">
                                Renders as: &lt;b&gt;Bold&lt;/b&gt; (literal
                                text)
                            </div>
                        </div>
                    </div>
                </div>

                <!-- innerHTML -->
                <div>
                    <div class="text-red-400 font-bold text-sm mb-2">
                        innerHTML (unsafe):
                    </div>
                    <div
                        class="bg-red-500/20 border border-red-500 rounded p-3"
                    >
                        <div class="text-red-300 font-mono text-xs space-y-0.5">
                            <div>el.innerHTML = '&lt;b&gt;Bold&lt;/b&gt;'</div>
                            <div class="text-gray-400 text-[10px] mt-1">
                                Renders as: <strong>Bold</strong> (parsed HTML)
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div
            class="text-gray-300 text-sm mt-3 p-3 bg-gray-800/50 rounded border border-gray-700"
        >
            <strong>textContent</strong> = plain text (safe), <strong
                >innerHTML</strong
            > = HTML (XSS risk with user input).
        </div>

        <ProTip>
            <div>⚠️ <strong>Never use innerHTML with user input:</strong></div>
            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                <div class="font-mono text-[10px]">
                    <span class="text-red-400"
                        >// Dangerous - XSS vulnerability ❌</span>
                </div>
                <div class="font-mono text-[10px]">
                    el.innerHTML = userInput
                </div>
                <div class="font-mono text-[10px] mt-1">
                    <span class="text-green-400"
                        >// Safe - escapes HTML ✅</span>
                </div>
                <div class="font-mono text-[10px]">
                    el.textContent = userInput
                </div>
            </div>
        </ProTip>
    </MethodCard>

    <!-- ============================================ -->
    <!-- 🎨 STYLING & CLASSES -->
    <!-- ============================================ -->

    <SectionTitle id="styling" color="green">
        🎨 Styling & Classes
    </SectionTitle>

    <!-- CLASSLIST -->
    <MethodCard
        id="class-list"
        methodName="classList"
        signature="element.classList.add/remove/toggle()"
        description="Manipulate element classes"
        mutates={true}
    >
        <div class="p-6 bg-gray-800 rounded">
            <div class="space-y-3">
                <!-- add -->
                <div class="flex items-center gap-3">
                    <div
                        class="bg-green-500/20 border border-green-500 rounded px-4 py-2 flex-1"
                    >
                        <div class="text-green-300 font-mono text-xs">
                            classList.add('active')
                        </div>
                        <div class="text-gray-400 text-[10px] mt-0.5">
                            Adds class to element
                        </div>
                        <div class="text-green-300 font-mono text-[10px] mt-1">
                            .add('btn', 'primary') <span class="text-gray-400"
                                >// multiple</span>
                        </div>
                    </div>
                    <div class="text-gray-400 text-xl">→</div>
                    <div
                        class="bg-blue-500/20 border border-blue-400 rounded px-4 py-2 w-32"
                    >
                        <div class="text-blue-300 font-mono text-[10px]">
                            class="active"
                        </div>
                    </div>
                </div>

                <!-- remove -->
                <div class="flex items-center gap-3">
                    <div
                        class="bg-red-500/20 border border-red-500 rounded px-4 py-2 flex-1"
                    >
                        <div class="text-red-300 font-mono text-xs">
                            classList.remove('hidden')
                        </div>
                        <div class="text-gray-400 text-[10px] mt-0.5">
                            Removes class from element
                        </div>
                        <div class="text-red-300 font-mono text-[10px] mt-1">
                            .remove('a', 'b') <span class="text-gray-400"
                                >// multiple</span>
                        </div>
                    </div>
                    <div class="text-gray-400 text-xl">→</div>
                    <div
                        class="bg-blue-500/20 border border-blue-400 rounded px-4 py-2 w-32"
                    >
                        <div class="text-blue-300 font-mono text-[10px]">
                            class=""
                        </div>
                    </div>
                </div>

                <!-- toggle -->
                <div class="flex items-center gap-3">
                    <div
                        class="bg-purple-500/20 border border-purple-400 rounded px-4 py-2 flex-1"
                    >
                        <div class="text-purple-300 font-mono text-xs">
                            classList.toggle('dark')
                        </div>
                        <div class="text-gray-400 text-[10px] mt-0.5">
                            Adds if absent, removes if present
                        </div>
                    </div>
                    <div class="text-gray-400 text-xl">⇄</div>
                    <div
                        class="bg-blue-500/20 border border-blue-400 rounded px-4 py-2 w-32"
                    >
                        <div class="text-blue-300 font-mono text-[10px]">
                            on/off
                        </div>
                    </div>
                </div>

                <!-- contains -->
                <div class="flex items-center gap-3">
                    <div
                        class="bg-cyan-500/20 border border-cyan-400 rounded px-4 py-2 flex-1"
                    >
                        <div class="text-cyan-300 font-mono text-xs">
                            classList.contains('active')
                        </div>
                        <div class="text-gray-400 text-[10px] mt-0.5">
                            Check if class exists
                        </div>
                    </div>
                    <div class="text-gray-400 text-xl">→</div>
                    <div
                        class="bg-yellow-500/20 border border-yellow-400 rounded px-4 py-2 w-32"
                    >
                        <div class="text-yellow-300 font-mono text-[10px]">
                            true/false
                        </div>
                    </div>
                </div>

                <!-- replace -->
                <div class="flex items-center gap-3">
                    <div
                        class="bg-orange-500/20 border border-orange-400 rounded px-4 py-2 flex-1"
                    >
                        <div class="text-orange-300 font-mono text-xs">
                            classList.replace('old', 'new')
                        </div>
                        <div class="text-gray-400 text-[10px] mt-0.5">
                            Swap classes
                        </div>
                    </div>
                    <div class="text-gray-400 text-xl">→</div>
                    <div
                        class="bg-blue-500/20 border border-blue-400 rounded px-4 py-2 w-32"
                    >
                        <div class="text-blue-300 font-mono text-[10px]">
                            class="new"
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <ProTip>
            <div>
                💡 <strong>Toggle with condition (force add/remove):</strong>
            </div>
            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                <div class="text-[10px]">
                    The second parameter of <code>toggle()</code> is a boolean that
                    forces add or remove:
                </div>
                <div class="font-mono text-[10px] mt-1">
                    el.classList.toggle('active', true) <span
                        class="text-gray-400">// always adds</span>
                </div>
                <div class="font-mono text-[10px]">
                    el.classList.toggle('active', false) <span
                        class="text-gray-400">// always removes</span>
                </div>
                <div class="font-mono text-[10px]">
                    el.classList.toggle('active', isActive) <span
                        class="text-gray-400">// dynamic</span>
                </div>
                <div class="font-mono text-[10px] mt-1">
                    <span class="text-gray-400">// This is cleaner than:</span>
                </div>
                <div class="font-mono text-[10px]">
                    if (isActive) {"{"} el.classList.add('active') {"}"}
                </div>
                <div class="font-mono text-[10px]">
                    else {"{"} el.classList.remove('active') {"}"}
                </div>
                <div class="font-mono text-[10px] mt-1">
                    <span class="text-green-400"
                        >// Real example: enable/disable button based on form
                        validity</span>
                </div>
                <div class="font-mono text-[10px]">
                    submitBtn.classList.toggle('disabled',
                    !form.checkValidity())
                </div>
            </div>
        </ProTip>

        <ProTip>
            <div>
                ⚠️ <strong
                    >Avoid inline styles - use element.style sparingly:</strong>
            </div>
            <div class="pl-2 border-l-2 border-red-500/30 space-y-0.5 mt-1">
                <div class="text-[10px]">
                    You <em>can</em> modify styles directly, but it's usually better
                    to use classes:
                </div>
                <div class="font-mono text-[10px] mt-1">
                    <span class="text-red-400"
                        >// ❌ Bad - hard to maintain</span>
                </div>
                <div class="font-mono text-[10px]">el.style.color = 'red'</div>
                <div class="font-mono text-[10px]">
                    el.style.backgroundColor = '#000' <span
                        class="text-gray-400">// camelCase!</span>
                </div>
                <div class="font-mono text-[10px]">
                    el.style.fontSize = '16px' <span class="text-gray-400"
                        >// include units</span>
                </div>
                <div class="font-mono text-[10px] mt-1">
                    <span class="text-green-400"
                        >// ✅ Good - define styles in CSS</span>
                </div>
                <div class="font-mono text-[10px]">
                    el.classList.add('highlighted')
                </div>
                <div class="text-[10px] mt-1">
                    <strong>When to use .style:</strong> Dynamic values that can't
                    be in CSS (e.g., element.style.width = {
                        "`${dynamicWidth}px`"
                    })
                </div>
                <div class="font-mono text-[10px] mt-1">
                    el.style.color = '' <span class="text-gray-400"
                        >// remove inline style</span>
                </div>
            </div>
        </ProTip>
    </MethodCard>

