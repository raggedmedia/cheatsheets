                <div class="font-mono text-[10px]">
                    <span class="text-gray-400"
                        >// Attribute = string in HTML (initial)</span>
                </div>
                <div class="font-mono text-[10px]">
                    input.getAttribute('value') <span class="text-gray-400"
                        >// '10' (initial)</span>
                </div>
                <div class="font-mono text-[10px] mt-1">
                    <span class="text-gray-400"
                        >// Property = live JS value (current)</span>
                </div>
                <div class="font-mono text-[10px]">
                    input.value <span class="text-gray-400"
                        >// '25' (user changed it)</span>
                </div>
                <div class="font-mono text-[10px] mt-1">
                    <span class="text-yellow-400"
                        >// Use properties for form inputs!</span>
