---
import '~styles/styles.css'
import MethodCard from '~components/visual-js/MethodCard.astro';
import Node from '~components/visual-js/Node.astro';
import ArrayDisplay from '~components/visual-js/ArrayDisplay.astro';
import Arrow from '~components/visual-js/Arrow.astro';
import ReturnValue from '~components/visual-js/ReturnValue.astro';
import MutableOrNot from '~components/visual-js/MutableOrNot.astro';
import ProcessContent from '~components/visual-js/ProcessContent.astro';
import ProTip from '~components/visual-js/ProTip.astro';
import GlobalNav from '~components/visual-js/GlobalNav.astro';
---

<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>JavaScript Conditionals - Visual Cheatsheet</title>
    </head>
    <body class="m-0 p-4 bg-[#1a1d29] text-gray-200">
        <div class="flex gap-6 max-w-[1600px] mx-auto">
            <!-- Main Content -->
            <main class="flex-1 min-w-0">
                <h1 class="text-white mb-1 text-2xl font-bold">JavaScript Conditionals</h1>
                <p class="text-gray-400 mb-6 text-sm">Visual blueprint-style reference for conditional logic and branching</p>

                <ProTip>
                    <div>💡 <strong>true/false vs truthy/falsy - what's the difference?</strong></div>
                    <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                        <div class="font-mono text-[10px] mt-1"><strong>false</strong> = the actual boolean value <code class="bg-black/30 px-1 py-0.5 rounded">false</code></div>
                        <div class="font-mono text-[10px]"><strong>falsy</strong> = any value that <em>acts like false</em> in a boolean context (if statements, etc.)</div>
                        <div class="font-mono text-[10px] mt-1"><span class="text-yellow-400">8 falsy values:</span> <code class="bg-black/30 px-1 py-0.5 rounded">false</code>, <code class="bg-black/30 px-1 py-0.5 rounded">0</code>, <code class="bg-black/30 px-1 py-0.5 rounded">-0</code>, <code class="bg-black/30 px-1 py-0.5 rounded">0n</code>, <code class="bg-black/30 px-1 py-0.5 rounded">""</code>, <code class="bg-black/30 px-1 py-0.5 rounded">null</code>, <code class="bg-black/30 px-1 py-0.5 rounded">undefined</code>, <code class="bg-black/30 px-1 py-0.5 rounded">NaN</code></div>
                        <div class="font-mono text-[10px] mt-1"><strong>truthy</strong> = everything else acts like true!</div>
                        <div class="font-mono text-[10px] mt-1"><span class="text-red-400">Common gotchas:</span></div>
                        <div class="font-mono text-[10px]">if ([]) &lbrace; ... &rbrace; <span class="text-gray-400">// RUNS! [] is truthy even when empty</span></div>
                        <div class="font-mono text-[10px]">if ("0") &lbrace; ... &rbrace; <span class="text-gray-400">// RUNS! string "0" is truthy</span></div>
                        <div class="font-mono text-[10px]">if ("false") &lbrace; ... &rbrace; <span class="text-gray-400">// RUNS! string "false" is truthy</span></div>
                        <div class="font-mono text-[10px] mt-1">0 === false <span class="text-red-400">// false</span> (different types, but both falsy)</div>
                        <div class="font-mono text-[10px]">[] == true <span class="text-red-400">// false</span> ([] is truthy, but not equal to true)</div>
                    </div>
                </ProTip>

                <!-- ============================================ -->
                <!-- 🔀 IF/ELSE -->
                <!-- ============================================ -->

                <h2 id="if-else" class="text-blue-300 text-xl my-4 pb-2 border-b-2 border-blue-600">
                    🔀 If/Else Statements
                </h2>

                <!-- IF -->
                <div id="if">
                    <MethodCard
                        methodName="if"
                        signature="if (condition) { }"
                        description="Execute code if condition is truthy"
                        mutates={false}
                    >
                        <div class="p-6 bg-gray-800 rounded">
                            <div class="space-y-3">
                                <!-- Visual flow diagram -->
                                <div class="bg-gray-900/50 border-2 border-blue-500 rounded-lg p-4 font-mono text-sm">
                                    <div class="flex items-center gap-3 mb-3">
                                        <div class="text-blue-400 font-bold">if</div>
                                        <div class="bg-blue-500/20 px-3 py-1.5 rounded border border-blue-400">
                                            <span class="text-blue-300">condition</span>
                                        </div>
                                    </div>
                                    <div class="ml-8 pl-4 border-l-4 border-green-500 space-y-1">
                                        <div class="text-gray-400 text-xs mb-1">↳ if <span class="text-green-400">true</span>, runs:</div>
                                        <div class="text-green-300">doSomething()</div>
                                        <div class="text-green-300">console.log('success')</div>
                                    </div>
                                    <div class="ml-8 mt-3 text-gray-500 text-xs">
                                        ↳ if <span class="text-red-400">false</span>, skips block entirely
                                    </div>
                                </div>

                                <!-- Example -->
                                <div class="bg-gray-800/50 border border-gray-700 rounded p-3">
                                    <div class="text-gray-400 text-xs mb-2">Example:</div>
                                    <div class="font-mono text-xs text-gray-300 space-y-0.5">
                                        <div><span class="text-blue-400">if</span> (age &gt;= 18) &lbrace;</div>
                                        <div class="ml-4 text-green-300">console.log('Can vote')</div>
                                        <div>&rbrace;</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="text-gray-300 text-sm mt-3 p-3 bg-gray-800/50 rounded border border-gray-700">
                            Executes block only if condition evaluates to truthy value. <strong>Condition is coerced to boolean.</strong>
                        </div>

                        <ProTip>
                            <div>Common patterns:</div>
                            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                                <div class="font-mono text-[10px]"><span class="text-gray-400">// Check existence</span></div>
                                <div class="font-mono text-[10px]">if (user) &lbrace; ... &rbrace; <span class="text-gray-400">// truthy check</span></div>
                                <div class="font-mono text-[10px] mt-1"><span class="text-gray-400">// Check array has items</span></div>
                                <div class="font-mono text-[10px]">if (arr.length) &lbrace; ... &rbrace; <span class="text-gray-400">// 0 is falsy</span></div>
                                <div class="font-mono text-[10px] mt-1"><span class="text-gray-400">// Early return pattern</span></div>
                                <div class="font-mono text-[10px]">if (!user) return <span class="text-gray-400">// guard clause</span></div>
                            </div>
                        </ProTip>
                    </MethodCard>
                </div>

                <!-- IF...ELSE -->
                <div id="if-else-statement">
                    <MethodCard
                        methodName="if...else"
                        signature="if (condition) { } else { }"
                        description="Execute one of two code paths"
                        mutates={false}
                    >
                        <div class="p-6 bg-gray-800 rounded">
                            <div class="space-y-3">
                                <!-- Visual flow diagram -->
                                <div class="bg-gray-900/50 border-2 border-blue-500 rounded-lg p-4 font-mono text-sm">
                                    <div class="flex items-center gap-3 mb-3">
                                        <div class="text-blue-400 font-bold">if</div>
                                        <div class="bg-blue-500/20 px-3 py-1.5 rounded border border-blue-400">
                                            <span class="text-blue-300">condition</span>
                                        </div>
                                    </div>
                                    <div class="ml-8 pl-4 border-l-4 border-green-500 space-y-1 mb-3">
                                        <div class="text-gray-400 text-xs mb-1">↳ if <span class="text-green-400">true</span>:</div>
                                        <div class="text-green-300">doThisThing()</div>
                                    </div>
                                    <div class="flex items-center gap-3 mb-3">
                                        <div class="text-orange-400 font-bold">else</div>
                                    </div>
                                    <div class="ml-8 pl-4 border-l-4 border-orange-500 space-y-1">
                                        <div class="text-gray-400 text-xs mb-1">↳ if <span class="text-red-400">false</span>:</div>
                                        <div class="text-orange-300">doOtherThing()</div>
                                    </div>
                                </div>

                                <!-- Example -->
                                <div class="bg-gray-800/50 border border-gray-700 rounded p-3">
                                    <div class="text-gray-400 text-xs mb-2">Example:</div>
                                    <div class="font-mono text-xs text-gray-300 space-y-0.5">
                                        <div><span class="text-blue-400">if</span> (age &gt;= 18) &lbrace;</div>
                                        <div class="ml-4 text-green-300">console.log('Adult')</div>
                                        <div>&rbrace; <span class="text-orange-400">else</span> &lbrace;</div>
                                        <div class="ml-4 text-orange-300">console.log('Minor')</div>
                                        <div>&rbrace;</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="text-gray-300 text-sm mt-3 p-3 bg-gray-800/50 rounded border border-gray-700">
                            Exactly one block executes. Use when you have two mutually exclusive paths.
                        </div>
                    </MethodCard>
                </div>

                <!-- ELSE IF -->
                <div id="else-if">
                    <MethodCard
                        methodName="else if"
                        signature="if (cond1) { } else if (cond2) { } else { }"
                        description="Chain multiple conditions"
                        mutates={false}
                    >
                        <div class="p-6 bg-gray-800 rounded">
                            <div class="space-y-3">
                                <!-- Visual cascade diagram -->
                                <div class="bg-gray-900/50 border-2 border-blue-500 rounded-lg p-4 font-mono text-sm">
                                    <!-- First if -->
                                    <div class="flex items-center gap-3 mb-2">
                                        <div class="text-blue-400 font-bold">if</div>
                                        <div class="bg-blue-500/20 px-3 py-1.5 rounded border border-blue-400">
                                            <span class="text-blue-300">condition1</span>
                                        </div>
                                        <div class="text-xs text-gray-500">← checks first</div>
                                    </div>
                                    <div class="ml-8 pl-4 border-l-4 border-green-500 mb-4">
                                        <div class="text-green-300">executeThis()</div>
                                        <div class="text-xs text-gray-500 mt-1">✓ done, skip rest</div>
                                    </div>

                                    <!-- else if 1 -->
                                    <div class="flex items-center gap-3 mb-2">
                                        <div class="text-purple-400 font-bold">else if</div>
                                        <div class="bg-purple-500/20 px-3 py-1.5 rounded border border-purple-400">
                                            <span class="text-purple-300">condition2</span>
                                        </div>
                                        <div class="text-xs text-gray-500">← if first was false</div>
                                    </div>
                                    <div class="ml-8 pl-4 border-l-4 border-purple-500 mb-4">
                                        <div class="text-purple-300">executeThat()</div>
                                        <div class="text-xs text-gray-500 mt-1">✓ done, skip rest</div>
                                    </div>

                                    <!-- else if 2 -->
                                    <div class="flex items-center gap-3 mb-2">
                                        <div class="text-purple-400 font-bold">else if</div>
                                        <div class="bg-purple-500/20 px-3 py-1.5 rounded border border-purple-400">
                                            <span class="text-purple-300">condition3</span>
                                        </div>
                                        <div class="text-xs text-gray-500">← if previous were false</div>
                                    </div>
                                    <div class="ml-8 pl-4 border-l-4 border-purple-500 mb-4">
                                        <div class="text-purple-300">executeOther()</div>
                                        <div class="text-xs text-gray-500 mt-1">✓ done, skip rest</div>
                                    </div>

                                    <!-- else -->
                                    <div class="flex items-center gap-3 mb-2">
                                        <div class="text-orange-400 font-bold">else</div>
                                        <div class="text-xs text-gray-500">← if ALL above were false</div>
                                    </div>
                                    <div class="ml-8 pl-4 border-l-4 border-orange-500">
                                        <div class="text-orange-300">fallback()</div>
                                        <div class="text-xs text-gray-500 mt-1">default case</div>
                                    </div>
                                </div>

                                <!-- Example -->
                                <div class="bg-gray-800/50 border border-gray-700 rounded p-3">
                                    <div class="text-gray-400 text-xs mb-2">Example - Grade Calculator:</div>
                                    <div class="font-mono text-xs text-gray-300 space-y-0.5">
                                        <div><span class="text-blue-400">if</span> (score &gt;= 90) &lbrace;</div>
                                        <div class="ml-4 text-green-300">grade = 'A'</div>
                                        <div>&rbrace; <span class="text-purple-400">else if</span> (score &gt;= 80) &lbrace;</div>
                                        <div class="ml-4 text-purple-300">grade = 'B'</div>
                                        <div>&rbrace; <span class="text-purple-400">else if</span> (score &gt;= 70) &lbrace;</div>
                                        <div class="ml-4 text-purple-300">grade = 'C'</div>
                                        <div>&rbrace; <span class="text-orange-400">else</span> &lbrace;</div>
                                        <div class="ml-4 text-orange-300">grade = 'F'</div>
                                        <div>&rbrace;</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="text-gray-300 text-sm mt-3 p-3 bg-gray-800/50 rounded border border-gray-700">
                            Checks conditions in order. <strong>Stops at first true condition.</strong> Only one block ever executes.
                        </div>

                        <ProTip>
                            <div>⚠️ Order matters - put most specific conditions first:</div>
                            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                                <div class="font-mono text-[10px] text-red-400"><span class="text-gray-400">// ❌ Wrong order:</span></div>
                                <div class="font-mono text-[10px]">if (score &gt;= 70) &lbrace; grade = 'C' &rbrace; <span class="text-gray-400">// catches 90 too!</span></div>
                                <div class="font-mono text-[10px]">else if (score &gt;= 90) &lbrace; grade = 'A' &rbrace; <span class="text-gray-400">// never runs</span></div>
                                <div class="font-mono text-[10px] mt-1 text-green-400"><span class="text-gray-400">// ✅ Correct order:</span></div>
                                <div class="font-mono text-[10px]">if (score &gt;= 90) &lbrace; grade = 'A' &rbrace; <span class="text-gray-400">// most specific first</span></div>
                                <div class="font-mono text-[10px]">else if (score &gt;= 70) &lbrace; grade = 'C' &rbrace;</div>
                            </div>
                        </ProTip>
                    </MethodCard>
                </div>

                <!-- ============================================ -->
                <!-- 🔄 SWITCH -->
                <!-- ============================================ -->

                <h2 id="switch" class="text-purple-300 text-xl my-4 pb-2 border-b-2 border-purple-600">
                    🔄 Switch Statements
                </h2>

                <!-- SWITCH/CASE -->
                <div id="switch-case">
                    <MethodCard
                        methodName="switch...case"
                        signature="switch (value) { case x: ... break; default: ... }"
                        description="Match value against multiple cases with fallback"
                        mutates={false}
                    >
                        <div class="p-6 bg-gray-800 rounded">
                            <div class="space-y-3">
                                <!-- Visual switch diagram -->
                                <div class="bg-gray-900/50 border-2 border-purple-500 rounded-lg p-4 font-mono text-sm">
                                    <div class="flex items-center gap-3 mb-3">
                                        <div class="text-purple-400 font-bold">switch</div>
                                        <div class="bg-purple-500/20 px-3 py-1.5 rounded border border-purple-400">
                                            <span class="text-purple-300">value</span>
                                        </div>
                                        <span class="text-gray-500 text-xs">← match against cases</span>
                                    </div>

                                    <!-- Cases -->
                                    <div class="space-y-3 ml-4">
                                        <!-- Case 1 -->
                                        <div>
                                            <div class="flex items-center gap-2 mb-1">
                                                <div class="text-blue-400">case</div>
                                                <div class="bg-blue-500/20 px-2 py-0.5 rounded text-xs border border-blue-400">
                                                    <span class="text-blue-300">'value1'</span>
                                                </div>
                                                <span class="text-gray-500 text-xs">:</span>
                                            </div>
                                            <div class="ml-6 pl-3 border-l-2 border-blue-500 space-y-0.5">
                                                <div class="text-blue-300 text-xs">doSomething()</div>
                                                <div class="text-yellow-400 text-xs">break <span class="text-gray-500">← stops here</span></div>
                                            </div>
                                        </div>

                                        <!-- Case 2 -->
                                        <div>
                                            <div class="flex items-center gap-2 mb-1">
                                                <div class="text-blue-400">case</div>
                                                <div class="bg-blue-500/20 px-2 py-0.5 rounded text-xs border border-blue-400">
                                                    <span class="text-blue-300">'value2'</span>
                                                </div>
                                                <span class="text-gray-500 text-xs">:</span>
                                            </div>
                                            <div class="ml-6 pl-3 border-l-2 border-blue-500 space-y-0.5">
                                                <div class="text-blue-300 text-xs">doOtherThing()</div>
                                                <div class="text-yellow-400 text-xs">break</div>
                                            </div>
                                        </div>

                                        <!-- Default -->
                                        <div>
                                            <div class="flex items-center gap-2 mb-1">
                                                <div class="text-orange-400">default</div>
                                                <span class="text-gray-500 text-xs">: ← if no matches</span>
                                            </div>
                                            <div class="ml-6 pl-3 border-l-2 border-orange-500 space-y-0.5">
                                                <div class="text-orange-300 text-xs">fallback()</div>
                                                <div class="text-gray-500 text-xs">no break needed (last)</div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Example -->
                                <div class="bg-gray-800/50 border border-gray-700 rounded p-3">
                                    <div class="text-gray-400 text-xs mb-2">Example:</div>
                                    <div class="font-mono text-xs text-gray-300 space-y-0.5">
                                        <div><span class="text-purple-400">switch</span> (day) &lbrace;</div>
                                        <div class="ml-4"><span class="text-blue-400">case</span> 'Mon':</div>
                                        <div class="ml-8">console.log('Start of week')</div>
                                        <div class="ml-8"><span class="text-yellow-400">break</span></div>
                                        <div class="ml-4"><span class="text-blue-400">case</span> 'Fri':</div>
                                        <div class="ml-8">console.log('Almost weekend!')</div>
                                        <div class="ml-8"><span class="text-yellow-400">break</span></div>
                                        <div class="ml-4"><span class="text-orange-400">default</span>:</div>
                                        <div class="ml-8">console.log('Regular day')</div>
                                        <div>&rbrace;</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="text-gray-300 text-sm mt-3 p-3 bg-gray-800/50 rounded border border-gray-700">
                            Uses <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">===</code> strict equality. ⚠️ <strong>Don't forget break!</strong> Without it, execution "falls through" to next case.
                        </div>

                        <ProTip>
                            <div>⚠️ <strong>The break gotcha:</strong></div>
                            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                                <div class="font-mono text-[10px]">switch (day) &lbrace;</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;case 'Mon':</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;&nbsp;&nbsp;console.log('Monday')</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;&nbsp;&nbsp;break <span class="text-green-400">// stops here ✅</span></div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;case 'Tue':</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;&nbsp;&nbsp;console.log('Tuesday') <span class="text-red-400">// without break, runs this too! ❌</span></div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;&nbsp;&nbsp;break</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;default:</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;&nbsp;&nbsp;console.log('Other')</div>
                                <div class="font-mono text-[10px]">&rbrace;</div>
                            </div>
                        </ProTip>

                        <ProTip>
                            <div>💡 <strong>Grouping multiple cases (fall-through pattern):</strong></div>
                            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                                <div class="font-mono text-[10px]">switch (day) &lbrace;</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;case 'Mon':</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;case 'Tue':</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;case 'Wed':</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;case 'Thu':</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;case 'Fri':</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;&nbsp;&nbsp;console.log('Weekday') <span class="text-gray-400">// shared code for all weekdays</span></div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;&nbsp;&nbsp;break</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;case 'Sat':</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;case 'Sun':</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;&nbsp;&nbsp;console.log('Weekend') <span class="text-gray-400">// shared code for weekend</span></div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;&nbsp;&nbsp;break</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;default:</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;&nbsp;&nbsp;console.error('Invalid day') <span class="text-green-400">// handle unexpected ✅</span></div>
                                <div class="font-mono text-[10px]">&rbrace;</div>
                                <div class="font-mono text-[10px] mt-1"><span class="text-gray-400">// Stack cases without break to share code - falls through until hitting break</span></div>
                            </div>
                        </ProTip>

                        <ProTip>
                            <div>✨ <strong>Always include default:</strong></div>
                            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                                <div class="font-mono text-[10px]">default: <span class="text-gray-400">// optional but recommended (like 'else')</span></div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;console.error('Unknown value') <span class="text-gray-400">// catch unexpected values</span></div>
                                <div class="font-mono text-[10px]"><span class="text-gray-400">// No break needed (it's last)</span></div>
                            </div>
                        </ProTip>
                    </MethodCard>
                </div>

                <!-- ============================================ -->
                <!-- ⚡ TERNARY -->
                <!-- ============================================ -->

                <h2 id="ternary" class="text-green-300 text-xl my-4 pb-2 border-b-2 border-green-600">
                    ⚡ Ternary Operator
                </h2>

                <!-- TERNARY -->
                <div id="ternary-op">
                    <MethodCard
                        methodName="Ternary"
                        signature="condition ? valueIfTrue : valueIfFalse"
                        description="Inline conditional expression (returns value)"
                        mutates={false}
                    >
                        <div class="p-4 bg-gray-800 rounded border border-gray-700">
                            <!-- Inline expression -->
                            <div class="font-mono text-sm mb-4">
                                <span class="text-gray-400">const</span> <span class="text-blue-300">status</span> =
                                <span class="text-orange-300 ml-2">age &gt;= 18</span>
                                <span class="text-purple-300 mx-2">?</span>
                                <span class="text-green-300">'Adult'</span>
                                <span class="text-purple-300 mx-2">:</span>
                                <span class="text-yellow-300">'Minor'</span>
                            </div>

                            <!-- Visual breakdown -->
                            <div class="space-y-2">
                                <div class="flex items-center gap-2">
                                    <div class="w-24 text-xs text-gray-400">Condition</div>
