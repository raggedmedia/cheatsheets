    <!-- DATA ATTRIBUTES -->
    <MethodCard
        id="data-attributes"
        methodName="dataset (Data Attributes)"
        signature="element.dataset.propertyName"
        description="Store custom data on elements"
        mutates={true}
    >
        <div class="p-6 bg-gray-800 rounded">
            <div class="space-y-4">
                <!-- HTML -->
                <div>
                    <div class="text-cyan-400 text-xs mb-2">HTML:</div>
                    <div
                        class="bg-cyan-500/20 border border-cyan-400 rounded p-3"
                    >
                        <div
                            class="text-cyan-300 font-mono text-xs space-y-0.5"
                        >
                            <div>
                                &lt;div data-user-id="123"
                                data-role="admin"&gt;&lt;/div&gt;
                            </div>
                        </div>
                    </div>
                </div>

                <!-- JavaScript -->
                <div>
                    <div class="text-green-400 text-xs mb-2">JavaScript:</div>
                    <div
                        class="bg-green-500/20 border border-green-500 rounded p-3"
                    >
                        <div
                            class="text-green-300 font-mono text-xs space-y-0.5"
                        >
                            <div>const div = querySelector('div')</div>
                            <div>
                                div.dataset.userId <span class="text-gray-400"
                                    >// '123'</span>
                            </div>
                            <div>
                                div.dataset.role <span class="text-gray-400"
                                    >// 'admin'</span>
                            </div>
