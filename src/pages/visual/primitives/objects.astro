                                <div class="font-mono text-[10px] mt-1"><span class="text-red-400">// || treats 0 as falsy ❌</span></div>
                                <div class="font-mono text-[10px]">count || 10 → 10 <span class="text-gray-400">// loses your 0!</span></div>
                                <div class="font-mono text-[10px] mt-1"><span class="text-green-400">// ?? only checks null/undefined ✅</span></div>
                                <div class="font-mono text-[10px]">count ?? 10 → 0 <span class="text-gray-400">// keeps your 0!</span></div>
                                <div class="font-mono text-[10px] mt-1.5"><span class="text-blue-400">// Perfect with optional chaining:</span></div>
                                <div class="font-mono text-[10px]">obj?.user?.age ?? 18</div>
                            </div>
                        </ProTip>
                    </MethodCard>
                </div>

                <!-- DEEP CLONE -->
                <MethodCard
                    id="deep-clone"
                    methodName="Deep Clone"
                        signature="structuredClone(obj)"
                        description="Create deep copy of nested objects"
                        mutates={false}
                    >
                        <div class="flex items-center gap-4 p-3 bg-gray-800 rounded overflow-x-auto">
                            <Node label="Input Object" type="input">
                                <div class="text-center text-sm font-mono">&lbrace;user: &lbrace;id: 1&rbrace;&rbrace;</div>
                            </Node>

                            <Arrow label="deep copy" />

                            <Node label="Method" type="process">
                                <ProcessContent name="structuredClone(obj)" description="Clone all levels" />
                            </Node>

                            <Arrow label="returns" />

                            <Node label="New Object" type="output">
                                <div class="text-center text-sm font-mono">&lbrace;user: &lbrace;id: 1&rbrace;&rbrace;</div>
                                <div class="text-center text-[10px] text-gray-400 mt-1">fully independent</div>
                            </Node>
                        </div>

                        <InfoBox mutates={false} message="">
                            Returns a <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">new object</code> with all nested levels cloned. Modifying nested objects won't affect original.
                        </InfoBox>

                        <ProTip>
                            <div><strong>Shallow vs Deep clone with nested objects:</strong></div>
                            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                                <div class="font-mono text-[10px]">const obj = &lbrace;user: &lbrace;id: 1&rbrace;&rbrace;</div>
                                <div class="font-mono text-[10px] mt-1"><span class="text-red-400">// Shallow: nested still shared! ⚠️</span></div>
                                <div class="font-mono text-[10px]">const shallow = &lbrace; ...obj &rbrace;</div>
                                <div class="font-mono text-[10px]">shallow.user.id = 999 <span class="text-red-400">// obj.user.id also becomes 999!</span></div>
                                <div class="font-mono text-[10px] mt-1"><span class="text-green-400">// Deep: fully independent ✅</span></div>
                                <div class="font-mono text-[10px]">const deep = structuredClone(obj)</div>
                                <div class="font-mono text-[10px]">deep.user.id = 999 <span class="text-green-400">// obj.user.id stays 1 ✅</span></div>
                            </div>
                        </ProTip>
                    </MethodCard>

                <!-- DEEP MERGE -->
                <MethodCard
                    id="deep-merge"
                    methodName="Deep Merge Pattern"
                        signature="Custom recursive merge function"
                        description="Merge nested objects recursively"
                        mutates={false}
                    >
                        <div class="flex items-center gap-4 p-3 bg-gray-800 rounded overflow-x-auto">
                            <Node label="Two Objects" type="input">
                                <div class="text-center text-sm font-mono">&lbrace;a: &lbrace;x: 1&rbrace;&rbrace;</div>
                                <div class="text-center text-sm font-mono">&lbrace;a: &lbrace;y: 2&rbrace;&rbrace;</div>
                            </Node>

                            <Arrow label="merge" />

                            <Node label="Deep Merge" type="process">
                                <ProcessContent name="deepMerge(obj1, obj2)" description="Recursive merge" />
                            </Node>

                            <Arrow label="returns" />

                            <Node label="Merged Object" type="output">
                                <div class="text-center text-sm font-mono">&lbrace;a: &lbrace;x: 1, y: 2&rbrace;&rbrace;</div>
                            </Node>
                        </div>

                        <InfoBox mutates={false} message="">
                            Returns a <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">new object</code>. Requires custom function or library (lodash.merge).
                        </InfoBox>

                        <ProTip>
                            <div><strong>Simple deep merge function:</strong></div>
                            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                                <div class="font-mono text-[10px]">function deepMerge(target, source) &lbrace;</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;const result = &lbrace; ...target &rbrace;</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;for (const key in source) &lbrace;</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;&nbsp;&nbsp;if (source[key] instanceof Object &amp;&amp; key in target) &lbrace;</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;result[key] = deepMerge(target[key], source[key])</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;&nbsp;&nbsp;&rbrace; else &lbrace;</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;result[key] = source[key]</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;&nbsp;&nbsp;&rbrace;</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;&rbrace;</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;return result</div>
                                <div class="font-mono text-[10px]">&rbrace;</div>
                            </div>
                        </ProTip>
                    </MethodCard>
                </div>

