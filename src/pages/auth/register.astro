---
import EmailInput from "~components/forms/EmailInput.astro";
import PasswordInput from "~components/forms/PasswordInput.astro";
import FormMessage from "~components/forms/FormMessage.astro";
import Layout from "~layouts/Layout.astro";
import { supabase } from "../../lib/supabase";

export const prerender = false;

// Handle form submission server-side
let errorMessage = "";

if (Astro.request.method === "POST") {
    try {
        const formData = await Astro.request.formData();
        const email = formData.get("email")?.toString();
        const password = formData.get("password")?.toString();

        if (!email || !password) {
            errorMessage = "Email and password are required";
        } else {
            const { error } = await supabase.auth.signUp({
                email,
                password,
            });

            if (error) {
                errorMessage = error.message;
            } else {
                // Success - redirect to signin page with success message
                return Astro.redirect(
                    "/auth/signin?message=account-created&type=success",
                );
            }
        }
    } catch (error) {
        errorMessage = "An unexpected error occurred. Please try again.";
        console.error("Registration error:", error);
    }
}
---

<Layout pageTitle="Register">
    <div class="mx-auto w-96">
        <div class="prose mb-12">
            <h1>Register</h1>
            <p>
                Already have an account? <a href="/signin" class="btn"
                    >Sign in</a
                >
            </p>
        </div>
        <form
            method="post"
            id="register-form"
            data-validate
            data-form-id="register-form"
            data-button-id="register-button"
        >
            {
                errorMessage && (
                    <FormMessage
                        id="register-error-message"
                        type="error"
                        message={errorMessage}
                        hidden={false}
                    />
                )
            }

            <EmailInput id="email" name="email" label="Email" required={true} />
            <PasswordInput
                id="password"
                name="password"
                label="Password"
                required={true}
                autocomplete="new-password"
                minlength={10}
                helperText="At least 10 characters with a mix of lowercase, uppercase, digits, and symbols."
            />
            <button
                type="submit"
                class="btn form-button"
                id="register-button"
                disabled
            >
                <span class="button-text">Register</span>
                <span class="button-loading" style="display: none;"
                    >Creating account...</span
                >
            </button>
        </form>
    </div>
</Layout>

<script src="~components/forms/form-validation.ts"></script>
