                        description="Return first truthy value, or last value if all falsy"
                        mutates={false}
                    >
                        <div class="p-4 bg-gray-800 rounded border border-gray-700">
                            <!-- Expression -->
                            <div class="font-mono text-sm mb-4">
                                <span class="text-orange-300">value1</span>
                                <span class="text-purple-300 mx-2">||</span>
                                <span class="text-orange-300">value2</span>
                            </div>

                            <!-- Evaluation logic -->
                            <div class="space-y-2 text-xs">
                                <div class="p-3 bg-orange-500/5 border border-orange-500/30 rounded">
                                    <div class="text-orange-300 font-bold mb-1">1. Evaluate left side (value1)</div>
                                    <div class="text-gray-300">Check if truthy or falsy</div>
                                </div>

                                <div class="flex items-center justify-center gap-4">
                                    <div class="flex-1 p-2 bg-green-500/10 border border-green-500/30 rounded text-center">
