---
import '~styles/styles.css'
import MethodCard from '~components/visual-js/MethodCard.astro';
import ProTip from '~components/visual-js/ProTip.astro';
import GlobalNav from '~components/visual-js/GlobalNav.astro';
---

<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>JavaScript Form Handling & Validation - Visual Cheatsheet</title>
    </head>
    <body class="m-0 p-4 bg-[#1a1d29] text-gray-200">
        <div class="flex gap-6 max-w-[1600px] mx-auto">
            <!-- Main Content -->
            <main class="flex-1 min-w-0">
                <h1 class="text-white mb-1 text-2xl font-bold">JavaScript Form Handling & Validation</h1>
                <p class="text-gray-400 mb-6 text-sm">Visual blueprint-style reference for working with forms</p>

                <ProTip>
                    <div>💡 <strong>Forms 101:</strong></div>
                    <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                        <div class="text-[10px]">Forms collect user input and submit data. JavaScript lets you validate input before submission and handle the data dynamically.</div>
                        <div class="text-[10px] mt-1"><strong>Two main tasks:</strong> (1) Validate user input, (2) Handle form submission</div>
                    </div>
                </ProTip>

                <ProTip>
                    <div>📝 <strong>Example form (used in all examples below):</strong></div>
                    <div class="pl-2 border-l-2 border-blue-500/30 space-y-0.5 mt-1">
                        <div class="bg-gray-800/50 border border-gray-700 rounded p-3 mt-1">
                            <div class="text-gray-300 font-mono text-[10px] space-y-0.5">
                                <div>&lt;form id="signup-form"&gt;</div>
                                <div>&nbsp;&nbsp;&lt;input type="text" name="username" /&gt;</div>
                                <div>&nbsp;&nbsp;&lt;input type="email" name="email" /&gt;</div>
                                <div>&nbsp;&nbsp;&lt;input type="password" name="password" /&gt;</div>
                                <div>&nbsp;&nbsp;</div>
                                <div>&nbsp;&nbsp;<span class="text-gray-400">&lt;!-- Radio buttons: same name, only one selected --&gt;</span></div>
                                <div>&nbsp;&nbsp;&lt;input type="radio" name="plan" value="free" /&gt;</div>
                                <div>&nbsp;&nbsp;&lt;input type="radio" name="plan" value="pro" /&gt;</div>
                                <div>&nbsp;&nbsp;&lt;input type="radio" name="plan" value="enterprise" /&gt;</div>
                                <div>&nbsp;&nbsp;</div>
                                <div>&nbsp;&nbsp;<span class="text-gray-400">&lt;!-- Checkboxes: same name, multiple can be selected --&gt;</span></div>
                                <div>&nbsp;&nbsp;&lt;input type="checkbox" name="hobbies" value="reading" /&gt;</div>
                                <div>&nbsp;&nbsp;&lt;input type="checkbox" name="hobbies" value="gaming" /&gt;</div>
                                <div>&nbsp;&nbsp;&lt;input type="checkbox" name="hobbies" value="cooking" /&gt;</div>
                                <div>&nbsp;&nbsp;</div>
                                <div>&nbsp;&nbsp;&lt;select name="country"&gt;</div>
                                <div>&nbsp;&nbsp;&nbsp;&nbsp;&lt;option value="us"&gt;USA&lt;/option&gt;</div>
                                <div>&nbsp;&nbsp;&nbsp;&nbsp;&lt;option value="uk"&gt;UK&lt;/option&gt;</div>
                                <div>&nbsp;&nbsp;&lt;/select&gt;</div>
                                <div>&nbsp;&nbsp;</div>
                                <div>&nbsp;&nbsp;&lt;button type="submit"&gt;Sign Up&lt;/button&gt;</div>
                                <div>&lt;/form&gt;</div>
                            </div>
                        </div>
                        <div class="text-[10px] mt-1"><strong>Key point:</strong> The <code>name</code> attribute is what JavaScript uses to access the values!</div>
                    </div>
                </ProTip>

                <!-- ============================================ -->
                <!-- 📋 GETTING FORM DATA -->
                <!-- ============================================ -->

                <h2 id="form-data" class="text-blue-300 text-xl my-4 pb-2 border-b-2 border-blue-600">
                    📋 Getting Form Data
                </h2>

                <!-- FORMDATA API -->
                <div id="formdata-api">
                    <MethodCard
                        methodName="FormData API"
                        signature="new FormData(form)"
                        description="Easy way to get all form values at once"
                        mutates={false}
                    >
                        <div class="p-6 bg-gray-800 rounded">
                            <div class="space-y-4">
                                <!-- Flow -->
                                <div class="flex items-center gap-3">
                                    <div class="bg-blue-500/20 border border-blue-400 rounded px-4 py-2 flex-1">
                                        <div class="text-blue-300 font-mono text-xs">&lt;form&gt;</div>
                                        <div class="text-gray-400 text-[10px] mt-0.5">HTML form element</div>
                                    </div>
                                    <div class="text-gray-400 text-xl">→</div>
                                    <div class="bg-purple-500/20 border border-purple-400 rounded px-4 py-2 flex-1">
                                        <div class="text-purple-300 font-mono text-xs">new FormData(form)</div>
                                        <div class="text-gray-400 text-[10px] mt-0.5">Constructor</div>
                                    </div>
                                    <div class="text-gray-400 text-xl">→</div>
                                    <div class="bg-green-500/20 border border-green-500 rounded px-4 py-2 flex-1">
                                        <div class="text-green-300 font-mono text-xs">FormData object</div>
                                        <div class="text-gray-400 text-[10px] mt-0.5">Key-value pairs</div>
                                    </div>
                                </div>

                                <!-- Usage -->
                                <div class="bg-gray-800/50 border border-gray-700 rounded p-3">
                                    <div class="text-gray-300 font-mono text-[10px] space-y-0.5">
                                        <div>const form = document.querySelector('form')</div>
                                        <div>const formData = new FormData(form)</div>
                                        <div class="mt-2"><span class="text-gray-400">// Get values</span></div>
                                        <div>formData.get('email') <span class="text-gray-400">// single value</span></div>
                                        <div>formData.getAll('hobbies') <span class="text-gray-400">// multiple (checkboxes)</span></div>
                                        <div class="mt-2"><span class="text-gray-400">// Convert to object</span></div>
                                        <div>const data = Object.fromEntries(formData)</div>
                                        <div><span class="text-gray-400">// {`{`} email: 'user@example.com', name: 'John' {`}`}</span></div>
                                    </div>
                                </div>

                                <!-- Methods -->
                                <div class="bg-cyan-500/20 border border-cyan-400 rounded p-3">
                                    <div class="text-cyan-300 font-mono text-[10px] space-y-0.5">
                                        <div class="text-yellow-400 mb-1">FormData methods:</div>
                                        <div>formData.get('name') <span class="text-gray-400">// get first value</span></div>
                                        <div>formData.getAll('name') <span class="text-gray-400">// get all values as array</span></div>
                                        <div>formData.set('name', 'value') <span class="text-gray-400">// set/replace (removes duplicates)</span></div>
                                        <div>formData.append('name', 'value') <span class="text-gray-400">// add value (allows duplicates)</span></div>
                                        <div>formData.delete('name') <span class="text-gray-400">// remove all values for name</span></div>
                                        <div>formData.has('name') <span class="text-gray-400">// check existence</span></div>
                                    </div>
                                </div>

                                <!-- set vs append -->
                                <div class="bg-orange-500/20 border border-orange-400 rounded p-3">
                                    <div class="text-orange-300 font-mono text-[10px] space-y-0.5">
                                        <div class="text-yellow-400 mb-1">set() vs append() with multiple values:</div>
                                        <div><span class="text-gray-400">// Start: hobbies = ['reading', 'gaming']</span></div>
                                        <div class="mt-1">formData.set('hobbies', 'cooking')</div>
                                        <div><span class="text-gray-400">// Result: hobbies = ['cooking'] (replaced all!)</span></div>
                                        <div class="mt-1">formData.append('hobbies', 'cooking')</div>
                                        <div><span class="text-gray-400">// Result: hobbies = ['reading', 'gaming', 'cooking'] (added)</span></div>
                                        <div class="mt-1">formData.delete('hobbies')</div>
                                        <div><span class="text-gray-400">// Result: hobbies = [] (removed all)</span></div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <ProTip>
                            <div>⚠️ <strong>set() vs append():</strong></div>
                            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                                <div class="font-mono text-[10px]">formData.set('name', 'value') <span class="text-gray-400">// replaces ALL existing values</span></div>
                                <div class="font-mono text-[10px]">formData.append('name', 'value') <span class="text-gray-400">// adds to existing values</span></div>
                                <div class="text-[10px] mt-1"><strong>Use set()</strong> for single values (email, username)</div>
                                <div class="text-[10px]"><strong>Use append()</strong> when you want multiple values (building a list)</div>
                            </div>
                        </ProTip>

                        <ProTip>
                            <div>⚠️ <strong>Important: inputs need a "name" attribute!</strong></div>
                            <div class="pl-2 border-l-2 border-yellow-500/30 space-y-0.5 mt-1">
                                <div class="font-mono text-[10px]"><span class="text-red-400">// ❌ Won't appear in FormData</span></div>
                                <div class="font-mono text-[10px]">&lt;input type="text" id="email" /&gt;</div>
                                <div class="font-mono text-[10px] mt-1"><span class="text-green-400">// ✅ Will appear in FormData</span></div>
                                <div class="font-mono text-[10px]">&lt;input type="text" name="email" id="email" /&gt;</div>
                                <div class="text-[10px] mt-1">FormData uses the <strong>name</strong> attribute as the key, not the id!</div>
                            </div>
                        </ProTip>

                        <ProTip>
                            <div>💡 <strong>get() vs getAll():</strong></div>
                            <div class="pl-2 border-l-2 border-blue-500/30 space-y-0.5 mt-1">
                                <div class="font-mono text-[10px]">formData.get('email') <span class="text-gray-400">// 'user@example.com' (single value)</span></div>
                                <div class="font-mono text-[10px]">formData.getAll('email') <span class="text-gray-400">// ['user@example.com'] (array with one item)</span></div>
                                <div class="font-mono text-[10px] mt-1">formData.get('plan') <span class="text-gray-400">// 'pro' (single radio selection)</span></div>
                                <div class="font-mono text-[10px]">formData.get('hobbies') <span class="text-gray-400">// 'reading' (first checked value only!)</span></div>
                                <div class="font-mono text-[10px]">formData.getAll('hobbies') <span class="text-gray-400">// ['reading', 'gaming'] (all checked)</span></div>
                                <div class="text-[10px] mt-1"><strong>Rule of thumb:</strong></div>
                                <div class="text-[10px]">• Radio buttons → use <code>get()</code> (only one can be selected)</div>
                                <div class="text-[10px]">• Checkboxes → use <code>getAll()</code> (multiple can be selected)</div>
                            </div>
                        </ProTip>

                        <ProTip>
                            <div>💡 <strong>FormData is perfect for file uploads:</strong></div>
                            <div class="pl-2 border-l-2 border-blue-500/30 space-y-0.5 mt-1">
                                <div class="font-mono text-[10px]">const formData = new FormData(form)</div>
                                <div class="font-mono text-[10px]">await fetch('/upload', {`{`}</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;method: 'POST',</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;body: formData <span class="text-gray-400">// automatically includes files!</span></div>
                                <div class="font-mono text-[10px]">{`}`})</div>
                            </div>
                        </ProTip>
                    </MethodCard>
                </div>

                <!-- MANUAL VALUE ACCESS -->
                <div id="manual-values">
                    <MethodCard
                        methodName="Manual Value Access"
                        signature="input.value, checkbox.checked, etc."
                        description="Direct access to form input values"
                        mutates={false}
                    >
                        <div class="p-6 bg-gray-800 rounded">
                            <div class="space-y-3">
                                <!-- Text inputs -->
                                <div class="bg-blue-500/20 border border-blue-400 rounded p-3">
                                    <div class="text-blue-300 font-mono text-[10px] space-y-0.5">
                                        <div class="text-yellow-400 mb-1">Text inputs:</div>
                                        <div>input.value <span class="text-gray-400">// text, email, password, number, etc.</span></div>
                                        <div>textarea.value <span class="text-gray-400">// textarea content</span></div>
                                    </div>
                                </div>

                                <!-- Checkboxes & Radio -->
                                <div class="bg-green-500/20 border border-green-500 rounded p-3">
                                    <div class="text-green-300 font-mono text-[10px] space-y-0.5">
                                        <div class="text-yellow-400 mb-1">Checkboxes & Radio buttons:</div>
                                        <div>checkbox.checked <span class="text-gray-400">// true/false</span></div>
                                        <div>radio.checked <span class="text-gray-400">// true if selected</span></div>
                                        <div class="mt-1"><span class="text-gray-400">// Get checked radio value in group</span></div>
                                        <div>const selected = document.querySelector('input[name="size"]:checked')</div>
                                        <div>const value = selected?.value</div>
                                    </div>
                                </div>

                                <!-- Select -->
                                <div class="bg-purple-500/20 border border-purple-400 rounded p-3">
                                    <div class="text-purple-300 font-mono text-[10px] space-y-0.5">
                                        <div class="text-yellow-400 mb-1">Select dropdowns:</div>
                                        <div>select.value <span class="text-gray-400">// selected option value</span></div>
                                        <div>select.selectedIndex <span class="text-gray-400">// index of selected option</span></div>
                                        <div>select.options[0].selected <span class="text-gray-400">// check if option selected</span></div>
                                    </div>
                                </div>

                                <!-- Files -->
                                <div class="bg-orange-500/20 border border-orange-400 rounded p-3">
                                    <div class="text-orange-300 font-mono text-[10px] space-y-0.5">
                                        <div class="text-yellow-400 mb-1">File inputs:</div>
                                        <div>fileInput.files <span class="text-gray-400">// FileList (array-like)</span></div>
                                        <div>fileInput.files[0] <span class="text-gray-400">// first File object</span></div>
                                        <div>fileInput.files[0].name <span class="text-gray-400">// filename</span></div>
                                        <div>fileInput.files[0].size <span class="text-gray-400">// size in bytes</span></div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <ProTip>
                            <div>💡 <strong>Multiple checkboxes with same name:</strong></div>
                            <div class="pl-2 border-l-2 border-blue-500/30 space-y-0.5 mt-1">
                                <div class="font-mono text-[10px]"><span class="text-gray-400">// Get all checked values</span></div>
                                <div class="font-mono text-[10px]">const checkboxes = document.querySelectorAll('input[name="hobbies"]:checked')</div>
                                <div class="font-mono text-[10px]">const values = [...checkboxes].map(cb =&gt; cb.value)</div>
                                <div class="font-mono text-[10px]"><span class="text-gray-400">// ['reading', 'gaming', 'cooking']</span></div>
                            </div>
                        </ProTip>
                    </MethodCard>
                </div>

                <!-- ============================================ -->
                <!-- 🎛️ SETTING CHECKBOX & RADIO GROUPS -->
                <!-- ============================================ -->

                <h2 id="setting-groups" class="text-cyan-300 text-xl my-4 pb-2 border-b-2 border-cyan-600">
                    🎛️ Setting Checkbox & Radio Groups
                </h2>

                <div id="setting-checkboxes">
                    <MethodCard
                        methodName="Setting Multiple Checkboxes"
                        signature="querySelectorAll + forEach"
                        description="Check/uncheck multiple checkboxes programmatically"
                        mutates={true}
                    >
                        <div class="p-6 bg-gray-800 rounded">
                            <div class="space-y-4">
                                <!-- Check specific values -->
                                <div class="bg-green-500/20 border border-green-500 rounded p-3">
                                    <div class="text-green-300 font-mono text-[10px] space-y-0.5">
                                        <div class="text-yellow-400 mb-1">Check specific checkboxes by value:</div>
                                        <div><span class="text-gray-400">// Check "reading" and "gaming" hobbies</span></div>
                                        <div>const valuesToCheck = ['reading', 'gaming']</div>
                                        <div>document.querySelectorAll('input[name="hobbies"]').forEach(cb =&gt; {`{`}</div>
                                        <div>&nbsp;&nbsp;cb.checked = valuesToCheck.includes(cb.value)</div>
                                        <div>{'}'})</div>
                                    </div>
                                </div>

                                <!-- Check all / Uncheck all -->
                                <div class="bg-blue-500/20 border border-blue-400 rounded p-3">
                                    <div class="text-blue-300 font-mono text-[10px] space-y-0.5">
                                        <div class="text-yellow-400 mb-1">Check all / Uncheck all:</div>
                                        <div><span class="text-gray-400">// Check all checkboxes in a group</span></div>
                                        <div>document.querySelectorAll('input[name="hobbies"]').forEach(cb =&gt; {`{`}</div>
                                        <div>&nbsp;&nbsp;cb.checked = true</div>
                                        <div>{'}'})</div>
                                        <div class="mt-2"><span class="text-gray-400">// Uncheck all</span></div>
                                        <div>document.querySelectorAll('input[name="hobbies"]').forEach(cb =&gt; {`{`}</div>
                                        <div>&nbsp;&nbsp;cb.checked = false</div>
                                        <div>{'}'})</div>
                                    </div>
                                </div>

                                <!-- Toggle -->
                                <div class="bg-purple-500/20 border border-purple-400 rounded p-3">
                                    <div class="text-purple-300 font-mono text-[10px] space-y-0.5">
                                        <div class="text-yellow-400 mb-1">Toggle all checkboxes:</div>
                                        <div>document.querySelectorAll('input[name="hobbies"]').forEach(cb =&gt; {`{`}</div>
                                        <div>&nbsp;&nbsp;cb.checked = !cb.checked</div>
                                        <div>{'}'})</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <ProTip>
                            <div>💡 <strong>Common use case:</strong> "Select All" button</div>
                            <div class="pl-2 border-l-2 border-blue-500/30 space-y-0.5 mt-1">
                                <div class="font-mono text-[10px]"><span class="text-gray-400">// HTML</span></div>
                                <div class="font-mono text-[10px]">&lt;button id="select-all"&gt;Select All&lt;/button&gt;</div>
                                <div class="font-mono text-[10px] mt-2"><span class="text-gray-400">// JavaScript</span></div>
                                <div class="font-mono text-[10px]">document.getElementById('select-all').addEventListener('click', () =&gt; {`{`}</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;const checkboxes = document.querySelectorAll('input[name="hobbies"]')</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;const allChecked = [...checkboxes].every(cb =&gt; cb.checked)</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;checkboxes.forEach(cb =&gt; cb.checked = !allChecked)</div>
                                <div class="font-mono text-[10px]">{'}'})</div>
                            </div>
                        </ProTip>
                    </MethodCard>
                </div>

                <div id="setting-radios">
                    <MethodCard
                        methodName="Setting Radio Button"
                        signature="querySelector + checked"
                        description="Select a radio button programmatically"
                        mutates={true}
                    >
                        <div class="p-6 bg-gray-800 rounded">
                            <div class="space-y-4">
                                <!-- Select by value -->
                                <div class="bg-green-500/20 border border-green-500 rounded p-3">
                                    <div class="text-green-300 font-mono text-[10px] space-y-0.5">
                                        <div class="text-yellow-400 mb-1">Select radio by value:</div>
                                        <div><span class="text-gray-400">// Select the "pro" plan radio button</span></div>
                                        <div>const radio = document.querySelector('input[name="plan"][value="pro"]')</div>
                                        <div>if (radio) radio.checked = true</div>
                                    </div>
                                </div>

                                <!-- Generic helper function -->
                                <div class="bg-blue-500/20 border border-blue-400 rounded p-3">
                                    <div class="text-blue-300 font-mono text-[10px] space-y-0.5">
                                        <div class="text-yellow-400 mb-1">Reusable function:</div>
                                        <div>function setRadioValue(name, value) {`{`}</div>
                                        <div>&nbsp;&nbsp;const radio = document.querySelector(`input[name="${'$'}{'{'}name{'}'}"][value="${'$'}{'{'}value{'}'}"]`)</div>
                                        <div>&nbsp;&nbsp;if (radio) radio.checked = true</div>
                                        <div>{'}'})</div>
                                        <div class="mt-2"><span class="text-gray-400">// Usage</span></div>
                                        <div>setRadioValue('plan', 'enterprise')</div>
                                    </div>
                                </div>

                                <!-- Uncheck all (rare) -->
                                <div class="bg-orange-500/20 border border-orange-400 rounded p-3">
                                    <div class="text-orange-300 font-mono text-[10px] space-y-0.5">
                                        <div class="text-yellow-400 mb-1">Uncheck all radios (unusual but possible):</div>
                                        <div>document.querySelectorAll('input[name="plan"]').forEach(r =&gt; {`{`}</div>
                                        <div>&nbsp;&nbsp;r.checked = false</div>
                                        <div>{'}'})</div>
                                        <div class="mt-1"><span class="text-gray-400">// ⚠️ Creates invalid state - typically avoid this</span></div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <ProTip>
                            <div>💡 <strong>Pre-filling forms with existing data:</strong></div>
                            <div class="pl-2 border-l-2 border-blue-500/30 space-y-0.5 mt-1">
                                <div class="font-mono text-[10px]"><span class="text-gray-400">// Load user's saved preferences</span></div>
                                <div class="font-mono text-[10px]">const savedData = {`{`}</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;plan: 'pro',</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;hobbies: ['reading', 'gaming']</div>
                                <div class="font-mono text-[10px]">{'}'})</div>
                                <div class="font-mono text-[10px] mt-2"><span class="text-gray-400">// Set radio</span></div>
                                <div class="font-mono text-[10px]">const radio = document.querySelector(`input[name="plan"][value="${'$'}{'{'}savedData.plan{'}'}"]`)</div>
                                <div class="font-mono text-[10px]">if (radio) radio.checked = true</div>
                                <div class="font-mono text-[10px] mt-2"><span class="text-gray-400">// Set checkboxes</span></div>
                                <div class="font-mono text-[10px]">document.querySelectorAll('input[name="hobbies"]').forEach(cb =&gt; {`{`}</div>
                                <div class="font-mono text-[10px]">&nbsp;&nbsp;cb.checked = savedData.hobbies.includes(cb.value)</div>
                                <div class="font-mono text-[10px]">{'}'})</div>
                            </div>
                        </ProTip>
                    </MethodCard>
                </div>

                <!-- ============================================ -->
                <!-- ✅ FORM VALIDATION -->
                <!-- ============================================ -->

                <h2 id="validation" class="text-green-300 text-xl my-4 pb-2 border-b-2 border-green-600">
                    ✅ Form Validation
                </h2>

                <div class="bg-blue-500/10 border-l-4 border-blue-500 p-4 mb-6 rounded">
                    <div class="text-blue-200 font-bold text-sm mb-2">📚 Validation Strategy - Best Practices</div>
                    <div class="text-gray-300 text-[11px] space-y-2">
                        <div><strong>Layer 1: HTML5 Attributes (required, pattern, etc.)</strong></div>
                        <div class="pl-3">✅ Free, works without JavaScript, good baseline</div>
                        <div class="pl-3">❌ Limited customization, can't be bypassed</div>

                        <div class="mt-3"><strong>Layer 2: JavaScript Validation (Constraint Validation API)</strong></div>
                        <div class="pl-3">✅ Custom error messages, cross-field validation (e.g., password match)</div>
                        <div class="pl-3">✅ Better UX with real-time feedback</div>
                        <div class="pl-3">❌ Can be bypassed by disabling JavaScript</div>

