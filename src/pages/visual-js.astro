                description="Reduces array to a single value by applying function with accumulator"
                mutates={false}
            >
                <div class="flex items-center gap-4 p-3 bg-gray-800 rounded overflow-x-auto">
                    <Node label="Input Array" type="input">
                        <ArrayDisplay values={[1, 2, 3, 4]} />
                    </Node>

                    <Arrow label="reduces" />

                    <Node label="Method" type="process">
                        <ProcessContent name="reduce((sum, n) => sum + n, 0)" description="Sum all values: 0 + 1 + 2 + 3 + 4" />
                    </Node>

                    <Arrow label="returns" />

                    <Node label="Single Value" type="output">
                        <ReturnValue value={10} type="accumulated result" />
                    </Node>
                </div>

                <InfoBox mutates={false} message="">
                    Returns a <code class="bg-black/30 px-1.5 py-0.5 rounded font-mono text-yellow-400">single value</code> of any type. ⚠️ Cannot be chained. The accumulator carries forward through each iteration.
                </InfoBox>

                <div class="mt-2 p-2 bg-purple-900/20 border border-purple-500/30 rounded text-[11px] leading-snug">
                    <div class="text-purple-300 font-bold mb-1">💡 Pro tip:</div>
                    <div class="text-gray-300 space-y-1.5">
                        <div>Reduce is super versatile! Common patterns:</div>
                        <div class="pl-2 border-l-2 border-purple-500/30 space-y-1">
                            <div class="font-mono text-[10px]"><span class="text-gray-400">// Count occurrences</span><br/>items.reduce((acc,v) =&gt; (&lbrace;...acc, [v]: (acc[v]||0)+1&rbrace;), &lbrace;&rbrace;)</div>
                            <div class="font-mono text-[10px]"><span class="text-gray-400">// Group by property</span><br/>users.reduce((acc,u) =&gt; (&lbrace;...acc, [u.role]: [...(acc[u.role]||[]),u]&rbrace;), &lbrace;&rbrace;)</div>
                            <div class="font-mono text-[10px]"><span class="text-gray-400">// Build object from array</span><br/>arr.reduce((acc,v,i) =&gt; (&lbrace;...acc, [i]: v&rbrace;), &lbrace;&rbrace;)</div>
                        </div>
                    </div>
                </div>
            </MethodCard>
