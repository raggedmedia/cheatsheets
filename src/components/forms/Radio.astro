---
interface Props {
    id: string;
    name: string;
    value: string;
    label: string;
    required?: boolean;
    checked?: boolean;
}

const {
    id,
    name,
    value,
    label,
    required = false,
    checked = false,
} = Astro.props;
---

<div class="form-radio">
    <input
        type="radio"
        id={id}
        name={name}
        value={value}
        class="radio-input"
        required={required}
        checked={checked}
    />
    <label for={id} class="radio-label">
        {label}
    </label>
</div>

<style>
    /* Component-specific styles only - shared styles are in _forms.css */
</style>
