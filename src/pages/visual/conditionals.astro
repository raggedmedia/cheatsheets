                        <li class="mt-4">
                            <a href="#ternary" class="text-green-300 font-semibold hover:text-green-200 block py-1">⚡ Ternary</a>
                            <ul class="ml-3 mt-1 space-y-1 border-l-2 border-green-500/30 pl-2">
                                <li><a href="#ternary-op" class="text-gray-300 hover:text-blue-400 block">Ternary Operator</a></li>
                            </ul>
                        </li>

                        <li class="mt-4">
                            <a href="#nullish" class="text-cyan-300 font-semibold hover:text-cyan-200 block py-1">🛡️ Nullish & Optional</a>
                            <ul class="ml-3 mt-1 space-y-1 border-l-2 border-cyan-500/30 pl-2">
                                <li><a href="#nullish-coalescing" class="text-gray-300 hover:text-blue-400 block">?? (Nullish Coalescing)</a></li>
                                <li><a href="#optional-chaining" class="text-gray-300 hover:text-blue-400 block">?. (Optional Chaining)</a></li>
