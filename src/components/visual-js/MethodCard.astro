---
interface Props {
    methodName: string;
    signature: string;
    description: string;
    mutates: boolean;
}

const { methodName, signature, description, mutates } = Astro.props;
---

<div class="bg-[#252936] rounded-lg p-4 mb-4 border border-gray-700 relative">
    <div class="mb-3 pb-2 border-b border-gray-700">
        <div class="flex items-center gap-2 mb-1">
            <span class="font-mono text-xl font-bold text-blue-400">{methodName}</span>
            {mutates ? (
                <span class="inline-block px-2 py-0.5 rounded text-[10px] font-semibold uppercase bg-red-500/20 text-red-300 border border-red-500">
                    Mutates
                </span>
            ) : (
                <span class="inline-block px-2 py-0.5 rounded text-[10px] font-semibold uppercase bg-green-500/20 text-green-300 border border-green-500">
                    Immutable
                </span>
            )}
        </div>
        <div class="font-mono text-xs text-gray-400 mb-1">{signature}</div>
        <div class="text-gray-300 text-xs">{description}</div>
    </div>

    <slot />
</div>
