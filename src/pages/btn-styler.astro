---
import '../styles/styles.css'
---
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Btn Builder</title>
	</head>
	<body>
        <h1>Btn Builder</h1>
        <p>Use a <code>a</code> for navigation and a <code>button</code> for actions. Links are for 'going', buttons are for 'doing'.</p>
        <p>So while we call it a button style, it's a visual flair that applies to two different HTML elements.</p>

        <div class="controls">
            <button id="decrease-width">-</button>
            <label for="width-range">
                Width: <span id="width-value">w-96</span>
            </label>
            <input
                type="range"
                id="width-range"
                min="0"
                step="1"
                class="w-96"
            />
            <button id="increase-width">+</button>

        </div>

        <div class="example mx-auto w-[500px]">
            <a id="achilles" href="" class="btn h-24 bg-blue-500 flex items-center justify-center text-white">Hello, world!</a>
        </div>
	</body>
</html>

<script>
    // Tailwind default width values in order
    const widthClasses = [
        'w-0.5',   // 2
        'w-1',     // 3
        'w-1.5',   // 4
        'w-2',     // 5
        'w-2.5',   // 6
        'w-3',     // 7
        'w-3.5',   // 8
        'w-4',     // 9
        'w-5',     // 10
        'w-6',     // 1
        'w-7',     // 12
        'w-8',     // 13
        'w-9',     // 14
        'w-10',    // 15
        'w-11',    // 16
        'w-12',    // 17
        'w-14',    // 18
        'w-16',    // 19
        'w-20',    // 20
        'w-24',    // 21
        'w-28',    // 22
        'w-32',    // 23
        'w-36',    // 24
        'w-40',    // 25
        'w-44',    // 26
        'w-48',    // 27
        'w-52',    // 28
        'w-56',    // 29
        'w-60',    // 30
        'w-64',    // 31
        'w-72',    // 32
        'w-80',    // 33
        'w-96',    // 34
    ];

    const rangeAmount = widthClasses.length.toString();

    const widthRange = document.getElementById('width-range');
    widthRange?.setAttribute('max', rangeAmount);
    const widthValue = document.getElementById('width-value');
    const btn = document.getElementById('achilles');

    const achilles = document.getElementById('achilles');
    achilles?.classList.add(`w-${parseInt(widthRange.value)}`)

    widthRange?.addEventListener('input', (e) => {
        const target = e.target as HTMLInputElement;
        const index = parseInt(target.value);
        const newWidthClass = widthClasses[index];

        // Remove all width classes
        btn?.classList.forEach(className => {
            if (className.startsWith('w-')) {
                btn.classList.remove(className);
            }
        });

        // Add new width class
        btn?.classList.add(newWidthClass);

        // Update display
        if (widthValue) {
            widthValue.textContent = newWidthClass;
        }
    });

    const widthDecrease = document.getElementById('decrease-width');
    widthDecrease?.addEventListener('click', () => {
        if (widthRange) {
            const currentValue = parseInt(widthRange.value);
            const newValue = Math.max(0, currentValue - 1);
            widthRange.value = newValue.toString();
            widthRange.dispatchEvent(new Event('input'));
        }
    });

    const widthIncrease = document.getElementById('increase-width');
    widthIncrease?.addEventListener('click', () => {
        if (widthRange) {
            const currentValue = parseInt(widthRange.value);
            const newValue = Math.max(0, currentValue + 1);
            widthRange.value = newValue.toString();
            widthRange.dispatchEvent(new Event('input'));
        }
    });
</script>
