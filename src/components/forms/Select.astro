---
interface Option {
    value: string;
    label: string;
}

interface Props {
    id: string;
    name: string;
    label: string;
    options: Option[];
    required?: boolean;
    helperText?: string;
}

const { id, name, label, options, required = false, helperText } = Astro.props;
---

<div class="form-group">
    <label for={id} class="form-label">
        {label}
        {
            required && (
                <span class="required-indicator" aria-label="required">
                    *
                </span>
            )
        }
    </label>

    <select
        id={id}
        name={name}
        class="form-select"
        required={required}
        aria-describedby={helperText ? `${id}-help` : undefined}
    >
        <option value="">Select an option</option>
        {
            options.map((option) => (
                <option value={option.value}>{option.label}</option>
            ))
        }
    </select>

    {
        helperText && (
            <div id={`${id}-help`} class="form-help-text">
                {helperText}
            </div>
        )
    }
</div>

<style>
    /* Component-specific styles only - shared styles are in _forms.css */
</style>
